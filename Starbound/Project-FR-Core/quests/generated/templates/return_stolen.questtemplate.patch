[{"op":"replace","path":"/scriptConfig/generatedText/title/0","value":"<questGiver>le justicier"},{"op":"replace","path":"/scriptConfig/generatedText/title/1","value":"Aider<victim>"},{"op":"replace","path":"/scriptConfig/generatedText/goalText/floran/0","value":"^cyan;Floran a découvert un crime choquant ! Réparons ça."},{"op":"replace","path":"/scriptConfig/generatedText/goalText/floran/1","value":"^cyan;Celui de quelqu'un<item>a été volé. Aidez Ressstore Justice !"},{"op":"replace","path":"/scriptConfig/generatedText/goalText/glitch/0","value":"^cyan;Troublé.<victim>a été victime d'un petit vol ! Aidons<victim.pronoun.object>!"},{"op":"replace","path":"/scriptConfig/generatedText/goalText/glitch/1","value":"^cyan;Opportuniste. J'ai découvert que<thief>a volé. Aide-moi à apporter<thief.pronoun.object>à la justice."},{"op":"replace","path":"/scriptConfig/generatedText/goalText/default/0","value":"^cyan;j'ai vu ça<victim>cherchait<victim.pronoun.possessiveDet>volé<item>, et je sais où il se trouve.<victim.pronoun.capitalSubject>Je serais très reconnaissant si nous aidions à le rendre."},{"op":"replace","path":"/scriptConfig/generatedText/goalText/default/1","value":"^cyan;<victim>me demandait si je connaissais quelqu'un qui pourrait m'aider à trouver<victim.pronoun.possessiveDet> <item>. Je sais où c'est, mais j'ai besoin de votre aide."},{"op":"replace","path":"/scriptConfig/generatedText/text/first/floran/0","value":"Floran a un problème et a besoin de votre aide. Ce voleur sournois^orange;<thief>^white;a volé une amende^orange;<item>^white;d'un citoyen debout<victim>! ^green;S'il vous plaît, reprenez-le et mettez-le dedans^orange;<victim>'ss^green;maison."},{"op":"replace","path":"/scriptConfig/generatedText/text/first/floran/1","value":"Vous ne croirez pas ce qui s'est passé !^orange;<victim>^white;a été volé par nul autre que^orange;<thief>.^white;Floran aimerait que nous puissions faire quelque chose pour l'aider. Peut-être que tu peux^green;restituer ce qui a été volé^orange;<item> ^green;à<victim>C'est maison ?"},{"op":"replace","path":"/scriptConfig/generatedText/text/first/glitch/0","value":"Concerné. Un voleur qui s'appelle^orange;<thief>^white;a volé<victim>est prisé^orange;<item>! Veux-tu^green;récupère-le et remets-le dedans^orange;<victim>c'est^green;maison?^white;Je suis sûr<victim.pronoun.subject>l'apprécierais."},{"op":"replace","path":"/scriptConfig/generatedText/text/first/glitch/1","value":"Sournois.<victim>je pourrais me faire davantage confiance, et je sais comment y parvenir.<thief>j'en ai volé un^orange;<item>^white;depuis<victim.pronoun.object>l'autre jour.^green;Allez-vous le récupérer^orange;<thief>c'est^green;maison^white;et^green;remets-le dedans^orange;<victim>c'est^green;maison?"},{"op":"replace","path":"/scriptConfig/generatedText/text/first/default/0","value":"Très bien, je sais pertinemment que^orange;<thief>^white;a volé^orange;<victim>c'est<item>^white;. Je veillerai pendant que toi^green;reprends-le.^white;Une fois que vous l'avez,^green;replacez-le dans^orange;<victim>c'est^green;maison."},{"op":"replace","path":"/scriptConfig/generatedText/text/first/default/1","value":"La première chose que nous devons faire implique un peu de vol. Eh bien, c'est une bonne sorte de vol. Le^orange;<item>^white;nous devons voler est situé dans^orange;<thief>est à la maison.^green;Va le chercher, puis remets-le dedans^orange;<victim>c'est^green;maison."},{"op":"replace","path":"/scriptConfig/generatedText/text/next/floran/0","value":"Oui, beau travail ! Floran a besoin d'une autre faveur de votre part...^orange;<thief>^white;a volé un précieux^orange;<item>^white;d'un voisin sympathique<victim>- tellement impoli !^green;S'il vous plaît, reprenez-le et mettez-le dedans^orange;<victim>c'est^green;maison."},{"op":"replace","path":"/scriptConfig/generatedText/text/next/floran/1","value":"Floran est bouleversé par quelque chose qui s'est passé -^orange;<thief> ^white;volé sans vergogne<victim>! Si tu pouvais^green;restituer ce qui a été volé^orange;<item>^green;à^orange;<victim>,^white;je suis sûr<victim.pronoun.subject>je serais reconnaissant."},{"op":"replace","path":"/scriptConfig/generatedText/text/next/glitch/0","value":"Irrité. That swindler,<thief>a eu le culot de voler le pauvre<victim>le préféré^orange;<item>.^white;Nous devons faire quelque chose à ce sujet ! Auriez-vous la gentillesse de^green;récupérez-le de^orange;<thief>c'est^green;maison^white;et^green;retournez-le à^orange;<victim>c'est^green;maison?"},{"op":"replace","path":"/scriptConfig/generatedText/text/next/glitch/1","value":"Calculateur. Ensuite, je parie que ça ferait^orange;<victim>^white;heureux si tu^green;récupéré le^orange;<item>^white;que^orange;<thief>^white;volé à<victim.pronoun.object>, et^green;remets-le dedans<victim.pronoun.possessiveDet>maison.^white;C'est quelque chose qui m'entraîne<victim.pronoun.possessiveDet>bons livres."},{"op":"replace","path":"/scriptConfig/generatedText/text/next/default/0","value":"Bon, maintenant on va faire du cambriolage.^green;Allez récupérer ce qui a été volé^orange;<item>^green;depuis^orange;<thief>c'est^green;à la maison, et^green;replacez-le dans^orange;<victim>c'est^green;maison.^white;Je vais garder un œil ouvert et m'assurer que personne ne regarde."},{"op":"replace","path":"/scriptConfig/generatedText/text/next/default/1","value":"Un peu d'effraction n'a jamais fait de mal à personne... En quelque sorte. Aller^green;voler le^orange;<item> ^green;dans^orange;<thief>c'est^green;maison. Puis remettez-le dedans^orange;<victim>c'est^green;maison."},{"op":"replace","path":"/scriptConfig/generatedText/text/last/floran/0","value":"Super ! Floran a besoin d'une faveur supplémentaire.^orange;<thief>^white;en a volé un^orange;<item>^white;des pauvres<victim>- comme c'est délicat !^green;Reprenez-le et mettez-le dedans^orange;<victim>c'est^green;maison.^white;Puis Floran vous laisse tranquille."},{"op":"replace","path":"/scriptConfig/generatedText/text/last/floran/1","value":"Oh non! Floran a entendu^orange;<victim>^white;a été volé par^orange;<thief>^white;. Personne n’était là pour arrêter le crime ! S'il vous plaît, voulez-vous^green;récupérer ce qui a été volé^orange;<item>^green;du voleur ?"},{"op":"replace","path":"/scriptConfig/generatedText/text/last/glitch/0","value":"Agité. Nous avons un dernier problème - ce satané^orange;<thief>^white;a volé<victim>le préféré^orange;<item>^white;! ^orange;<victim> ^white;sera dévasté à moins que nous... je veux dire... Toi,^green;récupère-le et remets-le dedans<victim.pronoun.possessiveDet>maison."},{"op":"replace","path":"/scriptConfig/generatedText/text/last/glitch/1","value":"Astucieux. Enfin, je sais que^orange;<thief>^white;récemment volé<victim>c'est^orange;<item>.^white;Je parie que si tu^green;je l'ai récupéré et remis dedans^orange;<victim>c'est^green;maison,^white; <victim.pronoun.subject>serait très reconnaissant et me favoriserait à l'avenir."},{"op":"replace","path":"/scriptConfig/generatedText/text/last/default/0","value":"Enfin, il est temps de rendre justice aux justiciers !^green;Supprimer le volé^orange;<item>^green;depuis^orange;<thief>c'est^green;à la maison, et^green;replacez-le dans^orange;<victim>c'est^green;maison.^white;Je serai le guetteur."},{"op":"replace","path":"/scriptConfig/generatedText/text/last/default/1","value":"Tout le reste est en place ! Il est temps de procéder à un cambriolage de type justicier. Je serai ton guetteur pendant que tu^green;récupérer ce qui a été volé^orange;<item>^green;depuis^orange;<thief>c'est^green;lieu. Puis remettez-le dans^orange;<victim>c'est^green;maison."},{"op":"replace","path":"/scriptConfig/generatedText/text/default/floran/0","value":"Toi! Floran a besoin de toi.^orange;<thief>^white;a volé une amende^orange;<item>^white;de cher ami<victim>- comme c'est sournois !^green;Reprenez-le et mettez-le dedans^orange;<victim>c'est^green;maison,^white;d'accord?"},{"op":"replace","path":"/scriptConfig/generatedText/text/default/floran/1","value":"Ce sont des temps sombres... Floran a entendu des rumeurs selon lesquelles^orange;<thief>^white;vol^orange;<victim>c'est^white; <item>. ^white;Nulle part n’est sûr de nos jours ! S'il vous plaît, pouvez-vous^green;retourner le^orange; <item> ^green;à son propriétaire légitime ?"},{"op":"replace","path":"/scriptConfig/generatedText/text/default/glitch/0","value":"Concerné. Dans un moment de désespoir,^orange;<thief>^white;volé<victim>de<victim.pronoun.possessiveDet> ^orange;<item>^white;! Si tu^green;récupère-le et remets-le dedans^orange;<victim>c'est^green;maison,^white; <victim.pronoun.subject>ne réalisera peut-être même jamais qu'il avait disparu. Je serais reconnaissant."},{"op":"replace","path":"/scriptConfig/generatedText/text/default/glitch/1","value":"Rusé.^orange;<thief>^white;récemment volé<victim>le préféré<item>. Je parie^orange;<victim>^white;serait très reconnaissant à quiconque^green;récupéré le^orange;<item> ^green;et remets-le dedans<victim.pronoun.possessiveDet>maison.^white;Veux-tu faire ça pour moi ?"},{"op":"replace","path":"/scriptConfig/generatedText/text/default/default/0","value":"Très bien, je vais surveiller pendant que tu^green;prendre ce qui a été volé^orange;<item>^green;depuis^orange;<thief>c'est^green;maison.^white;Une fois que vous avez terminé,^green;replacez-le dans^orange;<victim>c'est^green;maison."},{"op":"replace","path":"/scriptConfig/generatedText/text/default/default/1","value":"Le^orange;<item>^white;Je cherchais a été volé par^orange;<thief>.^white;En ce moment, il est assis<thief.pronoun.possessiveDet>maison.^green;Allez le récupérer,^white;alors^green;replacez-le dans^orange;<victim>c'est^green;maison^white;où il appartient. Je surveillerai les ennuis."},{"op":"replace","path":"/scriptConfig/generatedText/completionText/first/floran/0","value":"Génial !<victim>je serai très heureux d'avoir le<item>dos! Mais Floran a besoin de plus d'aide."},{"op":"replace","path":"/scriptConfig/generatedText/completionText/first/floran/1","value":"Maintenant, nous pouvons être tranquilles, sachant que<victim>a été réuni avec<victim.pronoun.possessiveDet> <item>. "},{"op":"replace","path":"/scriptConfig/generatedText/completionText/first/glitch/0","value":"Heureux. Excellent!<victim>a<victim.pronoun.possessiveDet> <item>et tout va bien dans l'univers... Presque."},{"op":"replace","path":"/scriptConfig/generatedText/completionText/first/glitch/1","value":"Sournois. Vous avez réussi à mettre le<item>de retour<victim>la maison - merci ! Si je peux convaincre<victim.pronoun.object>que j'étais responsable, j'aurai certainement mérité<victim.pronoun.possessiveDet>confiance!"},{"op":"replace","path":"/scriptConfig/generatedText/completionText/first/default/0","value":"Vous avez fait du si bon travail ! J'ai hâte de voir<thief>le visage de quand<thief.pronoun.subject>voit<thief.pronoun.subject>j'ai eu un avant-goût de<thief.pronoun.possessiveDet>propre médicament."},{"op":"replace","path":"/scriptConfig/generatedText/completionText/first/default/1","value":"Ce n'était pas aussi difficile que je le pensais. Vous êtes plutôt bon dans ce domaine, n'est-ce pas ?<victim>je serai heureux de voir<victim.pronoun.possessiveDet>les choses à leur place."},{"op":"replace","path":"/scriptConfig/generatedText/completionText/next/floran/0","value":"Superbe!<victim>serai très reconnaissant d'avoir le<item>dos. Maintenant, Floran a besoin de plus d'aide."},{"op":"replace","path":"/scriptConfig/generatedText/completionText/next/floran/1","value":"Vous l'avez fait ! Avec un peu de chance<thief>des regrets<thief.pronoun.possessiveDet>crime. Floran veillera à ce que cela ne se reproduise plus !"},{"op":"replace","path":"/scriptConfig/generatedText/completionText/next/glitch/0","value":"Satisfait. Bien joué!<victim>je serai très heureux d'avoir le<item>dos. Seriez-vous prêt à faire autre chose pour moi ?"},{"op":"replace","path":"/scriptConfig/generatedText/completionText/next/glitch/1","value":"Sournois. Merci d'avoir récupéré le<item>pour<victim>! J'espère que cela ne vous dérange pas que je prenne tout le mérite. j'aurai certainement gagné<victim>C'est la confiance alors !"},{"op":"replace","path":"/scriptConfig/generatedText/completionText/next/default/0","value":"C'était vraiment impressionnant ! J'aime aussi la façon dont vous n'avez laissé aucune empreinte digitale, c'est une réflexion intelligente. Attends juste que<victim>entend parler de ça !"},{"op":"replace","path":"/scriptConfig/generatedText/completionText/next/default/1","value":"Bon travail!<victim>sera content de moi, une fois<victim.pronoun.subject>voit<victim.pronoun.possessiveDet> <item>à sa juste place."},{"op":"replace","path":"/scriptConfig/generatedText/completionText/last/floran/0","value":"Succès !<victim>je serai si heureux d'avoir le<item>dos. Cela rend Floran heureux aussi."},{"op":"replace","path":"/scriptConfig/generatedText/completionText/last/floran/1","value":"Floran vous remercie profondément d'avoir rendu le<item>à<victim>. Floran savait qu'on pouvait compter sur toi !"},{"op":"replace","path":"/scriptConfig/generatedText/completionText/last/glitch/0","value":"Ravi. Crise évitée-<victim>a<victim.pronoun.possessiveDet> <item>dos! Merci d'avoir été si utile,<player>."},{"op":"replace","path":"/scriptConfig/generatedText/completionText/last/glitch/1","value":"Heureux. Je suis tellement contente que tu aies récupéré le<item>pour<victim>! Une fois que je prends tout le mérite d'avoir aidé<victim.pronoun.object>dehors,<victim.pronoun.subject>je vais certainement me faire confiance !"},{"op":"replace","path":"/scriptConfig/generatedText/completionText/last/default/0","value":"<player>et<questGiver>, pourvoyeurs de justice justicier ! Ça a l’air bien, non ?  Tu étais comme un fantôme là-dedans.<thief>je ne saurai pas quoi penser !"},{"op":"replace","path":"/scriptConfig/generatedText/completionText/last/default/1","value":"Tu as un vrai talent pour ce genre de chose, je vois que tu as même amené ton propre outil pour le travail.<victim>je serai ravi de voir<victim.pronoun.possessiveDet>les choses ont été retournées."},{"op":"replace","path":"/scriptConfig/generatedText/completionText/default/floran/0","value":"Mission accomplie !<victim>je serai si heureux d'avoir le<item>dos. Cela rend Floran heureux aussi."},{"op":"replace","path":"/scriptConfig/generatedText/completionText/default/floran/1","value":"Vous avez rendu le<item>! je suis sûr que<victim>je me sens plus en sécurité en sachant que vous êtes là pour nous aider !"},{"op":"replace","path":"/scriptConfig/generatedText/completionText/default/glitch/0","value":"Soulagé. Merci beaucoup!<victim>a<victim.pronoun.possessiveDet> <item>et<thief>sait mieux que voler<victim.pronoun.object>encore!"},{"op":"replace","path":"/scriptConfig/generatedText/completionText/default/glitch/1","value":"Heureux. Beau travail de retour du<item>à<victim>la maison en mon nom ! Cela ne vous dérange pas que je prenne tout le mérite, n'est-ce pas ? Bien sûr que non."},{"op":"replace","path":"/scriptConfig/generatedText/completionText/default/default/0","value":"Wow, tu as rendu ça facile !<victim>je serai ravi de voir que nous avons obtenu<victim.pronoun.possessiveDet> <item>dos. Avez-vous déjà fait cela ? Il n'y a aucun danger de laisser des empreintes digitales avec un outil spécialisé comme celui-là."},{"op":"replace","path":"/scriptConfig/generatedText/completionText/default/default/1","value":"Beau travail !<victim>je serai très reconnaissant de voir que j'ai aidé à obtenir<victim.pronoun.possessiveDet> <item>dos. Nous sommes désormais un duo de justiciers audacieux !"},{"op":"replace","path":"/scriptConfig/generatedText/failureText/0","value":"Je ne pouvais pas rendre justice à<victim>. C'est peut-être mieux que je ne m'en mêle pas."},{"op":"replace","path":"/scriptConfig/generatedText/failureText/1","value":"Je n'ai pas réussi à récupérer<victim>c'est<item>. <questGiver>j'aurais dû le faire<questGiver.pronoun.reflexive>."},{"op":"replace","path":"/scriptConfig/generatedText/failureText/2","value":"Je n'ai pas réussi à restituer l'objet volé à<victim>. Espérons que<victim.pronoun.subject>ça ne me dérange pas trop."},{"op":"replace","path":"/scriptConfig/objectives/0/text","value":"Prendre<victim>c'est<item>depuis<thief>la maison"},{"op":"replace","path":"/scriptConfig/objectives/1/text","value":"Renvoyez le<item>à<victim>la maison"}]