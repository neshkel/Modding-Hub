[{"op":"replace","path":"/title","value":"^orange;Pièces et Main-d'œuvre"},{"op":"replace","path":"/text","value":"Je travaille sur une toute nouvelle arme de mech, mais j'ai besoin d'un coup de main pour rassembler quelques pièces. Si vous pouviez ^green;aller dans l'espace^white; et ^green;me trouver 5^orange; puces d'interface de récupération^white; ainsi que ^green;10 ^orange;coupleurs de puissance de récupération^white;, je pense que ce sera suffisant pour la terminer !"},{"op":"replace","path":"/completionText","value":"Ces pièces sont suffisantes pour que je termine mon nouveau ^orange;bras lance-missiles^white; ! En signe de gratitude, j'ai envoyé une copie du ^green;schéma^white; à la ^green;table de fabrication de mech^white; — vous pouvez aller fabriquer le vôtre dès maintenant !"},{"op":"replace","path":"/scriptConfig/portraits/questStarted/title","value":"Dr. Akaggy"},{"op":"replace","path":"/scriptConfig/portraits/questComplete/title","value":"Dr. Akaggy"}]