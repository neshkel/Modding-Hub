[{"op":"replace","path":"/title","value":"^orange;Essai Routier"},{"op":"replace","path":"/text","value":"Salut là-dedans, l'ami ! Je suis le ^orange;Dr Akaggy^white;, et mon truc, c'est les robots ! J'ai ce ^green;mech spatial modulaire^white; expérimental qui a besoin d'un essai, mais mes pilotes habituels sont... indisposés. Pourriez-vous me rendre service et le ^green;piloter à travers mon parcours de test^white; ? \n\n^green;Parlez-moi quand vous serez prêt à partir^white; !"},{"op":"replace","path":"/completionText","value":"Vous êtes revenu ! Ce n'est pas de la surprise dans ma voix, c'est de l'exaltation ! En récompense, je vous donne assez de ^green;pièces de mech détachées^white; pour que vous puissiez déployer votre propre mech de voyage spatial ! Allez vers cette ^orange;station d'assemblage de mech^white; pour le personnaliser !"},{"op":"replace","path":"/scriptConfig/descriptions/enterInstance","value":"Parlez au ^orange;Dr Akaggy^reset; pour entrer dans le ^orange;parcours de test^reset;"},{"op":"replace","path":"/scriptConfig/descriptions/findGoal","value":"Terminez le ^orange;parcours de test du mech^reset;"},{"op":"replace","path":"/scriptConfig/descriptions/turnIn","value":"Retournez voir le ^orange;Dr Akaggy^reset; au ^orange;Refuge^reset;"}]