[{"op":"replace","path":"/title","value":"^orange;L'ultime frontière"},{"op":"replace","path":"/text","value":"Les vents murmurent ce que vous avez accompli — vous avez voyagé loin, jeune être. Mais il reste encore des portes que vous n'avez pas ouvertes. ^green;Je peux échanger des ^orange;clés^green; avec vous^white;, si vous souhaitez ^green;ouvrir les ^orange;Portes Anciennes^green; dispersées parmi les étoiles^white;."},{"op":"replace","path":"/completionText","value":"Je suis arrivé dans un ^orange;Ancien Caveau^white; ! Je me demande quels secrets cachent ces ruines ? Je devrais jeter un coup d'œil aux alentours..."},{"op":"replace","path":"/scriptConfig/portraits/questStarted/title","value":"Le Marchand"},{"op":"replace","path":"/scriptConfig/objectiveLists/obtainKey/0/0","value":"Obtenez une ^orange;Clé de Caveau^reset; auprès du marchand mystérieux"},{"op":"replace","path":"/scriptConfig/objectiveLists/enterVault/0/0","value":"Obtenez une Clé de Caveau auprès du marchand mystérieux"},{"op":"replace","path":"/scriptConfig/objectiveLists/enterVault/1/0","value":"Entrez dans une ^orange;Porte Ancienne^reset; isolée"}]