[{"op":"replace","path":"/title","value":"Cher Baron"},{"op":"replace","path":"/description","value":"Une lettre au Baron de la part d'un fonctionnaire Glitch exaspéré."},{"op":"replace","path":"/contentPages/0","value":"Cher Baron,\n\nJe vous prie (et pour la DERNIÈRE FOIS) d'avoir l'amabilité d'arrêter de proposer des édits législatifs. De plus, je voudrais encore une fois mettre au clair que vous ne POUVEZ PAS faire passer de lois.\n\nPour reformuler: VOUS N'AVEZ AUCUN POUVOIR AUTORITAIRE. Franchement, veuillez arrêter.\n\nSincèrement,\nLe Seigneur Président du Conseil Privé"}]