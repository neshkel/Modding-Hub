{
  "rainbowwoodblock": {
    "name": "Lames de bois arc-en-ciel",
    "desc": "Tout simplement fabuleux.",
    "metadata": {
      "glitchdescription": "Je suis ravie. Ces lames colorées sont lumineuses et gaies.",
      "florandescription": "Floran adore les planches colorées aux couleurs de l'arc-en-ciel.",
      "novakiddescription": "Des planches fabriquées à partir d'un bois aux couleurs vives."
    }
  },
  "redtoyblock": {
    "name": "Bloc de construction rouge",
    "desc": "Un gros bloc de construction empilable.",
    "metadata": {
      "glitchdescription": "C'est amusant. Ces blocs s'empilent et s'emboîtent les uns dans les autres.",
      "florandescription": "Floran aime les blocs de construction empilables.",
      "novakiddescription": "Ces blocs colorés sont faits pour jouer."
    }
  },
  "reedblock": {
    "name": "Bloc d'anches",
    "desc": "Un bloc constitué de roseaux étroitement tressés.",
    "metadata": {
      "glitchdescription": "Impressionnant. Ces roseaux étroitement entrelacés forment des blocs solides.",
      "florandescription": "Floran aime les roseaux robustes.",
      "novakiddescription": "Des roseaux entrelacés."
    }
  },
  "ridgebrick": {
    "name": "Bloc nervuré",
    "desc": "Briques de pierre présentant une arête sculptée près du sommet.",
    "metadata": {
      "glitchdescription": "Ça m'intéresse. Ces blocs de construction rainurés sont simples, mais efficaces.",
      "florandescription": "Blocs de pierre striés.",
      "novakiddescription": "Ces blocs de pierre sont vraiment très bien sculptés."
    }
  },
