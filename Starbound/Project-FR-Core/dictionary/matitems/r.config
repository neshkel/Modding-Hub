  "rooftiles": {
    "name": "Tuiles",
    "desc": "Des tuiles usées par les intempéries. Leur forme me met mal à l'aise.",
    "metadata": {
      "glitchdescription": "Remarque. Ces tuiles sont inclinées pour faciliter l'écoulement de l'eau de pluie.",
      "florandescription": "Tuiles.",
      "novakiddescription": "Ces tuiles semblent parfaites pour faire un toit."
    }
  },
  "ruinsplatform": {
    "name": "Plateforme des Ruines",
    "desc": "Une vieille plate-forme en bois poussiéreuse. On dirait qu'elle tombe en ruine.",
    "metadata": {
      "glitchdescription": "C'est inquiétant. Cette vieille plate-forme en bois présente des problèmes de sécurité.",
      "florandescription": "En décomposition et dangereux. Floran approuve.",
      "novakiddescription": "Je ferais mieux de faire attention, cette vieille plate-forme a l'air de tomber en ruine."
    }
  },
  "rustyblock": {
    "name": "Bloc rouillé",
    "desc": "Un vieux bloc de métal rouillé.",
    "metadata": {
      "glitchdescription": "C'est effrayant. Ce métal rouillé et abandonné est usé et abîmé par les intempéries.",
      "florandescription": "Blocs métalliques Russsty.",
      "novakiddescription": "Ce morceau de métal a l'air sacrément rouillé."
    }
  },
  "rustymetal": {
    "name": "Métal rouillé",
    "desc": "Du vieux métal recouvert de rouille.",
    "metadata": {
      "glitchdescription": "Je suis inquiet. La rouille sur ce métal me met très mal à l'aise.",
      "florandescription": "Métal recouvert de Russst.",
      "novakiddescription": "Un vieux morceau de métal recouvert d'une épaisse couche de rouille."
    }
  },
  "rustyrail": {
    "name": "Rail rouillé",
    "desc": "Ces rails sont un peu rugueux, mais ils font l'affaire.",
    "metadata": {
      "glitchdescription": "Je suis inquiet. Ces rails ont l'air usés et rouillés.",
      "florandescription": "Des rails métalliques rouillés.",
      "novakiddescription": "Des rails qui ont l'air rouillés… ça me donne envie de les essayer."
    }
  }
