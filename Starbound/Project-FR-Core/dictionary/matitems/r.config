    "metadata": {
      "glitchdescription": "Je ne suis pas impressionné. Ce ne sont que des pierres empilées comme des briques.",
      "florandescription": "Des pierres empilées.",
      "novakiddescription": "Ce n'est rien d'autre qu'un tas de cailloux."
    }
