  "glowbed": {
    "name": "Lit Luminescent",
    "desc": "Un lit traversé par des plantes lumineuses.",
    "metadata": {
      "apexDescription": "Ces lumières faciliteront la recherche du lit pendant la nuit.",
      "avianDescription": "Ce lit a-t-il été cultivé? C'est fascinant.",
      "floranDescription": "Floran aime lit-plante. Pas sssûr pour les étranges lumièress par contre.",
      "glitchDescription": "Détendu. Ce lit émet une lumière faible et apaisante.",
      "humanDescription": "Ce lit a des veilleuses intégrées? Sympa.",
      "hylotlDescription": "Les lumières apaisantes sont agréables sur ce lit organique.",
      "novakidDescription": "Un lit qui brille, ça me va très bien."
    }
  },
  "glowbush1": {
    "name": "Buisson à Fleurs Lumineuses",
    "desc": "Un buisson de jolies fleurs luminescentes.",
    "metadata": {
      "apexDescription": "De jolies fleurs lumineuses.",
      "avianDescription": "Ces fleurs lumineuses sont magnifiques!",
      "floranDescription": "Floran porterait fleurs qui brillent... mais alors Floran sserait repéré.",
      "glitchDescription": "Intrigué. Ces fleurs sont étonnamment bien adaptées à cet environnement rude.",
      "humanDescription": "J'adorerais avoir ces buissons dans mon jardin, mais ils ont l'air trop délicats pour être transplantés.",
      "hylotlDescription": "Ces fleurs brillent faiblement. Elles semblent désolées dans ce désert de neige.",
      "novakidDescription": "C'est-y pas une jolie plante."
    }
  },
