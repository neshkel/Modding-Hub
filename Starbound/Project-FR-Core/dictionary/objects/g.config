  "glowflowerlamp": {
    "name": "Lampe Fleur Luminescente",
    "desc": "Une fleur qui semble émettre une lueur agréable.",
    "metadata": {
      "apexDescription": "L'éclat de cette lumière me rappelle une expérience Apex, mais en moins glauque.",
      "avianDescription": "La lueur de cette fleur est réconfortante.",
      "floranDescription": "Floran veut des fleurss luminessscentes pour éclairer la maison de Floran.",
      "glitchDescription": "Captivé. La lumière de cette lampe est enivrante.",
      "humanDescription": "La lampe la plus parfumée au monde.",
      "hylotlDescription": "Une lampe exquise qui célèbre la beauté de la nature.",
      "novakidDescription": "C'est une bonne idée d'avoir fait une lampe avec l'une de ces fleurs."
    }
  },
  "glowroot1": {
    "name": "Racines",
    "desc": "De petites racines luminescentes dépassent du plafond.",
    "metadata": {
      "apexDescription": "De minuscules racines parsemées de petites lumières.",
      "avianDescription": "De petites racines scintillant comme des étoiles ornent le plafond.",
      "floranDescription": "Même les racinesss brillent... Floran a hâte d'être dans le noir.",
      "glitchDescription": "S'interroge. S'agit-il des racines des plantes au-dessus, ou d'un organisme distinct?",
      "humanDescription": "J'adore comme tout brille ici, même les racines!",
      "hylotlDescription": "Ces minuscules racines lumineuses rappellent certains vers tubicoles rares que j'ai vus jadis dans une fosse océanique profonde.",
      "novakidDescription": "Ces racines scintillantes sont vraiment jolies."
    }
  },
