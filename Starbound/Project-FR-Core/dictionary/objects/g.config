  "glowbushlamp": {
    "name": "Lampe Buisson Luminescent",
    "desc": "Un buisson qui émet une lueur agréable.",
    "metadata": {
      "apexDescription": "Un buisson brillant tout mignon. Fonctionne mieux la nuit.",
      "avianDescription": "Une charmante façon d'éclairer une pièce.",
      "floranDescription": "Floran n'essst pas fan des plantess en pot.",
      "glitchDescription": "Studieux. La lueur est produite par la bioluminescence naturelle de la fleur.",
      "humanDescription": "La lumière naturelle est une chose plaisante à contempler.",
      "hylotlDescription": "Cette remarquable lampe naturelle est à couper le souffle.",
      "novakidDescription": "Est-ce qu'une plante dans un pot ça compte vraiment comme une lampe?"
    }
  },
  "glowchair": {
    "name": "Chaise Luminescente",
    "desc": "Une chaise luminescente.",
    "metadata": {
      "apexDescription": "Cette chaise brillante a été cultivée pour sa fonction. Aucun circuit en vue.",
      "avianDescription": "Je n'aime pas la lueur effrayante de cette chaise.",
      "floranDescription": "Lumièress de plantess sont les meilleures. Encore mieux en chaise.",
      "glitchDescription": "Impressionné. Cette chaise organique possède des nœuds bioluminescents.",
      "humanDescription": "Pas idéal si vous aimez rester assis dans le noir.",
      "hylotlDescription": "Les trois lumières au sommet de cette chaise ressemblent presque au regard d'un Hylotl.",
      "novakidDescription": "De la lumière mais pas de chaleur. C'est deux fois moins bien qu'un feu de camp."
    }
  },
  "glowchest": {
    "name": "Coffre Luminescent",
    "desc": "Ce coffre semble être de construction organique.",
    "metadata": {
      "apexDescription": "Le coffre lui-même semble être organique.",
      "avianDescription": "Ce coffre a-t-il été construit, ou a-t-il poussé?",
      "floranDescription": "Floran Vert-doigt peut faire poussser coffre comme ça dans la terre.",
      "glitchDescription": "Impressionné. Il semble que cette plante ait été cultivée dans le but exprès de servir de coffre.",
      "humanDescription": "Est-ce que ce coffre a poussé?",
      "hylotlDescription": "Le coffre lui-même semble être organique, très impressionnant.",
      "novakidDescription": "Un coffre qui brille. Pratique pour ranger un truc qu'on veut pas perdre."
    }
  },
  "glowflower1": {
    "name": "Capsule de Fleur Luminescente",
    "desc": "Une capsule de fleur luminescente.",
    "metadata": {
      "apexDescription": "Une capsule de fleur luminescente.",
      "avianDescription": "Il y a quelque chose de troublant dans ces capsules de fleurs luminescentes.",
      "floranDescription": "Capsuless brillantes contiennent du nectar sssucré.",
      "glitchDescription": "Nerveux. Cette capsule de fleur a un éclat inquiétant.",
      "humanDescription": "Ces fleurs à capsules sont trop glauques. Pas mon genre de truc.",
      "hylotlDescription": "J'ai vu des capsules lumineuses similaires au fond de l'océan. Leur lumière est étrange et éthérée.",
      "novakidDescription": "On dirait un œuf d'extraterrestre!"
    }
  },
