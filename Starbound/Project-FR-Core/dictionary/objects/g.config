  "goldsample": {
    "name": "Échantillon d'Or",
    "desc": "Un échantillon parfait de minerai d'or."
  },
  "geodebed": {
    "name": "Lit Géode",
    "desc": "Un lit sculpté à l'intérieur d'une géode géante.",
    "metadata": {
      "apexDescription": "Cette géode est assez vide pour qu'on puisse s'y glisser et dormir.",
      "avianDescription": "Les lits Avians sont parfois faits de pierre, mais celui-ci semble assez inconfortable.",
      "floranDescription": "Pierress pointues font un mauvais lit.",
      "glitchDescription": "Inquiet. Les cristaux à l'intérieur de cette géode n'ont pas l'air confortables pour dormir.",
      "humanDescription": "Ce que ce lit n'a pas en confort, il le rattrape en sécurité. Dormir à l'intérieur d'un rocher!",
      "hylotlDescription": "Dormir dans une géode est une façon de s'immerger dans la beauté naturelle.",
      "novakidDescription": "J'pourrais m'recroqueviller là-dedans comme dans ma propre petite grotte."
    }
  },
  "geodeceilinglight": {
    "name": "Lampe de Plafond Géode",
    "desc": "Une lampe façonnée à partir d'une géode luminescente suspendue.",
    "metadata": {
      "apexDescription": "Cette géode lumineuse a été installée à l'intérieur.",
      "avianDescription": "J'ai vu beaucoup de lampes alimentées par des cristaux, mais celle-ci n'est clairement pas de conception Aviane.",
      "floranDescription": "Rochersss brillants font lampe suspendue.",
      "glitchDescription": "Émerveillé. D'une manière ou d'une autre, ce luminaire parvient à déclencher électroniquement la lumière naturelle de cette géode.",
      "humanDescription": "La luminescence naturelle de cette géode a été transformée en lampe.",
      "hylotlDescription": "Cette lampe est une synthèse intéressante entre la nature et la fabrication moderne.",
      "novakidDescription": "Une lampe faite avec des cailloux verts qui brillent."
    }
  },
  "geodechair": {
    "name": "Chaise Géode",
    "desc": "Une grande géode creuse sculptée en forme de chaise.",
    "metadata": {
      "apexDescription": "Cette géode a exactement la bonne forme pour un siège.",
      "avianDescription": "Cette chaise n'a pas l'air confortable, mais elle fait l'affaire.",
      "floranDescription": "Gros rocher fait un mauvais sssiège.",
      "glitchDescription": "Inquiet. Rester assis longtemps sur cette chaise causerait certainement un certain inconfort.",
      "humanDescription": "Cette géode creuse est juste assez grande pour s'asseoir à l'intérieur.",
      "hylotlDescription": "Ce qu'elle manque en confort, elle le rattrape en beauté.",
      "novakidDescription": "C'est sans doute le caillou pour s'asseoir le plus chic que j'aie jamais vu."
    }
  },
  "geodedoor": {
    "name": "Porte Géode",
    "desc": "Une porte sculptée dans la section transversale d'une grande géode.",
    "metadata": {
      "apexDescription": "Cette porte lourde a été taillée dans une géode verte.",
      "avianDescription": "Les cristaux de géode de cette porte ont été polis.",
      "floranDescription": "Porte faite de rochersss brillants.",
      "glitchDescription": "Sécurisé. Cette lourde porte géode pourrait facilement repousser les visiteurs indésirables.",
      "humanDescription": "Les cristaux de cette géode scintillent vivement quand on l'ouvre.",
      "hylotlDescription": "Cette pierre magnifique a été façonnée en porte.",
      "novakidDescription": "C'te grosse porte est faite de roche polie."
    }
  },
  "geodeplantpot": {
    "name": "Pot de Fleur Géode",
    "desc": "Une plante de cristal géode dans un pot de fleurs.",
    "metadata": {
      "apexDescription": "Les feuilles de cette plante sont en réalité des cristaux de géode.",
      "avianDescription": "Cette plante est aussi solide que la pierre.",
      "floranDescription": "À la fois plante et à la fois rochersss.",
      "glitchDescription": "Confus. Cette plante défie tout ce que je sais sur la formation des géodes.",
      "humanDescription": "Cette plante est couverte de petits cristaux verts.",
      "hylotlDescription": "Cette roche inhabituelle a été cultivée comme une plante.",
      "novakidDescription": "C'te plante fait pousser des cristaux de partout."
    }
  },
  "geodebnatural": {
    "name": "Géode Si (Naturelle)",
    "desc": "Une géode verte luminescente.",
    "metadata": {
      "apexDescription": "Une pierre qui tinte quand je m'en approche.",
      "avianDescription": "Une pierre lumineuse. Elle tinte.",
      "floranDescription": "Pierre brille, fait du bruit de clochette. Floran écoute.",
      "glitchDescription": "Curieux. Des ondes sonores sont émises par cette formation géologique.",
      "humanDescription": "Une pierre qui sonne. Plutôt cool.",
      "hylotlDescription": "Une pierre lumineuse émettant des sons.",
      "novakidDescription": "Un gros rocher vert qui sonne comme une cloche d'église. C'est un vrai casse-tête."
    }
  },
  "geodebnote": {
    "name": "Géode Si",
