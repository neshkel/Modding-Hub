{
  "gothicbed": {
    "name": "Lit Gothique",
    "desc": "Incarnez une goule mort-vivante avec ce cercueil effrayant!",
    "metadata": {
      "apexDescription": "Le Miniknog considérerait qu'enterrer les gens est un gaspillage...",
      "avianDescription": "Être enterré dans une telle chose n'apaiserait pas Kluex.",
      "floranDescription": "Essst-ce que c'est pour enterrer de la viande parfaitement ssavoureusse?",
      "glitchDescription": "Malaise. Ce lit cercueil me donne un mauvais pressentiment.",
      "humanDescription": "Ouaip, c'est tout à fait normal d'avoir un truc pareil chez soi.",
      "hylotlDescription": "Le peuple Hylotl ne s'attarde pas sur une imagerie aussi morbide.",
      "novakidDescription": "Ça me donne l'impression d'être dans un funérarium, ou un truc du genre."
    }
  },
  "gothicbookcase": {
    "name": "Bibliothèque Gothique",
    "desc": "Un cabinet morbide pour ranger des livres et d'autres choses.",
    "metadata": {
      "apexDescription": "La structure ouverte de cette bibliothèque fait qu'elle n'est pas très sécurisée.",
      "avianDescription": "Je ne peux pas dire que j'apprécie le look de cette bibliothèque à l'air triste.",
      "floranDescription": "Livress trop ennuyeux. Gappillage d'arbress.",
      "glitchDescription": "Intrigué. Je me demande ce qui est écrit dans ces vieux livres poussiéreux?",
      "humanDescription": "On dirait qu'elle est pleine de romans de vampires...",
      "hylotlDescription": "Les livres sont la source de toute connaissance! Enfin, peut-être pas ces livres de vampires.",
      "novakidDescription": "Je pense qu'elle aurait été plus jolie sans cette finition noire."
    }
  },
  "gothicchair": {
    "name": "Chaise Gothique",
    "desc": "Une chaise exceptionnellement gothique.",
    "metadata": {
      "apexDescription": "Une grande chaise gothique.",
      "avianDescription": "Une chaise luxueuse. Mais d'apparence plutôt lugubre.",
      "floranDescription": "Grande chaisse essst douce pour s'asasseoir.",
      "glitchDescription": "Observateur. Une chaise au look très gothique.",
      "humanDescription": "Une chaise gothique magnifiquement fabriquée.",
      "hylotlDescription": "Le matériau velouté du rembourrage est exquis.",
      "novakidDescription": "Une chaise élégante. Elle a l'air confortable."
    }
  },
  "gothiccouch": {
    "name": "Canapé Gothique",
    "desc": "Un canapé effrayant avec une finition peinte en noir.",
    "metadata": {
      "apexDescription": "Un canapé au style très gothique.",
      "avianDescription": "Ce canapé me donne la chair de poule.",
      "floranDescription": "Floran trouve que canapé ssent bon.",
      "glitchDescription": "Morbide. Il y a des taches sombres sur le cuir.",
      "humanDescription": "Le canapé a une odeur suspecte...",
      "hylotlDescription": "Ce canapé est aussi élégant que terrifiant.",
      "novakidDescription": "Je n'suis pas sûr d'avoir envie de m'asseoir sur c'te machine."
    }
  },
  "gothicdoor": {
    "name": "Porte Gothique",
    "desc": "Une porte en bois lugubre.",
    "metadata": {
      "apexDescription": "Cette porte a l'air vieille, ou est du moins faite pour paraître vieille.",
      "avianDescription": "Je préfère les meubles aux teintes plus naturelles.",
      "floranDescription": "Floran n'aime pas porte effrayante.",
      "glitchDescription": "Observateur. Cette porte semble ancienne et importante.",
      "humanDescription": "Ça irait très bien dans une crypte, moins ailleurs.",
      "hylotlDescription": "Cette porte est presque poétique dans sa morosité.",
      "novakidDescription": "C'te porte me flanque les jetons."
    }
  },
  "gothiclight": {
    "name": "Bougie Gothique",
    "desc": "La lumière d'une bougie, livrée de la manière la plus sinistre possible.",
    "metadata": {
      "apexDescription": "Un piédestal gothique exquis. Dommage pour le crâne.",
      "avianDescription": "Rien de tel pour décorer qu'un crâne sur un piédestal.",
      "floranDescription": "Floran met ausssi tête coupée préférée ssour piédesstal.",
      "glitchDescription": "Admiratif. Un piédestal remarquable.",
      "humanDescription": "C'est certainement une façon de mettre quelqu'un sur un piédestal...",
      "hylotlDescription": "Un présentoir très gothique.",
      "novakidDescription": "J'me demande ce qu'on ressent avec un de ces trucs dans la caboche."
    }
  },
  "geometricbed": {
    "name": "Lit Géométrique",
    "desc": "Un lit géométrique robuste.",
    "metadata": {
      "apexDescription": "Un lit très joli et confortable.",
      "avianDescription": "C'est un endroit très confortable pour reposer mes plumes.",
      "floranDescription": "Floran sse repoose dans ssuper lit.",
      "glitchDescription": "Ravi. Ce lit semble exceptionnellement confortable.",
      "humanDescription": "Un excellent lit. Je devrais pouvoir m'y reposer sans problème.",
      "hylotlDescription": "Qualité de fabrication très correcte. J'aime beaucoup.",
      "novakidDescription": "Voilà un bon endroit pour reposer ma tête fatiguée."
    }
  },
  "geometricchair": {
    "name": "Chaise Géométrique",
    "desc": "Une chaise géométrique exceptionnellement confortable.",
    "metadata": {
      "apexDescription": "Une chaise très confortable. J'en suis satisfait.",
      "avianDescription": "Un endroit très décent pour s'asseoir.",
      "floranDescription": "Floran s'asasseoit ssur chaisse et pense à la chassse.",
      "glitchDescription": "Détendu. Cette chaise est exceptionnellement confortable pour un Glitch.",
      "humanDescription": "Une chaise très moelleuse. Ça me rappelle la maison.",
      "hylotlDescription": "Presque le luxe auquel les Hylotls sont habitués. C'est très satisfaisant.",
      "novakidDescription": "Un sacré bon endroit pour faire une pause."
    }
  },
  "geometricdoor": {
    "name": "Porte Géométrique",
    "desc": "Une porte géométrique. Robuste!",
    "metadata": {
      "apexDescription": "Une porte robuste.",
      "avianDescription": "Une porte robuste.",
      "floranDescription": "Porte!",
      "glitchDescription": "Calme. Une porte très solide.",
      "humanDescription": "Une porte solide et géniale.",
      "hylotlDescription": "Une porte simple mais solide.",
      "novakidDescription": "C'te porte est drôlement costaude."
    }
  },
  "geometriclight": {
    "name": "Lampe Géométrique",
    "desc": "Une lampe géométrique luminescente.",
    "metadata": {
      "apexDescription": "Une source lumineuse bien conçue.",
      "avianDescription": "Cette lampe utile éclairera même la pièce la plus sombre.",
      "floranDescription": "Lumière de lampe ssans danger pour Floran.",
      "glitchDescription": "Ravi. Une lampe robuste.",
      "humanDescription": "Une lampe soignée et solide.",
      "hylotlDescription": "Une source de lumière utile.",
      "novakidDescription": "C'te lumière va être rudement utile."
    }
  },
  "geometricswitch": {
    "name": "Console Géométrique",
    "desc": "Une console géométrique. Assez solide pour sauter dessus.",
    "metadata": {
      "apexDescription": "Cette console offre un grand degré de contrôle.",
      "avianDescription": "Une console utile.",
      "floranDescription": "Floran appuie ssur boutonss. Fait arriver dess chosess!",
      "glitchDescription": "Impressionné. Une seule console peut contrôler autant de mécanismes différents à la fois.",
      "humanDescription": "Une console de commande. C'est plus fort que moi, il faut que je joue avec.",
      "hylotlDescription": "Une console de contrôle.",
      "novakidDescription": "J'ai juste envie d'appuyer sur tous ces boutons."
    }
  },
  "geometrictable": {
    "name": "Table Géométrique",
    "desc": "Une table géométrique très bien fabriquée.",
    "metadata": {
      "apexDescription": "Cette table géométrique est très élégante.",
      "avianDescription": "Une table géométrique immensément robuste.",
      "floranDescription": "Table assez bonne pour que Floran découpe viandess.",
      "glitchDescription": "Approbateur. Une table géométrique très bien fabriquée.",
      "humanDescription": "Une table géométrique cool.",
      "hylotlDescription": "Ce n'est pas mon genre de table habituel, mais c'est assez impressionnant.",
      "novakidDescription": "Elle a pas l'air stable comme ça, mais elle l'est!"
    }
  },
  "glitchcaptainschair": {
    "name": "Siège de Capitaine Glitch",
    "desc": "Le Capitaine s'assoit ici pour piloter le vaisseau.",
    "metadata": {
      "apexDescription": "Ah... La douce liberté. Je peux utiliser le navigateur du vaisseau depuis ce siège.",
      "avianDescription": "Le siège du Capitaine. C'est moi! Je peux utiliser le navigateur du vaisseau d'ici.",
      "floranDescription": "Meilleur ssiège du vaisasseau. Floran peut s'asasseoir ici pour usser navigateur et piloter!",
      "glitchDescription": "Excité. S'asseoir sur le siège du Capitaine me permet de piloter ce vaisseau. Où allons-nous?",
      "humanDescription": "Le siège du Capitaine. La personne assise ici décide de la destination!",
      "hylotlDescription": "S'asseoir sur le siège du Capitaine me permet de piloter ce vaisseau.",
      "novakidDescription": "Le siège du Capitaine. Le gars assis là décide où on va! Et c'est moi!"
    }
  },
  "glitchfuelhatch": {
    "name": "Trappe à Carburant STL",
    "desc": "Accepte l'Erchius Liquide comme carburant pour les sauts supraluminiques.",
    "metadata": {
      "apexDescription": "La trappe à carburant supraluminique. Convertit le carburant en liberté.",
      "avianDescription": "La trappe à carburant STL. Remplissons-la et partons vers les étoiles!",
      "floranDescription": "Trappe à carburant pour moteur STL. Remplisssons-la!",
      "glitchDescription": "Excité. Cette trappe alimente le moteur STL pour que je puisse visiter des planètes hors de ce système.",
      "humanDescription": "La trappe à carburant du vaisseau. Avec du carburant STL, je peux explorer au-delà de ce système.",
      "hylotlDescription": "L'humble trappe à carburant STL. Le carburant est la sève de l'exploration.",
      "novakidDescription": "Le carburant STL va là-dedans!"
    }
  },
  "glitchshipdoor": {
    "name": "Porte de Vaisseau Glitch",
    "desc": "Une porte adaptée à un vaisseau spatial.",
    "metadata": {
      "apexDescription": "Ce genre de porte est courant sur les vaisseaux.",
      "avianDescription": "Une porte de vaisseau spatial.",
      "floranDescription": "Porte de vaisasseau.",
      "glitchDescription": "Informé. Une porte de vaisseau standard.",
      "humanDescription": "Une porte de vaisseau spatial.",
      "hylotlDescription": "Une porte de vaisseau basique.",
      "novakidDescription": "Une porte, le genre qu'on trouve sur un vaisseau."
    }
  },
  "glitchshiphatch": {
    "name": "Écoutille de Vaisseau Glitch",
    "desc": "Une écoutille adaptée à un vaisseau spatial.",
    "metadata": {
      "apexDescription": "Ce design d'écoutille est courant sur les vaisseaux.",
      "avianDescription": "Une écoutille de vaisseau spatial.",
      "floranDescription": "Éccoutille de vaisasseau.",
      "glitchDescription": "Informé. Une écoutille de vaisseau standard.",
      "humanDescription": "Une écoutille de vaisseau spatial.",
      "hylotlDescription": "Une écoutille de vaisseau basique.",
      "novakidDescription": "Une écoutille, le genre qu'on trouve sur un vaisseau."
    }
  },
  "glitchshipdoorBroken": {
    "name": "Porte de Vaisseau Glitch",
    "desc": "Une porte adaptée à un vaisseau spatial.",
    "metadata": {
      "apexDescription": "Ces portes sont utilisées sur tous nos vaisseaux. Celle-ci ne veut pas coopérer.",
      "avianDescription": "Une porte. Elle ne s'ouvre pas.",
      "floranDescription": "Porte veut pas s'ouvrir!",
      "glitchDescription": "Déçu. Une porte. Elle semble être désactivée pour le moment.",
      "humanDescription": "Porte sympa. Dommage qu'elle ne s'ouvre pas pour l'instant.",
      "hylotlDescription": "Une porte de vaisseau basique. Elle ne s'ouvre pas actuellement.",
      "novakidDescription": "La porte est cassée, elle va pas s'ouvrir de sitôt."
    }
  },
  "glitchshiplocker": {
    "name": "Casier de Vaisseau",
    "desc": "Un casier. Pourquoi ne pas y ranger quelques trucs?",
    "metadata": {
      "apexDescription": "Une unité de stockage Glitch.",
      "avianDescription": "Le casier de stockage du vaisseau.",
      "floranDescription": "Glitch range dess trucs bien ici.",
      "glitchDescription": "Ravi. Un bon casier de stockage Glitch.",
      "humanDescription": "Un bon endroit pour ranger des objets de valeur.",
      "hylotlDescription": "Un vieux dicton Hylotl me revient: « N'oublie jamais où tu as rangé tes trésors. »",
      "novakidDescription": "Un casier, pour mettre des trucs dedans."
    }
  },
  "glitchshiplockerTier0": {
    "name": "Casier de Vaisseau",
    "desc": "Pourquoi ne pas y ranger quelques trucs?",
    "metadata": {
      "apexDescription": "Une unité de stockage Glitch. Elle semble mal fonctionner.",
      "avianDescription": "Le casier de stockage du vaisseau. Malheureusement, il semble cassé.",
      "floranDescription": "Glitch range dess trucs bien ici. Quand ça marche.",
      "glitchDescription": "Désespéré. Ce casier semble être cassé.",
      "humanDescription": "Un bon endroit pour ranger des objets de valeur, quand ça fonctionne vraiment.",
      "hylotlDescription": "Un vieux dicton Hylotl me revient, mais il ne veut rien dire quand le casier est cassé.",
      "novakidDescription": "Un casier pour mettre des choses dedans. Dommage que celui-ci soit bousillé."
    }
  },
  "glitchtechstation": {
    "name": "S.A.I.L",
    "desc": "Ship-based Artificial Intelligence Lattice (Matrice d'Intelligence Artificielle de Vaisseau), ou S.A.I.L en abrégé.",
    "metadata": {
      "apexDescription": "Je peux parler à SAIL via cette console.",
      "avianDescription": "Je peux utiliser cette station pour parler à SAIL.",
      "floranDescription": "Floran utilise ce panneau magique pour parler à SAIL!",
      "glitchDescription": "Heureux. Cette station me permet de parler à SAIL.",
      "humanDescription": "Cette station me permet de communiquer avec SAIL.",
      "hylotlDescription": "Cette console me permet de communiquer avec SAIL.",
      "novakidDescription": "C'te station là m'permet d'causer avec SAIL."
    }
  },
  "glitchtechstationTier0": {
    "name": "S.A.I.L",
    "desc": "Ship-based Artificial Intelligence Lattice, ou S.A.I.L en abrégé.",
    "metadata": {
      "apexDescription": "Quand elle fonctionne, je peux parler à SAIL via cette console.",
      "avianDescription": "Redémarrer cette station devrait me permettre de parler à SAIL.",
      "floranDescription": "Floran répare ce panneau pour réveiller le vaisasseau!",
      "glitchDescription": "Désespéré. Je dois d'abord redémarrer cette station pour communiquer avec SAIL.",
      "humanDescription": "Si je peux redémarrer cette station, SAIL devrait revenir en ligne!",
      "hylotlDescription": "Cette console me permettra de communiquer avec SAIL. Je dois d'abord la redémarrer.",
      "novakidDescription": "C'est l'heure de redémarrer c'te station pour pouvoir causer à SAIL."
    }
  },
  "glitchteleporter": {
    "name": "Téléporteur",
    "desc": "Fidèle téléporteur, que ferions-nous sans toi?",
    "metadata": {
      "apexDescription": "Le téléporteur du vaisseau. Se téléporter donne l'impression de faire des montagnes russes à la vitesse de la lumière.",
      "avianDescription": "Le téléporteur! Se téléporter donne l'impression de voler.",
      "floranDescription": "Téléporteur de vaisasseau. Floran se ssent confusss pendant téléportation.",
      "glitchDescription": "Suffisant. Un téléporteur. Je suis capable d'entrer en mode veille pendant le processus de téléportation.",
      "humanDescription": "Le téléporteur! Se téléporter est une telle décharge d'adrénaline.",
      "hylotlDescription": "Un téléporteur. Se téléporter donne l'impression de plonger dans l'océan depuis le sommet d'une montagne.",
      "novakidDescription": "Téléporteur du vaisseau. On va l'faire chauffer un peu!"
    }
  },
  "glitchteleporterTier0": {
    "name": "Téléporteur",
    "desc": "Fidèle téléporteur, que ferions-nous sans toi?",
    "metadata": {
      "apexDescription": "Le téléporteur du vaisseau. Je dois le mettre sous tension.",
      "avianDescription": "Le téléporteur! Si seulement celui-ci était alimenté.",
      "floranDescription": "Téléporteur de vaisasseau. Celui-ci essst mort.",
      "glitchDescription": "Déçu. Un téléporteur sans électricité. Je dois le mettre sous tension.",
      "humanDescription": "Le téléporteur! Dommage qu'il ne soit pas alimenté.",
      "hylotlDescription": "Ce téléporteur est éteint.",
      "novakidDescription": "Téléporteur du vaisseau. Faut qu'je l'mette en marche!"
    }
  },
  "greenceilingspike1": {
    "name": "Pointes Aiguisées",
    "desc": "Attention!",
    "metadata": {
      "apexDescription": "Des pointes de pierre tranchantes.",
      "avianDescription": "La pierre semble tranchante comme un rasoir.",
      "floranDescription": "Tranchant et pointu.",
      "glitchDescription": "Prudent. La roche tranchante pourrait pénétrer la carapace Glitch.",
      "humanDescription": "Je ferais mieux de ne pas toucher à ça.",
      "hylotlDescription": "Je vais éviter cela avec élégance.",
      "novakidDescription": "Ça a l'air drôlement pointu, j'suis prêt à déguerpir d'ici!"
    }
  },
