  "geometricshard1": {
    "name": "Morceau de Glace",
    "desc": "Un gros morceau de glace.",
    "metadata": {
      "apexDescription": "Un bloc de glace.",
      "avianDescription": "Un morceau de glace pointu.",
      "floranDescription": "Glace givrée. Floran se ssent givré aussii.",
      "glitchDescription": "Neutre. De l'eau gelée.",
      "humanDescription": "Glacial! Si je le lèche, ma langue va rester collée.",
      "hylotlDescription": "Un éclat de glace solide. Froid jusqu'au cœur.",
      "novakidDescription": "Un éclat de glace. L'arme du crime parfaite."
    }
  },
