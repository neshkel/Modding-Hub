  "glowvinelamp": {
    "name": "Lampe Liane Luminescente",
    "desc": "Une liane qui semble émettre une lueur agréable.",
    "metadata": {
      "apexDescription": "Une grande liane avec des fruits lumineux suspendus.",
      "avianDescription": "Les bulbes de cette liane illumineront n'importe quelle pièce.",
      "floranDescription": "Floran apprécie la lumière naturelle de cette liane.",
      "glitchDescription": "Satisfait. Une lueur agréable est produite par les bulbes bioluminescents de la liane.",
      "humanDescription": "La plus jolie lampe naturelle que j'aie jamais vue.",
      "hylotlDescription": "Avoir une source de lumière naturelle à l'intérieur est une véritable bénédiction.",
      "novakidDescription": "Une chouette lampe pour y voir clair."
    }
  },
  "goldenducky": {
    "name": "Petit Canard en Or",
    "desc": "Un canard en or!",
    "metadata": {
      "apexDescription": "Un petit canard en or.",
      "avianDescription": "Ces objets ont en fait beaucoup de valeur.",
      "floranDescription": "Petit canard tout brillant.",
      "glitchDescription": "Épris. Il est adorable.",
      "humanDescription": "Un petit canard adorable.",
      "hylotlDescription": "Un caneton, immortalisé dans l'or.",
      "novakidDescription": "Un canard en or massif."
    }
  },
  "goldenjar1": {
    "name": "Vase d'Oiseau en Or",
    "desc": "Ce vase à tête d'oiseau aux yeux globuleux est fait d'or massif.",
    "metadata": {
      "apexDescription": "On dirait que ceci a été conçu pour contenir quelque chose d'important.",
      "avianDescription": "Ce pot contient les organes d'un Stargazer après sa mort.",
      "floranDescription": "Pot d'oiseau chic, tout en or et brillant. Bonne odeur de l'intérieur.",
      "glitchDescription": "Dégoûté. Ce pot semble contenir un cœur, des poumons et un cerveau d'origine Aviane.",
      "humanDescription": "Ça sent la chair putréfiée.",
      "hylotlDescription": "L'odeur suggère qu'il y a des restes corporels à l'intérieur.",
      "novakidDescription": "Un vase provenant d'une tombe Aviane, y'a probablement encore des tripes d'oiseau dedans."
    }
  },
  "goldenurn": {
    "name": "Urne en Or",
    "desc": "Les cendres des Stargazers Avians sont souvent conservées dans des urnes comme celle-ci.",
    "metadata": {
      "apexDescription": "C'est rempli de cendres et de plumes.",
      "avianDescription": "Une urne de Stargazer. Contient non seulement leurs cendres, mais aussi chacune de leurs plumes arrachées.",
      "floranDescription": "Pousssière d'oiseau sssavoureuse à l'intérieur.",
      "glitchDescription": "Pensif. Pourquoi l'urne contient-elle des plumes en plus des cendres?",
      "humanDescription": "Une collection de plumes et de cendres, probablement pleine de sens pour un Avian.",
      "hylotlDescription": "Il semble que les Avians accordent une grande valeur à leurs plumes. Cette urne en est remplie.",
      "novakidDescription": "Ce bocal contient les restes d'un gars ou d'une fille Avian décédé."
    }
  },
  "genericpainting1": {
    "name": "Tableau Curieux",
    "desc": "Ah, Le Fils de l'Homme, tu me donnes faim!",
    "metadata": {
      "apexDescription": "C'est plutôt abstrait.",
      "avianDescription": "Quelle est cette créature?",
      "floranDescription": "Floran est trop confuss.",
      "glitchDescription": "Confus. Y a-t-il un sens caché derrière cette pomme?",
      "humanDescription": "Comme c'est abstrait. Appétissant, mais abstrait.",
      "hylotlDescription": "Ahh... Je comprends. Ce tableau fait réfléchir.",
      "novakidDescription": "Il porte un chapeau sacrément chic pour une pomme."
    }
  },
  "glitchianman": {
    "name": "Homme Glitchien",
    "desc": "Un croquis assez détaillé de l'anatomie Glitch.",
    "metadata": {
      "apexDescription": "Il semble que ce soit l'anatomie d'un Glitch.",
      "avianDescription": "Est-ce ainsi que les Glitch sont assemblés?",
      "floranDescription": "Manuel d'insstruction pour Glitch. Ça a l'air dur.",
      "glitchDescription": "Analytique. La médecine Glitch est encore très primitive. Une grande partie de ce diagramme anatomique est fausse.",
      "humanDescription": "On dirait un diagramme d'anatomie.",
      "hylotlDescription": "Les Glitch semblent enquêter sur leur propre anatomie. Peut-être que la médecine Glitch en bénéficiera.",
      "novakidDescription": "Regardez-moi tous ces bras et ces jambes. Ça doit pas être simple de se déplacer."
    }
  },
  "glitchspeare": {
    "name": "Portrait de Glitchspeare",
    "desc": "Un portrait de William Glitchspeare.",
    "metadata": {
      "apexDescription": "Comment se fait-il que ce Glitch ait autant de poils qu'un Apex?",
      "avianDescription": "Ce Glitch a des poils faciaux. Comment est-ce possible?",
      "floranDescription": "Glitch a une barbe. Essst-elle vraie?",
      "glitchDescription": "Déductif. Ma base de données suggère que certains Glitch ont été modélisés d'après de grandes personnalités observées chez d'autres races. Celui-ci pourrait en être un.",
      "humanDescription": "Il ressemble beaucoup à un poète terrien présent au début de notre histoire.",
      "hylotlDescription": "Un genre d'artiste Glitch? Les Glitch sont-ils capables d'art?",
      "novakidDescription": "Un poète Glitch? Jamais entendu parler d'un truc pareil."
    }
  },
  "goldenegg": {
    "name": "Œuf en Or",
    "desc": "Un œuf en or! Quoi!?",
    "metadata": {
      "apexDescription": "Incroyable! D'où vient cet œuf?",
      "avianDescription": "Les légendes sont vraies! Quel spectacle magnifique à contempler.",
      "floranDescription": "Floran va garder le joli œuf.",
      "glitchDescription": "Émerveillement. Un œuf aussi magnifique vaudrait une petite fortune.",
      "humanDescription": "Ça, c'est un bel œuf.",
      "hylotlDescription": "Un merveilleux œuf d'or étincelant. Une véritable merveille.",
      "novakidDescription": "C'est rudement brillant, je peux voir mon reflet dedans."
    }
  },
  "grandfatherclock": {
    "name": "Horloge Comtoise",
    "desc": "Je ne savais pas que les horloges étaient capables de se reproduire.",
    "metadata": {
      "apexDescription": "Toutes les horloges Apex sont réglées automatiquement par radio.",
      "avianDescription": "L'heure Aviane est basée sur la lecture de la direction des ombres.",
      "floranDescription": "Floran sse fie toujours au coucher et au lever du ssoleil pour connaître l'heure.",
      "glitchDescription": "Impressionné. Ce garde-temps semble être précis à une milliseconde près.",
      "humanDescription": "Le son de cette horloge peut être à la fois inquiétant et apaisant.",
      "hylotlDescription": "Le son du métronome est parfait pour la méditation.",
      "novakidDescription": "Tic, tac, tic, tac. On peut pas ignorer le bruit d'une horloge."
    }
  },
  "greenflask": {
    "name": "Flacon Vert",
    "desc": "Un flacon rempli de glue verte.",
    "metadata": {
      "apexDescription": "Un horrible mélange Apex.",
      "avianDescription": "Une grande partie du mélange est figée. Cela rappelle le jaune d'œuf.",
      "floranDescription": "Glue verte qui pue.",
      "glitchDescription": "Suspicieux. Un mélange inconnu.",
      "humanDescription": "Il vaut probablement mieux ne pas y toucher.",
      "hylotlDescription": "On peut sentir la toxicité à plein nez.",
      "novakidDescription": "J'ai pas besoin d'enquêter plus pour savoir que ce truc annonce rien de bon."
    }
  },
  "gasdispenser": {
    "name": "Distributeur de Gaz",
    "desc": "Distribue du gaz."
  },
  "gleapaf": {
    "name": "Figurine de Gleap",
    "desc": "L'étiquette indique: \"Elle est faite d'une substance élastique.\""
  },
  "gosmetaf": {
    "name": "Figurine de Gosmet",
    "desc": "L'étiquette indique: \"Ces créatures ont des corps éthérés qu'elles moulent en armure lorsqu'elles sont menacées.\""
  }
}