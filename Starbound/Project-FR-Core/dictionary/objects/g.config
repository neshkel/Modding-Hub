  "giantflower1": {
    "name": "Fleur Géante",
    "desc": "Une fleur rouge géante. Jolie ET intimidante!",
    "metadata": {
      "apexDescription": "Une fleur immense. Elle me détend.",
      "avianDescription": "Une fleur géante. Magnifique.",
      "floranDescription": "Fleur ssi grande que Floran pourrait dansser desssus.",
      "glitchDescription": "Curieux. L'ADN de cette fleur a muté au fil des ans, d'où sa grande taille.",
      "humanDescription": "Imaginez débarquer chez quelqu'un avec un bouquet de ces trucs!",
      "hylotlDescription": "Une grande et belle fleur.",
      "novakidDescription": "C'est sans doute la plus grosse fleur que j'aie jamais vue."
    }
  },
