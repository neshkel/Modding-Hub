      "avianDescription": "Une charmante petite figurine.",
      "floranDescription": "C'est un jouet?",
      "glitchDescription": "Amusé. Une reproduction parfaite d'une tenue de noble Glitch.",
      "humanDescription": "Une charmante statuette, avec une petite cape en velours vert!",
      "hylotlDescription": "Un peu rudimentaire dans sa fabrication, mais charmante à sa manière.",
      "novakidDescription": "C'te p'tite figurine a l'air drôlement chic."
    }
  },
  "glitchchess": {
    "name": "Table d'Échecs Thématique",
    "desc": "Cet échiquier possède des pièces personnalisées.",
    "metadata": {
      "apexDescription": "Les échecs sont un jeu de stratégie que peu parviennent à maîtriser.",
      "avianDescription": "Quelqu'un a mis beaucoup de soin dans la fabrication de ce jeu de pièces.",
      "floranDescription": "Beaucoup de piècesss à dispersser pour Floran!",
      "glitchDescription": "Mélancolique. Mes parties d'échecs me manquent. Ces pièces sont bien conçues.",
      "humanDescription": "On dirait que ce sont des pièces faites sur mesure.",
      "hylotlDescription": "Quelqu'un a tenté de recréer des choses spécifiques avec ces pièces.",
      "novakidDescription": "J'ai jamais vraiment pigé l'truc avec ce jeu."
    }
  },
  "glitchdecree": {
    "name": "Décret Royal",
    "desc": "Ce décret royal mentionne un donjon où des trésors reposent sous bonne garde.",
    "metadata": {
      "apexDescription": "Ce vieux décret fait mention de trésors, gardés dans un grand donjon.",
      "avianDescription": "Ce décret mentionne l'emplacement d'un donjon rempli de trésors.",
      "floranDescription": "Floran ne sait pas pourquoi ces motss ennuyeux ssont encadrés.",
      "glitchDescription": "Curieux. Ce vieux décret fait mention d'un donjon rempli de trésors.",
      "humanDescription": "Ce décret royal mentionne un donjon lourdement gardé, protégeant une immense richesse.",
      "hylotlDescription": "Ce vieux décret royal indique l'emplacement d'un trésor conservé dans un donjon gardé.",
      "novakidDescription": "Cet écrit mentionne de l'or caché dans un vieux donjon quelque part."
    }
  },
  "glitchhorndisplay": {
    "name": "Bannière de Cor Murale",
    "desc": "Un cor de cérémonie qui soutient une bannière tissée.",
    "metadata": {
      "apexDescription": "On dirait que c'est utilisé pour une sorte de cérémonie.",
      "avianDescription": "Cela semble important.",
      "floranDescription": "Floran veut faire sssonner le cor!",
      "glitchDescription": "Fier. Des cors comme celui-ci sont utilisés lors de cérémonies spéciales.",
      "humanDescription": "Ce cor a l'air important, pourquoi d'autre serait-il exposé?",
      "hylotlDescription": "Je ne sais pas trop pourquoi un tel instrument est ainsi exposé.",
      "novakidDescription": "Ça a l'air important, certes, mais ça vaut combien?"
    }
  },
  "glitchscribe": {
    "name": "Bureau de Scribe",
    "desc": "Un bureau en bois utilisé par les scribes.",
    "metadata": {
      "apexDescription": "Un bureau pour la paperasse. Il est couvert de taches d'encre.",
      "avianDescription": "Un bureau conçu pour un universitaire.",
      "floranDescription": "Les éruditss mettent de l'encre ssur le papier ici.",
      "glitchDescription": "Enjoué. C'est un bureau digne d'un savant.",
      "humanDescription": "Un secrétaire. La surface est couverte d'éclaboussures d'encre.",
      "hylotlDescription": "Les Hylotls pratiquent la calligraphie sur des bureaux comme celui-ci.",
      "novakidDescription": "Un vieux bureau d'écriture."
    }
  },
  "gasgiant": {
    "name": "Géant Gazeux",
    "desc": "Ces insectes flottent sur les courants ascendants de gaz toxiques."
  },
  "glowbug": {
    "name": "Luciole",
    "desc": "Plus cet insecte a chaud, plus il brille."
  },
  "goldbuck": {
    "name": "Scarabée d'Or",
    "desc": "Un insecte aux ailes d'or étincelantes, très chic!"
  },
  "greentip": {
    "name": "Bout-Vert",
    "desc": "On dirait que cet insecte porte de minuscules chaussures vertes."
  },
  "gasprimer": {
    "name": "Racine",
    "desc": "C'est une racine.",
    "metadata": {
      "apexDescription": "Une sorte de racine d'arbre.",
      "avianDescription": "C'est une racine.",
      "floranDescription": "Racinesss.",
      "glitchDescription": "Neutre. Une racine quelconque.",
      "humanDescription": "Ouaip. C'est une racine.",
      "hylotlDescription": "Une racine.",
      "novakidDescription": "C'est juste une racine."
    }
  },
  "goldrock": {
    "name": "Rocher Aurifère",
    "desc": "Un rocher fissuré rempli d'or.",
    "metadata": {
      "apexDescription": "Il semble y avoir de l'or à l'intérieur de ce rocher fragile.",
      "avianDescription": "Si je brise ce rocher, je devrais pouvoir récolter le minerai d'or qu'il contient.",
      "floranDescription": "Caillou qui brille. Fracassse-le!",
      "glitchDescription": "Observateur. Ce rocher contient de l'or et est couvert de fissures.",
      "humanDescription": "Un rocher plein d'or! Je peux peut-être le casser.",
      "hylotlDescription": "Un coup sec sur ce rocher libérerait l'or qu'il contient.",
      "novakidDescription": "Un rocher riche en or. J'devrais l'briser."
    }
  },
  "goldrocksmall": {
