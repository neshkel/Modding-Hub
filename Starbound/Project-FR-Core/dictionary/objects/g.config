    "metadata": {
      "apexDescription": "Les géodes sont des formations rocheuses fascinantes!",
      "avianDescription": "Une géode miroitante. Jolie!",
      "floranDescription": "Jolie pierre qui brille.",
      "glitchDescription": "Ravi. Ah, une charmante géode!",
      "humanDescription": "Cool à l'intérieur mais ennuyeux à l'extérieur. Juste comme moi!",
      "hylotlDescription": "Les géodes gardent de beaux secrets à l'intérieur.",
      "novakidDescription": "L'intérieur de ce rocher, c'est vraiment quelque chose."
    }
  },
