  "glowtree1": {
    "name": "Arbre Luminescent",
    "desc": "Un arbre luminescent. C'est beau, mais un peu étrange.",
    "metadata": {
      "apexDescription": "J'ai comme un doute sur le fait que ces fruits brillants soient comestibles.",
      "avianDescription": "Ces arbres stockent-ils simplement la lumière du soleil ou génèrent-ils leur propre lumière?",
      "floranDescription": "Arbre brillant n'essst pas bon pour la chassse nocturne.",
      "glitchDescription": "Curieux. Quel processus biochimique alimente cette luminescence?",
      "humanDescription": "Des arbres qui brillent? C'est pratique!",
      "hylotlDescription": "Cet arbre brille comme s'il était habité par un esprit solitaire.",
      "novakidDescription": "Cet arbre est livré avec ses propres lanternes."
    }
  },
