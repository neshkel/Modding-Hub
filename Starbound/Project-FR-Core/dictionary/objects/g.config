  "giantflowerbed": {
    "name": "Lit de Fleur Géant",
    "desc": "Un lit en forme de fleur. J'espère que vous n'avez pas le rhume des foins.",
    "metadata": {
      "apexDescription": "Ce lit est amusant et rebondissant.",
      "avianDescription": "Dormir ici me donne des démangeaisons aux plumes.",
      "floranDescription": "Floran s'endort facilement dans les plantess.",
      "glitchDescription": "Inconfortable. Le lit est fait d'une plante carnivore. Inquiétant.",
      "humanDescription": "L'odeur doucereuse de la plante ne m'aide pas à dormir.",
      "hylotlDescription": "La nature adaptée pour d'autres usages. Remarquable.",
      "novakidDescription": "Un lit aux senteurs agréables. On ne peut que rêver de prairies fleuries là-dedans."
    }
  },
  "giantflowerchair": {
    "name": "Chaise Fleur Géante",
    "desc": "Une chaise fleur. Si vous aimez vous asseoir ici, ça veut dire que vous aimez le beurre.",
    "metadata": {
      "apexDescription": "Cette chaise semble spongieuse et bizarre.",
      "avianDescription": "Le dossier de cette chaise frotte contre mes plumes.",
      "floranDescription": "Floran s'assoit dans la fleur, Floran est content.",
      "glitchDescription": "Pensif. Combien d'années a-t-il fallu pour que les pétales se renforcent assez pour supporter mon poids?",
      "humanDescription": "Une chaise faite d'une fleur. Le pollen me fait éternuer.",
      "hylotlDescription": "Cette fleur a-t-elle poussé ainsi naturellement ou a-t-elle été façonnée?",
      "novakidDescription": "S'asseoir sur des pétales me donne l'impression d'être une fée de la forêt."
    }
  },
  "giantflowerchest": {
    "name": "Coffre Fleur Géante",
    "desc": "Un coffre fait de fleurs.",
    "metadata": {
      "apexDescription": "On pourrait facilement ramasser ce coffre et partir avec.",
      "avianDescription": "Un coffre-fleur. Facile à ouvrir.",
      "floranDescription": "Floran pourrait adapter coffre pour qu'il mange les voleurss.",
      "glitchDescription": "Observateur. L'ouverture de ce coffre libère des nuages de pollen invisibles. Les effets à long terme sont inconnus.",
      "humanDescription": "Un coffre mignon et coloré.",
      "hylotlDescription": "Un magnifique coffre naturel.",
      "novakidDescription": "Un coffre brillant comme ça doit être plein de joie."
    }
  },
  "giantflowerdoor": {
    "name": "Porte Fleur Géante",
    "desc": "Une porte ornée d'une couronne joyeuse.",
    "metadata": {
      "apexDescription": "Une porte en bois garnie d'une couronne accueillante.",
      "avianDescription": "Quiconque a mis cette couronne ici voulait que les gens se sentent les bienvenus.",
      "floranDescription": "Floran utilise la couronne comme sssigne pour club de chasse ssecret.",
      "glitchDescription": "Neutre. Une porte avec une couronne dessus.",
      "humanDescription": "Quelle porte joyeuse.",
      "hylotlDescription": "Cette porte est conçue pour être accueillante.",
      "novakidDescription": "Une jolie porte pour une maison accueillante. Comme un beau sourire sur un visage amical."
    }
  },
  "giantflowerlamp": {
    "name": "Lampe Fleur Géante",
    "desc": "Une fleur qui semble émettre les rayons du soleil.",
    "metadata": {
      "apexDescription": "Une fleur rougeoyante mignonne. Fonctionne mieux la nuit.",
      "avianDescription": "L'éclat de cette fleur illumine n'importe quelle pièce.",
      "floranDescription": "Floran aime fleur qui brille.",
      "glitchDescription": "Intéressé. L'éclat est produit par la fleur qui stocke l'énergie solaire pour l'expulser progressivement.",
      "humanDescription": "La lampe la plus parfumée de tous les temps.",
      "hylotlDescription": "Cette remarquable lampe naturelle est à couper le souffle.",
      "novakidDescription": "Une fleur lumineuse éblouissante. Un régal pour n'importe quelle maison."
    }
  },
  "giantflowertable": {
    "name": "Table Fleur Géante",
    "desc": "Une fleur géante. Parfaite pour servir de table.",
    "metadata": {
      "apexDescription": "Si vous aviez trop faim, vous pourriez manger la table elle-même.",
      "avianDescription": "Cette table semble assez fragile.",
      "floranDescription": "Table va vaciller quand Floran coupera la viande.",
      "glitchDescription": "Impressionné. Cette fleur géante est le produit d'années de culture soignée.",
      "humanDescription": "Manger ici donnerait l'impression de faire un pique-nique magique.",
      "hylotlDescription": "La nature donne autant qu'elle détruit.",
      "novakidDescription": "Une table ayant poussé naturellement. A-t-elle poussé à partir d'une graine de table?"
    }
  },
  "geodebluesample": {
    "name": "Échantillon de Géode Bleue",
