  "wateremblem": {
    "name": "Emblème d'Eau Avian",
    "desc": "Cet emblème représente l'élément tranquille et nourricier qu'est l'eau.",
    "metadata": {
      "apexDescription": "C'est l'emblème d'eau Avian.",
      "avianDescription": "Oh, l'emblème d'eau, il doit y avoir de l'eau plus loin.",
      "floranDescription": "Une sssorte de sssymbole, Floran pense que ça veut dirrre eau.",
      "glitchDescription": "Hésitant. Est-ce que ce symbole signifie eau ou feu? Eau. Ça doit être l'eau.",
      "humanDescription": "On dirait un peu un visage de Hylotl grincheux. C'est comme ça que je me rappelle que ça veut dire eau!",
      "hylotlDescription": "Un glyphe qui dépeint l'élément eau et indique sa présence.",
      "novakidDescription": "Je sais pas trop ce que ce truc essaie de me dirre. Mais ça me donne ssoif."
    }
  },
  "windchicken": {
    "name": "Girouette",
    "desc": "Est-ce un Avian... ou un poulet?",
    "metadata": {
      "apexDescription": "Je pense qu'elle indique la direction du vent.",
      "avianDescription": "Les Avians ont toujours porté une attention particulière au vent.",
      "floranDescription": "Poulet du vent!",
      "glitchDescription": "Observateur. Un dispositif rudimentaire conçu pour mesurer la direction du vent.",
      "humanDescription": "C'est une girouette!",
      "hylotlDescription": "Les Hylotls mesurent de la même manière les courants marins.",
      "novakidDescription": "C'est pas une jourrnée venteuse aujourd'hui."
    }
  },
  "wingedurn": {
    "name": "Urne Ailée",
    "desc": "Une urne ailée, on pensait peut-être qu'elle transportait les morts dans l'au-delà.",
    "metadata": {
      "apexDescription": "Une urne avec des ailes.",
      "avianDescription": "Ces urnes étaient données aux Avians estropiés au combat. L'urne est censée emmener les morts vers l'éther.",
      "floranDescription": "Pot avec des ailesss. Mais le pot ne vole pas.",
      "glitchDescription": "Observateur. Les ailes doivent avoir une signification religieuse quelconque.",
      "humanDescription": "Je pense que c'est une urne ailée. Remplie de cendres.",
      "hylotlDescription": "Où les ailes emmènent-elles les morts, je me le demande?",
      "novakidDescription": "Une urne ailée. Où c'est qu'elle va s'envoler?"
    }
  },
  "wallbuttontrigger": {
    "name": "Petit Bouton Mural",
    "desc": "Qui sait ce qu'il pourrait activer... appuyez dessus, c'est tout!"
  },
  "weaponupgradeanvil": {
    "name": "Enclume d'Amélioration d'Armes",
    "desc": "Cette technologie ancienne et avancée peut augmenter l'efficacité de certaines armes.",
    "metadata": {
      "apexDescription": "L'enclume fonctionne, je me demande quels êtres ont fabriqué ça.",
      "avianDescription": "Cette enclume est d'origine antique.",
      "floranDescription": "Floran appuie sssur les boutons. Fait arriver des chosssess!",
      "glitchDescription": "Impressionné. Les applications techniques de cette enclume sont aussi avancées qu'elles sont anciennes.",
      "humanDescription": "Une enclume faite pour résister à l'épreuve du temps.",
      "hylotlDescription": "Cette enclume semble extrêmement vieille, mais elle est toujours fonctionnelle.",
      "novakidDescription": "Cette enclume a l'air antique..."
    }
  },
  "wisperaf": {
    "name": "Figurine de Wisper",
    "desc": "L'étiquette indique: « Certains pensent que les Wispers sont des esprits perdus. La nuit, leur lueur peut égarer les explorateurs. »"
