  "wildautomatoseed": {
    "name": "Graine d'Automatate",
    "desc": "Des automatates! Assurez-vous de recracher les vis.",
    "metadata": {
      "apexDescription": "Des automatates... Plutôt classique, si on ne se casse pas les dents sur les vis.",
      "avianDescription": "Des automatates. Les graines sont assez bonnes toutes seules.",
      "floranDescription": "Charrrnu et jusssseux, avec des morrrceaux qui croquent. Comme les humainsss.",
      "glitchDescription": "Désapprobateur. Les autres retirent les vis. Les Glitchs trouvent qu'elles rehaussent le goût.",
      "humanDescription": "Une tomate remplie de vis. Savoureux mais dangereux.",
      "hylotlDescription": "Une nourriture de paysan Glitch courante. Pas à mon goût.",
      "novakidDescription": "Les automatates ont un goût acidulé et métallique."
    }
  },
  "wildavesmingoseed": {
    "name": "Graine d'Avesmingo",
    "desc": "L'Avesmingo, la plante aux 100 saveurs différentes.",
    "metadata": {
      "apexDescription": "On dit qu'il a cent saveurs différentes. Est-ce que la banane en fait partie?",
      "avianDescription": "Une plante si riche en goût. La graine est particulièrement savoureuse.",
      "floranDescription": "Ce frrruit a du goût. Aucune de cesss sssaveurs n'a le goût de la vian-de.",
      "glitchDescription": "Confus. Ça a le goût de... brocoli.",
      "humanDescription": "Si les saveurs comptent, ça devrait couvrir mes besoins en fruits et légumes cinquante fois.",
      "hylotlDescription": "L'Avesmingo, le fruit aux multiples saveurs. Un délice exotique sous l'océan.",
      "novakidDescription": "Ce fruit a beaucoup trop de saveurs. J'arrive pas à en apprécier une seule."
    }
  },
  "wildbananaseed": {
    "name": "Graine de Banane",
    "desc": "Des bananes génétiquement modifiées. Des arbres plus petits pour des fruits plus gros.",
    "metadata": {
      "apexDescription": "Il y a ce stéréotype comme quoi les Apex adorent les bananes, merci au Miniknog. Elles sont délicieuses, cela dit.",
      "avianDescription": "Ces bananes ont un goût étrange que je n'arrive pas à définir.",
      "floranDescription": "Çssa sssent l'homme-singe.",
      "glitchDescription": "Cynique. Les Apex adorent ça, mais les Glitchs n'y voient rien de spécial.",
      "humanDescription": "C'est comme une banane, mais encore plus « banane ».",
      "hylotlDescription": "Une banane génétiquement modifiée, je sens bien le goût artificiel.",
      "novakidDescription": "Les bananes génétiquement modifiées sont les meilleures bananes."
    }
  },
  "wildbeakseedseed": {
    "name": "Graine de Bec-Graine",
    "desc": "Fait pousser des bec-graines croquants. La narine est la meilleure partie.",
    "metadata": {
      "apexDescription": "Le bec-graine est étrangement croquant, et pas tout à fait agréable.",
      "avianDescription": "Il existe un vieux conte populaire sur des Avians mangeant des bec-graines lors d'un banquet... J'aime bien celui-là.",
      "floranDescription": "Bec-graine crrroquant, pas mou comme les autrrres bouchesss.",
      "glitchDescription": "Philosophique. Est-ce que le bec-graine ressemble à un bec, ou est-ce que les becs ressemblent aux bec-graines?",
      "humanDescription": "Cette récolte ressemble à un visage d'Avian. C'est un peu déconcertant.",
      "hylotlDescription": "Les bec-graines sont étonnamment savoureux. On ne peut qu'imaginer que les vrais becs sont loin d'être aussi appétissants.",
      "novakidDescription": "Je voudrais pas manger un vrai bec par erreur."
    }
  },
  "wildboltbulbseed": {
    "name": "Graine de Boulonpoule",
    "desc": "Le Boulonpoule! Étonnamment tendre.",
    "metadata": {
      "apexDescription": "Tendre comme une banane, mais avec un horrible goût métallique.",
      "avianDescription": "Les Cloués se sont pris d'affection pour cet étrange légume métallique.",
      "floranDescription": "Métal mou, pas comme la chairrr des Glitchsss.",
      "glitchDescription": "Sentimental. Ce légume a le goût du pays.",
      "humanDescription": "Dégueu, manger ça c'est comme croquer dans des morceaux de camion.",
      "hylotlDescription": "Le boulonpoule est l'un des rares légumes véritablement savoureux, pour les vrais connaisseurs.",
      "novakidDescription": "Un légume métallique? Je goûterai n'importe quoi une fois pour voir."
    }
  },
  "wildbonebooseed": {
    "name": "Graine de Boneboo",
    "desc": "Le Boneboo, une bonne source de calcium.",
    "metadata": {
      "apexDescription": "Une plante particulièrement inhabituelle. Tige croquante, fruit charnu.",
      "avianDescription": "Les Boneboos ne sont pas au goût des Avians.",
      "floranDescription": "Nourrriture croquante, ten-dre et charrnue.",
      "glitchDescription": "Désintéressé. Cette plante ressemble apparemment à une anatomie organique interne. Les Glitchs n'ont pas de telles pièces.",
      "humanDescription": "Cette plante n'est peut-être pas adaptée aux végétariens.",
      "hylotlDescription": "De nombreux plats végétariens Hylotls sont préparés avec la plante Boneboo.",
      "novakidDescription": "Un fruit qui a le goût de la viande. C'est déroutant!"
    }
  },
  "wildcarrotseed": {
    "name": "Graine de Carotte",
    "desc": "Fait pousser de délicieuses carottes, apportées de la Terre à travers les étoiles.",
    "metadata": {
      "apexDescription": "Faites bouillir une carotte et c'est un peu comme une banane... mais ça n'a pas aussi bon goût.",
      "avianDescription": "Une simple carotte. Bonne pour la soupe.",
      "floranDescription": "Parfois, la carrotte pousse en spirale. Ça amuse le Floran.",
      "glitchDescription": "Approbateur. Les carottes sont agréablement croquantes.",
      "humanDescription": "Des carottes. Parfaites pour manger, ou pour servir de nez à un bonhomme de neige.",
      "hylotlDescription": "Les carottes sont un légume polyvalent, bien qu'insipide.",
      "novakidDescription": "L'humble carotte."
    }
  },
  "wildchiliseed": {
    "name": "Graine de Piment",
    "desc": "Caliente! C'est la fiesta! Très piquant pour n'importe qui, sauf les humains.",
    "metadata": {
      "apexDescription": "Peindre les piments en jaune est une farce populaire chez les jeunes Apex. S'ils sont pris, beaucoup ne survivraient pas pour recommencer.",
      "avianDescription": "Une plante piquante et épicée. Exotique.",
      "floranDescription": "Fruitsss brûlantsss et épicésss. Cette plante fait mal aux bouchesss de chair.",
      "glitchDescription": "Pensif. Qui choisirait de manger une nourriture qui lui fait mal?",
      "humanDescription": "Les piments sont épicés, mais tellement addictifs.",
      "hylotlDescription": "Juste le bon équilibre entre saveur et piquant. Utilisé avec modération, c'est délicieux.",
      "novakidDescription": "Les Novakids sont de grands fans de piment, plus c'est fort, mieux c'est!"
    }
  },
  "wildcocoaseed": {
    "name": "Graine de Cacao",
    "desc": "Les fèves de cacao peuvent être infusées pour faire une boisson savoureuse.",
    "metadata": {
      "apexDescription": "Le cacao est recherché pour ses propriétés énergisantes.",
      "avianDescription": "Les fèves de cacao ressemblent à une friandise tentante, mais sont extrêmement amères.",
      "floranDescription": "Le cacao empêche le Floran de s'endormirr.",
      "glitchDescription": "Pensif. Les Glitchs ne voient aucune utilité à ces fèves amères.",
      "humanDescription": "Le cacao, la plante la plus tonifiante connue de l'homme.",
      "hylotlDescription": "Voyez au-delà de son goût amer et le cacao est une ressource utile.",
      "novakidDescription": "Le cacao sent bon, mais j'ai jamais remarqué d'effets bénéfiques à boire ce truc."
    }
  },
  "wildcoffeeseed": {
    "name": "Graine de Café",
    "desc": "Les grains de café peuvent être infusés pour faire une boisson savoureuse.",
    "metadata": {
      "apexDescription": "Le café est recherché pour ses propriétés énergisantes.",
      "avianDescription": "Les grains de café ressemblent à une friandise tentante, mais sont extrêmement amers.",
      "floranDescription": "Le café empêche le Floran de s'endormirr.",
      "glitchDescription": "Pensif. Les Glitchs ne voient aucune utilité à ces grains amers.",
      "humanDescription": "Le café, la plante la plus tonifiante connue de l'homme.",
      "hylotlDescription": "Voyez au-delà de son goût amer et le café est une ressource utile.",
      "novakidDescription": "Le café sent bon, mais j'ai jamais remarqué d'effets bénéfiques à boire ce truc."
    }
  },
  "wildcoralcreepseed": {
    "name": "Graine de Coralcreep",
    "desc": "Le fruit du Coralcreep ressemble à une créature marine.",
    "metadata": {
      "apexDescription": "Le Coralcreep est en fait un fruit, malgré les apparences.",
      "avianDescription": "Le goût des fruits de mer dans un fruit. C'est effrayant.",
      "floranDescription": "Une plante déguisssée en créaturrre. Malin.",
      "glitchDescription": "Sceptique. Ça ressemble à une créature marine, comment est-ce possible que ce soit un fruit?",
      "humanDescription": "Un fruit qui a l'aspect et le goût du homard.",
      "hylotlDescription": "Délicieux Coralcreep. Une véritable délicatesse. Tout le monde devrait essayer.",
      "novakidDescription": "Le véritable fruit de la mer."
    }
  },
  "wildcornseed": {
    "name": "Graine de Maïs",
    "desc": "Du maïs jaune et sucré.",
    "metadata": {
      "apexDescription": "Du maïs. Encore un aliment qui ressemble à une banane, mais n'en est pas.",
      "avianDescription": "Picorer un épi de maïs fait un excellent en-cas.",
      "floranDescription": "Maïs jaune durrr, on cuit et ça fait p-pop.",
      "glitchDescription": "Sceptique. On prétend que si les Glitchs mangent du maïs, il éclatera à l'intérieur de nous.",
      "humanDescription": "Un approvisionnement régulier en maïs doux est une chose merveilleuse.",
      "hylotlDescription": "Un en-cas courant et sans saveur, de peu de mérite.",
      "novakidDescription": "Le maïs peut être apprécié sous bien des formes."
    }
  },
  "wildcottonseed": {
    "name": "Graine de Coton",
    "desc": "Une plante qui fait pousser des bourgeons de coton duveteux!",
    "metadata": {
      "apexDescription": "Le coton est facile à cultiver et possède une grande variété d'utilisations productives.",
      "avianDescription": "Des plants de coton! Ces récoltes ingénieuses ont tellement d'utilisations!",
      "floranDescription": "Floran pourrrait f-faire des trrucss doux avec les plantsss de coton.",
      "glitchDescription": "Créatif. Je pourrais utiliser ce coton pour une multitude de choses.",
      "humanDescription": "Le coton, l'une des ressources les plus anciennes de l'humanité. Tellement utile!",
      "hylotlDescription": "Les tisserands Hylotls peuvent créer les tissus les plus doux avec du coton.",
      "novakidDescription": "Un coton comme ça, on peut en faire un sacré paquet de trucs."
    }
  },
  "wildcrystalplantseed": {
    "name": "Graine de Plante de Cristal",
    "desc": "Une plante de cristal. Il s'avère que l'argent pousse bien sur les arbres.",
    "metadata": {
      "apexDescription": "Faites pousser vos propres cristaux. Pratique.",
      "avianDescription": "Une plante qui fait pousser des cristaux. C'est magique!",
      "floranDescription": "Floran intrrigué par la plante brrillante.",
      "glitchDescription": "Inquiet. Cultiver ces cristaux en abondance pourrait nuire à l'économie.",
      "humanDescription": "Quand j'étais petit, je voulais toujours un arbre à argent. C'est ce qui s'en rapproche le plus.",
      "hylotlDescription": "Une plante qui fait germer de magnifiques cristaux luisants.",
      "novakidDescription": "Un cristal cultivable! Là, on cause!"
    }
  },
  "wildcurrentcornseed": {
    "name": "Graine de Currentcorn",
    "desc": "Le Currentcorn, rempli d'acide. Pas bon pour les créatures de chair.",
    "metadata": {
      "apexDescription": "J'ai entendu parler de gens ayant reçu des brûlures acides à cause du Currentcorn. Je ferais mieux de manipuler ça avec soin.",
      "avianDescription": "Du maïs acide. Désagréable et dangereux.",
      "floranDescription": "Maïs acide et g-goûtu. Fait mal aux cho-s-ses de chairrr.",
      "glitchDescription": "Fier. Les Glitchs connaissent un moyen d'utiliser ces légumes comme batteries.",
      "humanDescription": "On dirait du maïs... mais ça n'en est vraiment pas.",
      "hylotlDescription": "Une variante de maïs ignoble et acide. Nuisible à n'importe quel plat.",
      "novakidDescription": "Le Currentcorn est plus proche d'une cellule de batterie que d'une denrée comestible."
    }
  },
  "wilddiodiaseed": {
    "name": "Graine de Diodia",
    "desc": "Le Diodia, un légume-racine tendre avec un goût de cuivre.",
    "metadata": {
      "apexDescription": "Les Diodias n'ont pas le goût le plus agréable, mais ils sont faciles à cultiver.",
      "avianDescription": "Un Diodia ressemble à une noix, mais n'en a pas le goût.",
      "floranDescription": "A le goût du sssang, Floran trouve que le Diodia est un bon sssubstitut.",
      "glitchDescription": "Insulté. Les Diodias sont vraiment des légumes sous-estimés.",
      "humanDescription": "Ressemble à une pomme de terre, a le goût d'un sou. Pas un super échange.",
      "hylotlDescription": "Un légume-racine amer. Bon pour relever le goût.",
      "novakidDescription": "Les Diodias au goût cuivré font fureur chez les Glitchs."
    }
  },
  "wilddirturchinseed": {
    "name": "Graine d'Oursin de Terre",
    "desc": "Les oursins de terre sont spongieux et plutôt insipides.",
    "metadata": {
      "apexDescription": "Plutôt une mauvaise herbe commune qu'un légume.",
      "avianDescription": "Quand il n'y a rien d'autre à manger, l'oursin de terre dépanne.",
      "floranDescription": "L'oursssin de terrre ressemble à un minussccule cactus rrrond.",
      "glitchDescription": "Désintéressé. Une plante commune et ennuyeuse.",
      "humanDescription": "Il a été prouvé statistiquement que 93 % des humains ont la phobie des oursins de terre.",
      "hylotlDescription": "Pourquoi quelqu'un mangerait ça me dépasse complètement.",
      "novakidDescription": "Les ourssins de terre sont aussi ternes que la boue d'où ils sssortent."
    }
  },
  "wildeggshootseed": {
    "name": "Graine d'Eggshoot",
    "desc": "L'Eggshoot, plein de délices coulants.",
    "metadata": {
      "apexDescription": "L'Eggshoot est connu pour déclencher des dilemmes existentiels chez les oiseaux.",
      "avianDescription": "Eggshoot: pour quand les Avians veulent des omelettes.",
      "floranDescription": "Rres s s emble à un œuf, mais n'éclos s s e pas.",
      "glitchDescription": "Curieux. Les Avians en mangent volontiers, malgré leur apparence d'œuf.",
      "humanDescription": "Un œuf végétarien.",
      "hylotlDescription": "Un substitut acceptable pour ceux d'entre nous qui ne mangent pas d'œufs.",
      "novakidDescription": "Un Eggshoot ressemble à un œuf et a le goût d'un œuf, mais c'est pas un œuf."
    }
  },
  "wildfeathercrownseed": {
    "name": "Graine de Feathercrown",
    "desc": "Des plumes poussent au sommet du Feathercrown et s'envolent au vent.",
    "metadata": {
      "apexDescription": "On dirait un croisement entre une carotte et un Avian. Inhabituel, c'est le moins qu'on puisse dire.",
      "avianDescription": "Un mets délicat pour les Avians. Seuls les meilleurs plats contiennent du Feathercrown.",
      "floranDescription": "Rres s s emble à un homme-oiseau, a le goût de la terrre. Hommes-oiseaux plus s s s avoureux.",
      "glitchDescription": "Philosophique. Peut-être qu'un jour un Feathercrown deviendra conscient et s'envolera vers les cieux.",
      "humanDescription": "Une carotte avec une plume. Pratique pour manger ou pour faire des chatouilles.",
      "hylotlDescription": "Les plumes ne s'épanouissent pas sous l'eau. Les Feathercrowns non plus.",
      "novakidDescription": "Le fruit avec une petite surprise plumeuse."
    }
  },
  "wildgrapesseed": {
    "name": "Graine de Raisin",
    "desc": "Le raisin, l'en-cas de la nature.",
    "metadata": {
      "apexDescription": "Un fruit de luxe. Hélas, beaucoup d'Apex n'ont jamais l'occasion d'en goûter.",
      "avianDescription": "Petits raisins simples, faciles à picorer.",
      "floranDescription": "Les rraisins s s s'éclatent et s s sont jus s s teux, comme des globes oculairrres viollets.",
      "glitchDescription": "Espiègle. Les raisins font de bons projectiles tout autant que de bons en-cas.",
      "humanDescription": "Du raisin. Un cadeau traditionnel pour ceux qui sont à l'infirmerie.",
      "hylotlDescription": "Le raisin de mer a tellement meilleur goût, ceux-là sont trop sucrés.",
      "novakidDescription": "Le raisin, c'est bon pour grignoter."
    }
  },
  "wildkiwiseed": {
    "name": "Graine de Kiwi",
    "desc": "Cette variété particulière de kiwi de l'espace pousse près du sol.",
    "metadata": {
      "apexDescription": "Le duvet du kiwi de l'espace ressemble à celui d'un Apex.",
      "avianDescription": "Un drôle de fruit poilu, rempli de graines délicieuses.",
      "floranDescription": "Frrruit-crréaturrre poilu et mou.",
      "glitchDescription": "Amusé. Il est remarquable de voir combien d'aliments ressemblent à ceux qui les mangent.",
      "humanDescription": "C'est un kiwi de terre, un \"tierre\".",
      "hylotlDescription": "Encore un fruit trop sucré. La surface est désagréable au toucher.",
      "novakidDescription": "Ça a exactement le même goût qu'un kiwi normal!"
    }
  },
  "wildneonmelonseed": {
    "name": "Graine de Néonmelon",
    "desc": "La chair vibrante du néonmelon a un goût de chewing-gum.",
    "metadata": {
      "apexDescription": "Un néonmelon juteux et savoureux. Plus la couleur est vive, meilleur est le goût.",
      "avianDescription": "Un néonmelon juteux, rempli de délicieuses graines lumineuses.",
      "floranDescription": "Floran écrrassse néonmelon pour ffaire b-brruit de s s s s-quouic. Aussi pour manger.",
      "glitchDescription": "Ravi. J'ai toujours trouvé que le néonmelon avait l'air délicieux.",
      "humanDescription": "On pourrait les manger, ou décorer sa chambre avec. Je choisis la première option.",
      "hylotlDescription": "Le néonmelon est trop sucré au goût. Son apparence est exquise, cependant.",
      "novakidDescription": "Le néonmelon a une bonne tête à l'intérieur."
    }
  },
  "wildoculemonseed": {
    "name": "Graine d'Oculemon",
    "desc": "L'iris est la meilleure partie de cet étrange fruit.",
    "metadata": {
      "apexDescription": "L'Oculemon me rappelle Big Ape. Cet œil qui surveille tout.",
      "avianDescription": "Un fruit acide au regard perçant.",
      "floranDescription": "Ce qu'il y a de mieux après les vrrais yeux. Floran aime, les autrrres s s sont perrturbés.",
      "glitchDescription": "Introspectif. Ce fruit est-il peut-être une fenêtre sur sa propre âme?",
      "humanDescription": "De tous les fruits de l'univers, l'Oculemon est sans doute le plus flippant.",
      "hylotlDescription": "Certaines parties de l'Oculemon sont mortelles, à moins d'être préparées avec soin.",
      "novakidDescription": "Est-ce qu'un fruit devrait vous rrregarder? J'en sssais rrien..."
    }
  },
  "wildpearlpeaseed": {
    "name": "Graine de Perle-Pois",
    "desc": "Le Perle-Pois, je vais devoir mordre un bon coup.",
    "metadata": {
      "apexDescription": "Un pois croquant qui mène à beaucoup de dents cassées.",
      "avianDescription": "Les perles-pois sont assez agréables à picorer pendant un moment.",
      "floranDescription": "Petites ballesss durrres. Floran les a déjà utilissées comme arrrme.",
      "glitchDescription": "Fierté. Les dents des Glitchs ne font qu'une bouchée des perles-pois.",
      "humanDescription": "Comme un petit pois, mais avec un mal de dents en bonus.",
      "hylotlDescription": "De délicieux pois croquants. Assez précieux sous l'eau.",
      "novakidDescription": "Les perles-pois sont parrfaites pour charger mon pistolet! Piou piou!"
    }
  },
  "wildpineappleseed": {
    "name": "Graine d'Ananas",
    "desc": "L'ananas, assurez-vous de l'ouvrir d'abord.",
    "metadata": {
      "apexDescription": "Les ananas sont sucrés et juteux. Une friandise rafraîchissante.",
      "avianDescription": "Les feuilles ressemblent à des plumes, mais elles sont loin d'être aussi douces.",
      "floranDescription": "Les ananasss ressemblent à des têtesss de Floran.",
      "glitchDescription": "Suffisant. Les Glitchs sont connus pour utiliser les ananas comme cibles d'entraînement.",
      "humanDescription": "Des ananas. Parfaits pour les desserts, ou sur une pizza!",
      "hylotlDescription": "Écoeurant de sucre. On n'en trouverait jamais sous la mer.",
      "novakidDescription": "Qui l'eût cru qu'un truc si piquant sserait si doux à l'intérieur?"
    }
  },
  "wildpotatoseed": {
    "name": "Graine de Pomme de Terre",
    "desc": "Des patates! Bouillies, en purée, ou dans un ragoût.",
    "metadata": {
      "apexDescription": "Les pommes de terre sont tout à fait banales.",
      "avianDescription": "La purée de pommes de terre est un plat réconfortant.",
      "floranDescription": "Patatesss durrres et croquantesss tout juste sssorties de la terre.",
      "glitchDescription": "Admiration. Les humains créent de nombreux plats à partir d'une chose aussi simple.",
      "humanDescription": "Ahhh, les patates. Y a-t-il quelque chose qu'elles ne savent pas faire?",
      "hylotlDescription": "Un légume-racine commun et ennuyeux.",
      "novakidDescription": "Parfait pour rôtir sur un feu de camp par une nuit de froid."
    }
  },
  "wildpussplumseed": {
    "name": "Graine de Pussplum",
    "desc": "La juteuse Pussplum tire son nom de son centre crémeux.",
    "metadata": {
      "apexDescription": "Les Pussplums ont meilleur goût qu'elles n'en ont l'air (ou que leur nom ne le suggère).",
      "avianDescription": "De délicatesses petites, juteuses et faciles à digérer. Peuvent être servies roulées dans des graines.",
      "floranDescription": "Dégoulinant, sssanglant, délicieuxss.",
      "glitchDescription": "Alarmé. Pratiquement n'importe quoi peut devenir un mets délicat, tant que quelqu'un lui trouve bon goût.",
      "humanDescription": "Apparemment, c'est excellent... Pour une raison obscure, j'hésite à vérifier.",
      "hylotlDescription": "Crémeuses mais acides, les Pussplums ne sont pas au goût des Hylotls.",
      "novakidDescription": "On m'a dit que c'était bon, mais après en avoir rregardé une, j'ssuis pas ssi sûr."
    }
  },
  "wildreefpodseed": {
    "name": "Graine de Reefpod",
    "desc": "Le Reefpod, a le goût d'un smoothie croquant à l'eau de mer.",
    "metadata": {
      "apexDescription": "Les Reefpods ont un goût sucré et salé. Inhabituel mais pas désagréable.",
      "avianDescription": "Délicieusement savoureux.",
      "floranDescription": "A le goût d'hommess-poisssons.",
      "glitchDescription": "Confus. Le Reefpod est certainement inhabituel. Comment un fruit peut-il avoir un goût salé?",
      "humanDescription": "Un Reefpod est sucré, salé et croquant. Ça me rappelle le popcorn.",
      "hylotlDescription": "Un Reefpod a juste le bon niveau de douceur pour les papilles Hylotls.",
      "novakidDescription": "Est-ce qu'un Reefpod est un plat ssalé ou ssucré? J'en ai pas la moindre idée."
    }
  },
  "wildriceseed": {
    "name": "Graine de Riz",
    "desc": "Bouilli, frit, ou lancé sur une mariée. Le riz! Pour tous vos besoins culinaires.",
    "metadata": {
      "apexDescription": "Du riz. Un excellent ajout à n'importe quel repas.",
      "avianDescription": "Le riz, un délicieux en-cas à picorer.",
      "floranDescription": "Floran préparrre le riz comme accompagnement pour les cœurs bouillisss.",
      "glitchDescription": "Amusé. Un Glitch a mangé un jour du riz cru et a lancé une carrière florissante d'instrument à percussion.",
      "humanDescription": "Du riz. Pratique quand on a faim et qu'on veut manger des milliers d'un même truc.",
      "hylotlDescription": "Du riz. Goût fade, mais utile. Une base simple pour un repas.",
      "novakidDescription": "Le riz, c'est pas mal de temps en temps. Surtout avec du piment!"
    }
  },
  "wildsugarcaneseed": {
    "name": "Graine de Canne à Sucre",
    "desc": "La canne à sucre est une culture fibreuse dotée d'une sève riche et sucrée.",
    "metadata": {
      "apexDescription": "Mâcher de la canne à sucre est bon pour les dents des Apex, à ce qu'on dit.",
      "avianDescription": "Le sucre peut être utilisé pour rehausser les saveurs.",
      "floranDescription": "Bâton sssucré.",
      "glitchDescription": "Pensif. Cette plante est tranchante et potentiellement mortelle entre de bonnes mains.",
      "humanDescription": "Canne à sucre. N'en mangez pas trop, c'est mauvais pour les dents.",
      "hylotlDescription": "Peut être utilisée pour créer de l'édulcorant, bien qu'on ne comprenne pas pourquoi on voudrait faire ça.",
      "novakidDescription": "Doux comme le ssucre. Attendez une minute..."
    }
  },
  "wildtomatoseed": {
    "name": "Graine de Tomate",
    "desc": "Les tomates sont un fruit riche et juteux. Ou un légume. L'un des deux.",
    "metadata": {
      "apexDescription": "J'aime beaucoup les tomates mûres et succulentes.",
      "avianDescription": "Les graines de tomate peuvent améliorer bien des plats.",
      "floranDescription": "Les tomatesss sont rrougesss comme le sssang et sss'éclatent.",
      "glitchDescription": "Malicieux. Les tomates pourries font de bons projectiles.",
      "humanDescription": "Les tomates sont parfaites pour une salade saine... Ou mieux encore, une pizza.",
      "hylotlDescription": "Les tomates sont acceptables, bien que banales.",
      "novakidDescription": "Les tomates font un bon encas, c'est ausssi super pour les lancer sur les vauriens."
    }
  },
  "wildtoxictopseed": {
    "name": "Graine de Toxictop",
    "desc": "Un fruit à l'aspect toxique, mais est-ce vraiment si terrible?",
    "metadata": {
      "apexDescription": "Cette plante pourrait me rendre malade. Ou pourrait-elle guérir les maladies?",
      "avianDescription": "Acide et délicieux.",
      "floranDescription": "Floran donne des toxictopsss à sesss amis pour rrigo-ler.",
      "glitchDescription": "Perplexe. Cette plante est toxique pour toutes les espèces connues, sauf les pingouins.",
      "humanDescription": "Un ananas toxique, pour quand un ananas normal n'est juste pas assez toxique.",
      "hylotlDescription": "La toxicité de ce fruit peut être habilement exploitée pour guérir des maux.",
      "novakidDescription": "Je f'rais pas confiance à quoi que ce ssoit avec « toxique » dans le nom."
    }
  },
  "wartweedseed": {
    "name": "Graine de Verrue-Herbe",
    "desc": "Pas une plante difficile, la verrue-herbe pousse facilement dans n'importe quelles conditions.",
    "metadata": {
      "apexDescription": "La verrue-herbe est une culture facile à entretenir.",
      "avianDescription": "Les verrues-herbes sont difficiles à percer à coups de bec.",
      "floranDescription": "Les verrues-herrbesss sont parfaites pour que Floran les mange ou leur donne des coups de pied.",
      "glitchDescription": "Observateur. La peau d'une verrue-herbe est presque aussi résistante que la mienne.",
      "humanDescription": "Regarder une verrue-herbe me met un peu mal à l'aise.",
      "hylotlDescription": "La verrue-herbe est une plante robuste et terne, appréciée pour sa capacité à prospérer dans des conditions difficiles.",
      "novakidDescription": "Je vois pas l'utilité d'une récolte ausssi corraille que la verrue-herbe."
    }
  },
