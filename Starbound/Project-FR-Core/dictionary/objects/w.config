  "wiredtarget": {
    "name": "Cible Câblée",
    "desc": "Cette cible d'entraînement émet un signal filaire jusqu'à ce qu'elle soit brisée.",
    "metadata": {
      "apexDescription": "Cette cible d'entraînement transmet un signal filaire jusqu'à sa destruction.",
