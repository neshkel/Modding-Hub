  "wreckcrate1": {
    "name": "Caisse en Épave",
    "desc": "Une caisse antique, je me demande ce qu'il y a dedans...",
    "metadata": {
      "apexDescription": "Une caisse cabossée.",
      "avianDescription": "Pourrait-il rester quelque chose là-dedans?",
      "floranDescription": "Vieux sstockage frrracasssé.",
      "glitchDescription": "Intrigué. Un vieux conteneur de stockage.",
      "humanDescription": "Une vieille caisse. Il pourrait encore y avoir quelque chose à l'intérieur.",
      "hylotlDescription": "Des trésors de valeur pourraient-ils être dissimulés dans une caisse aussi ruinée?",
      "novakidDescription": "Même moi je suis pas sûr que cette caisse vaille le coup d'œil."
    }
  },
  "wreckdoor": {
    "name": "Porte en Épave",
    "desc": "Cette porte est presque scellée par la rouille.",
    "metadata": {
      "apexDescription": "Une porte rouillée, elle s'ouvre de justesse.",
      "avianDescription": "Cette porte est lourde et rouillée.",
      "floranDescription": "Porrte lourrrde essst difficile à ouvrirrr.",
      "glitchDescription": "Observateur. La rouille fait grincer cette porte.",
      "humanDescription": "Une vieille porte rouillée. Très lourde.",
      "hylotlDescription": "Cette porte était autrefois très sécurisée.",
      "novakidDescription": "Ça devait être du solide autrefois, avant que les charnières ne rouillent."
    }
  },
  "wreckfan": {
    "name": "Ventilateur en Épave",
    "desc": "L'air vicié ne produit guère plus qu'un grincement de ce vieux ventilateur.",
    "metadata": {
      "apexDescription": "Un vieux ventilateur rouillé. Il tourne à peine.",
      "avianDescription": "Un sifflement d'air passe encore au travers.",
      "floranDescription": "Les paless du ventilateurrr ont cessssé de tourrrner.",
      "glitchDescription": "Lamentable. Autrefois, cela aurait fourni de l'air frais.",
      "humanDescription": "Les pales sont rouillées.",
      "hylotlDescription": "Vieux et brisé, ce ventilateur ne fait plus circuler l'air.",
      "novakidDescription": "Tout ça est rouillé, c'est bon pour la casse."
    }
  },
  "wreckgenerator": {
    "name": "Générateur en Épave",
    "desc": "Il fut un temps où deux de ces trucs pouvaient alimenter un vaisseau entier.",
