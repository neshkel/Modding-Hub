  "wrecktv": {
    "name": "Écran en Épave",
    "desc": "L'écran émet une lueur vacillante et inquiétante.",
    "metadata": {
      "apexDescription": "Il semblerait qu'il n'y ait pas de signal.",
      "avianDescription": "Rien que de la neige.",
      "floranDescription": "Jolie machine à motifs dan sssants!",
      "glitchDescription": "Triste. Pas de signal, juste de la neige.",
      "humanDescription": "De la neige. Pas de signal, je suppose.",
      "hylotlDescription": "Ce moniteur manque d'une source d'entrée.",
      "novakidDescription": "Nan, y a rien qui passe."
    }
  },
  "wreckvat1": {
    "name": "Cuve en Épave",
    "desc": "Une cuve fracassée, l'intérieur est couvert de bave séchée... Quelque chose s'en est-il échappé?",
    "metadata": {
      "apexDescription": "Est-ce que quelque chose s'est... libéré?",
      "avianDescription": "C'est de mauvais augure.",
      "floranDescription": "Frrracassse, frrracassse, frrracassse... Oh oh.",
      "glitchDescription": "Perturbé. Il semblerait que quelque chose ait quitté cette machine.",
      "humanDescription": "Oh mon Dieu, ça me rappelle un film que j'ai vu un jour.",
      "hylotlDescription": "Le verre a été brisé de l'intérieur...",
      "novakidDescription": "Je suis pas très chaud pour toucher à ça."
    }
  },
  "wreckvendingmachine": {
    "name": "Distributeur en Épave",
