  "wiringstation": {
    "name": "^orange;Station de Câblage^white;",
    "desc": "Utilisée pour produire des composants de câblage complexes.",
    "metadata": {
      "interactData.paneLayoutOverride.windowtitle.title": " Station de Câblage",
      "interactData.paneLayoutOverride.windowtitle.subtitle": " Pour tout ce qui touche au câblage",
      "apexDescription": "Je peux créer de l'équipement de câblage ici.",
      "avianDescription": "C'est un poste de travail pour fabriquer du matériel de câblage.",
      "floranDescription": "Floran peut ffaire du matérrriel pour câbler des trrucsss.",
      "glitchDescription": "Ravi. Un poste de travail pour créer du matériel lié au câblage. Très pratique.",
      "humanDescription": "Du matériel de câblage peut être fabriqué sur ce poste de travail. Classe!",
      "hylotlDescription": "Pour les outils et accessoires de câblage, c'est le poste de travail de référence.",
      "novakidDescription": "Un poste de trravail pour tout ce qui touche au câblage."
    }
  },
  "woodencookingtable": {
    "name": "^orange;Plan de Travail de Cuisine^white;",
    "desc": "Utilisé pour produire des aliments sains aux effets variés.",
    "metadata": {
      "apexDescription": "Cette table contient tout ce dont on pourrait avoir besoin pour créer presque n'importe quel plat.",
      "avianDescription": "Presque tous les plats Avians pourraient être préparés ici. Et beaucoup de plats non-Avians aussi, d'ailleurs!",
      "floranDescription": "Floran prépare la nourriture avec sssesss mains nues s s . Mais table auss s si utile.",
      "glitchDescription": "Inspiré. Créons de la nourriture!",
      "humanDescription": "Une table de chef. Tout un tas d'ustensiles différents pour cuisiner.",
      "hylotlDescription": "La préparation culinaire est un art et ceci est le pinceau.",
      "novakidDescription": "Je pourrrais mitonner un sacrré festin sur ce machin-là."
    }
  },
  "wavebird": {
    "name": "Oiseau-Vague",
    "desc": "Un insecte que l'on trouve généralement en train de chasser la crête d'une vague."
  },
  "woodenutilitypole1": {
    "name": "Poteau de Services en Bois",
    "desc": "Un poteau de services en bois.",
