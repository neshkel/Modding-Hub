  "wheatseed": {
    "name": "Graine de Blé",
    "desc": "Du blé, une culture de base aux multiples usages.",
    "metadata": {
      "apexDescription": "Le blé est désagréable lorsqu'il n'est pas transformé, mais il peut être utilisé pour préparer toutes sortes de plats.",
      "avianDescription": "Le blé est délicieux tel quel, ou lorsqu'il est utilisé pour faire de la chapelure.",
      "floranDescription": "Le blé a des orrreilles. Floran arrrrache les orrreilles pour rrigo-ler.",
      "glitchDescription": "Pensif. Je me demande si toutes les utilisations possibles du blé ont été trouvées.",
      "humanDescription": "Du blé, parfait pour cuire du pain frais.",
      "hylotlDescription": "Sur terre, le blé a de nombreux usages. Sous l'eau, presque aucun.",
      "novakidDescription": "J'ai une de cesss fringales de pain frais dès que je vois du blé."
    }
  },
