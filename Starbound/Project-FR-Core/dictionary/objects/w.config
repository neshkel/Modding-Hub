{
  "wreckbed": {
    "name": "Lit en Épave",
    "desc": "La saleté et la rouille ont rongé ce lit. Heureusement, je ne suis pas du tout fatigué.",
    "metadata": {
      "apexDescription": "Un endroit terrible pour dormir.",
      "avianDescription": "Un endroit pas très invitant pour dormir.",
      "floranDescription": "Un lit rrrrouillé.",
      "glitchDescription": "Dégoûté. De la rouille!",
      "humanDescription": "J'ai du mal à imaginer que ça ait pu être accueillant un jour.",
      "hylotlDescription": "Ce lit est rouillé au-delà de toute réparation. Le temps finit par nous emporter tous.",
      "novakidDescription": "Faudrait être sacrément fatigué pour vouloir pioncer là-dedans."
    }
  },
  "wreckboiler": {
    "name": "Chaudière en Épave",
    "desc": "Une vieille chaudière. Un égouttement résonne à l'intérieur.",
    "metadata": {
      "apexDescription": "Un vieux chauffe-eau rouillé.",
      "avianDescription": "Cette chaudière a connu des jours meilleurs.",
      "floranDescription": "Un vieux réservoirrr de chaudièrre rrrrouillé.",
      "glitchDescription": "Mélancolique. Cette chaudière fuira dès que la rouille l'aura transpercée.",
      "humanDescription": "L'eau restée à l'intérieur de cette chaudière sent terriblement mauvais.",
      "hylotlDescription": "Un vieux réservoir de chaudière plein d'eau fétide.",
      "novakidDescription": "Une chaudière rouillée qui vaut plus rien."
    }
  },
  "wreckchair": {
    "name": "Chaise en Épave",
    "desc": "Une chaise immonde. Des insectes entrent et sortent par les trous du tissu.",
