  },
  "wiredcustomsign": {
    "name": "Enseigne",
    "desc": "Un panneau d'affichage personnalisé.",
    "metadata": {
      "apexDescription": "Une bonne signalisation publique est indispensable à toute civilisation.",
      "avianDescription": "L'alphabet avien original a été perdu au fil des âges.",
      "floranDescription": "Dess motss, dess motss, dess motsss.",
      "glitchDescription": "Pensif. Un panneau est comme une interface primitive.",
      "humanDescription": "Les panneaux servent aux informations vitales, ou aux jeux de mots foireux.",
      "hylotlDescription": "Bien que cela ne soutienne pas la comparaison avec la calligraphie Hylotl, cela fera l'affaire pour le moment.",
      "novakidDescription": "Une sorte de panneau."
    }
  },
  "watercooler": {
    "name": "Fontaine à Eau",
    "desc": "Une fontaine à eau. Le meilleur endroit pour dégoter les derniers potins.",
    "metadata": {
      "apexDescription": "Je ressens l'envie de traîner ici pour critiquer le Miniknog.",
      "avianDescription": "Une fontaine à eau. Rafraîchissant!",
      "floranDescription": "Floran aime boirre de l'eau frrraîche!",
      "glitchDescription": "Désintéressé. Une fontaine à eau.",
      "humanDescription": "Ça me ferait presque regretter la vie de bureau. Ah non, en fait.",
      "hylotlDescription": "Une fontaine à eau - un appareil purement pratique.",
      "novakidDescription": "Eh bien, c'est sacrément pratique!"
    }
  },
  "wagonwheel": {
    "name": "Roue de Chariot",
    "desc": "Une roue de chariot en bois décorative.",
    "metadata": {
      "apexDescription": "Une roue, provenant probablement d'un vieux chariot.",
      "avianDescription": "Une roue en bois. Peut-être faisait-elle partie d'un véhicule autrefois?",
      "floranDescription": "Floran ne connaît passs l'utilité de la rrroue.",
      "glitchDescription": "Curieux. Je me demande si elle était fixée à un vrai chariot autrefois?",
      "humanDescription": "Je n'aurais pas cru qu'une vieille roue de chariot ferait une bonne déco, et pourtant ça marche plutôt bien!",
      "hylotlDescription": "Je ne suis pas certain de la fonction de cette roue. Est-ce simplement décoratif?",
      "novakidDescription": "La roue de chariot - un accessoire de premier choix pour n'importe quelle bicoque!"
    }
  },
  "wantedposter": {
    "name": "Avis de Recherche",
    "desc": "Une affiche délavée, offrant une prime datant d'il y a longtemps.",
    "metadata": {
      "apexDescription": "Je me demande si le sujet de cet avis de recherche était un criminel ou un héros rebelle?",
      "avianDescription": "Cette affiche est très vieille. Je me demande si le criminel a fini par être capturé?",
      "floranDescription": "Floran aime l'image de l'imposssant chas s s eur.",
      "glitchDescription": "Curieux. Cette vieille affiche offrait une prime pour la capture d'un criminel - a-t-il jamais été pris?",
      "humanDescription": "Je me demande si le criminel sur cette vieille affiche a été attrapé un jour?",
      "hylotlDescription": "Cette affiche est très ancienne maintenant. Je me demande si la prime a un jour été touchée?",
      "novakidDescription": "Un avis de recherche? Je me demande s'ils ont fini par coffrer le lascar."
    }
  },
  "watermachine": {
    "name": "Fontaine à Eau",
    "desc": "C'est une de ces machines à boire autour desquelles les gens discutent de tout et de rien.",
    "metadata": {
      "apexDescription": "De l'eau fraîche et claire. Rafraîchissant!",
      "avianDescription": "Je prendrais bien un verre.",
      "floranDescription": "La grrrande bouteille d'eau essst coincée ssur la machine... Dommage.",
      "glitchDescription": "Observateur. Une fontaine à eau. Elle garde une grande quantité d'eau au frais.",
      "humanDescription": "Je suis tellement assoiffé que je pourrais boire un chameau. S'il était fait en eau.",
      "hylotlDescription": "Un petit réservoir d'eau. En voir une réserve si limitée me donne la nostalgie de mon foyer.",
      "novakidDescription": "Un distributeur d'eau. Utile, si vous avez la gorge sèche."
    }
  },
  "wazlights": {
    "name": "Guirlandes Waz",
    "desc": "Des guirlandes lumineuses qui forment le mot 'waz', quoi que cela puisse vouloir dire.",
    "metadata": {
      "apexDescription": "Je ne sais pas quoi penser de ces lumières... 'waz'?",
      "avianDescription": "C'est quoi un 'waz'?",
      "floranDescription": "Waaaazzzz? C'essst quoi çssa?",
      "glitchDescription": "Confus. Qu'est-ce qu'un 'waz'?",
      "humanDescription": "Waaaaaaaz.",
      "hylotlDescription": "Ce 'waz' a-t-il une signification profonde?"
    }
  },
  "woodencrategoldfilled": {
    "name": "Caisse Remplie de Trésors",
