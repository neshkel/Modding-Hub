    "metadata": {
      "apexDescription": "Ce lit est amusant et rebondissant.",
      "avianDescription": "Ce lit balance sur son pied. J'ai la nausée.",
      "floranDescription": "Lit de Floran s'oscille, Floran tombe.",
      "glitchDescription": "Détection. Ce lit champignon émet de légères spores hallucinogènes.",
      "humanDescription": "C'est un lit pour les gens qui n'ont pas peur de se faire 'cham-pignonner'.",
      "hylotlDescription": "Ce lit se balance doucement, comme si on était sur un bateau. C'est apaisant.",
      "novakidDescription": "Pas sûr que ce lit champignon soit vraiment stable..."
    }
  },
  "shroomchair": {
    "name": "Chaise Champignon",
    "desc": "Une chaise champignon. Ou peut-être un tabouret de crapaud.",
    "metadata": {
      "apexDescription": "Cette chaise est spongieuse et bizarre au toucher.",
      "avianDescription": "Le dossier de cette chaise frotte contre mes plumes.",
      "floranDescription": "Floran écrassse la chaisse.",
      "glitchDescription": "Réflexion. Combien d'années a-t-il fallu aux champignons pour développer cette forme?",
      "humanDescription": "Je parie que celui qui s'assoit ici est un 'champy-on'.",
      "hylotlDescription": "Cette chaise a la texture d'une éponge de mer.",
      "novakidDescription": "Cette chaise est vraiment spongieuse."
    }
  },
  "shroomchest": {
    "name": "Coffre Champignon",
    "desc": "Un champignon transformé en coffre.",
    "metadata": {
      "apexDescription": "On pourrait facilement ramasser ce coffre et partir avec.",
      "avianDescription": "Un coffre champignon. Facile à ouvrir.",
      "floranDescription": "Floran pille le cofffrre. Floran trrrouve des trrucss.",
      "glitchDescription": "Analyse. L'ouverture de ce coffre libère des spores invisibles. Effets à long terme inconnus.",
      "humanDescription": "Un petit coffre champignon tout mou et mignon.",
      "hylotlDescription": "Une idée de coffre absolument ridicule.",
      "novakidDescription": "Ce coffre ressemble juste à un p'tit champignon tout mignon."
    }
  },
  "shroomdoor": {
    "name": "Porte Champignon",
    "desc": "Une porte faite de champignons. Elle a même une poignée champignon mignonne.",
    "metadata": {
      "apexDescription": "Une porte champignon toute molle.",
      "avianDescription": "Cette porte ne semble pas très sûre.",
      "floranDescription": "Floran compresse la porrte.",
      "glitchDescription": "Fasciné. Une porte champignon.",
      "humanDescription": "Une petite porte champignon trop mignonne.",
      "hylotlDescription": "Une porte faite de champignons. Bizarre.",
      "novakidDescription": "Une porte champignon toute molle. C'est mignon!"
    }
  },
  "shroomlamp": {
    "name": "Lampe Champignon",
    "desc": "Un champignon phosphorescent. Pratique ET mignon.",
    "metadata": {
      "apexDescription": "Un mignon champignon lumineux. Idéal comme veilleuse.",
      "avianDescription": "L'éclat de ce champignon illumine n'importe quelle pièce.",
      "floranDescription": "Floran aime champignon brrrillant.",
      "glitchDescription": "Analyse. La lueur est produite par des spores qui semblent avoir un comportement parasitaire.",
      "humanDescription": "Une lampe qu'on aurait envie de câliner.",
      "hylotlDescription": "Cette lampe champignon est pratique et utile.",
      "novakidDescription": "C'est un champignon qui brille! Ça rend la pièce toute chaleureuse."
    }
  },
  "shroomtable": {
    "name": "Table Champignon",
    "desc": "Un champignon géant. Parfait pour servir de table.",
    "metadata": {
      "apexDescription": "Si on avait trop faim, on pourrait manger la table elle-même.",
      "avianDescription": "Cette table semble assez fragile.",
      "floranDescription": "Floran a besoin d'une meilleure table pour déperrre la vviande.",
      "glitchDescription": "Biologie. Ce champignon géant est le produit de plusieurs années de croisements fongiques inter-espèces.",
      "humanDescription": "Manger ici donnerait l'impression de faire un pique-nique magique.",
      "hylotlDescription": "La nature donne autant qu'elle détruit.",
      "novakidDescription": "C'est pas une table bien solide, mais c'est mignon!"
    }
  },
  "shroomwardrobe": {
    "name": "Armoire Champignon",
    "desc": "Une armoire champignon.",
    "metadata": {
      "apexDescription": "Quel genre de champignon ont-ils utilisé pour construire cette armoire?",
      "avianDescription": "Si je range des choses dedans, est-ce qu'elles sentiront le champignon?",
      "floranDescription": "Floran veut mettrre dess chosess dans le champignon.",
      "glitchDescription": "Analyse. Ils ont dû utiliser beaucoup de champignons pour construire cette armoire.",
      "humanDescription": "Quel genre de personne voudrait ranger ses vêtements dans un champignon?",
      "hylotlDescription": "Est-ce un champignon qui ressemble à une armoire, ou une armoire qui ressemble à un champignon?",
      "novakidDescription": "C'est une armoire qui ressemble à un gros vieux champignon!"
    }
  },
  "snowglobe1": {
    "name": "Boule à Neige Bonhomme de Neige",
    "desc": "Une boule à neige avec un bonhomme de neige à l'intérieur. Festif!",
    "metadata": {
      "apexDescription": "Une sphère de verre avec un bonhomme de neige. C'est adorable.",
      "avianDescription": "Un bonhomme de neige est emprisonné à l'intérieur, figé dans le temps.",
      "floranDescription": "Floran veut ffrrapper et brriser la boule à neige.",
      "glitchDescription": "Lecture. D'après mon traducteur, 'fabriqué en Chine' est inscrit dessous. Qu'est-ce que cela signifie?",
      "humanDescription": "Oh, une boule à neige! Impossible de ne pas la secouer!",
      "hylotlDescription": "Cela me rappelle un bocal à poissons. Même des modèles de bonhommes de neige ne devraient pas être captifs.",
      "novakidDescription": "Oh, regardez-moi ce p'tit gars de neige là-dedans."
    }
  },
  "snowglobe2": {
    "name": "Boule à Neige Pingouin",
    "desc": "Une boule à neige avec un pingouin à l'intérieur. L'oiseau a l'air en colère.",
    "metadata": {
      "apexDescription": "Un pingouin adorable dans une boule à neige.",
      "avianDescription": "Ah, le pingouin. Je compatis, mon cousin incapable de voler.",
      "floranDescription": "Floran aime le verrre avec un en-cas dedansss.",
      "glitchDescription": "Alarme. De faibles signes de vie proviennent de l'intérieur de cette boule à neige.",
      "humanDescription": "Oh, un petit pingouin trop chou. J'ai envie de lui faire un câlin.",
      "hylotlDescription": "Un minuscule pingouin piégé dans une prison de verre. Barbare.",
      "novakidDescription": "Les pingouins sont mignons, c'est sûr, mais j'suis pas dupe. C'est tous des fripouilles!"
    }
  },
  "smallchurch": {
    "name": "Bâtiment Minuscule",
    "desc": "Un minuscule bâtiment communal. Qui peut bien le visiter?",
    "metadata": {
      "apexDescription": "C'est la plus petite maison que j'aie jamais vue.",
      "avianDescription": "Une toute petite maison.",
      "floranDescription": "Toc toc. Floran entrrre.",
      "glitchDescription": "Pensif. Je ne pense pas qu'un Glitch puisse vivre ici.",
      "humanDescription": "Je ne me rappelle plus, c'est 'mange-moi' ou 'bois-moi'?",
      "hylotlDescription": "Je me demande où sont les minuscules habitants?",
      "novakidDescription": "Ça doit être une maison pour les fourmis."
    }
  },
