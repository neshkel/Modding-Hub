  "shadowshrine": {
    "name": "Autel d'Ombre",
    "desc": "Un autel à l'aspect vraiment sinistre.",
    "metadata": {
      "apexDescription": "Effrayant...",
      "avianDescription": "Cet autel me donne la chair de poule...",
      "floranDescription": "Sssanctuaire stylé, ça a l'airrr terrrifiant.",
      "glitchDescription": "Terrifié. Mon envie de quitter cette zone a augmenté.",
      "humanDescription": "Cet autel me donne de vraiment mauvaises ondes.",
      "hylotlDescription": "Je ne souhaite pas découvrir l'histoire qui se cache derrière cet autel.",
      "novakidDescription": "Ouaip, c'est glauque, pas de doute."
    }
  },
