    "desc": "C'est un sac de couchage. Ce n'est pas le plus confortable, mais ça fera l'affaire.",
    "metadata": {
      "apexDescription": "Les rebelles Apex passent de nombreuses nuits à dormir là-dedans.",
      "avianDescription": "Dormir ici serait inconfortable pour mes plumes.",
      "floranDescription": "Floran n'aime passs dorrmir dans un sssac.",
      "glitchDescription": "Sarcasme. Oh, comme c'est merveilleux.",
      "humanDescription": "Un sac de couchage. Une bonne protection contre les éléments en cas de besoin.",
      "hylotlDescription": "Est-ce que ça fonctionne sous l'eau?",
      "novakidDescription": "Je n'y passerai pas ma meilleure nuit, mais ça dépanne bien."
    }
  },
  "slidingdoor": {
    "name": "Porte Coulissante",
    "desc": "La porte monte... La porte descend... La porte monte... La porte descend...",
    "metadata": {
      "apexDescription": "Une porte sans poignée. Elle semble glisser vers le haut et vers le bas.",
      "avianDescription": "Cette porte s'ouvre vers le haut.",
      "floranDescription": "Sssupide porrte conffond Floran.",
      "glitchDescription": "Appréciation. Le mécanisme derrière cette porte est complexe.",
      "humanDescription": "Cette porte bouge si vite qu'elle produit un souffle d'air.",
      "hylotlDescription": "Des portes comme celle-ci sont utilisées pour contrôler le débit d'eau dans les cités Hylotls.",
      "novakidDescription": "C'est une porte coulissante."
    }
  },
  "smashcrystal": {
    "name": "Cristal Fracassable",
    "desc": "Un cristal fracassable. C'est l'heure de passer en mode \"Breaking Bad\".",
    "metadata": {
      "apexDescription": "Je dois briser ce cristal!",
      "avianDescription": "Fracasser ce cristal va être satisfaisant.",
      "floranDescription": "Brriser le brillant!",
      "glitchDescription": "Excité. Briser ce cristal produira une grande richesse.",
      "humanDescription": "C'est l'heure de faire un carnage de cristal.",
      "hylotlDescription": "Des cristaux bleus. Jolis. J'espère que je ne vais pas les casser!",
      "novakidDescription": "J'ai soudain une irrésistible envie de fracasser c'te cristal."
    }
  },
  "sprinkler": {
    "name": "Arroseur automatique",
    "desc": "Une solution d'arrosage automatique pour le sol.",
    "metadata": {
      "apexDescription": "Un arroseur. Une façon assez ingénieuse d'arroser les cultures.",
      "avianDescription": "C'est une machine qui arrose les cultures automatiquement.",
      "floranDescription": "Arrrose les récoltesss..",
      "glitchDescription": "Pas impressionné. C'est une solution d'arrosage automatique. J'aime arroser mes plantes à la main.",
      "humanDescription": "C'est un arroseur pour les cultures! Courir à travers les arroseurs me rend nostalgique.",
      "hylotlDescription": "C'est utilisé pour arroser les cultures. Simple, mais plutôt malin.",
      "novakidDescription": "L'arrosage des récoltes rendu simple."
    }
  },
  "statuspod": {
    "name": "Capsule d'État",
    "desc": "Une capsule d'état. Tentez votre chance...",
    "metadata": {
      "apexDescription": "Une capsule d'état. Aurai-je de la chance?",
      "avianDescription": "Une capsule d'état. J'espère que la chance sera de mon côté.",
      "floranDescription": "Floran déclenche la petite capsule avec une insssouciance totale.",
      "glitchDescription": "Prudent. Les effets de cette capsule d'état sont impossibles à analyser.",
      "humanDescription": "C'est une capsule d'état! Devrais-je tenter le diable en la déclenchant?",
      "hylotlDescription": "Je parie qu'il va m'arriver quelque chose de mal.",
      "novakidDescription": "Une capsule d'état! J'espère bien que c'est mon jour de chance!"
    }
  },
  "stepladder": {
    "name": "Escabeau",
    "desc": "Un escabeau.",
    "metadata": {
      "apexDescription": "Un escabeau. Pour quand on a besoin d'être un peu plus haut.",
      "avianDescription": "Un escabeau plutôt banal.",
      "floranDescription": "Tout petite échellle.",
      "glitchDescription": "Curieux. C'est une échelle assez courte.",
      "humanDescription": "Un petit pas pour l'homme..",
      "hylotlDescription": "Un escabeau. Pas grand-chose d'autre à dire à son sujet.",
      "novakidDescription": "Un escabeau! Parfois, on a besoin d'un petit coup de pouce."
    }
  },
  "symbiotesample": {
    "name": "Symbiote en Bocal",
    "desc": "Une créature dans un bocal, en train de rêvasser.",
    "metadata": {
      "apexDescription": "Un petit symbiote dans un bocal. Ils sont fréquemment utilisés pour des tests.",
      "avianDescription": "Une petite créature gélatineuse piégée dans un bocal.",
      "floranDescription": "Sssupide petite créaturre de gelée.",
      "glitchDescription": "Compatissant. Ce symbiote a l'air un peu... triste.",
      "humanDescription": "Oh, c'est juste un petit symbiote en bocal. Pauvre petite chose.",
      "hylotlDescription": "Je doute que ce symbiote apprécie de vivre dans un bocal plus que moi.",
      "novakidDescription": "Oh, de la gelée d'oursin de terre! Je plaisante."
    }
  },
  "sugarcaneseed": {
    "name": "Graine de Canne à Sucre",
    "desc": "La canne à sucre est une plante fibreuse à la sève riche et sucrée.",
    "metadata": {
      "apexDescription": "Mâcher de la canne à sucre est bon pour les dents des Apex, à ce qu'on dit.",
      "avianDescription": "Le sucre peut être utilisé pour rehausser les saveurs.",
      "floranDescription": "Bâton sssucré.",
      "glitchDescription": "Songeur. Cette plante est tranchante et potentiellement mortelle entre de bonnes mains.",
      "humanDescription": "De la canne à sucre. N'en mangez pas trop, c'est mauvais pour les dents.",
      "hylotlDescription": "Peut être utilisée pour créer de l'édulcorant, bien que l'intérêt échappe aux Hylotls.",
      "novakidDescription": "Doux comme le sucre. Attendez une minute..."
    }
  },
  "separatoraddon": {
    "name": "^orange;Module Separator^white;",
    "desc": "Un module qui ajoute de l'équipement de mêlée et des armures supplémentaires au réplicateur.",
    "metadata": {
      "apexDescription": "Très utile, cela va ajouter de l'équipement de mêlée et des armures au réplicateur.",
      "avianDescription": "Je peux utiliser ceci pour ajouter des armures et de l'équipement au réplicateur.",
      "floranDescription": "Floran utilissse ça pour ajouter pluss de trucs au rréplicateur.",
