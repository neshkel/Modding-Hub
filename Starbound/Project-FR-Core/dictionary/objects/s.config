  "stationmedscanner": {
    "name": "Scanner Médical de Station",
    "desc": "Un lit conçu pour effectuer des scanners médicaux.",
    "metadata": {
      "apexDescription": "Ce lit médical semble être un endroit où je pourrais me reposer une minute.",
      "avianDescription": "M'allonger sur ce lit entouré de ces scanners me rendrait assez mal à l'aise.",
      "floranDescription": "Des lumières chic tout autour de ce lit en métal.",
      "glitchDescription": "Curieux. Je me demande si ce lit médical peut prendre en compte l'anatomie des Glitchs.",
      "humanDescription": "On dirait une sorte de lit scanner médical, mais j'imagine que ça reste un endroit où s'allonger.",
      "hylotlDescription": "Ce lit médical a probablement été conçu pour assister les médecins ou les chercheurs.",
      "novakidDescription": "Un lit au look sophistiqué entouré de lumières vives."
    }
  },
  "stationpylon": {
    "name": "Pylône de Station",
    "desc": "Un grand générateur rotatif, ou un radar, ou peut-être un moteur...",
    "metadata": {
      "apexDescription": "Cela semble être une machine incroyablement complexe. Je me demande ce qu'elle fait réellement?",
      "avianDescription": "Quelle machine ravissante! Je ne parviens cependant pas à identifier sa fonction.",
      "floranDescription": "Floran pas ssûr de ce qu'est le truc qui tourne.",
      "glitchDescription": "Confus. Cette machine semble très importante, mais je n'arrive pas à identifier son utilité.",
      "humanDescription": "Cette machine est très grande et semble importante. Est-ce qu'elle... fait vraiment quelque chose?",
      "hylotlDescription": "Cette machine mal entretenue ne semble rien faire d'immédiatement utile.",
      "novakidDescription": "C'est certainement un brin plus complexe qu'une machine à vapeur, ça c'est sûr..."
    }
  },
  "stationtable": {
    "name": "Table de Station",
    "desc": "Une table ronde en métal lourd.",
    "metadata": {
      "apexDescription": "Cette table au look industriel semble très solide.",
      "avianDescription": "C'est une table simple, mais elle fait l'affaire.",
      "floranDescription": "Cette table en métal essst petite et rronde.",
      "glitchDescription": "Pas impressionné. Cette petite table en métal est banale.",
      "humanDescription": "C'est une table en métal basse.",
      "hylotlDescription": "Cette table en métal simple semble assez robuste.",
      "novakidDescription": "Cette table ronde me semble parfaite pour une partie de cartes."
    }
  },
  "stationtradesignelectronics": {
    "name": "Enseigne d'Électronique",
    "desc": "Un panneau affichant un composant électronique, indiquant un poste d'électronique.",
    "metadata": {
      "apexDescription": "Ce panneau est destiné à indiquer un poste d'électronique.",
      "avianDescription": "Ce panneau signale un poste d'électronique.",
      "floranDescription": "Ce ssigne d'électronique brille fort.",
      "glitchDescription": "Informé. L'image de ce composant est destinée à indiquer un poste d'électronique.",
      "humanDescription": "Un panneau qui marque un poste d'électronique.",
      "hylotlDescription": "Les panneaux comme celui-ci signifient généralement qu'il y a un poste d'électronique à proximité.",
      "novakidDescription": "J'imagine que ce signe veut dire qu'il devrait y avoir un coin électronique par ici."
    }
  },
  "stationtradesignfood": {
    "name": "Enseigne de Nourriture",
    "desc": "Un panneau affichant des ustensiles de cuisine, indiquant un poste de ravitaillement.",
