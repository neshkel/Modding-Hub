  "smashbones1": {
    "name": "Tas d'Os",
    "desc": "Un tas d'os, idéal pour être fracassé.",
    "metadata": {
      "apexDescription": "Ces os ne demandent qu'à être brisés.",
      "avianDescription": "Tu es poussière et tu retourneras à la poussière.",
      "floranDescription": "Floran fffracasse les osss. Journée réussie.",
      "glitchDescription": "Excité. Un coup de pied sauté transformerait probablement ce tas d'os en poussière.",
      "humanDescription": "Puisqu'ils sont déjà morts, briser ces os ne peut pas faire de mal.",
      "hylotlDescription": "Fracasser des os est de mauvais goût. Je crains de les heurter accidentellement en passant. Inévitable.",
      "novakidDescription": "Des os secs et poussiéreux, qui supplient qu'on leur donne un bon coup de pied."
    }
  },
  "smashbones2": {
    "name": "Tas d'Os",
    "desc": "Une cage thoracique intacte. Plus pour longtemps.",
    "metadata": {
      "apexDescription": "Ces os ne demandent qu'à être brisés.",
