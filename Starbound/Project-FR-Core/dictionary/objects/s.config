      "hylotlDescription": "Je vais éviter ça avec grâce.",
      "novakidDescription": "Ça a l'air drôlement tranchant, j'ferais mieux d'déguerpir d'ici!"
    }
  },
  "savannahgroundspike4": {
    "name": "Pointes Tranchantes",
    "desc": "Mieux vaut ne pas marcher là-dessus...",
    "metadata": {
      "apexDescription": "Des pointes de pierre tranchantes.",
      "avianDescription": "La pierre semble tranchante comme un rasoir.",
      "floranDescription": "Tranchant et pointu.",
      "glitchDescription": "Prudent. La roche tranchante pourrait pénétrer la coque des Glitchs.",
      "humanDescription": "Je ferais mieux de ne pas toucher à ça.",
      "hylotlDescription": "Je vais éviter ça avec grâce.",
      "novakidDescription": "Ça a l'air drôlement tranchant, j'ferais mieux d'déguerpir d'ici!"
    }
  },
  "safe": {
    "name": "Coffre-fort",
    "desc": "Un petit coffre-fort en fer robuste.",
    "metadata": {
      "apexDescription": "Un coffre-fort. Celui-ci coulerait facilement. Pour une sécurité accrue.",
      "avianDescription": "Bien que cela garde les choses en sécurité, pourquoi en auriez-vous besoin?",
      "floranDescription": "Un coffre-forrt. Garde le trrésor loin desss autress.",
      "glitchDescription": "Confiant. C'est un coffre-fort fonctionnel.",
      "humanDescription": "Je pourrais utiliser ça pour garder mes affaires... en sécurité.",
      "hylotlDescription": "Un coffre-fort. Utile pour se protéger des visiteurs indésirables.",
      "novakidDescription": "Ça empêchera ces bestioles de toucher à mon butin!"
    }
  },
  "saloonbar": {
    "name": "Bar de Saloon",
    "desc": "Un comptoir de bar poli, accompagné de trois tabourets.",
    "metadata": {
      "apexDescription": "La surface de ce bar a été polie jusqu'à briller. Il a sans doute beaucoup servi.",
      "avianDescription": "Je suis sûr que toutes sortes de gens intéressants se sont assis à ce bar!",
      "floranDescription": "Floran pen sse que le bar pourrait être un bon endroit pour déclencher desss bagarresss...",
      "glitchDescription": "Impressionné. La surface de ce bar a beaucoup servi, mais elle est toujours polie et brillante.",
      "humanDescription": "Ah, s'asseoir derrière ce bar, voir défiler toutes sortes de gens... Quelle vie.",
      "hylotlDescription": "Je suis sûr que ce bar a vu passer bien des taches au fil des ans.",
      "novakidDescription": "Un bar qui a d'la gueule. J'y poserais bien mon verre sans hésiter."
    }
  },
  "salooncabinet": {
    "name": "Meuble de Saloon",
    "desc": "Un meuble à boissons, garni de verrerie et de bouteilles aux formes étranges.",
    "metadata": {
      "apexDescription": "Un meuble à boissons chic, mais je ne vois pas de jus de banane.",
      "avianDescription": "Un meuble rempli de verres bizarres et de liquide à l'odeur sucrée.",
      "floranDescription": "Jus dégoûtantsss.",
      "glitchDescription": "Observateur. Le liquide à l'intérieur de ces bouteilles semble être du jus.",
      "humanDescription": "Un meuble à boissons au look vintage. Je ne sais pas trop ce qu'il y a dans ces bouteilles.",
      "hylotlDescription": "Un meuble à boissons. Le liquide à l'intérieur de ces bouteilles sent merveilleusement bon...",
      "novakidDescription": "Parfait pour un bon remontant! Quoique j'vois pas de Rosée des Prairies..."
    }
  },
  "saloondoor": {
    "name": "Porte de Saloon",
    "desc": "Une porte battante de saloon pour garder ces satanés virevoltants à l'extérieur.",
    "metadata": {
      "apexDescription": "C'est un singe qui entre dans un bar...",
      "avianDescription": "Malgré tous ses battements, cette pauvre porte ne s'envolera jamais.",
      "floranDescription": "Ttruc battant sstupide sur le chemin de Floran.",
      "glitchDescription": "Amusé. Cette 'porte' semble ne servir que de signal dramatique pour indiquer que quelqu'un est entré.",
      "humanDescription": "Ça ferait presque une meilleure fenêtre qu'une porte.",
      "hylotlDescription": "Il faut être prêt pour un duel avant de franchir un seuil comme celui-ci.",
      "novakidDescription": "Quand on franchit l'une d'elles, on a intérêt à être prêt à tout."
    }
  },
  "saloonlight": {
    "name": "Lampe de Saloon",
    "desc": "Une applique murale électrique.",
    "metadata": {
      "apexDescription": "Lueur de cette lampe est chaude et réconfortante.",
      "avianDescription": "Le travail du fer surpasse celui des forgerons de lances Avians.",
      "floranDescription": "Aucun feu ne brûle à l'intérieur.",
      "glitchDescription": "Confus. Bien que cette lampe soit manifestement conçue pour utiliser du gaz inflammable, la source lumineuse est électrique.",
      "humanDescription": "Une lampe électrique. On dirait qu'elle a été construite pour accueillir une flamme.",
      "hylotlDescription": "La lampe semble conçue pour abriter une flamme mais elle est entièrement électrique.",
      "novakidDescription": "Une bonne vieille applique murale, même si elle marche pas à la flamme."
    }
  },
  "saloonpiano": {
    "name": "Piano de Saloon",
    "desc": "Un piano digne d'un saloon!",
    "metadata": {
      "apexDescription": "Tous les Apex doivent apprendre à jouer. Cependant, seule la musique autorisée peut être interprétée. Un micro est caché dans chaque piano.",
      "avianDescription": "Les touches produisent des sons agréables.",
      "floranDescription": "Floran fait de la mussique avec peau et osss, maître du tambourr. Pas sstupide machine à sson.",
      "glitchDescription": "Prétentieux. Les principes mathématiques derrière cette machine sont d'une simplicité dérisoire.",
      "humanDescription": "Un piano... Je sais jouer 'Chopsticks'!",
      "hylotlDescription": "Ah, la musique... Elle a le pouvoir d'éclairer même nos heures les plus sombres.",
      "novakidDescription": "Un piano parfait pour un bon vieux honky-tonk."
    }
  },
  "saloonseat": {
    "name": "Chaise de Saloon",
    "desc": "Une chaise de saloon qui a l'air inconfortable.",
    "metadata": {
      "apexDescription": "Une chaise en bois de type saloon.",
      "avianDescription": "Une chaise de saloon rudimentaire avec un mince rembourrage rouge.",
      "floranDescription": "Chaissse a un cousssin. Floran peut s'asseoir.",
      "glitchDescription": "Tranché. Objectivement inconfortable.",
      "humanDescription": "Elle a l'air assez inconfortable, mais au moins il y a un coussin.",
      "hylotlDescription": "Un petit effort a été fait pour rendre cela confortable.",
      "novakidDescription": "C'est pas une selle, mais un ssiège est un ssiège."
    }
  },
  "saloonsign": {
    "name": "Enseigne de Saloon",
    "desc": "Une enseigne en bois peint pour les saloons.",
    "metadata": {
      "apexDescription": "Cette vieille enseigne peinte indique \"Saloon\". C'est assez explicite.",
      "avianDescription": "Un \"Saloon\"? Ça a l'air sympa!",
      "floranDescription": "Floran n'a passs le temps de lire desss trucsss.",
      "glitchDescription": "Observateur. Cette enseigne semble très attrayante - je soupçonne qu'elle soit faite pour attirer les clients.",
      "humanDescription": "Un saloon, hein? Vais-je avoir droit à une bagarre de bar ou simplement à une partie de cartes?",
      "hylotlDescription": "Une enseigne grossière, décorée d'une peinture bon marché qui s'écaille.",
      "novakidDescription": "Voilà exactement le genre de bel établissement que j'recherche."
    }
  },
  "saloonspittoon": {
    "name": "Crachoir de Saloon",
    "desc": "Beurk.",
    "metadata": {
      "apexDescription": "Quelqu'un a craché dans ce pot. Quel manque de savoir-vivre!",
      "avianDescription": "C'est plein de crachat...",
      "floranDescription": "Floran ne veut même passs ssavoir.",
      "glitchDescription": "Nauséeux. Je regrette d'avoir analysé le contenu de ce pot.",
      "humanDescription": "Je ne sais pas trop à quoi je m'attendais...",
      "hylotlDescription": "Beurk. L'intérieur n'est pas beau à voir...",
      "novakidDescription": "Un bon vieux cusspidor à l'ancienne..."
    }
  },
  "saloontable": {
    "name": "Table de Saloon",
    "desc": "Une table richement teintée, digne d'un vieux western.",
    "metadata": {
      "apexDescription": "Cette table est jonchée de cartes à jouer.",
      "avianDescription": "Il y a un tas de jetons colorés éparpillés dessus.",
      "floranDescription": "Joli bureau.",
      "glitchDescription": "Amusé. Une table très simple ornée d'attirail de jeu.",
      "humanDescription": "Cette table sort tout droit du Far West!",
      "hylotlDescription": "Une table conçue pour jouer aux cartes et déclencher des bagarres.",
      "novakidDescription": "Une table de jeu! Drôlement chouette!"
    }
  },
  "saloontumbler": {
    "name": "Verre de Saloon",
    "desc": "Un verre à pied qui a l'air sale.",
    "metadata": {
      "apexDescription": "Un petit verre pour boire.",
      "avianDescription": "Un petit verre à boire.",
      "floranDescription": "Floran veut voir le verrre s'écrassser.",
      "glitchDescription": "Observateur. Un petit verre.",
      "humanDescription": "Un petit verre. Il y a des années d'éclats et de rayures sur sa surface.",
      "hylotlDescription": "Un petit verre tout simple.",
      "novakidDescription": "Ce verre a l'air un peu sale, mais je l'utiliserais quand même."
    }
  },
  "secretsign1": {
    "name": "Symbole Secret 1",
    "desc": "Un symbole mystérieux.",
    "metadata": {
      "apexDescription": "Ces symboles sont mystérieux en effet.",
      "avianDescription": "Qu'est-ce qui déclenche ce symbole mystérieux?",
      "floranDescription": "Chossse étrange!",
      "glitchDescription": "Curieux. Je n'arrive pas à analyser la signification de ce symbole.",
      "humanDescription": "Étrange symbole extraterrestre. Bizarre.",
      "hylotlDescription": "Je n'ai jamais vu un symbole comme celui-ci, même dans les livres.",
      "novakidDescription": "Une écriture dans une langue étrangère. Ça m'dit rien."
    }
  },
  "secretsign2": {
    "name": "Symbole Secret 2",
    "desc": "Un symbole mystérieux.",
    "metadata": {
      "apexDescription": "Ces symboles sont mystérieux en effet.",
      "avianDescription": "Qu'est-ce qui déclenche ce symbole mystérieux?",
      "floranDescription": "Sssymbole!",
      "glitchDescription": "Curieux. Je n'arrive pas à analyser la signification de ce symbole.",
      "humanDescription": "Je me demande si ça veut dire quelque chose, ou si c'est juste joli?",
      "hylotlDescription": "Ce sigile pourrait signifier quelque chose.",
      "novakidDescription": "Une écriture dans une langue étrangère. Ça m'dit rien."
    }
  },
  "secretsign3": {
    "name": "Symbole Secret 3",
    "desc": "Un symbole mystérieux.",
    "metadata": {
      "apexDescription": "Ces symboles sont mystérieux en effet.",
      "avianDescription": "Est-ce censé représenter quelque chose?",
      "floranDescription": "Sssymbole!",
      "glitchDescription": "Pensif. Je me demande si ce sigile représente un chiffre.",
      "humanDescription": "En plissant les yeux, on dirait presque un visage joyeux.",
      "hylotlDescription": "Ce sigile pourrait signifier quelque chose.",
      "novakidDescription": "Une écriture dans une langue étrangère. Ça m'dit rien."
    }
  },
  "skulltorch": {
    "name": "Support de Torche Crâne",
    "desc": "Des ombres profondes s'étirent à partir de cette torche menaçante.",
    "metadata": {
      "apexDescription": "Cette torche morbide fournit de la chaleur autant que de la lumière.",
      "avianDescription": "Une torche plutôt macabre, si je puis dire...",
      "floranDescription": "Visssage brûlant!",
      "glitchDescription": "Mal à l'aise. Je crois que c'est un vrai crâne.",
      "humanDescription": "Un crâne avec des flammes en guise de cheveux! Cool.",
      "hylotlDescription": "Qui utiliserait les morts à cette fin?",
      "novakidDescription": "Salut, l'ami."
    }
  },
  "skullwalltorch": {
    "name": "Torche Murale Crâne",
    "desc": "Une torche sinistre faite de vieux os.",
    "metadata": {
      "apexDescription": "Cette torche morbide fournit de la chaleur autant que de la lumière.",
      "avianDescription": "Une torche plutôt macabre, si je puis dire...",
      "floranDescription": "Visssage brûlant!",
      "glitchDescription": "Mal à l'aise. Je crois que c'est un vrai crâne.",
      "humanDescription": "Un crâne avec des flammes en guise de cheveux! Cool.",
      "hylotlDescription": "Qui utiliserait les morts à cette fin?",
      "novakidDescription": "Salut, l'ami."
    }
  },
  "statuslight": {
    "name": "Voyant d'État",
    "desc": "Un voyant qui indique l'état d'un interrupteur.",
    "metadata": {
      "apexDescription": "Le voyant indique l'état de l'interrupteur.",
      "avianDescription": "Quand la lumière est bleue, l'interrupteur est activé.",
      "floranDescription": "Lumièrre bleue signifie que l'interrrupteur essst allumé.",
      "glitchDescription": "Perceptif. Une lumière bleue indique un interrupteur actif.",
      "humanDescription": "L'interrupteur est actif quand la lumière est bleue.",
      "hylotlDescription": "Un voyant pour indiquer l'état d'un interrupteur.",
      "novakidDescription": "La lumière devient bleue quand on actionne l'interrupteur."
    }
  },
  "strangeweb1": {
    "name": "Toile Étrange",
    "desc": "Une étrange sangle organique.",
    "metadata": {
      "apexDescription": "Cela semble d'origine organique. Qu'est-ce qui a bien pu créer cette substance?",
      "avianDescription": "Ça a l'air collant. Je n'aimerais pas que ça se prenne dans mes plumes.",
      "floranDescription": "Sssent comme une proie!",
      "glitchDescription": "Observateur. Cette substance fluide a été créée par quelque chose d'organique.",
      "humanDescription": "Ce truc sent encore plus mauvais qu'il n'en a l'air. Qu'est-ce qui l'a fabriqué?",
      "hylotlDescription": "Encore une bizarrerie déplaisante des Florans, peut-être? Ou quelque chose de pire...",
      "novakidDescription": "On dirait du chewing-gum collé à une botte."
    }
  },
