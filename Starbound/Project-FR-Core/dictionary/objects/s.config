  "shadowurnlarge1": {
    "name": "Grande Urne d'Ombre",
    "desc": "Un grand vase sombre. Semble plutôt facile à fracasser.",
    "metadata": {
      "apexDescription": "Je crois entendre quelque chose à l'intérieur...",
      "avianDescription": "Cette urne semble maudite...",
      "floranDescription": "Frrracassse et arrrrache ses entrailless sombress!",
      "glitchDescription": "Destructeur. Je pense qu'il pourrait y avoir quelque chose d'encore plus sombre à l'intérieur.",
      "humanDescription": "J'ai presque peur de briser cette urne flippante.",
      "hylotlDescription": "On dit que briser une urne porte malheur. Je n'ose imaginer le sort qui nous attend si on brise celle-là.",
      "novakidDescription": "Mieux vaut laisser ce genre d'urnes tranquilles."
    }
  },
