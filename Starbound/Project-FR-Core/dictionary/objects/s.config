  "slimebed": {
    "name": "Lit de Slime",
    "desc": "Dormez paisiblement, suspendu dans le slime.",
    "metadata": {
      "apexDescription": "Un lit de slime. Ça m'a l'air suspect.",
      "avianDescription": "Est-ce que je vais avoir du slime dans mes plumes?",
      "floranDescription": "C'essst tout mou!",
      "glitchDescription": "Prudent. Le slime pourrait causer de la rouille.",
      "humanDescription": "C'est fait de slime. J'espère que je pourrai respirer là-dedans.",
      "hylotlDescription": "Un lit de slime. Offrira-t-il un sommeil paisible?",
      "novakidDescription": "Du slime en guise de lit? Ça vaut le coup d'essayer."
    }
  },
  "slimechair": {
    "name": "Chaise de Slime",
    "desc": "Un endroit collant et visqueux pour s'asseoir.",
    "metadata": {
      "apexDescription": "Cette chaise n'a aucun sens.",
      "avianDescription": "Est-ce que je vais passer à travers cette chaise?",
      "floranDescription": "Une chaisse ssic rriddicule.",
      "glitchDescription": "Fasciné. Bien que le matériau soit désagréable, sa courbure naturelle est plaisante à l'œil.",
      "humanDescription": "Comment ça marche? Je dois juste croiser les doigts pour que ce soit une chaise?",
      "hylotlDescription": "Une fois passé sa texture déplaisante, cette chaise de slime est assez confortable.",
      "novakidDescription": "Pas si sûr que ce soit vraiment une chaise."
    }
  },
  "slimehide": {
    "name": "Coffre de Slime",
    "desc": "Un coffre fait d'une épaisse substance visqueuse.",
    "metadata": {
      "apexDescription": "Je me méfie de l'utilité d'un coffre translucide.",
      "avianDescription": "Je peux voir le contenu du coffre à travers le slime. C'est chouette!",
      "floranDescription": "Un coffrre trranssparrent n'esst pass trrès disscret.",
      "glitchDescription": "Surpris. Je peux voir le contenu de ce coffre à travers sa paroi de slime.",
      "humanDescription": "Si je regarde de près, je peux voir à travers le slime.",
      "hylotlDescription": "Ce coffre semble être fait de verre vert.",
      "novakidDescription": "À quoi ça sert d'avoir un coffre où on voit l'intérieur sans l'ouvrir?"
    }
  },
  "slimetorch": {
    "name": "Torche de Slime",
    "desc": "Une torche faite de slime.",
    "metadata": {
      "apexDescription": "Je ne fais pas confiance à quelque chose qui sent aussi mauvais.",
      "avianDescription": "Cette torche de slime sent si mauvais que j'en ai mal au bec.",
      "floranDescription": "La torrrche brûle en verrrt, mais ce n'esst pass naturrrel.",
      "glitchDescription": "Amusé. Le slime brûle en vert.",
      "humanDescription": "Cette torche brûle de la mélasse gluante.",
      "hylotlDescription": "Une torche de slime. Elle dégage une odeur désagréable en brûlant.",
      "novakidDescription": "Une torche faite de slime... comment ça peut seulement brûler?"
    }
  },
  "scorchedbench": {
    "name": "Banc Calciné",
    "desc": "Un banc calciné.",
    "metadata": {
      "apexDescription": "Ce banc a subi quelques dégâts.",
      "avianDescription": "Ce banc a l'air rouillé et usé.",
      "floranDescription": "Vieux banc rrouillé.",
      "glitchDescription": "Perturbé. Ce banc prouve que même le métal le plus solide peut être corrodé.",
      "humanDescription": "Ce banc a connu des jours meilleurs.",
      "hylotlDescription": "S'il pouvait parler, je me demande quelles histoires ce banc raconterait.",
      "novakidDescription": "Ce banc a l'air sacrément usé."
    }
  },
  "scorchedcityarrowsign": {
    "name": "Panneau Fléché de Pneu",
    "desc": "Un panneau en forme de flèche.",
    "metadata": {
      "apexDescription": "Un panneau fléché. Je me demande s'il pointe vers quelque chose d'utile.",
      "avianDescription": "Un panneau fléché, vers quoi pointe-t-il?",
      "floranDescription": "Panneau flèche.",
      "glitchDescription": "Rusé. Un panneau fléché. Le suivre serait bien trop prévisible.",
      "humanDescription": "Un panneau fléché. Rien de mal ne peut arriver en suivant un panneau au hasard.",
      "hylotlDescription": "Un panneau fléché. Dois-je le suivre ou tracer mon propre chemin?",
      "novakidDescription": "C'est quoi l'intérêt de c'te flèche de toute façon?"
    }
  },
  "scorchedcitybed": {
    "name": "Lit Élégant",
    "desc": "Un lit propre et robuste.",
    "metadata": {
      "apexDescription": "Un lit à l'aspect frais et propre.",
      "avianDescription": "Un lit simple. Les draps sont frais.",
      "floranDescription": "Un lit prrropre est bon pour un ssommeil rréparrateur.",
      "glitchDescription": "Calme. Un lit avec un niveau de stérilité très séduisant.",
      "humanDescription": "Un lit qui a l'air propre, il semble assez confortable.",
      "hylotlDescription": "Un lit simple, il remplira sa fonction.",
      "novakidDescription": "Ce lit a l'air un peu trop propre, si vous voulez mon avis."
    }
  },
  "scorchedcitybrokenbed": {
    "name": "Lit Élégant Cassé",
    "desc": "Un lit cassé.",
    "metadata": {
      "apexDescription": "Un lit cassé. Il est inutile maintenant.",
      "avianDescription": "Un lit cassé, il a l'air d'avoir été oublié.",
      "floranDescription": "Ce lit essst casssé.",
      "glitchDescription": "Triste. Ce lit est cassé.",
      "humanDescription": "Un lit cassé, dormir dessus maintenant serait une terrible idée.",
      "hylotlDescription": "Un lit cassé. Il n'est même plus fonctionnel.",
      "novakidDescription": "Ce lit est carrémment naze."
    }
  },
  "scorchedcitybrokenchair": {
    "name": "Chaise Élégante Cassée",
    "desc": "Une chaise cassée.",
    "metadata": {
      "apexDescription": "Une chaise cassée.",
      "avianDescription": "Une chaise cassée, c'est triste.",
      "floranDescription": "Cette chaisse essst cassssée!",
      "glitchDescription": "Surpris. Cette chaise est cassée au-delà de toute réparation.",
      "humanDescription": "Cette chaise est cassée.",
      "hylotlDescription": "Une chaise cassée. Elle n'est plus adaptée à son usage.",
      "novakidDescription": "C'était une chaise, fut un temps."
    }
  },
  "scorchedcitybrokenchestdrawerlarge": {
    "name": "Grande Commode Cassée",
    "desc": "Une commode, à laquelle il manque quelques tiroirs.",
    "metadata": {
      "apexDescription": "C'était autrefois une commode, il ne reste que quelques étagères.",
      "avianDescription": "Cette commode est cassée.",
      "floranDescription": "Une grrande commode cassssée.",
      "glitchDescription": "Triste. Une grande commode, brisée en morceaux.",
      "humanDescription": "Une commode, il en manque quelques-uns.",
      "hylotlDescription": "Une commode, beaucoup de tiroirs sont maintenant manquants.",
      "novakidDescription": "C'est bien cassé, il manque même des tiroirs."
    }
  },
