  "stonebed": {
    "name": "Lit de Pierre",
    "desc": "Un lit fait de pavés.",
    "metadata": {
      "apexDescription": "Un lit dur, j'ai dormi sur pire.",
      "avianDescription": "Un endroit bien dur pour faire son nid.",
      "floranDescription": "Un lit en rroche.",
      "glitchDescription": "Irrité. Je pourrais rayer ma peinture en dormant ici.",
      "humanDescription": "Ce lit n'a pas l'air très confortable.",
      "hylotlDescription": "Un lit rude apporte des rêves rudes.",
      "novakidDescription": "Ce lit est fait de cailloux. Inconfortable."
    }
  },
  "stonechair": {
    "name": "Chaise de Pierre",
    "desc": "Une chaise faite de pavés.",
    "metadata": {
      "apexDescription": "Plus confortable que les chaises utilisées par les Apex lors des interrogatoires.",
      "avianDescription": "Artisanat médiocre.",
      "floranDescription": "Chaise de pierrre fait mal au dos de Floran.",
      "glitchDescription": "Hautain. Si j'avais des muscles dorsaux, cela les endommagerait sûrement.",
      "humanDescription": "Ça n'a pas l'air confortable du tout.",
      "hylotlDescription": "Il serait difficile de méditer ici.",
      "novakidDescription": "Pas vraiment mon genre de chaise."
    }
  },
  "stonechest": {
    "name": "Coffre de Pierre",
    "desc": "Un coffre au trésor fait de pavés.",
    "metadata": {
      "apexDescription": "Un lourd coffre de pierre.",
      "avianDescription": "Les charnières de ce coffre grincent quand il s'ouvre.",
      "floranDescription": "Cofffrre de pierrre garde trrésorsss de Floran en sécurité.",
      "glitchDescription": "Pensif. Il ne faudrait pas beaucoup de force pour forcer ce coffre.",
      "humanDescription": "Un coffre trop lourd à déplacer, même vide.",
      "hylotlDescription": "Ce coffre est de pierre dure mais peut contenir de délicats trésors. Une métaphore du cœur.",
      "novakidDescription": "Un caillou dans lequel on peut mettre des trucs."
    }
  },
  "stonedoor": {
    "name": "Porte de Pierre",
    "desc": "Une porte faite de pavés.",
    "metadata": {
      "apexDescription": "Les Apex sont très familiers avec les portes secrètes.",
      "avianDescription": "Une porte bien camouflée.",
      "floranDescription": "Le mur rrentre, le mur sssort. Floran aime ça.",
      "glitchDescription": "Approbateur. Utilisation magistrale de matériaux naturels.",
      "humanDescription": "Il serait facile de cacher cette porte dans une pièce en pavés.",
      "hylotlDescription": "Les plus grands secrets sont cachés à la vue de tous.",
      "novakidDescription": "Y'a un rocher qui m'bloque la route."
    }
  },
  "stonetable": {
    "name": "Table de Pierre",
    "desc": "Une table faite de pavés.",
    "metadata": {
      "apexDescription": "Une table simple. Elle fera l'affaire.",
      "avianDescription": "Quelqu'un a simplement empilé deux dalles de pierre.",
      "floranDescription": "Table en pierrre.",
      "glitchDescription": "Pas impressionné. Artisanat rudimentaire.",
      "humanDescription": "Je suppose que ça compte comme une table.",
      "hylotlDescription": "La fonction avant la forme. Cette table est susceptible de résister au temps.",
      "novakidDescription": "Un petit caillou avec un plus gros caillou par-dessus."
    }
  },
  "sacrificialaltar": {
    "name": "Autel Sacrificiel",
    "desc": "Un autel collant de vieux sang et de plumes.",
    "metadata": {
      "apexDescription": "Quels actes sombres ont été commis sur cet autel?",
      "avianDescription": "Le sacrifice est courant chez les Avians. C'est pourquoi beaucoup choisissent de devenir des 'Terrestres'.",
      "floranDescription": "Sang délicieux. Floran veut goûterrr.",
      "glitchDescription": "Observateur. L'autel semble éclaboussé de sang.",
      "humanDescription": "Du sang et des plumes. Lugubre.",
      "hylotlDescription": "Qui choisirait de suivre un dieu qui exige que ses fidèles sacrifient leur vie?",
      "novakidDescription": "Cet autel est couvert d'éclaboussures de sang. Atroce."
    }
  },
  "sarcoavian1": {
    "name": "Sarcophage Avian",
    "desc": "Un sarcophage Avian expertement sculpté. Je me demande ce qu'il y a dedans.",
    "metadata": {
      "apexDescription": "Un sarcophage. Je me demande si quelqu'un est à l'intérieur.",
      "avianDescription": "Les Avians les plus riches et les plus respectés y préservent leur corps entier.",
      "floranDescription": "L'en-casss à l'intérieur n'est passs frais.",
      "glitchDescription": "Neutre. L'Avian à l'intérieur est vraiment très vieux.",
      "humanDescription": "Un sarcophage poussiéreux.",
      "hylotlDescription": "Les Hylotls confient leurs morts à l'océan.",
      "novakidDescription": "Un endroit pour un cadavre."
    }
  },
  "sarcoavian2": {
    "name": "Grand Sarcophage Avian",
    "desc": "Un sarcophage Avian expertement sculpté. La plume suggère qu'il était destiné à quelqu'un d'important.",
    "metadata": {
      "apexDescription": "Un sarcophage. Je me demande si quelqu'un est à l'intérieur.",
      "avianDescription": "Les Avians les plus riches et les plus respectés y préservent leur corps entier. La plume marque la faveur des Astronomes.",
      "floranDescription": "L'en-casss à l'intérieur n'est passs frais.",
      "glitchDescription": "Neutre. L'Avian à l'intérieur est vraiment très vieux.",
      "humanDescription": "Un sarcophage poussiéreux.",
      "hylotlDescription": "Les Hylotls confient leurs morts à l'océan.",
      "novakidDescription": "Un endroit pour un cadavre."
    }
  },
  "sarcobunny": {
    "name": "Sarcophage Lapin",
    "desc": "Est-ce mal d'emmener son lapin avec soi dans l'au-delà?",
    "metadata": {
      "apexDescription": "Pourquoi ce sarcophage est-il en forme de lapin?",
      "avianDescription": "Un sarcophage pour les criminels et les hérétiques. L'Avian à l'intérieur perdra ses ailes dans l'au-delà.",
      "floranDescription": "Longuesss oreillesss, morrt depuis longtemps.",
      "glitchDescription": "Observateur. Malgré le design du sarcophage, il y a un Avian à l'intérieur.",
      "humanDescription": "Un sarcophage lapin! Trop chou!",
      "hylotlDescription": "Les cristaux sur ce sarcophage semblent le maintenir fermé. L'habitant était-il encore en vie quand on l'a enfermé?",
      "novakidDescription": "Un sarcophage Avian. Mais pourquoi a-t-il la forme d'un lapin?"
    }
  },
  "sarcohuman": {
    "name": "Sarcophage Humain",
    "desc": "Les Avians sont connus pour tenter d'emmener des compagnons humains avec eux dans l'au-delà.",
    "metadata": {
      "apexDescription": "Un sarcophage. Il est de forme humaine.",
      "avianDescription": "Certains des premiers Avians parmi les étoiles avaient de profondes amitiés avec les humains. C'est une tentative de les amener dans l'éther pour qu'ils gagnent aussi des ailes.",
      "floranDescription": "Ça sssent l'humain.",
      "glitchDescription": "Observateur. Un humain repose à l'intérieur de ce sarcophage.",
      "humanDescription": "Est-ce un humain?",
      "hylotlDescription": "Ceci n'est pas un sarcophage Avian.",
      "novakidDescription": "Un sarcophage en forme d'humain. Y a-t-il un corps humain à l'intérieur?"
    }
  },
  "sarcohumanalive": {
    "name": "Sarcophage Humain",
    "desc": "On raconte que les Avians tentent d'emmener des humains avec eux dans l'au-delà. Attendez... je crois entendre quelque chose à l'intérieur!",
    "metadata": {
      "apexDescription": "Un sarcophage de forme humaine. Attendez... c'était quoi ça?",
      "avianDescription": "Certains des premiers Avians avaient des amitiés avec les humains. C'est une tentative de les amener dans l'éther pour qu'ils gagnent aussi des ai... attendez... j'ai entendu quelque chose?",
      "floranDescription": "Ça sssent le frrrais!",
      "glitchDescription": "Observateur. Un humain est dans ce sarcophage. Je reçois des signes vitaux!",
      "humanDescription": "Est-ce que je viens d'entendre quelque chose?",
      "hylotlDescription": "Est-ce que ce sarcophage vient de bouger?",
      "novakidDescription": "Un sarcophage en forme d'humain. Attendez... j'ai rêvé ou ça a fait du bruit?"
    }
  },
  "sawblade": {
    "name": "Piège à Scie Circulaire",
    "desc": "Ouah, ça a l'air tranchant!",
    "metadata": {
      "apexDescription": "Ça a l'air coupant.",
      "avianDescription": "Les Avians protègent bien leurs tombes.",
      "floranDescription": "Trranchant. Floran doit éviter.",
      "glitchDescription": "Inquiet. Cela semble tourner à quatre mille tours par minute.",
      "humanDescription": "Waouh, je dois faire attention ici.",
      "hylotlDescription": "Je n'ai aucune envie de finir en sushi.",
      "novakidDescription": "Ça n'a pas l'air très amical."
    }
  },
  "screen1": {
    "name": "Écran de Données",
    "desc": "De vieilles lectures système qui semblent périmées.",
    "metadata": {
      "apexDescription": "Cela semble être des diagnostics système. Je ne les comprends pas.",
      "avianDescription": "Cet écran décrit l'état des cristaux environnants. Seuls les Astronomes peuvent le comprendre.",
      "floranDescription": "Technologie d'homme-oiseau. Floran ne comprrrend pas.",
      "glitchDescription": "Confus. Je ne peux pas m'interfacer avec cette machine.",
      "humanDescription": "Ça a l'air complexe. Peut-être que ça décrit l'état de la technologie Avian.",
      "hylotlDescription": "Les Hylotls ne peuvent pas lire ceci. Ce sont apparemment des statistiques système.",
      "novakidDescription": "Je ne pige absolument rien à ces informations."
    }
  },
  "screen2": {
    "name": "Écran de Vaisseau",
    "desc": "C'est un vaisseau spatial en orbite autour d'une planète.",
    "metadata": {
      "apexDescription": "Un grand vaisseau en orbite.",
      "avianDescription": "Les Avians suivaient leurs mouvements dans l'univers.",
      "floranDescription": "Un grrrand vaisssseau et une grrrande planète.",
      "glitchDescription": "Observateur. Il semble que ce soit un vaisseau en orbite autour d'une planète assez vaste.",
      "humanDescription": "Un vaisseau qui tourne en rond autour d'une planète. Ça me donne le tournis.",
      "hylotlDescription": "On dirait un impressionnant vaisseau approchant de l'orbite d'une planète.",
      "novakidDescription": "Y'a un vaisssseau spatial qui tourne autour d'une planète."
    }
  },
  "screen3": {
    "name": "Écran de Carte Stellaire",
    "desc": "Une carte des étoiles! C'est un peu primitif.",
    "metadata": {
      "apexDescription": "Une carte du système stellaire environnant.",
      "avianDescription": "La résonance des cristaux était utilisée pour cartographier les systèmes stellaires.",
      "floranDescription": "Ce sssont les étoilesss aux alentoursss.",
      "glitchDescription": "Neutre. Voici le système stellaire actuel.",
      "humanDescription": "Un modèle de ce système stellaire précis.",
      "hylotlDescription": "Les étoiles sont un océan à part entière.",
      "novakidDescription": "Je vois des étoiles. Littéralement. Ça doit être ce système stellaire-ci."
    }
  },
  "screen4": {
    "name": "Écran de Glyphes",
    "desc": "Des glyphes palpitent de façon inquiétante... que signifient-ils?",
    "metadata": {
      "apexDescription": "Des glyphes. Je n'arrive pas à les lire.",
      "avianDescription": "Seuls les Astronomes peuvent vraiment lire ceci. Je reconnais le glyphe du sacrifice.",
      "floranDescription": "Desssins stupidesss. Floran ne peut pas rreconnaître.",
      "glitchDescription": "Déçu. Je ne peux pas traduire ceci.",
      "humanDescription": "Des glyphes. Mon traducteur n'arrive pas à les déchiffrer.",
      "hylotlDescription": "Des symboles anciens. Mon traducteur ne peut pas les décoder.",
      "novakidDescription": "Ces symboles me sont étrangers. Ça sert à rien d'essayer de les interpréter."
    }
  },
  "screen5": {
    "name": "Écran d'Activité Cérébrale",
    "desc": "Est-ce que ce sont... des ondes cérébrales? Oui. Absolument.",
    "metadata": {
      "apexDescription": "On dirait des ondes cérébrales... d'où proviennent-elles?",
      "avianDescription": "Des ondes cérébrales. On dit que les cristaux qui alimentent la technologie Avian ont leur propre conscience.",
      "floranDescription": "Lignesss qui ondulent.",
      "glitchDescription": "Observateur. Cela semble être des ondes cérébrales.",
      "humanDescription": "Des ondes cérébrales? À qui appartiennent-elles?",
      "hylotlDescription": "Cela semble être des schémas de pensée. Mais à qui appartiennent-ils?",
      "novakidDescription": "Qu'est-ce que ces vagues sont censées vouloir dire?"
    }
  },
  "shipwheel": {
    "name": "Barre de Navire en Bois",
    "desc": "À l'abordage, mes gaillards!",
    "metadata": {
      "apexDescription": "Un dispositif de contrôle.",
      "avianDescription": "Pour diriger un navire volant Avian.",
      "floranDescription": "Fait tourrrner la roue, dirrriger le vaisssseau.",
      "glitchDescription": "Critique. Une méthode de contrôle de vaisseau peu précise.",
      "humanDescription": "Un gouvernail de capitaine!",
      "hylotlDescription": "Semble plus adapté pour diriger un navire sur les flots que dans les airs.",
      "novakidDescription": "Une barre de navire. J'en ai déjà vu quelques-unes."
    }
  },
  "smalljar1": {
    "name": "Petit Pot",
    "desc": "Un petit pot à l'air fragile. Il semble facile à briser...",
    "metadata": {
      "apexDescription": "Un petit pot. Pourrait contenir des provisions.",
      "avianDescription": "Un petit pot, rien de spécial.",
      "floranDescription": "Floran brrrise beaucoup de potsss.",
      "glitchDescription": "Pensif. Briser ou ne pas briser?",
      "humanDescription": "Un autre jour, un autre pot à fracasser.",
      "hylotlDescription": "Ces pots ont fait de moi un individu bien plus agressif.",
      "novakidDescription": "Faut les casser pour voir ce qu'il y a dedans."
    }
  },
  "spearrack": {
    "name": "Râtelier à Lances Avian",
    "desc": "Le râtelier est rempli de lances Avian antiques.",
    "metadata": {
      "apexDescription": "Des lances tranchantes. On dirait qu'ils font collection.",
      "avianDescription": "La lance est l'arme de prédilection des gardiens Avians.",
      "floranDescription": "Les hommess-oiseaux collectionnent les bâtonsss pointus.",
      "glitchDescription": "Déçu. Il n'y a que trois lances ici.",
      "humanDescription": "Un ensemble de lances Avian.",
      "hylotlDescription": "Les lances sont utiles pour le combat sous-marin.",
      "novakidDescription": "Je préfère un flingue, mais ces gens n'avaient sûrement pas trop le choix."
    }
  },
  "sundecor": {
    "name": "Soleil Décoratif",
    "desc": "Ironiquement, regarder ce soleil décoratif me donne froid dans le dos.",
    "metadata": {
      "apexDescription": "Un emblème solaire. Il semble important.",
      "avianDescription": "Les Avians croient que le soleil est une porte vers l'éther.",
      "floranDescription": "L'homme-oisseau est en feu!",
      "glitchDescription": "Surpris. Les croyances Avian ne sont pas plus ridicules que celles des Glitchs.",
      "humanDescription": "Le soleil a-t-il une signification particulière pour un Avian?",
      "hylotlDescription": "Pouvez-vous imaginer ne jamais voir de lever de soleil?",
      "novakidDescription": "C'est un soleil avec un visage d'Avian. Qu'est-ce que ça veut dire?"
    }
  },
  "sandstonestatueapex": {
    "name": "Statue d'Apex en Grès",
    "desc": "Une statue d'Apex. Une ressemblance parfaite.",
    "metadata": {
      "apexDescription": "Cette Apex me dit quelque chose. Je crois qu'elle était catcheuse professionnelle.",
      "avianDescription": "Une statue d'Apex. Un hommage approprié à ces simiens stoïques.",
      "floranDescription": "Singe de pierrre pas bon à manger.",
      "glitchDescription": "Contemplatif. Un Apex de pierre robuste. Une représentation fidèle.",
      "humanDescription": "Une statue d'Apex sympa. Elle a l'air plutôt coriace.",
      "hylotlDescription": "Un Apex sculpté grossièrement. Leurs traits simples s'accordent bien avec cet aspect brut.",
      "novakidDescription": "Une sculpture d'un Apex à l'air coriace."
    }
  },
  "sandstonestatueavian": {
    "name": "Statue d'Avian en Grès",
    "desc": "Une statue d'Avian. Peu de chances qu'elle s'envole.",
    "metadata": {
      "apexDescription": "Un Avian à l'allure curieuse. Il a l'air royal.",
      "avianDescription": "Cet Avian est connu pour avoir uni les Terrestres et nous avoir encouragés à déployer nos ailes.",
      "floranDescription": "Stupide homme-oiseau à bec fait en grrrès.",
      "glitchDescription": "Informé. L'Avian représenté ici avait une grande importance historique.",
      "humanDescription": "Cet Avian a l'air d'un type cool. Je parie que personne ne venait l'embêter.",
      "hylotlDescription": "Les traits comiques de l'Avian ont été bien capturés ici.",
      "novakidDescription": "On dirait une sssculpture d'un Avian quelconque."
    }
  },
  "sandstonestatuefloran": {
    "name": "Statue de Floran en Grès",
    "desc": "Une statue de Floran. Ne vous poignardera pas... probablement.",
    "metadata": {
      "apexDescription": "Un Floran à l'air suave. Intimidant.",
      "avianDescription": "Malgré son visage de pierre, ce Floran a l'air plus abordable que d'habitude.",
      "floranDescription": "Verrt-de-gris. Floran sssspécial. Sssent bizarre.",
      "glitchDescription": "Hypothétique. Je pense que cette statue dépeint un grand chef Floran.",
      "humanDescription": "Un Floran adorable. C'est une chose que je n'aurais jamais pensé dire.",
      "hylotlDescription": "La pierre vide de la statue dépeint parfaitement les yeux froids et morts des Florans.",
      "novakidDescription": "Sculpter toutes ces feuilles a dû être un sacré boulot."
    }
  },
  "sandstonestatueglitch": {
    "name": "Statue de Glitch en Grès",
    "desc": "Un Glitch en grès. Il n'est pas doué de raison.",
    "metadata": {
      "apexDescription": "Un Glitch. Ils se ressemblent tous pour moi.",
      "genericDescription": "Une statue de Glitch. Je me demande s'il était important.",
      "floranDescription": "Homme-machine fait de pierrre. Floran trouve que l'homme-machine a l'airrr stupide.",
      "glitchDescription": "Informé. Cette statue représente le premier modèle Glitch, avant que ceux dotés de conscience ne commencent à se modifier.",
      "humanDescription": "J'ai toujours voulu un Glitch comme acolyte. Cette statue est ce qui s'en rapproche le plus.",
      "hylotlDescription": "Un Glitch. Leur apparence artificielle sera toujours dérangeante.",
      "novakidDescription": "Qui irait construire un homme de métal avec du grrrès?"
    }
  },
  "sandstonestatuehuman": {
    "name": "Statue d'Humain en Grès",
    "desc": "Une statue d'humain. Regardez cette tignasse.",
    "metadata": {
      "apexDescription": "Un humain. On comprend facilement pourquoi certains pensent que les humains et les Apex sont liés.",
      "avianDescription": "Un humain. Sa coiffure ressemble presque à des plumes.",
      "floranDescription": "Stupide homme-viande avec cheveux sstupidess. Sstatue.",
      "glitchDescription": "Inquiet. Je me sens mal pour les humains, devoir subir des coiffures aussi excentriques.",
      "humanDescription": "Un artiste humain très populaire. Je possédais tous ses albums.",
      "hylotlDescription": "Une statue d'humain. Cet homme semble essayer de se donner un genre.",
      "novakidDescription": "C'est une sacrée tignasse. On dirait qu'il vient juste d'enlever son chapeau."
    }
  },
  "sandstonestatuehylotl": {
    "name": "Statue de Hylotl en Grès",
    "desc": "Une statue de Hylotl. Un vrai look d'Innsmouth.",
    "metadata": {
      "apexDescription": "Une statue de Hylotl. L'artiste a parfaitement capturé son ricanement méprisant.",
      "avianDescription": "Un Hylotl de pierre. Elle semble me regarder avec désapprobation.",
      "floranDescription": "Statue de poissson gluant.",
      "glitchDescription": "Critique. Il semble que les Hylotls aient toujours souffert d'un manque de goût flagrant.",
      "humanDescription": "Un Hylotl à l'air grincheux. C'est assez fidèle à la réalité.",
      "hylotlDescription": "Une statue de Lili Shian, une princesse Hylotl légendaire.",
      "novakidDescription": "Une vieille statue sablonneuse d'un Hylotl."
    }
  },
  "selfportraitofhylotlshu": {
    "name": "Autoportrait de Hylotl-Shu",
    "desc": "Un autoportrait très célèbre d'un artiste Hylotl très célèbre.",
    "metadata": {
      "apexDescription": "Un autoportrait Hylotl classique. Magistralement exécuté.",
      "avianDescription": "Le travail au pinceau sur ce portrait est presque au niveau des standards Avians.",
      "floranDescription": "Floran veut voler le tableau et le vendrrre au marrché noirrr.",
      "glitchDescription": "Appréciatif. Cet autoportrait est une œuvre d'art majeure.",
      "humanDescription": "Il me semble familier, et pourtant... pas vraiment.",
      "hylotlDescription": "Un autoportrait d'un célèbre artiste historique de mon monde d'origine.",
      "novakidDescription": "Pas un mauvais tableau. On dirait qu'il joue aux carrrtes."
    }
  },
  "shroomstatue": {
    "name": "Statue de Champignon",
    "desc": "Une statue de champignon.",
    "metadata": {
      "apexDescription": "Une majestueuse statue de champignon.",
      "avianDescription": "C'est un vraiment gros champignon.",
      "floranDescription": "Joli caillou-champignon.",
      "glitchDescription": "Ravi. J'ai envie de m'asseoir à côté de cette statue.",
      "humanDescription": "Une statue de champignon vraiment immense.",
      "hylotlDescription": "Un gros champignon sculpté dans la roche.",
      "novakidDescription": "Celui qui a taillé ce caillou devait drôlement aimer les champignons."
    }
  },
  "sandbags": {
    "name": "Sacs de Sable",
    "desc": "Une pile de sacs de sable.",
    "metadata": {
      "apexDescription": "Ces sacs de sable sont simples et efficaces.",
      "avianDescription": "Des sacs lourds, probablement remplis de sable.",
      "floranDescription": "Grrrands ssacs de ssable ont l'airrr lourrrds.",
      "glitchDescription": "Impressionné. Le sable à l'intérieur transforme ces grands sacs en une barrière impressionnante.",
      "humanDescription": "De gros sacs de sable, ils font une excellente barricade.",
      "hylotlDescription": "Une pile de sacs de sable. Le sable... Un matériau tellement polyvalent.",
      "novakidDescription": "Ces vieux ssacs de ssable sont empilés bien haut."
    }
  },
  "smallfloorspike": {
    "name": "Petit Pieu de Sol",
    "desc": "C'est un pieu."
  },
  "sawblade2": {
    "name": "Ancien Piège à Scie",
    "desc": "Ouah, ça a l'air tranchant!",
    "metadata": {
      "apexDescription": "Ça a l'air coupant.",
      "avianDescription": "Ça a l'air tranchant.",
      "floranDescription": "Effrrrayant. Floran doit éviter ça.",
      "glitchDescription": "Inquiet. Cela semble tourner à quatre mille tours par minute.",
      "humanDescription": "Waouh, je dois faire attention ici.",
      "hylotlDescription": "Je n'ai pas envie de finir en sushi.",
      "novakidDescription": "Ça n'a pas l'airrr très amical."
    }
  },
  "speedbooster": {
    "name": "Accélérateur",
    "desc": "Le gaz libéré par ces conduits augmente votre vitesse de course.",
    "metadata": {
      "apexDescription": "Un appareil ingénieux, il émet un gaz capable d'augmenter ma vitesse physique.",
      "avianDescription": "Ce gaz vert à l'odeur sucrée donne du peps à ma démarche.",
      "floranDescription": "Gaz verrrt fait courrrir Floran plus vite.",
      "glitchDescription": "Optimiste. Le gaz de cet appareil a une odeur sucrée.",
      "humanDescription": "Ce gaz sent frais et bon. Qu'est-ce qu'il fait?",
      "hylotlDescription": "Les propriétés bénéfiques de ce gaz sont liées à l'amélioration de la vitesse physique.",
      "novakidDescription": "Un gaz verrrt. Ça augmente ma vitesse."
    }
  },
  "scandroidaf": {
    "name": "Figurine de Scandroid",
    "desc": "L'étiquette indique: \"Le scandroid est en quête perpétuelle. Personne ne sait de quoi.\""
  },
  "scaveranaf": {
    "name": "Figurine de Scaveran",
    "desc": "L'étiquette indique: \"L'intérieur de son bec est un spectacle véritablement terrifiant.\""
  },
  "shockhoppermkiaf": {
    "name": "Figurine de Shockhopper MK I",
    "desc": "L'étiquette indique: \"Un mecha Pingouin expérimental, maniant un bras lance-flammes et un poing pneumatique.\""
  },
  "skimbusaf": {
    "name": "Figurine de Skimbus",
    "desc": "L'étiquette indique: \"Son corps léger flotte au gré du vent.\""
  },
  "smoglinaf": {
    "name": "Figurine de Smoglin",
    "desc": "L'étiquette indique: \"Une réaction chimique dans son ventre rend son haleine chaude toxique.\""
  },
  "snaggleraf": {
    "name": "Figurine de Snaggler",
    "desc": "L'étiquette indique: \"Sa carapace est impossible à pénétrer, ce qui peut en faire un ennemi redoutable.\""
  },
  "snauntaf": {
    "name": "Figurine de Snaunt",
    "desc": "L'étiquette indique: \"Il est célèbre pour ses vols dans les potagers.\""
  },
  "snuffishaf": {
    "name": "Figurine de Snuffish",
    "desc": "L'étiquette indique: \"Ils attaquent quiconque les surprend, et ils sont très faciles à surprendre.\""
  },
  "spookitaf": {
    "name": "Figurine de Spookit",
    "desc": "L'étiquette indique: \"Lorsqu'il ferme les yeux, il devient insensible aux attaques en entrant dans un autre plan d'existence.\""
  },
  "sporgusaf": {
    "name": "Figurine de Sporgus",
    "desc": "L'étiquette indique: \"Il préfère les climats chauds et humides où il se développe plus rapidement.\""
  },
  "squeemaf": {
    "name": "Figurine de Squeem",
    "desc": "L'étiquette indique: \"Ses mouvements sont déterminés par les niveaux de température de l'atmosphère.\""
  },
  "swansongaf": {
    "name": "Figurine de Swansong",
    "desc": "L'étiquette indique: \"Une armure mecha expérimentale, construite et pilotée par Asra Nox.\""
  }
}