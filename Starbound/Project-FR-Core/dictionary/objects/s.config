  "swampbed": {
    "name": "Lit de Marais",
    "desc": "Un lit traditionnel fait de racines et de feuilles.",
    "metadata": {
      "apexDescription": "Ce lit est à des années-lumière des meubles MiniKnog produits en masse.",
      "avianDescription": "Dormir dans une literie naturelle est une idée charmante.",
      "floranDescription": "Floran dorrt dans les feuilless et les rraciness.",
      "glitchDescription": "Somnolent. Je pourrais faire une petite sieste ici.",
      "humanDescription": "Je suis tout à fait pour ne faire qu'un avec la nature, mais je ne suis pas sûr pour ce lit.",
      "hylotlDescription": "Si ce lit était fait d'algues, il serait peut-être plus invitant.",
      "novakidDescription": "Y'a un charme fou dans la literie faite main."
    }
  },
  "swampchair": {
    "name": "Chaise de Marais",
    "desc": "Un petit siège fait de feuilles et de racines.",
    "metadata": {
      "apexDescription": "Je présume que c'est pour s'asseoir. Ça n'a pas l'air très confortable.",
      "avianDescription": "Ce siège est simple. Pas besoin d'extravagance.",
      "floranDescription": "Chaise sssent comme le marraisss. Floran aime ça.",
      "glitchDescription": "Inconfortable. S'asseoir ici semblerait étrange.",
      "humanDescription": "J'imagine que c'est un siège.",
      "hylotlDescription": "Ceci n'est pas fait avec beaucoup de finesse.",
      "novakidDescription": "C'est une chaise, j'suppose."
    }
  },
  "swampchest": {
