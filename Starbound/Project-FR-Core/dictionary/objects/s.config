  "stationvendingmachine": {
    "name": "Distributeur de Station",
    "desc": "Un distributeur automatique, il contient des en-cas de qualité.",
    "metadata": {
      "apexDescription": "Ce distributeur semble utile, il pourrait fournir des rations alimentaires nécessaires.",
      "avianDescription": "Cette machine semble contenir des provisions et a l'air d'être en état de marche.",
      "floranDescription": "En-casss sspatiaux!",
      "glitchDescription": "Intéressé. Ce distributeur automatique semble fonctionner, il contient peut-être des vivres.",
      "humanDescription": "Quelle chance d'avoir ce distributeur ici, je commence à avoir un peu faim.",
      "hylotlDescription": "Un distributeur automatique, semblable à ceux que l'on trouve dans les cités Hylotls.",
      "novakidDescription": "C'te machine est comme un marchand robot! Je lui donne de l'argent et les provisions sortent.",
      "interactData.paneLayoutOverride.windowtitle.title": " Distributeur",
      "interactData.paneLayoutOverride.windowtitle.subtitle": " En-cas Savoureux"
    }
  },
  "stationwallpanel": {
    "name": "Panneau Mural de Station",
    "desc": "Un panneau conçu pour être fixé à une structure spatiale ou un vaisseau.",
    "metadata": {
      "apexDescription": "Je ne sais pas à quoi sert ce panneau, mais il a un look intéressant.",
      "avianDescription": "Ce panneau doit avoir une utilité, je ne sais juste pas laquelle.",
      "floranDescription": "Ce panneau rronde se colle au mur.",
      "glitchDescription": "Confus. Je ne suis pas sûr de la fonction de ce panneau.",
      "humanDescription": "C'est un panneau qui se fixe au mur, je ne peux pas en dire beaucoup plus.",
      "hylotlDescription": "Ce panneau mural au look industriel a certainement un but obscur.",
      "novakidDescription": "Une sorte de panneau mural sophistiqué. Je sais pas à quoi ça sert."
    }
  },
