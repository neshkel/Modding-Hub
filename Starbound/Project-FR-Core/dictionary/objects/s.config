      "humanDescription": "L'utiliser ajoute des armures et de l'équipement de mêlée au réplicateur!",
      "hylotlDescription": "Ce module utile ajoutera de l'équipement de mêlée et des armures supplémentaires au réplicateur.",
      "novakidDescription": "Ce bon vieux module ajoutera encore plus de trucs au réplicateur.",
      "addonConfig.isAddons.1.name": "separatorAddon"
    }
  },
