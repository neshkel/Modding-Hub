  "swamptable": {
    "name": "Table de Marais",
    "desc": "Une table bancale faite de feuilles et de racines.",
    "metadata": {
      "apexDescription": "Une table très rudimentaire faite de racines.",
      "avianDescription": "Cette table est faite de racines de marais.",
      "floranDescription": "Sssimple table de marrais.",
      "glitchDescription": "Observateur. Une table principalement fabriquée à partir de grosses racines.",
      "humanDescription": "Une table artisanale faite d'osier et de racines de marais.",
      "hylotlDescription": "Rudimentaire, mais ça fait le travail.",
      "novakidDescription": "Cette table a l'air dure à garder propre. Heureusement que j'suis pas du genre difficile."
    }
  },
  "swampybed": {
    "name": "Couchette de Marais",
    "desc": "Un lit inhabituel, avec des parois en racines et une litière de feuilles.",
    "metadata": {
      "apexDescription": "Ce lit pourrait être plus confortable qu'il n'en a l'air.",
      "avianDescription": "Un cadre de bateau en bois avec des feuilles en guise de couverture.",
      "floranDescription": "Floran dorrt dans les feuillesss.",
      "glitchDescription": "Somnolent. Niveau d'énergie bas. Mode sommeil requis.",
      "humanDescription": "On dirait un genre de bateau. Un bateau rempli de feuilles.",
      "hylotlDescription": "Je me sentirais mal à l'aise de dormir dans un lit aussi médiocre.",
      "novakidDescription": "C'est l'genre de lit pour ceux qui vivent la vie simple."
    }
  },
  "steamboiler1": {
    "name": "Petite Chaudière à Vapeur",
    "desc": "Une petite chaudière rouillée, servant à transformer l'eau glacée en vapeur.",
    "metadata": {
      "apexDescription": "Cette chaudière rudimentaire semble bien plus vieille que je ne le pensais.",
      "avianDescription": "Dans cette boîte en métal, l'eau est chauffée pour devenir de la vapeur.",
      "floranDescription": "Floran ssse demande si l'eau va fuirrr si Floran donne un coup de poignarrrd!",
      "glitchDescription": "Intrigué. Cette machine semble chauffer l'eau à l'aide de feux internes.",
      "humanDescription": "Une chaudière à l'aspect plutôt rouillé. Je me demande quel âge elle a?",
      "hylotlDescription": "Un engin affreux, fait pour produire de la vapeur à partir d'eau.",
      "novakidDescription": "Y'a un p'tit côté artisanal dans cette vieille chaudière."
    }
  },
  "steamboiler2": {
    "name": "Chaudière à Vapeur Moyenne",
    "desc": "Une longue chaudière cabossée, servant à transformer l'eau glacée en vapeur.",
    "metadata": {
      "apexDescription": "On dirait presque un énorme tube à essai.",
      "avianDescription": "Je suppose qu'elle produit de la vapeur pour une raison précise.",
      "floranDescription": "Floran sssurpris par la chaleurrr de ce truc.",
      "glitchDescription": "Impressionné. Elle parvient à rester debout malgré son apparence instable.",
      "humanDescription": "Cette chaudière semble très obsolète par rapport aux standards modernes, c'est le moins qu'on puisse dire...",
      "hylotlDescription": "Je ne pense pas qu'un Hylotl aurait fabriqué quelque chose d'aussi peu attrayant.",
      "novakidDescription": "Collez-en une dans un train et on va bien s'marrer."
    }
  },
  "steamboiler3": {
    "name": "Grande Chaudière à Vapeur",
    "desc": "Une énorme chaudière peinte, servant à transformer l'eau glacée en vapeur.",
    "metadata": {
      "apexDescription": "Ce truc énorme a l'air de pouvoir s'effondrer à tout moment.",
      "avianDescription": "Cette chaudière imposante semble plutôt décrépite.",
      "floranDescription": "Floran veut poussser le grrand trruc pour le fairre tomber!",
      "glitchDescription": "Impressionné. Malgré les nombreuses années qui l'ont usée, cette structure tient toujours debout.",
      "humanDescription": "Cette vieille chaudière a connu des jours meilleurs, cela ne fait aucun doute.",
      "hylotlDescription": "Je ne pense pas qu'un Hylotl aurait fabriqué quelque chose d'aussi peu attrayant.",
      "novakidDescription": "Ce truc est une sacrée prouesse d'ingénierie."
    }
  },
  "steamclock": {
    "name": "Cadran d'Horloge à Vapeur",
    "desc": "Un beau et grand cadran d'horloge alimenté par la vapeur.",
    "metadata": {
      "apexDescription": "Une horloge impressionnante.",
      "avianDescription": "Une grande horloge. On ne peut pas la rater.",
      "floranDescription": "Maintenant Floran sssait quelle heure il essst.",
      "glitchDescription": "Douteux. Cette horloge affiche-t-elle l'heure correcte?",
      "humanDescription": "Qu'est-ce qui a des aiguilles mais ne coud pas?",
      "hylotlDescription": "Une horloge plus grande ne vous donnera pas plus de temps.",
      "novakidDescription": "Une grande horloge. Impossible de la louper."
    }
  },
  "steamspringbed": {
    "name": "Lit Steamspring",
    "desc": "Un lit confortable soutenu par une structure de tuyaux.",
    "metadata": {
      "apexDescription": "Ce lit utilise des tuyaux en laiton réutilisés comme cadre - Un choix ingénieux.",
      "avianDescription": "Les tuyaux en laiton de ce lit élégant brillent au soleil.",
      "floranDescription": "Floran conffusss. Pourquoi ce lit est fait de tuyauxx?",
      "glitchDescription": "Confus. Est-ce que les tuyaux de ce lit le rendent plus confortable?",
      "humanDescription": "J'ai l'impression que de vieux tuyaux en laiton ne sont pas la meilleure base pour un lit solide.",
      "hylotlDescription": "Je suppose que ce lit est fait pour avoir l'air démodé. Je ne suis pas très impressionné.",
      "novakidDescription": "Je pourrais m'allonger sous les étoiles sur un lit comme celui-là."
    }
  },
  "steamspringchair": {
    "name": "Chaise Steamspring",
    "desc": "Une chaise séduisante, faite de bois fin et de tuyaux en laiton.",
    "metadata": {
      "apexDescription": "Cette chaise semble être faite avec de la vraie tuyauterie fonctionnelle. Étrange.",
      "avianDescription": "Cette chaise sent le bois fraîchement coupé. Comme c'est agréable.",
      "floranDescription": "Pourquoi la chaisse fait un sssifflement?",
      "glitchDescription": "Intrigué. Pourquoi fabriquerait-on une chaise avec des tuyaux?",
      "humanDescription": "Si l'on ignore ces étranges tuyaux, elle ressemble à une chaise plutôt sympa.",
      "hylotlDescription": "Les tuyaux sur cette chaise sont-ils là pour une raison particulière?",
      "novakidDescription": "Certains pourraient trouver la tuyauterie de cette chaise dérangeante, mais moi j'aime bien."
    }
  },
  "steamspringdoor": {
    "name": "Porte Steamspring",
    "desc": "Une porte en bois robuste, avec un cadre en tuyaux de laiton.",
    "metadata": {
      "apexDescription": "Je me demande si les tuyaux en laiton de cette porte l'aident à rester solide?",
      "avianDescription": "Les tuyaux en laiton de cette porte l'aident vraiment à se démarquer.",
      "floranDescription": "Floran ssse demande si la porrte a des ussagess tactiquess?",
      "glitchDescription": "Approbateur. Une porte à l'aspect robuste.",
      "humanDescription": "Cette porte a-t-elle vraiment besoin de tuyaux en laiton?",
      "hylotlDescription": "Une porte acceptable, avec une sorte de cadre en tuyaux de laiton.",
      "novakidDescription": "C'est le genre de porte que je m'attendrais à voir chez un shérif."
    }
  },
  "steamspringlamp": {
    "name": "Lampe Steamspring",
    "desc": "Une étrange lampe faite de bois et de laiton.",
    "metadata": {
      "apexDescription": "Cette lampe a une forme très unique.",
      "avianDescription": "Quelle lampe à la forme intéressante!",
      "floranDescription": "La lampe est bizarre - Essst-ce sssécrètement une arrrme?",
      "glitchDescription": "Curieux. Une source lumineuse assemblée de façon étrange.",
      "humanDescription": "Qui a fabriqué cette lampe? Elle est un peu bizarre.",
      "hylotlDescription": "La forme de cette lampe lui donne un charme étrange.",
      "novakidDescription": "C'est une drôle de lampe, si j'en ai jamais vu une."
    }
  },
  "steamspringtable": {
    "name": "Table Steamspring",
    "desc": "Une table soignée décorée de tuyaux en laiton.",
    "metadata": {
      "apexDescription": "Les tuyaux sur cette table doivent la rendre très solide.",
      "avianDescription": "Les tuyaux en laiton et le plateau en bois vont bien ensemble.",
      "floranDescription": "Floran ssse demande si ffrrapper les tuyaux ferait un brruit forrt.",
      "glitchDescription": "Observateur. Cette table en bois est principalement soutenue par de vieux tuyaux.",
      "humanDescription": "Une table faite de bois et de tuyaux. Plutôt cool.",
      "hylotlDescription": "Je me demande si les tuyaux de cette table aident vraiment à la soutenir?",
      "novakidDescription": "Je pourrais faire une partie de cartes sur une table comme celle-là."
    }
  },
  "splendidplant": {
    "name": "Fleur Splendide",
    "desc": "Une plante en pot rose plutôt adorable.",
