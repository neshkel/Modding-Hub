{
  "scanner": {
    "name": "Scanner de Proximité",
    "desc": "Parfait pour tous vos besoins de portes automatisées!",
    "metadata": {
      "apexDescription": "C'est un appareil de proximité. Il détectera quand je m'en approcherai.",
      "avianDescription": "Un dispositif de proximité. Il pourrait déclencher quelque chose si je suis près.",
      "floranDescription": "Œil qui sssoigne sur le mur. Il regarde Floran!",
      "glitchDescription": "Suspicieux. Ce scanner de proximité est peut-être conscient de ma présence.",
      "humanDescription": "Un capteur de proximité. Il peut dire quand je suis proche.",
      "hylotlDescription": "Ce dispositif de balayage peut dire quand je suis présent.",
      "novakidDescription": "Un scanner de proximité. Est-ce qu'il me surveille en ce moment?"
    }
  },
  "secretdoor": {
    "name": "Porte Secrète",
    "desc": "Une entrée habilement dissimulée.",
    "metadata": {
      "apexDescription": "Il y a quelque chose d'étrange avec ce mur...",
      "avianDescription": "Il y a quelque chose d'étrange avec ce mur...",
      "floranDescription": "Le mur essst bizarre...",
      "glitchDescription": "Suspicieux. Ce mur ne semble pas naturel...",
      "humanDescription": "Il y a quelque chose d'étrange avec ce mur...",
      "hylotlDescription": "Il y a quelque chose d'étrange avec ce mur...",
      "novakidDescription": "Y'a un truc qui cloche avec ce mur..."
    }
  },
  "secrettrapdoor": {
    "name": "Trappe Secrète",
    "desc": "Une entrée habilement dissimulée.",
    "metadata": {
      "apexDescription": "Il y a quelque chose d'étrange avec ce sol...",
      "avianDescription": "Il y a quelque chose d'étrange avec ce sol...",
      "floranDescription": "Le sssol est bizarre...",
      "glitchDescription": "Suspicieux. Ce sol ne semble pas naturel...",
      "humanDescription": "Il y a quelque chose d'étrange avec ce sol...",
      "hylotlDescription": "Il y a quelque chose d'étrange avec ce sol...",
      "novakidDescription": "Y'a un truc qui va pas avec ce sol..."
    }
  },
  "shieldgenerator": {
    "name": "Générateur de Bouclier",
    "desc": "On dirait vraiment pas que ce truc peut générer un bouclier.",
    "metadata": {
      "apexDescription": "Un interrupteur. Il active le générateur de bouclier.",
      "avianDescription": "Cet interrupteur génère le bouclier.",
      "floranDescription": "Interrrupteur!",
      "glitchDescription": "Surpris. Ce petit interrupteur n'a pas l'air si puissant.",
      "humanDescription": "Si j'actionne ce commutateur, ça allumera ou éteindra le générateur de bouclier.",
      "hylotlDescription": "Un interrupteur basique. Il peut être utilisé pour activer le générateur de bouclier.",
      "novakidDescription": "Je peux basculer c't'interrupteur pour activer le générateur de bouclier."
    }
  },
  "smallfloorbutton": {
    "name": "Petit Bouton de Sol",
    "desc": "Appuyer dessus pourrait être amusant, au moins un instant.",
    "metadata": {
      "apexDescription": "Un bouton. Sa fonction est inconnue. Il n'y a qu'un moyen de le savoir.",
      "avianDescription": "Pourquoi suis-je toujours obligé d'appuyer sur les boutons?",
      "floranDescription": "Floran appuie sssur les boutons!",
      "glitchDescription": "Tenté. Un bouton qui ne demande qu'à être pressé.",
      "humanDescription": "Il y a un bouton! Je ne peux pas m'empêcher d'appuyer!",
      "hylotlDescription": "Les boutons sont exaspérants. Pourtant, je dois appuyer dessus.",
      "novakidDescription": "Pourquoi c'est toujours aussi tentant d'appuyer sur les boutons?"
    }
  },
  "smallwallbutton": {
    "name": "Petit Bouton Mural",
    "desc": "Qui sait ce qu'il pourrait activer... appuyez, c'est tout!",
    "metadata": {
      "apexDescription": "Un bouton. Sa fonction est inconnue. Il n'y a qu'un moyen de le savoir.",
      "avianDescription": "Pourquoi suis-je toujours obligé d'appuyer sur les boutons?",
      "floranDescription": "Floran appuie sssur les boutons!",
      "glitchDescription": "Tenté. Un bouton qui ne demande qu'à être pressé.",
      "humanDescription": "Il y a un bouton! Je ne peux pas m'empêcher d'appuyer!",
      "hylotlDescription": "Les boutons sont exaspérants. Pourtant, je dois appuyer dessus.",
      "novakidDescription": "Pourquoi c'est toujours aussi tentant d'appuyer sur les boutons?"
    }
  },
  "smallwallswitch": {
    "name": "Petit Interrupteur Mural",
    "desc": "C'est renversant.",
    "metadata": {
      "apexDescription": "Un interrupteur. Il active quelque chose.",
      "avianDescription": "Cet interrupteur doit activer quelque chose.",
      "floranDescription": "Interrrupteur!",
      "glitchDescription": "Surpris. Ce petit interrupteur n'a pas l'air si puissant.",
      "humanDescription": "Je me demande combien de fois je peux allumer et éteindre ce truc.",
      "hylotlDescription": "Un interrupteur basique. Il peut être utilisé pour activer quelque chose.",
      "novakidDescription": "Je peux basculer c't'interrupteur!"
    }
  },
  "smallwallswitchlit": {
    "name": "Petit Interrupteur Mural (Lumineux)",
    "desc": "C'est renversant.",
    "metadata": {
      "apexDescription": "Un interrupteur. Il active quelque chose.",
      "avianDescription": "Cet interrupteur doit activer quelque chose.",
      "floranDescription": "Interrrupteur!",
      "glitchDescription": "Surpris. Ce petit interrupteur n'a pas l'air si puissant.",
      "humanDescription": "Je me demande combien de fois je peux allumer et éteindre ce truc.",
      "hylotlDescription": "Un interrupteur basique. Il peut être utilisé pour activer quelque chose.",
      "novakidDescription": "Je peux basculer c't'interrupteur!"
    }
  },
  "standingturret": {
    "name": "Tourelle de Défense",
    "desc": "Une tourelle pour votre protection! Ne peut être placée qu'une seule fois.",
    "metadata": {
      "subtitle": "Défense de Base Automatique",
      "apexDescription": "Toujours vigilante.",
      "avianDescription": "Les monstres n'ont aucune chance, à moins qu'ils ne sachent voler.",
      "floranDescription": "Efficace contre les choosses vivantes.",
      "glitchDescription": "Prudent. Je ne dois pas perturber mon frère dans sa vigilance.",
      "humanDescription": "Un système de sécurité automatisé.",
      "hylotlDescription": "On dirait une sorte de tourelle.",
      "novakidDescription": "On dirait bien que ce truc pourrait faire de sacrés dégâts!"
    }
  },
  "steampunkarmchair": {
    "name": "Fauteuil Steampunk",
    "desc": "Un fauteuil à l'allure très chic.",
    "metadata": {
      "apexDescription": "C'est le genre de fauteuil que j'imagine chez Big Ape.",
      "avianDescription": "Ce fauteuil a l'air plutôt réconfortant.",
      "floranDescription": "Floran pense que la chaisse ssent bizarre.",
      "glitchDescription": "Impressionné. Ce fauteuil a été conçu pour le confort.",
      "humanDescription": "Je veux m'allonger dans ce fauteuil pour l'éternité.",
      "hylotlDescription": "J'aurais peur que si je restais assis trop longtemps, je ne voudrais plus jamais le quitter.",
      "novakidDescription": "C'est l'genre de fauteuil où j'pourrais rester des heures."
    }
  },
  "steampunkbed": {
    "name": "Lit Steampunk",
    "desc": "Un lit soutenu par une structure de tuyaux.",
    "metadata": {
      "apexDescription": "Ce lit a un cadre fait de vieux tuyaux en laiton. Intéressant.",
      "avianDescription": "Un lit plutôt charmant et fantaisiste.",
      "floranDescription": "Floran veut démonter les tuyauxxx, pour en faire des armesss.",
      "glitchDescription": "Intrigué. Est-ce que ces tuyaux ont une fonction?",
      "humanDescription": "Un lit fait de tuyaux! Quel délicieux côté rétro.",
      "hylotlDescription": "Ce lit est conçu pour avoir l'air plus fonctionnel qu'il ne l'est réellement.",
      "novakidDescription": "C'est un lit auquel je pourrais m'habituer."
    }
  },
  "steampunkdesk": {
    "name": "Bureau Steampunk",
    "desc": "Un bureau en métal, couvert d'appareils curieux.",
    "metadata": {
      "apexDescription": "Cela ressemble à un bureau pour un savant fou en herbe.",
      "avianDescription": "Je n'ai aucune idée de l'utilité des objets sur ce bureau.",
      "floranDescription": "Floran sssent une odeur de brûlé à l'intérieur de cette boîte...",
      "glitchDescription": "Inquiet. Il semble y avoir une tête en métal sur ce bureau.",
      "humanDescription": "Il y a une tête de robot qui me fixe depuis ce bureau. C'est un peu flippant.",
      "hylotlDescription": "Aucun des outils sur ce bureau ne ressemble aux outils d'artisan auxquels je suis habitué...",
      "novakidDescription": "Y'a un truc carrément bizarre avec ce meuble."
    }
  },
  "steampunkglobe": {
    "name": "Globe Steampunk",
    "desc": "Un vieux globe en bois sculpté.",
    "metadata": {
      "apexDescription": "Un globe sculpté à la main. Je me demande s'il est fidèle à la planète qu'il représente?",
      "avianDescription": "Il y a un vrai dévouement dans ce globe sculpté à la main.",
      "floranDescription": "Floran veut faire rouler la planète en boisss en bas d'une colline pour écrassser ses ennemiss.",
      "glitchDescription": "Intrigué. Je me demande si la cartographie de ce globe est exacte?",
      "humanDescription": "Je me demande quelle planète ce globe en bois poli représente?",
      "hylotlDescription": "Il y a un véritable savoir-faire dans la sculpture de ce globe.",
      "novakidDescription": "Quelqu'un a vraiment pris son temps pour sculpter cette pièce."
    }
  },
  "steampunklamp": {
    "name": "Lampe Steampunk",
    "desc": "Une applique murale électrique, remplie d'un gaz fluide et incandescent.",
    "metadata": {
      "apexDescription": "Je soupçonne que cette lampe fonctionne en ionisant des gaz xénon avec une charge électrique.",
      "avianDescription": "Quelle curieuse lampe. Je me demande comment elle est fabriquée?",
      "floranDescription": "Floran ne peut pass s'empêcher de regarder la lampe.",
      "glitchDescription": "Mesmérisé. Les substances mouvantes à l'intérieur de cette lampe sont fascinantes.",
      "humanDescription": "Les gaz épais à l'intérieur bougent tout en brillant. C'est presque hypnotique.",
      "hylotlDescription": "L'ondulation à l'intérieur de cette lampe est, il faut l'avouer, plutôt apaisante.",
      "novakidDescription": "J'imagine que j'ai des points communs avec les gaz brillants de c'te vieille lampe."
    }
  },
  "steampunkshelf": {
    "name": "Étagère Steampunk",
    "desc": "Un ensemble d'étagères suspendues par des tuyaux.",
    "metadata": {
      "apexDescription": "Les tuyaux sont une solution robuste pour créer un rangement mural sécurisé.",
      "avianDescription": "Il y a un vrai flair créatif dans cette étagère au look recyclé.",
      "floranDescription": "Floran n'aime passs les livresss, mais l'étagère est correcte, j'imagine.",
      "glitchDescription": "Impressionné. Les tuyaux ont été agencés pour soutenir les étagères.",
      "humanDescription": "C'est une utilisation assez créative de vieille tuyauterie.",
      "hylotlDescription": "C'est une méthode de stockage de boîtes assez inélégante, mais j'admire l'effort.",
      "novakidDescription": "Je me demande si c'te vieille horloge est cassée?"
    }
  },
  "spookybed": {
    "name": "Lit Effrayant",
    "desc": "Il y a quelque chose de dérangeant dans ce vieux lit luxueux.",
    "metadata": {
      "apexDescription": "Je n'arrive pas à me défaire d'un mauvais pressentiment concernant ce lit...",
      "avianDescription": "Il y a quelque chose qui ne va pas avec ce lit, je peux le sentir...",
      "floranDescription": "Floran est nerveux à l'idée de dormir ici...",
      "glitchDescription": "Nerveux. Il y a quelque chose de malveillant dans ce meuble.",
      "humanDescription": "Pourquoi dormir quand on peut rester pétrifié de terreur?",
      "hylotlDescription": "Il faudrait que je sois désespéré pour dormir dans un truc pareil.",
      "novakidDescription": "Est-ce qu'y a un truc caché là-dessous?"
    }
  },
  "spookycandles": {
    "name": "Bougies Effrayantes",
    "desc": "La structure métallique de ce bougeoir s'enroule comme des doigts.",
    "metadata": {
      "apexDescription": "Des bougies. Technologie rudimentaire, et un classique dans chaque culture de l'histoire.",
      "avianDescription": "Hmm, je pense que ce serait plus joli en or plutôt qu'en noir.",
      "floranDescription": "Floran ne veut pass rester sssi près...",
      "glitchDescription": "Approbateur. Un bougeoir de style traditionnel.",
      "humanDescription": "Un bougeoir noir. Comme c'est pittoresque.",
      "hylotlDescription": "Cela ne fonctionnerait probablement pas au fond de la mer...",
      "novakidDescription": "Des bougies: une bonne source de lumière quand on n'a pas de lampe à gaz."
    }
  },
  "spookycauldron": {
    "name": "Chaudron Effrayant",
    "desc": "Un chaudron bouillonnant, assez grand pour y loger une personne entière.",
    "metadata": {
      "apexDescription": "Ça semble être une mauvaise idée, mais ça ne me dérangerait pas de m'asseoir là-dedans.",
      "avianDescription": "Je me demande si je vais finir cuit si je reste assis là trop longtemps?",
      "floranDescription": "Floran ne veut passs être bouilli en ssoupe.",
      "glitchDescription": "Interrogatif. Combien de temps devrai-je rester là-dedans pour rouiller?",
      "humanDescription": "S'asseoir là-dedans a l'air de chatouiller!",
      "hylotlDescription": "Ça sent bizarre, mais s'asseoir là-dedans est en fait relaxant.",
      "novakidDescription": "C'est un peu petit pour faire office de baignoire."
    }
  },
  "spookyclock": {
    "name": "Horloge Effrayante",
    "desc": "Une vieille horloge comtoise, surmontée d'une sculpture de chauve-souris inquiétante.",
    "metadata": {
      "apexDescription": "Je préfère les horloges numériques ; le tic-tac n'attire pas l'attention sur vous.",
      "avianDescription": "Cette horloge semble être bloquée à une certaine heure...",
      "floranDescription": "Floran aime la fassusse chauve-sssouris. Pas sûr de savoir à quoi sert le resste.",
      "glitchDescription": "Impressionné. L'appareil utilise des rouages pour suivre l'heure actuelle.",
      "humanDescription": "Vous savez, s'acheter une montre coûterait moins cher que ça.",
      "hylotlDescription": "Le but est-il d'inspirer la peur? C'est raté.",
      "novakidDescription": "C'te vieille horloge me donne les jetons."
    }
  },
  "spookypumpkinhead": {
    "name": "Tête de Citrouille Effrayante",
    "desc": "La vieille tradition de la sculpture de citrouille perdure.",
    "metadata": {
      "apexDescription": "C'est plus mignon qu'intimidant.",
      "avianDescription": "Je me demande si ce serait facile de faire une citrouille avec un visage d'Avian?",
      "floranDescription": "Floran approuve ce visssage de plante qui fait peur.",
      "glitchDescription": "Alarmé. J'ai cru que c'était vivant, un instant.",
      "humanDescription": "Oh, une minuscule tête de citrouille! Comme c'est adorable.",
      "hylotlDescription": "Personnellement, je pense que ce serait mieux avec un troisième œil.",
      "novakidDescription": "Si c'était censé m'effrayer, c'est pas très réussi."
    }
  },
  "spookytombchair": {
    "name": "Chaise Tombe Effrayante",
    "desc": "Reposez en paix avec cette chaise ornementale rembourrée.",
    "metadata": {
      "apexDescription": "Cette chaise aurait pu être faite pour être plus confortable. Enfin, regardez-la!",
      "avianDescription": "Je suppose que... le but est de nous rappeler à tous l'au-delà?",
      "floranDescription": "Floran veut sss'cacher derrière la chaisse en pierre.",
      "glitchDescription": "Alarmé. Pourquoi fabriquer des meubles pareils?",
      "humanDescription": "Je n'arrive pas à savoir si cette chaise est de bon goût ou non.",
      "hylotlDescription": "Est-ce une sorte de chaise-tombe? Quelle barbarie.",
      "novakidDescription": "Perso, j'dirais que cette chaise est de bien mauvais goût."
    }
  },
  "serenebed": {
    "name": "Lit Serein",
    "desc": " un lit serein exceptionnellement confortable.",
    "metadata": {
      "apexDescription": "Un très beau lit douillet.",
      "avianDescription": "C'est un endroit très confortable pour reposer mes plumes.",
      "floranDescription": "Floran sss'repose dans un super lit.",
      "glitchDescription": "Ravi. Ce lit est juste à la bonne hauteur.",
      "humanDescription": "Un excellent lit. Je devrais pouvoir m'y reposer facilement.",
      "hylotlDescription": "Qualité de fabrication très décente. J'aime ce lit.",
      "novakidDescription": "J'pourrais dormir sur mes deux oreilles là-dedans."
    }
  },
  "serenechair": {
    "name": "Chaise Sereine",
    "desc": "Une chaise sereine très confortable.",
    "metadata": {
      "apexDescription": "Une chaise très confortable. J'en suis satisfait.",
      "avianDescription": "Un endroit fort décent pour s'asseoir.",
      "floranDescription": "Floran sss'assoit sur la chaisse et pense à la chassse.",
      "glitchDescription": "Relaxé. Cette chaise est exceptionnellement confortable pour un Glitch.",
      "humanDescription": "Une chaise très douillette. Ça me rappelle la maison.",
      "hylotlDescription": "On frôle le luxe auquel les Hylotls sont habitués. C'est très satisfaisant.",
      "novakidDescription": "Je peux me reposer tranquillement là-dedans."
    }
  },
  "serenedoor": {
    "name": "Porte Sereine",
    "desc": "Une porte sereine très robuste.",
    "metadata": {
      "apexDescription": "Sa forme rend cette porte très sûre.",
      "avianDescription": "Une porte très robuste.",
      "floranDescription": "Floran se cache derrière la porte. Bondit. Sssplatch!",
      "glitchDescription": "Approbateur. La forme de cette porte la rend très solide.",
      "humanDescription": "Une porte sereine robuste.",
      "hylotlDescription": "Une porte sereine vigoureuse.",
      "novakidDescription": "C'te porte a l'air plutôt sécurisée."
    }
  },
  "serenelight": {
    "name": "Lumière Sereine",
    "desc": "Une lueur sereine et apaisante.",
    "metadata": {
      "apexDescription": "Design étrange, mais c'est néanmoins une source de lumière utile.",
      "avianDescription": "Elle éclaire beaucoup pour une si petite lampe.",
      "floranDescription": "La lampe rresste froide au toucher, même allumée longtemps.",
      "glitchDescription": "Calme. Cette lampe émet une lueur apaisante.",
      "humanDescription": "Une lampe originale.",
      "hylotlDescription": "Toutes les sources de lumière peuvent être considérées comme belles à leur façon.",
      "novakidDescription": "Une lampe au look singulier."
    }
  },
  "sereneswitch": {
    "name": "Console Sereine",
    "desc": "Une console sereine. L'utiliser est apaisant.",
    "metadata": {
      "apexDescription": "Cette console offre un grand degré de contrôle.",
      "avianDescription": "Une console utile.",
      "floranDescription": "Floran appuie sur les boutonsss. Fait bouger les choosses!",
      "glitchDescription": "Impressionné. Une seule console peut contrôler autant de mécanismes à la fois.",
      "humanDescription": "Une console de commande. C'est plus fort que moi, faut que je joue avec.",
      "hylotlDescription": "Une console de contrôle.",
      "novakidDescription": "J'ai envie d'appuyer sur tous les boutons!"
    }
  },
  "serenetable": {
    "name": "Table Sereine",
    "desc": "Une table sereine résistante.",
    "metadata": {
      "apexDescription": "Cette table sereine est très élégante.",
      "avianDescription": "Une table sereine immensément robuste.",
      "floranDescription": "Table asssez bonne pour que Floran découpe la viannde.",
      "glitchDescription": "Approbateur. Une table sereine très bien faite.",
      "humanDescription": "Une table sereine sympa.",
      "hylotlDescription": "Ce n'est pas mon genre de table habituel, mais c'est assez impressionnant.",
      "novakidDescription": "Une jolie vieille table verte."
    }
  },
  "seabed": {
    "name": "Lit Coquillage",
    "desc": "Un lit en forme de coquillage.",
    "metadata": {
      "apexDescription": "Garanti pour induire un sommeil subaquatique.",
      "avianDescription": "Ce lit est fait d'une coquille de palourde géante, il a l'air douillet.",
      "floranDescription": "Facile de dormir dans un lit fait d'alguesss.",
      "glitchDescription": "Fier. Un lit digne d'un roi Hylotl.",
      "humanDescription": "Ce lit est chic, il a même un matelas à eau.",
      "hylotlDescription": "Il n'y a rien de plus confortable que de dormir entre des draps d'algues.",
      "novakidDescription": "Ce lit est vraiment classe. Et il ssent la bonne crevette."
    }
  },
  "seachair": {
    "name": "Fauteuil Coquillage",
    "desc": "Un fauteuil en forme de coquillage.",
    "metadata": {
      "apexDescription": "Une magnifique chaise façonnée à partir d'un grand coquillage.",
      "avianDescription": "Je me demande quel genre de créature marine vivait dans cette coquille.",
      "floranDescription": "Les coquillaggess font de bons sièges.",
      "glitchDescription": "Amusé. Cette chaise est faite d'une coquille de palourde géante.",
      "humanDescription": "Quelqu'un a fait une chaise élégante avec ce coquillage énorme.",
      "hylotlDescription": "Un magnifique coquillage a été massacré pour créer cette abomination.",
      "novakidDescription": "Une chaise solide faite d'une palourde géante."
    }
  },
  "sealamp": {
    "name": "Lampe Marine",
    "desc": "Un joli coquillage qui diffuse de la lumière.",
    "metadata": {
      "apexDescription": "Cette lampe vient de la mer.",
      "avianDescription": "Cette lampe est en fait un énorme coquillage.",
      "floranDescription": "Douce lampe.",
      "glitchDescription": "Surpris. Un coquillage qui utilise de l'énergie pour briller.",
      "humanDescription": "Je me demande si cette lampe fonctionne sous l'eau.",
      "hylotlDescription": "Une lampe charmante.",
      "novakidDescription": "C'est une bien jolie lampe que v'là. Si on aime ce genre de truc."
    }
  },
  "seaweedpot": {
    "name": "Pot d'Algues",
    "desc": "Une algue dans un pot de fleurs.",
    "metadata": {
      "apexDescription": "Des algues. Je n'en vois pas l'intérêt.",
      "avianDescription": "Une plante mouillée.",
      "floranDescription": "Bonne plante. Alguesss.",
      "glitchDescription": "Curieux. Des algues en pot. Drôle de goût.",
      "humanDescription": "Les algues ne peuvent pas vivre hors de la mer.",
      "hylotlDescription": "Les algues ont besoin de la mer. Sinon, ce ne sont que des mauvaises herbes.",
      "novakidDescription": "Quelle drôle de plante à avoir chez soi."
    }
  },
  "satellite": {
    "name": "Maquette de Satellite",
    "desc": "Un modèle détaillé d'un ancien satellite terrestre.",
    "metadata": {
      "apexDescription": "Un satellite orbital autrefois utilisé par les humains. Assez ingénieux.",
      "avianDescription": "Je me demande à quoi les humains s'en servaient.",
      "floranDescription": "Jouet sspatial humain tout brillant.",
      "glitchDescription": "Impressionné. La technologie humaine a toujours été une source d'inspiration pour moi.",
      "humanDescription": "Un vieux satellite, il ne fonctionne plus mais il a toujours la classe.",
      "hylotlDescription": "La preuve que les humains ont toujours été fascinés par la communication.",
      "novakidDescription": "De la camelote spatiale glorifiée."
    }
  },
  "saturnmodel": {
    "name": "Maquette de Saturne",
    "desc": "Un modèle détaillé de la planète aux anneaux la plus célèbre du système Sol, Saturne.",
    "metadata": {
      "apexDescription": "Saturne est une géante gazeuse et la sixième planète du système Sol.",
      "avianDescription": "Saturne a été nommée d'après un ancien dieu de l'agriculture de la Terre. La culture Avian possède un dieu étrangement similaire.",
      "floranDescription": "Saturne est une géante gazzzeuse du système Sol. Les anneaux sont les plus grands du système.",
      "glitchDescription": "Fasciné. Les anneaux planétaires massifs sont composés de poussière spatiale et de rochers pouvant atteindre dix mètres de large.",
      "humanDescription": "Saturne est la plus grande géante gazeuse du système Sol. Ses anneaux la distinguent des autres planètes locales.",
      "hylotlDescription": "L'hexagone de Saturne est un autre exemple de la beauté inattendue et logique de la nature.",
      "novakidDescription": "Saturne a abrité les premiers hors-la-loi spatiaux d'origine terrestre. Ils s'cachaient dans les anneaux pour piller les navires marchands."
    }
  },
  "spaceshuttlebed": {
    "name": "Lit Navette Spatiale",
    "desc": "Le design de ce lit est basé sur une ancienne navette spatiale terrestre.",
    "metadata": {
      "apexDescription": "Je ne me sentirais pas en sécurité en voyageant dans un engin pareil.",
      "avianDescription": "Un petit morceau d'histoire humaine.",
      "floranDescription": "Les humainsss volaient là-dedans autrefois.",
      "glitchDescription": "Fier. Que de chemin parcouru par l'Humanité.",
      "humanDescription": "C'est agréable de regarder en arrière et de se souvenir de nos racines. Et puis, les lits navettes, c'est le summum du cool.",
      "hylotlDescription": "Les Hylotls ont aussi leurs propres reliques des débuts du voyage spatial. On n'en fait juste pas des lits.",
      "novakidDescription": "Eh bien, regardez-moi ça. Un vieux chef-d'œuvre."
    }
  },
  "sunmodel": {
    "name": "Maquette de Sol",
    "desc": "Un modèle détaillé de Sol, la naine jaune responsable de toute vie sur Terre. Elle diffuse même de la lumière.",
    "metadata": {
      "apexDescription": "Le Soleil. Le centre du système Sol. C'est une naine jaune qui représente environ 7,6 % de toutes les étoiles de la séquence principale.",
      "avianDescription": "L'étoile du système Sol. Elle n'est pas si différente de l'une des étoiles jumelles de mon propre système d'origine.",
      "floranDescription": "Le Ssoleil. Malgré la destruction de la Terre, il brille encore de mille feux.",
      "glitchDescription": "Tristesse. Je me demande quand je pourrai revoir le Soleil de mes propres yeux.",
      "humanDescription": "Mon étoile natale, le Soleil. Je me souviendrai toujours de la vue depuis la Terre au coucher du soleil...",
      "hylotlDescription": "L'étoile du système Sol ; une étoile de type G de la séquence principale qui sert de standard interstellaire pour définir la masse solaire.",
      "novakidDescription": "Je passais des heures à fixer le Soleil quand j'étais à l'Académie. Ça va me manquer."
    }
  },
  "scienceteleporter": {
    "name": "Téléporteur Scientifique",
    "desc": "Un téléporteur personnel, se connecte aux destinations enregistrées. \n^red;Détruit s'il est cassé.",
    "metadata": {
      "apexDescription": "Un téléporteur personnel. Un équipement fonctionnel mais amusant.",
      "avianDescription": "J'adore le bruissement de mes plumes quand je me téléporte!",
      "floranDescription": "Le téléporteur perrsonnel est chic!",
      "glitchDescription": "Attiré. Un téléporteur personnel avec un design personnalisé.",
      "humanDescription": "Un téléporteur personnel! Ça, c'est voyager avec style.",
      "hylotlDescription": "Un téléporteur personnel arborant un design personnalisé.",
      "novakidDescription": "Pour un téléporteur, il a sacrément d'la gueule!"
    }
  },
  "stoneteleporter": {
    "name": "Téléporteur en Pierre",
    "desc": "Un téléporteur personnel, se connecte aux destinations enregistrées. \n^red;Détruit s'il est cassé.",
    "metadata": {
      "apexDescription": "Un téléporteur personnel. Un équipement fonctionnel mais amusant.",
      "avianDescription": "J'adore le bruissement de mes plumes quand je me téléporte!",
      "floranDescription": "Le téléporteur perrsonnel est chic!",
      "glitchDescription": "Attiré. Un téléporteur personnel avec un design personnalisé.",
      "humanDescription": "Un téléporteur personnel! Ça, c'est voyager avec style.",
      "hylotlDescription": "Un téléporteur personnel arborant un design personnalisé.",
      "novakidDescription": "Pour un téléporteur, il a sacrément d'la gueule!"
    }
  },
  "spawnerapex": {
    "name": "Générateur d'Apex",
    "desc": "Générez votre propre villageois Apex!",
    "metadata": {
      "apexDescription": "Ceci me permettra d'invoquer l'un des miens.",
      "avianDescription": "Un distributeur d'Apex. Insolite.",
      "floranDescription": "Homme-singe magique qui ssort de nulle part!",
      "glitchDescription": "Philosophique. Ces êtres générés ont-ils une âme?",
      "humanDescription": "Cool, une machine à singes.",
      "hylotlDescription": "Pourquoi voudrais-je générer un Apex?"
    }
  },
  "spawneravian": {
    "name": "Générateur d'Avian",
    "desc": "Générez votre propre villageois Avian!",
    "metadata": {
      "apexDescription": "Je pourrais générer quelques amis Avians.",
      "avianDescription": "Peut-être puis-je utiliser ceci pour invoquer des semblables Terrestres.",
      "floranDescription": "Floran fait venir des homm-oiseaux pour Floran!",
      "glitchDescription": "Réflexion. Qu'est-ce que Kluex en penserait?",
      "humanDescription": "Cool, je pourrais invoquer une armée d'oiseaux.",
      "hylotlDescription": "Je suppose qu'invoquer un Avian serait acceptable."
    }
  },
  "spawnerchef": {
    "name": "Générateur de Chef",
    "desc": "Générez votre propre chef cuisinier!",
    "metadata": {
      "apexDescription": "Ce chef sera-t-il mon esclave?",
      "avianDescription": "Invoquer un chef serait parfait.",
      "floranDescription": "Floran fait venir qu'un pour cuirre la viannnde!",
      "glitchDescription": "Interrogatif. Un chef est-il jamais vraiment libre?",
      "humanDescription": "Ça va être bien mieux que de manger chez McFloran!",
      "hylotlDescription": "J'espère que ce chef respectera mon palais délicat."
    }
  },
  "spawnerfloran": {
    "name": "Générateur de Floran",
    "desc": "Générez votre propre villageois Floran!",
    "metadata": {
      "apexDescription": "Générer des Florans pourrait être un désastre.",
      "avianDescription": "Je ne suis pas sûr de vouloir générer des Florans.",
      "floranDescription": "Floran invoque des parrents-cocon! Ouui!",
      "glitchDescription": "Ravi. J'apprécie toujours d'interagir avec les plantes.",
      "humanDescription": "On fait venir des Florans ici et on lance la fête!",
      "hylotlDescription": "Invoquer des Florans serait une idée terrible."
    }
  },
  "spawnerglitch": {
    "name": "Générateur de Glitch",
    "desc": "Générez votre propre villageois Glitch!",
    "metadata": {
      "apexDescription": "Je pourrais construire une armée de robots pour renverser Big Ape.",
      "avianDescription": "Peut-être que ces Glitchs pourraient servir de travailleurs.",
      "floranDescription": "Floran invoque des amis en métal!",
      "glitchDescription": "Encouragé. Cette technologie pourrait permettre à notre espèce de croître de manière exponentielle.",
      "humanDescription": "Un majordome robot, un!",
      "hylotlDescription": "Je suppose qu'un Glitch ferait l'affaire pour des tâches ingrates."
    }
  },
  "spawnerguard": {
    "name": "Générateur de Garde",
    "desc": "Générez votre propre garde!",
    "metadata": {
      "apexDescription": "J'aurais bien besoin d'un peu de protection supplémentaire contre le Miniknog.",
      "avianDescription": "Avec un garde, Kluex n'oserait pas me toucher.",
      "floranDescription": "Floran peut se garder sseul! Mais plusss de gardes ne fait pas de mal.",
      "glitchDescription": "Satisfait. L'union fait la force.",
      "humanDescription": "J'ai toujours voulu avoir un entourage.",
      "hylotlDescription": "Des gardes pourraient m'aider à répandre la paix."
    }
  },
  "spawnerhuman": {
    "name": "Générateur d'Humain",
    "desc": "Générez votre propre villageois humain!",
    "metadata": {
      "apexDescription": "Une source inépuisable de singes sans poils.",
      "avianDescription": "Qu'est-ce que je pourrais bien vouloir faire avec des humains?",
      "floranDescription": "Floran ssait pas s'il veut invoquer des gens-viande.",
      "glitchDescription": "Inquiet. J'ai entendu dire que les humains sont superstitieux vis-à-vis de ce genre de choses.",
      "humanDescription": "Quelle diablerie est-ce là! Des clones humains?! Génial.",
      "hylotlDescription": "Un générateur d'humain. Comme c'est délicieusement inutile."
    }
  },
  "spawnerhylotl": {
    "name": "Générateur d'Hylotl",
    "desc": "Générez votre propre villageois Hylotl!",
    "metadata": {
      "apexDescription": "Générer des Hylotls... Heu... peut-être plus tard.",
      "avianDescription": "Je devrai faire attention à ne pas utiliser ceci trop souvent.",
      "floranDescription": "Floran invoque l'homm-poisson drectement sur l'épée!",
      "glitchDescription": "Hypocrite. Un rassemblement d'Hylotls serait tout simplement merveilleux.",
      "humanDescription": "Eh bien, j'imagine qu'un seul Hylotl ne ferait pas de mal...",
      "hylotlDescription": "Quelle joie! Je peux enfin m'entourer de culture à nouveau."
    }
  },
  "spawnerwizard": {
    "name": "Générateur de Sorcier",
    "desc": "Générez votre propre sorcier!",
    "metadata": {
      "apexDescription": "Un sorcier devrait sûrement pouvoir se téléporter ici tout seul.",
      "avianDescription": "Magie et science. Quelle belle union.",
      "floranDescription": "Floran veut un ssorcier dans son groupe!",
      "glitchDescription": "Méfiance. Les Glitchs ne sont pas friands de magie.",
      "humanDescription": "Peut-être que je peux devenir l'apprenti de ce sorcier.",
      "hylotlDescription": "Cela va-t-il générer un sorcier, ou encore un autre charlatan?"
    }
  },
  "spawnerstation": {
    "name": "^orange;Station d'Embauche^white;",
    "desc": "Une station utilisée pour obtenir des balises d'emploi qui font appel à toutes sortes d'assistants.",
    "metadata": {
      "interactData.paneLayoutOverride.windowtitle.title": " Station d'Embauche",
      "interactData.paneLayoutOverride.windowtitle.subtitle": " Utilisez des balises d'emploi pour appeler de l'aide",
      "apexDescription": "Je me demande si je peux commander un combattant de la liberté.",
      "avianDescription": "Une telle technologie est controversée sur Avos.",
      "floranDescription": "Rrestau fassst-food?",
      "glitchDescription": "Impressionné. Un système si équitable. Pas de seigneurs ni de dames, pas de pauvres paysans.",
      "humanDescription": "C'est l'évolution ultime des petites annonces en ligne.",
      "hylotlDescription": "Aider un autre être apporte la paix intérieure."
    }
  },
  "shipgreeble1": {
    "name": "Composant de Vaisseau 1",
    "desc": "Un morceau de vaisseau étrange. On dirait qu'il pourrait servir à quelque chose, mais qui sait vraiment?"
  },
  "shipgreeble2": {
    "name": "Composant de Vaisseau 2",
    "desc": "Un morceau de vaisseau étrange. On dirait qu'il pourrait servir à quelque chose, mais qui sait vraiment?"
  },
  "shipgreeble3": {
    "name": "Composant de Vaisseau 3",
    "desc": "Un morceau de vaisseau étrange. On dirait qu'il pourrait servir à quelque chose, mais qui sait vraiment?"
  },
  "shipgreeble4": {
    "name": "Composant de Vaisseau 4",
    "desc": "Un morceau de vaisseau étrange. On dirait qu'il pourrait servir à quelque chose, mais qui sait vraiment?"
  },
  "solarpanel": {
    "name": "Panneau Solaire",
    "desc": "Un panneau qui génère de l'électricité à partir de l'énergie solaire.",
    "metadata": {
      "apexDescription": "Ce panneau photovoltaïque génère de l'électricité en absorbant la lumière solaire.",
      "avianDescription": "Ce panneau puise l'énergie des étoiles pour générer de la puissance!",
      "floranDescription": "Le panneau crée de l'énergie à partir de la lumière du ssoleil. Floran comprend ça.",
      "glitchDescription": "Impressionné. Ce panneau absorbe la lumière pour créer de l'énergie. Si seulement j'avais été conçu pour faire ça...",
      "humanDescription": "Ce panneau solaire crée de l'énergie à partir de la lumière. J'ai entendu dire que les anciens humains les aimaient beaucoup.",
      "hylotlDescription": "Ce panneau solaire génère de l'énergie propre à partir du soleil. J'imagine qu'il ne serait pas très utile sous l'eau.",
      "novakidDescription": "Ça génère du courant avec la lumière du soleil? Je pourrais gagner grassement ma vie juste en m'asseyant dessus."
    }
  },
  "spacebarbottom": {
    "name": "Bar Spatial",
    "desc": "Un bar en métal avec une surface lisse et polie.",
    "metadata": {
      "apexDescription": "Ce bar ne sert pas à grand-chose, si ce n'est à perdre son temps.",
      "avianDescription": "Ce bar est froid et industriel, mais au moins les tabourets ont l'air confortables.",
      "floranDescription": "Ce bar pourrait être un bon endroit pour que Floran déclenche des bagarresss...",
      "glitchDescription": "Désintéressé. La plupart des Glitchs préfèrent une grande table à un bar pour boire et festoyer.",
      "humanDescription": "Ce bar est sympa, mais pas très utile sans personne pour faire le service.",
      "hylotlDescription": "Rien de tel que de s'asseoir à côté de nouveaux visages dans un bar pour se faire des amis.",
      "novakidDescription": "On dirait bien un bon endroit pour tirer un tabouret et se reposer un moment."
    }
  },
  "spaceslideshow": {
    "name": "Diaporama Spatial",
    "desc": "Un écran affichant une série de photographies sur le thème de l'espace.",
    "metadata": {
      "apexDescription": "Cet écran surdimensionné montre des images de l'espace profond.",
      "avianDescription": "La résolution de ces photos est incroyable.",
      "floranDescription": "Images sssereines de lieux dans l'espace.",
      "glitchDescription": "Curieux. Ces images représentent des endroits précis dans l'espace, sont-elles liées d'une manière ou d'une autre?",
      "humanDescription": "Avec cet écran, je pourrais observer l'espace depuis le confort d'un canapé.",
      "hylotlDescription": "Cet écran affiche des photographies de l'espace en très haute résolution.",
      "novakidDescription": "C'est la plus grande télé que j'aie jamais vue, par contre y'a qu'une seule chaîne."
    }
  },
  "stationbench": {
    "name": "Banc de Station",
    "desc": "Un banc en métal élégant.",
    "metadata": {
      "apexDescription": "Les bandes de couleurs sur ce banc sont décoratives et de bon goût.",
      "avianDescription": "Les bancs sont meilleurs quand on les partage avec des amis.",
      "floranDescription": "Le banc fournit une couverture tactique.",
      "glitchDescription": "Observateur. Un long banc pour s'asseoir avec ses alliés.",
      "humanDescription": "Est-ce un banc, ou simplement une chaise très large?",
      "hylotlDescription": "Un banc plaisant.",
      "novakidDescription": "Je m'y allongerais bien un peu, mais ce s'rait p'têt pas très poli..."
    }
  },
  "stationceilingvent": {
    "name": "Bouche d'Aération de Plafond",
    "desc": "Un évent généralement utilisé pour maintenir l'air propre à bord des stations spatiales.",
    "metadata": {
      "apexDescription": "Une bouche d'aération. Il est bénéfique de maintenir la propreté de l'air.",
      "avianDescription": "Je suppose que ceci sert à aider à purifier l'air.",
      "floranDescription": "Évent trop petit pour que Floran s'y cache.",
      "glitchDescription": "Curieux. Je me demande si les poumons des Glitchs fonctionnent comme cet évent.",
      "humanDescription": "C'est l'extrémité d'un conduit. Pas sûr que je puisse entrer dedans.",
      "hylotlDescription": "Un vilain dispositif pour garder l'air exempt de pollution. Au moins, c'est pour une noble cause.",
      "novakidDescription": "Une bonne vieille bouche d'aération de plafond en métal."
    }
  },
  "stationchair": {
    "name": "Chaise de Station",
    "desc": "Une chaise en métal courbée, d'aspect formel.",
    "metadata": {
      "apexDescription": "Une chaise simple, entièrement faite d'alliages métalliques.",
      "avianDescription": "Une chaise argentée brillante.",
      "floranDescription": "Floran n'a passs le temps de s'asseoir.",
      "glitchDescription": "Impressionné. Cette chaise semble être nettement plus solide que la majorité des chaises de l'univers.",
      "humanDescription": "J'ai vu beaucoup de chaises dans ma vie, mais celle-là... n'est pas ma préférée.",
      "hylotlDescription": "Une chaise décorée de bandes de couleurs qui s'harmonisent bien.",
      "novakidDescription": "Ouaip, c'est une chaise, pas de doute."
    }
  },
  "stationconsole": {
    "name": "Console de Station",
    "desc": "Un petit terminal avec un écran d'affichage compact.",
    "metadata": {
      "apexDescription": "Ce terminal compact possède un petit écran d'affichage.",
      "avianDescription": "Ce terminal n'a pas besoin d'une tonne de boutons, juste l'essentiel.",
      "floranDescription": "Floran veut appuyer ssur les boutons de cette console.",
      "glitchDescription": "Intéressé. Cette console semble conçue pour un but précis, il n'y a pas beaucoup de boutons.",
      "humanDescription": "Une petite console sur pied, avec un écran d'affichage intégré.",
      "hylotlDescription": "Cette petite console n'a que les boutons nécessaires, je suis sûr qu'elle a une fonction claire.",
      "novakidDescription": "Juste quelques minuscules boutons sur c'te console."
    }
  },
  "stationcrate": {
    "name": "Caisse de Station",
    "desc": "Une caisse d'expédition, conçue pour transporter des marchandises spatiales.",
    "metadata": {
      "apexDescription": "Cette caisse semble très robuste et dispose d'un bon espace de stockage.",
      "avianDescription": "Cette caisse en métal peut contenir des marchandises en toute sécurité.",
      "floranDescription": "Cette caisse en métal est faite pour transporter des rravitaillementsss spatiaux.",
      "glitchDescription": "Observateur. Cette simple caisse industrielle est conçue pour le transport spatial.",
      "humanDescription": "Une caisse d'expédition au look industriel, j'en ai vu à l'intérieur des vaisseaux et des stations.",
      "hylotlDescription": "Je ne sais pas ce que signifient ces marquages, mais il est clair que cette caisse est faite pour le transport spatial.",
      "novakidDescription": "Une caisse en métal, faite pour contenir des provisions spatiales."
    }
  },
  "stationdisplay": {
    "name": "Écran de Station",
    "desc": "Un écran mural éclairé avec beaucoup de texte bleu.",
    "metadata": {
      "apexDescription": "Un écran affichant ce que je présume être des informations importantes.",
      "avianDescription": "Le texte sur cet écran est d'un bleu glacial.",
      "floranDescription": "Floran s'en fiche du ssigne bleu.",
      "glitchDescription": "Intrigué. Je me demande quelle proportion du texte sur cet écran est réellement utile?",
      "humanDescription": "Un écran angulaire, rempli d'un texte bleu qui défile à l'infini.",
      "hylotlDescription": "Les lumières bleues froides me rappellent le reflet de la lune sur la surface d'une rivière.",
      "novakidDescription": "Y'a sacrément beaucoup d'infos là-dessus. Pas sûr que j'pourrais m'souvenir de tout."
    }
  },
  "stationdoor": {
    "name": "Porte de Station",
    "desc": "Une porte automatique élégante, faite des mêmes matériaux que l'extérieur des stations spatiales.",
    "metadata": {
      "apexDescription": "Une porte en métal élégante. J'apprécie son design anguleux.",
      "avianDescription": "C'est une porte en métal plutôt bien faite!",
      "floranDescription": "La porte a l'air tranchannnte. Floran envisage la porte comme arme potentielle.",
      "glitchDescription": "Nostalgique. Le design anguleux de cette porte me rappelle les bannières traditionnelles des Glitchs.",
      "humanDescription": "Cette porte pourrait probablement encaisser quelques coups, pour ne pas dire plus.",
      "hylotlDescription": "Une porte de facture impressionnante. Étonnamment, je me surprends à l'apprécier.",
      "novakidDescription": "C'te porte a l'air de pouvoir résister à une tempête ou deux."
    }
  },
  "stationdoorlarge": {
    "name": "Grande Porte de Station",
    "desc": "Une grande porte automatique élégante, faite des mêmes matériaux que l'extérieur des stations spatiales.",
    "metadata": {
      "apexDescription": "Une porte en métal élégante. J'apprécie son design anguleux.",
      "avianDescription": "C'est une porte en métal plutôt bien faite!",
      "floranDescription": "La porte a l'air tranchannnte. Floran envisage la porte comme arme potentielle.",
      "glitchDescription": "Nostalgique. Le design anguleux de cette porte me rappelle les bannières traditionnelles des Glitchs.",
      "humanDescription": "Cette porte pourrait probablement encaisser quelques coups, pour ne pas dire plus.",
      "hylotlDescription": "Une porte de facture impressionnante. Étonnamment, je me surprends à l'apprécier.",
      "novakidDescription": "C'te porte a l'air de pouvoir résister à une tempête ou deux."
    }
  },
  "stationhatch": {
    "name": "Écoutille de Station",
    "desc": "Une grande écoutille automatique élégante, faite des mêmes matériaux que l'extérieur des stations spatiales.",
    "metadata": {
      "apexDescription": "Une écoutille en métal élégante. J'apprécie son design anguleux.",
      "avianDescription": "C'est une écoutille en métal plutôt bien faite!",
      "floranDescription": "L'écoutille a l'air tranchannnte. Floran envisage l'écoutille comme arme potentielle.",
      "glitchDescription": "Nostalgique. Le design anguleux de cette écoutille me rappelle les bannières traditionnelles des Glitchs.",
      "humanDescription": "Cette écoutille pourrait probablement encaisser quelques coups, pour ne pas dire plus.",
      "hylotlDescription": "Une écoutille de facture impressionnante. Étonnamment, je me surprends à l'apprécier.",
      "novakidDescription": "C'te écoutille a l'air de pouvoir résister à une tempête ou deux."
    }
  },
  "stationrailhatch": {
    "name": "Écoutille à Rail de Station",
    "desc": "Une grande écoutille élégante avec un connecteur de rail intégré pour les ascenseurs.",
    "metadata": {
      "apexDescription": "Une écoutille en métal élégante. J'apprécie son design anguleux.",
      "avianDescription": "C'est une écoutille en métal plutôt bien faite!",
      "floranDescription": "L'écoutille a l'air tranchannnte. Floran envisage l'écoutille comme arme potentielle.",
      "glitchDescription": "Nostalgique. Le design anguleux de cette écoutille me rappelle les bannières traditionnelles des Glitchs.",
      "humanDescription": "Cette écoutille pourrait probablement encaisser quelques coups, pour ne pas dire plus.",
      "hylotlDescription": "Une écoutille de facture impressionnante. Étonnamment, je me surprends à l'apprécier.",
      "novakidDescription": "C'te écoutille a l'air de pouvoir résister à une tempête ou deux."
    }
  },
  "stationhologram": {
    "name": "Hologramme de Station",
    "desc": "Un affichage holographique vacillant d'une planète non identifiée.",
    "metadata": {
      "apexDescription": "Un hologramme d'une planète et d'une lune. La qualité de la projection est discutable.",
      "avianDescription": "Un hologramme de planète: une image en trois dimensions faite de lumière!",
      "floranDescription": "Floran peut passs lancer la balle bleue, la balle n'essst pas rréelle.",
      "glitchDescription": "Curieux. Je me demande quelle planète cet hologramme représente?",
      "humanDescription": "Je me demande encore pourquoi tous les hologrammes doivent être bleus. Est-ce un choix stylistique?",
      "hylotlDescription": "Le bleu est véritablement la meilleure couleur pour les projections holographiques.",
      "novakidDescription": "Une image flottante d'un monde bleu azur."
    }
  },
  "stationlighth": {
    "name": "Large Éclairage de Station",
    "desc": "Un long éclairage fluorescent au look industriel.",
    "metadata": {
      "apexDescription": "Cet éclairage industriel est assez imposant.",
      "avianDescription": "Cette lampe n'est pas très jolie, et la lumière qu'elle diffuse est froide.",
      "floranDescription": "Floran n'aime passs la lumière électrique froide.",
      "glitchDescription": "Informé. Ces lampes possèdent chacune une source d'énergie compacte intégrée.",
      "humanDescription": "De grands tubes fluorescents, du genre qu'on voit dans les vaisseaux et les stations.",
      "hylotlDescription": "Une grande lampe fluorescente, je me demande si elle est étanche.",
      "novakidDescription": "Une bonne vieille grosse lampe électrique."
    }
  },
  "stationlightv": {
    "name": "Haut Éclairage de Station",
    "desc": "Un long éclairage fluorescent au look industriel.",
    "metadata": {
      "apexDescription": "Cet éclairage industriel est assez imposant.",
      "avianDescription": "Cette lampe n'est pas très jolie, et la lumière qu'elle diffuse est froide.",
