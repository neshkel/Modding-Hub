  "shipyardcaptain": {
    "name": "Capitaine du Chantier Naval",
    "desc": "Un capitaine à l'air louche.",
    "metadata": {
      "apexDescription": "Cet homme est suspect... Mais il vend de bons véhicules.",
      "avianDescription": "Cet homme vend des véhicules.",
      "floranDescription": "Homme louche, vennnd des véhiculesss.",
      "glitchDescription": "Ravi. Je peux acheter des véhicules à ce gentilhomme.",
      "humanDescription": "D'habitude, j'éviterais les personnages aussi louches... Mais je veux vraiment un véhicule.",
      "hylotlDescription": "On m'a dit que ce capitaine vendait des véhicules.",
      "novakidDescription": "Je m'demande quel genre de véhicules ce gars peut bien vendre?",
      "interactData.paneLayoutOverride.windowtitle.title": "Parc de véhicules de Penguin Pete",
      "interactData.paneLayoutOverride.windowtitle.subtitle": "Affaire de pirates totalement légitime"
    }
  },
  "shipyardjunk": {
    "name": "Débris de Chantier Naval",
    "desc": "Une collection de pièces de vaisseau.",
    "metadata": {
      "apexDescription": "On dirait une collection de pièces de vaisseau.",
      "avianDescription": "C'est un tas de pièces de vaisseau.",
      "floranDescription": "Piècesss de vaisssseau.",
      "glitchDescription": "Intéressé. Un tas de pièces de vaisseau.",
      "humanDescription": "C'est un tas de pièces de vaisseau. Certaines semblent avoir subi des dégâts de combat.",
      "hylotlDescription": "C'est une collection de pièces de vaisseau.",
      "novakidDescription": "Un tas de pièces de vaisseau récupérées."
    }
  },
  "shipyardwelding": {
    "name": "Pingouin Soudeur",
    "desc": "Il a l'air occupé.",
    "metadata": {
      "apexDescription": "Je n'arrive pas à savoir s'il construit ou s'il démonte cet objet.",
      "avianDescription": "Un pingouin avec un chalumeau... Je ne me sens pas en sécurité.",
      "floranDescription": "Ce pingouin est de la taille d'une bouchée.",
      "glitchDescription": "Fasciné. Je me demande ce que ce pingouin prépare?",
      "humanDescription": "Je parie que ce pingouin a eu du mal à monter en haut de cette échelle.",
      "hylotlDescription": "Ça me rend nerveux de voir un pingouin en haut d'une échelle avec un chalumeau.",
      "novakidDescription": "Ce p'tit pingouin manigance quelque chose."
    }
  },
  "signdispenser": {
    "name": "Armoire EASEL",
    "desc": "C'est de cette armoire que sortent les enseignes. Peut-être que je peux en insérer une?",
    "metadata": {
      "apexDescription": "Un scanner et une imprimante. Très utile.",
      "avianDescription": "Ce distributeur scanne et imprime des enseignes.",
      "floranDescription": "Imprime ssignesss, sscanne ssignesss.",
      "glitchDescription": "Observateur. Les enseignes imprimées apparaissent ici, et on peut aussi en scanner.",
      "humanDescription": "C'est une imprimante et un scanner!",
      "hylotlDescription": "Les enseignes imprimées sont distribuées ici, et on peut aussi en scanner.",
      "novakidDescription": "C'te chose, c'est là qu'on imprime les enseignes. On peut aussi les scanner."
    }
  },
  "signstore": {
    "name": "EASEL",
    "desc": "Le Lithographe d'Ingénierie d'Enseignes Élégamment Automatique.",
    "metadata": {
      "apexDescription": "Je peux imprimer toutes sortes d'enseignes ici.",
      "avianDescription": "C'est un endroit où je peux créer et imprimer des enseignes.",
      "floranDescription": "Combien de motsss c'est trop de motsss? Trois. Trois motsss.",
      "glitchDescription": "Stupéfait. Gutenbergbot serait fasciné par cette invention.",
      "humanDescription": "Je peux fabriquer des enseignes spécialisées ici!",
      "hylotlDescription": "Des enseignes pour informer et éclairer.",
      "novakidDescription": "J'pourrais faire toutes sortes d'enseignes si j'étais pas si occupé à l'aventure."
    }
  },
  "signstoreclosed": {
    "name": "Magasin d'Enseignes Fermé",
    "desc": "Ce serait un endroit sympa pour un étal.",
    "metadata": {
      "apexDescription": "L'écran indique que l'étal ouvrira bientôt.",
      "avianDescription": "Je me demande ce que ce sera quand ce sera ouvert.",
      "floranDescription": "Floran ssait pas ce que ce ssera quand ce ssera ouvert.",
      "glitchDescription": "Excité. L'affichage lumineux de cet étal indique qu'il ouvrira bientôt!",
      "humanDescription": "C'est un étal au look curieux. Je me demande quelle est sa fonction?",
      "hylotlDescription": "Le côté de cet étal est peint avec la marque des Hylotls.",
      "novakidDescription": "Quel stand curieux."
    }
  },
