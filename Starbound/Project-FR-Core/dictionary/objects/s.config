  "salesign": {
    "name": "Enseigne de Promotion",
    "desc": "Une bannière annonçant des soldes. Tout le monde aime les soldes!",
    "metadata": {
      "apexDescription": "Oh, on dirait qu'ils font des soldes par ici...",
      "avianDescription": "Ce magasin fait des promotions.",
      "floranDescription": "Trucsss pas chers? Floran aime ça.",
      "glitchDescription": "Intrigué. Je me demande s'ils ont de bonnes affaires?",
      "humanDescription": "On dirait que ce magasin fait des soldes.",
      "hylotlDescription": "Cette boutique semble proposer des promotions.",
      "novakidDescription": "Y'a des soldes!"
    }
  },
  "shippingcontainer": {
    "name": "Conteneur d'Expédition",
    "desc": "Un très grand conteneur d'expédition.",
    "metadata": {
      "apexDescription": "C'est une caisse énorme pour transporter de grosses cargaisons.",
      "avianDescription": "Je suppose que c'est destiné au transport d'objets très volumineux.",
      "floranDescription": "Y'a peut-être de la nourrrriture dedans.",
      "glitchDescription": "Curieux. Qu'est-ce qui est stocké là-dedans?",
      "humanDescription": "C'est un conteneur d'expédition vraiment massif.",
      "hylotlDescription": "Un conteneur assez imposant pour expédier de grandes quantités de fret.",
      "novakidDescription": "Un gros conteneur pour trimballer des marchandises."
    }
  },
  "shopline": {
    "name": "Panneau de File d'Attente",
    "desc": "Un panneau indiquant le début d'une file d'attente à la caisse.",
    "metadata": {
      "apexDescription": "Je ne suis pas fan de faire la queue.",
      "avianDescription": "Ce panneau marque le début de la file d'attente du magasin.",
      "floranDescription": "Ils s'attendent à ce que Floran attende à causse d'un sssigne sstupide?",
      "glitchDescription": "Agacé. Je déteste faire la queue dans de longues files.",
      "humanDescription": "Faut encore se taper des files d'attente interminables jusque dans l'espace, hein?",
      "hylotlDescription": "C'est un panneau marquant le début d'une file d'attente.",
      "novakidDescription": "J'suis censé rester là à attendre? Et puis quoi encore?"
    }
  },
  "smashabledrink1": {
    "name": "Bouteille de Cordial Vide",
    "desc": "Une bouteille vide de cordial d'avesmingo.",
    "metadata": {
      "apexDescription": "La bouteille est vide, alors que reste-t-il à faire à part la fracasser?",
      "avianDescription": "La bouteille est vide, alors que reste-t-il à faire à part la fracasser?",
      "floranDescription": "Fracassser!",
      "glitchDescription": "Espiègle. Il ne reste plus rien dans la bouteille, il est donc tentant de la briser.",
      "humanDescription": "La bouteille est vide, alors que reste-t-il à faire à part la fracasser?",
      "hylotlDescription": "Une petite partie de moi aimerait beaucoup briser cette bouteille...",
      "novakidDescription": "Yeehaw! Parfait pour l'entraînement au tir!"
    }
  },
