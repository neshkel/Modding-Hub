  "silversample": {
    "name": "Échantillon d'Argent",
    "desc": "\"Un échantillon parfait de minerai d'argent.\""
  },
  "solariumsample": {
    "name": "Échantillon de Solarium",
    "desc": "\"Un échantillon parfait de minerai de solarium.\""
  },
  "sandstonebed": {
    "name": "Lit en Grès",
    "desc": "Un lit en grès. Assurez-vous de le dépoussiérer avant usage.",
    "metadata": {
      "apexDescription": "Un lit en grès rugueux. Assez confortable avec le bon matelas.",
      "avianDescription": "Un lit en grès rugueux.",
      "floranDescription": "Floran dorrt dans un lit en grrrès.",
      "glitchDescription": "Observateur. Bondir sur ce lit avec le bon angle ferait s'effriter le grès.",
      "humanDescription": "Ce lit semble digne d'un pharaon.",
      "hylotlDescription": "Un lit de pierre rugueux et granuleux. Ce n'est pas un endroit idéal pour dormir.",
      "novakidDescription": "Ça n'a pas l'air confortable. En fait, je préférerais dormir par terre juste à côté."
    }
  },
  "sandstonechair": {
    "name": "Chaise en Grès",
    "desc": "Une chaise en grès. Friable.",
    "metadata": {
      "apexDescription": "Une chaise rugueuse et granuleuse.",
      "avianDescription": "Cette chaise est rêche contre les plumes.",
      "floranDescription": "Floran s'agite, la chaisse s'effrrite.",
      "glitchDescription": "Estimatif. Si deux personnes s'asseyaient ensemble sur cette chaise, le grès pourrait s'effondrer.",
      "humanDescription": "Asseyez-vous là et vous aurez du sable partout!",
      "hylotlDescription": "Une chaise en grès rudimentaire. Rude pour la peau.",
      "novakidDescription": "Si tu restes assis trop longtemps là-dessus, t'auras le derrière tout engourdi."
    }
  },
  "sandstonechest": {
    "name": "Coffre en Grès",
    "desc": "Un coffre en grès grossièrement taillé.",
    "metadata": {
      "apexDescription": "Un coffre en grès.",
      "avianDescription": "Un coffre en grès rugueux.",
      "floranDescription": "Cofffrre sssableux.",
      "glitchDescription": "Observateur. Un coffre fait de grès.",
      "humanDescription": "Peut-être que ce coffre vient d'un château de sable.",
      "hylotlDescription": "Un coffre de facture rudimentaire.",
      "novakidDescription": "Un coffre en grès. J'espère qu'il n'est pas plein de sable."
    }
  },
  "sandstonedoor": {
    "name": "Porte en Grès",
    "desc": "Une porte en grès rugueux.",
    "metadata": {
      "apexDescription": "Une porte faite de grès.",
      "avianDescription": "Une porte en grès bien conçue.",
      "floranDescription": "Porrte sssableuse.",
      "glitchDescription": "Observateur. Une porte en grès robuste.",
      "humanDescription": "Belle porte.",
      "hylotlDescription": "Une porte rugueuse et sablonneuse. Rudimentaire.",
      "novakidDescription": "C'est une porte lourde. Rêche au toucher."
    }
  },
  "sandstonetable": {
    "name": "Table en Grès",
    "desc": "Une table en grès. Ne renversez pas d'eau dessus.",
    "metadata": {
      "apexDescription": "Une table en grès. Ma nourriture a un goût de sable.",
      "avianDescription": "Une table abrasive.",
      "floranDescription": "Floran découpe ici.",
      "glitchDescription": "Neutre. Une table faite de grès.",
      "humanDescription": "Une table granuleuse et rugueuse.",
      "hylotlDescription": "Une table en grès rudimentaire.",
      "novakidDescription": "Une table en grès. On risque de mettre du sable dans sa nourriture!"
    }
  },
  "sandstonetorch": {
    "name": "Torche en Grès",
    "desc": "Cette torche vacille doucement.",
    "metadata": {
      "apexDescription": "Une torche.",
      "avianDescription": "Une torche qui brûle.",
      "floranDescription": "Une torrrche qui brr brûle. Dangereux.",
      "glitchDescription": "Neutre. C'est simplement une torche.",
      "humanDescription": "Une simple torche en grès.",
      "hylotlDescription": "C'est une simple torche.",
      "novakidDescription": "C'est une torche vacillante."
    }
  },
  "shadowchest": {
    "name": "Coffre d'Ombre",
    "desc": "Un coffre sombre et ténébreux.",
    "metadata": {
      "apexDescription": "Un coffre au trésor sombre et effrayant. Quelque chose de mal pourrait être à l'intérieur.",
      "avianDescription": "Un coffre sombre. Je ne peux pas imaginer que de bonnes choses se trouvent dedans.",
      "floranDescription": "Un cofffrre au trrrésor noir. Je parie que les meilleures chosess sont à l'intérieur.",
      "glitchDescription": "Nerveux. Ce coffre ténébreux est sinistre et j'hésiterais à l'ouvrir.",
      "humanDescription": "Probablement le coffre le plus inquiétant que j'aie jamais vu.",
      "hylotlDescription": "Ce coffre semble absorber toute la lumière environnante.",
      "novakidDescription": "Un coffre aussi noir que le ciel nocturne."
    }
  },
  "shadowchimes": {
    "name": "Carillon Éolien",
    "desc": "Beaucoup trouvent le tintement doux des carillons éoliens comme celui-ci très apaisant.",
    "metadata": {
      "apexDescription": "Ce carillon crée certainement une atmosphère particulière.",
      "avianDescription": "Un carillon avec un joli tintement.",
      "floranDescription": "Le vent souffle sur le carrrillon d'ombre pour ffaire de jolis sssons.",
      "glitchDescription": "Ravi. Ce carillon plaisant me donne de l'entrain.",
      "humanDescription": "Quelque chose dans le tintement de ce carillon me donne la chair de poule.",
      "hylotlDescription": "Ce carillon inquiétant produit un son éthéré.",
      "novakidDescription": "Un carillon au son très doux."
    }
  },
  "shadowmarker": {
    "name": "Marqueur d'Ombre",
    "desc": "Un mystérieux marqueur. De quel genre de cuir s'agit-il?",
    "metadata": {
      "apexDescription": "Effrayant... Ça pourrait être un signal d'avertissement.",
      "avianDescription": "Ce marqueur... est-ce un avertissement?",
      "floranDescription": "Ah, un marrqueur d'averrtissement. Floran se demande ce qu'il y a ici.",
      "glitchDescription": "Alarmé. Mon envie de quitter cette zone a augmenté.",
      "humanDescription": "C'est quoi ça? Une sorte de balise?",
      "hylotlDescription": "Ce marqueur est très troublant...",
      "novakidDescription": "Je parie que c'est une sorte de repère pour éloigner les étrangers."
    }
  },
  "shadowrock1": {
    "name": "Roche Sombre",
    "desc": "Une roche sombre.",
    "metadata": {
      "apexDescription": "Cette roche a l'air volcanique.",
      "avianDescription": "Je ferais mieux de regarder où je marche avec ces rochers dans le coin!",
      "floranDescription": "Rroche magmatique.",
      "glitchDescription": "Surpris. Une roche très sombre, j'ai failli ne pas la voir du tout.",
      "humanDescription": "C'est le genre de truc parfait pour se prendre les pieds dedans.",
      "hylotlDescription": "Un dépôt rocheux récemment formé, cela ressemble encore à de la lave refroidie.",
      "novakidDescription": "Une roche aussi noire que la nuit, les étoiles en moins."
    }
  },
