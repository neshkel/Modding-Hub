  "crossroadssign": {
    "name": "Panneau de Croisement",
    "desc": "Des panneaux routiers inutiles.",
    "metadata": {
      "apexDescription": "Un panneau de signalisation. Mais il est vierge...",
      "avianDescription": "Il semble donner des directions, mais rien n'est indiqué.",
      "floranDescription": "Panneau confuse Floran.",
      "glitchDescription": "Curieux. Qu'est-ce qui pourrait expliquer ce panneau vide?",
      "humanDescription": "Je ne suis pas sûr de l'utilité d'un panneau vierge.",
      "hylotlDescription": "Ce panneau n'a aucune inscription, peut-être à cause de l'érosion du temps.",
      "novakidDescription": "Un panneau vide, ça sert à rien pour personne."
    }
  },
  "cactiflowerpot": {
    "name": "Pot de Cactus",
    "desc": "Un cactus d'aspect exotique dans un pot de fleurs.",
    "metadata": {
      "apexDescription": "Un cactus en pot. Je ne vois pas l'intérêt.",
      "avianDescription": "Une plante épineuse avec une petite fleur colorée.",
      "floranDescription": "Plante grassse a de l'autodéfensse.",
      "glitchDescription": "Informé. Les cactus comme celui-ci ne nécessitent presque pas d'eau pour rester en bonne santé.",
      "humanDescription": "Un cactus! Facile à faire pousser, facile à entretenir.",
      "hylotlDescription": "Une plante à l'aspect douloureux. Je ferais mieux de ne pas la toucher.",
      "novakidDescription": "Je peux pas l'expliquer, mais j'aime vraiment ce cactus."
    }
  },
  "capsulebig": {
    "name": "Grande Capsule",
    "desc": "Une grande capsule fragile. Je me demande ce qu'il y a dedans.",
    "metadata": {
      "apexDescription": "Une capsule. Elles contiennent souvent des fournitures.",
      "avianDescription": "Une capsule. Il y a quelque chose à l'intérieur, je me demande quoi...",
      "floranDescription": "Fracassse-la! Prends les trucs à l'intérieur!",
      "glitchDescription": "Destructeur. Il est difficile de résister à l'envie de briser cette capsule.",
      "humanDescription": "Je pense qu'il y a quelque chose là-dedans. Je peux probablement l'ouvrir en la cassant.",
      "hylotlDescription": "Parfois, la force peut s'avérer payante.",
      "novakidDescription": "Cette capsule s'rait parfaite pour s'entraîner au tir."
    }
  },
