  "carbed": {
    "name": "Lit Voiture",
    "desc": "Un lit en forme de voiture, pour ceux qui sont restés jeunes de cœur.",
    "metadata": {
      "apexDescription": "Un lit confortable construit pour ressembler à un vieux véhicule terrestre.",
      "avianDescription": "Un lit conçu pour ressembler à une sorte de véhicule humain.",
      "floranDescription": "Floran pas ssûre de ce que c'est... Lit ou voiture?",
      "glitchDescription": "Intrigué. Ce lit a un design mécanique, pourtant l'analyse suggère qu'il est en bois.",
      "humanDescription": "Un lit en forme de voiture! J'en voulais un comme ça depuis que je suis gamin.",
      "hylotlDescription": "Un lit décoratif puéril. Il est peint de couleurs vives.",
