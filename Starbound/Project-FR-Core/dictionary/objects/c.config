  "crystalbed": {
    "name": "Lit de Cristal",
    "desc": "Un lit de cristal, pour quand on veut rêver de richesse.",
    "metadata": {
      "apexDescription": "Un lit de cristal, séduisant mais solide, c'est le moins qu'on puisse dire.",
      "avianDescription": "Un lit magnifique et scintillant.",
      "floranDescription": "Floran aime lit en crissstaux tranchantsss.",
      "glitchDescription": "Peu impressionné. Ces cristaux sont en fait assez communs et ne valent pas grand-chose.",
      "humanDescription": "Je parie que ce lit est l'objet le plus précieux de l'univers!",
      "hylotlDescription": "Ce lit rappelle les formations naturelles de corail sous l'eau.",
      "novakidDescription": "Un lit de cristal froid."
    }
  },
  "crystalchair": {
    "name": "Chaise de Cristal",
    "desc": "Une chaise de cristal. Digne d'un monarque.",
    "metadata": {
      "apexDescription": "Une chaise de cristal très royale.",
      "avianDescription": "Cette chaise de cristal est exotique et séduisante.",
      "floranDescription": "Floran pourrait utilisser chaissse pour écrassser créature.",
      "glitchDescription": "Désintéressé. Malgré leur banalité, l'un des cristaux de cette chaise réussit quand même à être un faux.",
      "humanDescription": "Cette chaise a l'air de valoir une fortune.",
      "hylotlDescription": "Une magnifique chaise étincelante.",
      "novakidDescription": "Est-ce que j'dois porter une couronne de cristal pour m'asseoir là?"
    }
  },
  "crystalchest": {
    "name": "Coffre de Cristal",
    "desc": "Un coffre de cristal. Peut-être que le coffre lui-même est le trésor?",
    "metadata": {
      "apexDescription": "Un superbe coffre de cristal. C'est déjà une trouvaille digne de ce nom en soi.",
      "avianDescription": "Quoi que contienne ce coffre, cela doit sûrement être impressionnant.",
      "floranDescription": "Coffre de crissstal essst lourd et froid, comme un frigo.",
      "glitchDescription": "Sentimental. Ce coffre servait autrefois à conserver de grands secrets.",
      "humanDescription": "Je parie que ce coffre a toujours contenu les plus belles richesses.",
      "hylotlDescription": "Un coffre magnifique. Il scintille comme l'océan.",
      "novakidDescription": "Ce coffre est si froid qu'il s'rait parfait pour stocker des denrées périssables."
    }
  },
  "crystallamp": {
    "name": "Lampe de Cristal",
    "desc": "Un cristal lumineux qui fait office de lampe.",
    "metadata": {
      "apexDescription": "Cette lampe crée une atmosphère calme.",
      "avianDescription": "Le cristal émet une lueur éthérée.",
      "floranDescription": "Qu'importe pourquoi crissstal brille? Ça fait une belle lampe.",
      "glitchDescription": "Inquiet. Cette lumière semble alimentée par une source d'énergie inconnue.",
      "humanDescription": "Un cristal brillant. C'est comme de la magie. Peut-être que je peux devenir un sorcier!",
      "hylotlDescription": "L'éclat du cristal est à la fois apaisant et revigorant, ce qui donne une expérience plutôt déroutante.",
      "novakidDescription": "Ce cristal brille comme une pleine lune en hiver."
    }
  },
  "crystallinebush1": {
    "name": "Buisson Cristallin",
    "desc": "Un dépôt cristallin. Brillant.",
    "metadata": {
      "apexDescription": "Les cristaux sont tout à fait magnifiques.",
      "avianDescription": "Un tas de cristaux brillants.",
      "floranDescription": "Pierresss brillantes et pointuesss.",
      "glitchDescription": "Impatient. Les cristaux sont désagréables sous les pieds.",
      "humanDescription": "Oh, c'est joli.",
      "hylotlDescription": "Ce cristal me rappelle le corail gelé.",
      "novakidDescription": "Un cristal étincelant."
