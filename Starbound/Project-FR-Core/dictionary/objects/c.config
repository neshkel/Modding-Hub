  "chestplant1": {
    "name": "Petit Coffre Envahi",
    "desc": "Un coffre fait de matières végétales. Il semble être encore en train de pousser.",
    "metadata": {
      "apexDescription": "Le coffre lui-même semble être organique.",
      "avianDescription": "Ce coffre a-t-il été construit, ou a-t-il poussé?",
      "floranDescription": "Seul Floran Doigt-Vert ssait comment faire poussser coffre dans le ssol.",
      "glitchDescription": "Impressionné. Il semble que cette plante ait été cultivée dans le but exprès de devenir un coffre.",
      "humanDescription": "Ce coffre a-t-il poussé directement sous cette forme?",
      "hylotlDescription": "Il semble que les Florans aient appris à exploiter la nature pour faire pousser les objets dont ils ont besoin.",
      "novakidDescription": "Comment les Florans font-ils pousser des objets? Ils commandent les graines sur catalogue comme des meubles?"
    }
  },
  "carrotseed": {
    "name": "Graine de Carotte",
    "desc": "Fait pousser de délicieuses carottes, venues de la Terre à travers les étoiles.",
    "metadata": {
      "apexDescription": "Une carotte bouillie ressemble un peu à une banane... mais le goût n'est pas aussi bon.",
      "avianDescription": "Une simple carotte. Bon pour la soupe.",
      "floranDescription": "Parfois carotte poussse toute tordue. Ça amuse Floran.",
      "glitchDescription": "Approbateur. Les carottes sont agréablement croquantes.",
      "humanDescription": "Des carottes. Parfaites à manger, ou pour faire le nez d'un bonhomme de neige.",
      "hylotlDescription": "Les carottes sont un légume polyvalent, bien qu'insipide.",
      "novakidDescription": "L'humble carotte."
    }
  },
  "chiliseed": {
    "name": "Graine de Piment",
    "desc": "Fiesta pimentée!! Extra fort pour tout le monde, sauf pour les humains.",
    "metadata": {
      "apexDescription": "Peindre des piments en jaune est une farce populaire chez les jeunes Apex. S'ils se font prendre, beaucoup n'y survivraient pas.",
      "avianDescription": "Une plante forte et épicée. Exotique.",
      "floranDescription": "Fruitsss brûlantsss et piquantsss. Cette plante fait mal aux bouchess de chair.",
      "glitchDescription": "Pensif. Qui choisirait de manger une nourriture qui lui fait mal?",
      "humanDescription": "Les piments sont forts, mais tellement addictifs.",
      "hylotlDescription": "Juste le bon équilibre entre saveur et piquant. Utilisé avec modération, c'est délicieux.",
      "novakidDescription": "Les Novakids sont fans de piment, plus c'est fort, mieux c'est!"
    }
  },
  "cocoaseed": {
    "name": "Graine de Cacao",
    "desc": "Un plant de cacao. Une fois mûres, les cabosses peuvent être transformées en chocolat.",
    "metadata": {
      "apexDescription": "Une source de cacao, utilisée pour faire du délicieux chocolat.",
      "avianDescription": "Le contenu d'une cabosse de cacao peut être broyé en une pâte savoureuse.",
      "floranDescription": "Quand cosssses sont mûresss, Floran peut faire pâte ssavoureuse.",
      "glitchDescription": "Intrigué. Un plant de cacao, l'origine du chocolat.",
      "humanDescription": "C'est avec le cacao qu'on fait le chocolat! C'est un arbre à chocolat!",
      "hylotlDescription": "Du soleil, de l'eau et un peu de patience sont le secret d'une récolte généreuse.",
      "novakidDescription": "Du chocolat qui pousse sur les arbres."
    }
  },
  "coffeeseed": {
    "name": "Graine de Café",
    "desc": "Les grains de café peuvent être infusés pour faire une boisson savoureuse.",
    "metadata": {
      "apexDescription": "Le café est recherché pour ses propriétés énergisantes.",
      "avianDescription": "Les grains de café ressemblent à une friandise tentante, mais ils sont extrêmement amers.",
      "floranDescription": "Le café garde Floran réveillé.",
      "glitchDescription": "Pensif. Les Glitchs ne voient aucune utilité à ces grains amers.",
      "humanDescription": "Le café, la plante la plus stimulante connue de l'homme.",
      "hylotlDescription": "Au-delà de son goût amer, le café est une ressource utile.",
      "novakidDescription": "Le café sent bon, mais j'ai jamais remarqué d'effet bénéfique à boire ce truc."
    }
  },
  "coralcreepseed": {
    "name": "Graine de Rampant de Corail",
    "desc": "Le fruit du rampant de corail ressemble à une créature marine.",
    "metadata": {
      "apexDescription": "Le rampant de corail, c'est en fait un fruit malgré les apparences.",
      "avianDescription": "Le goût des fruits de mer dans un fruit. C'est vraiment glauque.",
      "floranDescription": "Une plante déguissée en créature. Malin.",
      "glitchDescription": "Sceptique. On dirait une créature marine, comment est-ce possible que ce soit un fruit?",
      "humanDescription": "Un fruit qui a le look et le goût du homard.",
      "hylotlDescription": "Le délicieux rampant de corail. Un vrai délice. Tout le monde devrait goûter.",
      "novakidDescription": "Le vrai fruit de mer."
    }
  },
  "cornseed": {
    "name": "Graine de Maïs",
    "desc": "Du maïs jaune et sucré.",
    "metadata": {
      "apexDescription": "Du maïs. Encore un aliment qui ressemble à une banane, mais qui n'en est pas une.",
      "avianDescription": "Picorer un épi de maïs fait un excellent goûter.",
      "floranDescription": "Maïs jaune et dur, on cuit et ça fait pof.",
      "glitchDescription": "Sceptique. On raconte que si les Glitchs mangent du maïs, il éclatera à l'intérieur de nous.",
      "humanDescription": "Une réserve constante de maïs doux est une chose merveilleuse.",
      "hylotlDescription": "Un en-cas courant et sans saveur, de peu d'intérêt.",
      "novakidDescription": "Le maïs peut s'apprécier sous bien des formes."
    }
  },
  "cottonseed": {
    "name": "Graine de Coton",
    "desc": "Une plante qui fait pousser des bourgeons de coton duveteux.",
    "metadata": {
      "apexDescription": "Le coton est facile à cultiver et a une grande variété d'utilisations productives.",
      "avianDescription": "Des plants de coton! Ces cultures ingénieuses ont tellement d'usages!",
      "floranDescription": "Floran pourrait faire trucs doux avec plantss de coton.",
      "glitchDescription": "Créatif. Je pourrais utiliser ce coton pour une multitude de choses.",
      "humanDescription": "Le coton, l'une des plus anciennes ressources de l'humanité. Trop pratique!",
      "hylotlDescription": "Les tisserands Hylotls peuvent créer les tissus les plus doux avec le coton.",
      "novakidDescription": "Le coton comme ça, on peut en faire un sacré paquet de trucs."
    }
  },
  "crystalplantseed": {
    "name": "Graine de Plante de Cristal",
    "desc": "Une plante de cristal. Finalement, l'argent pousse bien sur les arbres.",
    "metadata": {
      "apexDescription": "Faire pousser ses propres cristaux. Pratique.",
      "avianDescription": "Une plante qui fait pousser des cristaux. C'est magique!",
      "floranDescription": "Floran intrigué par plante qui brille.",
      "glitchDescription": "Inquiet. Cultiver ces cristaux en abondance pourrait nuire à l'économie.",
      "humanDescription": "Quand j'étais petit, je voulais un arbre à argent. C'est ce qui s'en rapproche le plus.",
      "hylotlDescription": "Une plante d'où germent de magnifiques cristaux luisants.",
      "novakidDescription": "Un cristal qu'on peut cultiver! Là, on cause!"
    }
  },
  "currentcornseed": {
    "name": "Graine de Maïs Électrique",
    "desc": "Du maïs électrique, plein d'acide. Pas bon pour les créatures de chair.",
    "metadata": {
      "apexDescription": "J'ai entendu parler de gens brûlés à l'acide par ce maïs. Je ferais mieux de le manipuler avec soin.",
      "avianDescription": "Du maïs acide. Désagréable et dangereux.",
      "floranDescription": "Maïs acide et ssavoureux. Fait mal aux êtres de chair.",
      "glitchDescription": "Fier. Les Glitchs connaissent un moyen d'utiliser ces légumes comme des piles.",
      "humanDescription": "On dirait du maïs... mais ça n'en est vraiment pas.",
      "hylotlDescription": "Une variante de maïs acide et ignoble. Gâche n'importe quel plat.",
      "novakidDescription": "Le maïs électrique est plus proche d'une pile que d'un aliment comestible."
    }
  },
