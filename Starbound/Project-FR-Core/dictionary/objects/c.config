  "clubdecks": {
    "name": "Platines de Club",
    "desc": "D'énormes haut-parleurs crachent de la musique de danse à plein volume.",
    "metadata": {
      "apexDescription": "Cette musique me donne envie de danser!",
      "avianDescription": "C'est quoi cet horrible bruit?",
      "floranDescription": "Cette mussique donne envie à Floran de bouger les hanchesss!",
      "glitchDescription": "Négatif. Cette musique n'est pas plaisante.",
      "humanDescription": "Une musique de club typique, pas très différente de ce que j'entendais sur Terre.",
      "hylotlDescription": "C'est un morceau de club vraiment populaire.",
      "novakidDescription": "J'ai jamais rien entendu de tel. Pas sûr que ce soit mon genre d'air."
    }
  },
  "clublampsmall": {
    "name": "Lampe de Club",
    "desc": "La lampe émet une faible lumière bleue d'ambiance.",
    "metadata": {
      "apexDescription": "Il manque juste une machine à fumée pour vraiment donner une ambiance de boîte de nuit.",
      "avianDescription": "Je me demande quel genre de cristal pourrait diffuser une lumière bleue?",
      "floranDescription": "Une lumière bleue.",
      "glitchDescription": "Désintéressé. C'est une lumière bleue.",
      "humanDescription": "Des lumières d'ambiance. Pour quelle ambiance? Pas sûr.",
      "hylotlDescription": "Juste une lumière bleue d'ambiance.",
      "novakidDescription": "Une lumière bleue. Ça pose l'ambiance."
    }
  },
  "clubspeaker": {
    "name": "Enceinte de Club",
    "desc": "Une grande enceinte de club.",
    "metadata": {
      "apexDescription": "Cette musique me donne envie de danser!",
      "avianDescription": "C'est quoi cet horrible bruit?",
      "floranDescription": "Cette mussique donne envie à Floran de bouger les hanchesss!",
      "glitchDescription": "Négatif. Cette musique n'est pas plaisante.",
      "humanDescription": "Une musique de club typique, pas très différente de ce que j'entendais sur Terre.",
      "hylotlDescription": "C'est un morceau de club vraiment populaire.",
      "novakidDescription": "J'ai jamais rien entendu de tel. Pas sûr que ce soit mon genre d'air."
    }
  },
  "combinationprop": {
    "name": "Serrure à Combinaison (Déco)",
    "desc": "Le rideau le plus élégant.",
    "metadata": {
      "apexDescription": "-todo- c'est un objet temporaire...",
      "avianDescription": "Doux au toucher.",
      "floranDescription": "Apex fait rideau avec velours épais, Floran fait rideau avec ppeau.",
      "glitchDescription": "Tactile. Peu d'objets sont aussi agréables à caresser.",
      "humanDescription": "Ces rideaux auraient leur place dans un manoir.",
      "hylotlDescription": "Ces rideaux collent presque à la peau Hylotl."
    }
  },
  "chalktally": {
    "name": "Marques de Pointage",
    "desc": "Quelqu'un n'a pas su compter jusqu'à 25.",
    "metadata": {
      "apexDescription": "On trouve souvent des marques similaires sur les murs des cellules du Miniknog.",
      "avianDescription": "Quelqu'un comptait quelque chose, mais quoi?",
      "floranDescription": "Floran utilise cess marquesss pour compter sses victimes.",
      "glitchDescription": "Curieux. Cela signifie vingt-cinq occurrences de... quelque chose. Nous ne saurons jamais quoi.",
      "humanDescription": "Une série de bâtons de comptage, ou des dessins de clôtures? Impossible à dire, vraiment.",
      "hylotlDescription": "Une méthode de comptage simple mais efficace.",
      "novakidDescription": "Un gars que j'ai connu comptait ses prises comme ça."
    }
  },
  "curtain1": {
    "name": "Rideau",
    "desc": "Ça ressemble à un bon endroit pour se cacher.",
    "metadata": {
      "apexDescription": "Rideaux luxueux. L'intimité n'est pas une chose à laquelle nous, les Apex, sommes habitués.",
      "avianDescription": "Des rideaux flottants. Comme des plumes dans la brise.",
      "floranDescription": "Rideaux ssont doux comme de la ssoie, mais Floran préfère le cuir.",
      "glitchDescription": "Nostalgique. Ces rideaux sont aussi doux que des draps Glitch.",
      "humanDescription": "Des rideaux. Ils sont plutôt jolis.",
      "hylotlDescription": "Rideaux bien confectionnés. Ils ont un aspect luxueux.",
      "novakidDescription": "Un rideau tout doux."
    }
  },
  "castledoor": {
    "name": "Porte Médiévale",
    "desc": "Une porte solide et sécurisée.",
    "metadata": {
      "apexDescription": "Bien qu'en bois, cette porte est solide.",
      "avianDescription": "Cette porte est bien plus résistante qu'elle n'en a l'air.",
      "floranDescription": "Porte ssi ssolide.",
      "glitchDescription": "Fier. Cette porte est renforcée pour la rendre plus sûre.",
      "humanDescription": "Une porte lourde avec une lucarne à barreaux.",
      "hylotlDescription": "La porte parfaite pour une structure défensive.",
      "novakidDescription": "Une porte solide et robuste."
    }
  },
  "castledungeondoor": {
    "name": "Porte de Cellule Médiévale",
    "desc": "Une porte de cellule de donjon, conçue pour retenir même le plus fort des prisonniers.",
    "metadata": {
      "apexDescription": "Une porte de cellule incroyablement solide.",
      "avianDescription": "Une porte d'une grande résistance.",
      "floranDescription": "Ssolide porte en métal.",
      "glitchDescription": "Détressé. Les Glitchs enferment les prisonniers derrière des portes comme celle-ci. Souvent, ce sont d'autres Glitchs ayant acquis une conscience de soi.",
      "humanDescription": "Personne ne s'échappe d'une cellule avec une porte pareille.",
      "hylotlDescription": "Les Hylotls traitent leurs prisonniers comme des invités de marque.",
      "novakidDescription": "Une bonne porte pour garder les hors-la-loi sous clé."
    }
  },
  "castlehiddendoor": {
    "name": "Porte en Briques Cachée",
    "desc": "Quelque chose ne tourne pas rond avec ces briques.",
    "metadata": {
      "apexDescription": "Certaines de ces briques sont mal placées.",
      "avianDescription": "Ces briques n'ont pas l'air réelles.",
      "floranDescription": "Briquesss ssentent différent des autress briquesss.",
      "glitchDescription": "Curieux. Quelque chose est caché ici.",
      "humanDescription": "Ces briques ont un éclat artificiel.",
      "hylotlDescription": "La façon dont ces briques sont façonnées est étrange.",
      "nokavidDescription": "Y'a un truc qui cloche avec ces briques."
    }
  },
  "castlehiddentrapdoor": {
    "name": "Trappe en Briques Cachée",
    "desc": "Quelque chose ne tourne pas rond avec ces briques.",
    "metadata": {
      "apexDescription": "Certaines de ces briques sont mal placées.",
      "avianDescription": "Ces briques n'ont pas l'air réelles.",
      "floranDescription": "Briquesss ssentent différent des autress briquesss.",
      "glitchDescription": "Curieux. Quelque chose est caché ici.",
      "humanDescription": "Ces briques ont un éclat artificiel.",
      "hylotlDescription": "La façon dont ces briques sont façonnées est étrange.",
      "nokavidDescription": "Y'a un truc qui cloche avec ces briques."
    }
  },
  "castleswitch": {
    "name": "Interrupteur Gemme",
    "desc": "Un cristal suspect qui cache bien son jeu.",
    "metadata": {
      "apexDescription": "Un cristal. On dirait qu'il a une autre utilité.",
      "avianDescription": "Est-ce un simple cristal? Non... C'est autre chose.",
      "floranDescription": "Brillant crysstal, tu sers à quoi?",
      "glitchDescription": "Amusé. Les Glitchs cachent des interrupteurs dans des cristaux comme celui-ci.",
      "humanDescription": "Ce cristal doit forcément servir à quelque chose.",
      "hylotlDescription": "Un grand cristal. Il semble avoir un autre usage.",
      "novakidDescription": "On dirait qu'ce cristal fait quelque chose."
    }
  },
  "chessbishop": {
    "name": "Fou en Pierre Blanche",
    "desc": "Un fou blanc provenant d'un jeu d'échecs géant.",
    "metadata": {
      "apexDescription": "Une pièce d'échecs. Le Miniknog n'autorise pas les jeux d'échecs.",
      "avianDescription": "Une sorte de statue décorative, peut-être?",
      "floranDescription": "Étrange ssstatue. Qu'essst-ce que c'est?",
      "glitchDescription": "Sentimental. La noblesse Glitch apprend à jouer aux échecs dès le plus jeune âge. Ils jouent sur de grands plateaux extérieurs.",
      "humanDescription": "Une pièce d'échecs géante.",
      "hylotlDescription": "On dirait une grande pièce de jeu. Les Hylotls apprécient de nombreux jeux de société.",
      "novakidDescription": "Quel que soit ce jeu, ça a l'air drôlement ennuyeux."
    }
  },
