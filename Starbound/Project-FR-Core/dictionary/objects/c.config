  "cellstructure1": {
    "name": "Structure Cellulaire",
    "desc": "Un étrange méli-mélo de cellules.",
    "metadata": {
      "apexDescription": "Comme c'est inhabituel, est-ce une mutation? Qu'étaient ces cellules au départ?",
      "avianDescription": "Ces cellules sont d'une taille inquiétante.",
      "floranDescription": "Esst-ce des plantesss, ou de la viandeee?",
      "glitchDescription": "Fasciné. Je n'arrive pas à déterminer l'origine de ces structures.",
      "humanDescription": "Ça me rappelle les cours de physique. Ou c'était de la biologie?",
      "hylotlDescription": "Un objet étrange mais original. Pas particulièrement beau, mais intéressant.",
      "novakidDescription": "Des cellules géantes? Qui a laissé ça là?"
    }
  },
  "cellstructure2": {
    "name": "Structure Cellulaire",
    "desc": "Un étrange méli-mélo de cellules.",
    "metadata": {
      "apexDescription": "Une étrange exposition.",
      "avianDescription": "Une exposition. Cela me rappelle les cristaux d'énergie.",
      "floranDescription": "Chosesss à l'air sspécial.",
      "glitchDescription": "Analyse. Cette structure cellulaire semble être celle d'un Apex modifié.",
      "humanDescription": "Ça me rappelle les cours de physique. Ou c'était de la biologie?",
      "hylotlDescription": "Quand la science rencontre l'art.",
      "novakidDescription": "Des cellules géantes? Qui a laissé ça là?"
    }
  },
  "cellstructure3": {
    "name": "Structure Cellulaire",
    "desc": "Un étrange méli-mélo de cellules.",
    "metadata": {
      "apexDescription": "Une étrange exposition.",
      "avianDescription": "Une exposition. Cela me rappelle les cristaux d'énergie.",
      "floranDescription": "Chosesss à l'air sspécial.",
      "glitchDescription": "Analyse. Cette structure cellulaire semble être celle d'un Apex modifié.",
      "humanDescription": "Ça me rappelle les cours de physique. Ou c'était de la biologie?",
      "hylotlDescription": "Quand la science rencontre l'art.",
      "novakidDescription": "Des cellules géantes? Qui a laissé ça là?"
    }
  },
  "cellstructure4": {
    "name": "Structure Cellulaire",
    "desc": "Un étrange méli-mélo de cellules.",
    "metadata": {
      "apexDescription": "Une étrange exposition.",
      "avianDescription": "Une exposition. Cela me rappelle les cristaux d'énergie.",
      "floranDescription": "Chosesss à l'air sspécial.",
      "glitchDescription": "Analyse. Cette structure cellulaire semble être celle d'un Apex modifié.",
      "humanDescription": "Ça me rappelle les cours de physique. Ou c'était de la biologie?",
      "hylotlDescription": "Quand la science rencontre l'art.",
      "novakidDescription": "Des cellules géantes? Qui a laissé ça là?"
    }
  },
  "cellstructure5": {
    "name": "Structure Cellulaire",
    "desc": "Un étrange méli-mélo de cellules.",
    "metadata": {
      "apexDescription": "Une étrange exposition.",
      "avianDescription": "Une exposition. Cela me rappelle les cristaux d'énergie.",
      "floranDescription": "Chosesss à l'air sspécial.",
      "glitchDescription": "Analyse. Cette structure cellulaire semble être celle d'un Apex modifié.",
      "humanDescription": "Ça me rappelle les cours de physique. Ou c'était de la biologie?",
      "hylotlDescription": "Quand la science rencontre l'art.",
      "novakidDescription": "Des cellules géantes? Qui a laissé ça là?"
    }
  },
  "cellchair": {
    "name": "Chaise Cellulaire",
    "desc": "Une chaise au look moderne et vif.",
    "metadata": {
      "apexDescription": "Une chaise construite à partir de grandes cellules... Plutôt criard.",
      "avianDescription": "Elle a l'air un peu inconfortable...",
      "floranDescription": "Floran préfère quelque chose de pluss sssimple.",
      "glitchDescription": "Peu impressionné. Vive, basique et faite de cellules.",
      "humanDescription": "Une chaise faite de charabia scientifique.",
      "hylotlDescription": "Quelle ostentation, cette chaise manque d'élégance.",
      "novakidDescription": "Si j'avais l'choix entre m'asseoir là-dessus ou par terre, je choisirais l'sol."
    }
  },
  "cellchest": {
    "name": "Coffre Cellulaire",
    "desc": "Un coffre avec une serrure sphérique.",
    "metadata": {
      "apexDescription": "Il a un aspect métallique, mais il est en fait composé de matière organique.",
      "avianDescription": "Le loquet ressemble un peu à une baie, c'est sympa.",
      "floranDescription": "C'est brillant, mais ça a l'air trop bête pour intéresser Floran.",
      "glitchDescription": "Peu enthousiaste. Quel joli coffre...",
      "humanDescription": "Je sais que c'est fait de cellules, mais on dirait des bonbons.",
      "hylotlDescription": "La sobriété n'était pas un concept familier au concepteur de ce coffre.",
      "novakidDescription": "Un peu trop voyant pour y garder quoi que ce soit d'important."
    }
  },
  "celldoor": {
    "name": "Porte Cellulaire",
    "desc": "Une barrière composée de deux barres entrelacées.",
    "metadata": {
      "apexDescription": "Certainement pas une porte sécurisée. Si j'étais plus mince, je pourrais me faufiler sur le côté.",
      "avianDescription": "Elle a l'air un peu fragile.",
      "floranDescription": "Porte sstupide qui tourne et qui sspirale.",
      "glitchDescription": "Exaspéré. Cette porte privilégie clairement la forme sur la fonction.",
      "humanDescription": "Un désordre de porte tout entortillé.",
      "hylotlDescription": "À peine utile et certainement pas belle.",
      "novakidDescription": "Regarder cette porte, c'est comme fixer un baril de sserpents."
    }
  },
  "celllamp": {
    "name": "Lampe Cellulaire",
    "desc": "Une lampe haute, dont chaque lumière est reliée à une autre.",
    "metadata": {
      "apexDescription": "Personne ne pourrait accuser cette lampe d'être utilitaire.",
      "avianDescription": "Même une pie trouverait ça trop brillant.",
      "floranDescription": "Cellules comme bourgeonsss brillantsss.",
      "glitchDescription": "Pensif. Semble inorganique, mais est fait de cellules organiques. Vivant mais pas vivant.",
      "humanDescription": "Joyeux mais peu pratique. Mon genre de truc préféré.",
      "hylotlDescription": "Mes yeux sont offensés.",
      "novakidDescription": "Ça prouve bien qu'les cellules, c'est pas tout c'qu'on raconte."
    }
  },
  "celltable": {
    "name": "Table Cellulaire",
    "desc": "Une table propre aux couleurs vives.",
    "metadata": {
      "apexDescription": "Un peu trop coloré pour le Miniknog, ce qui, je suppose, joue en sa faveur.",
      "avianDescription": "Dire que c'est vif serait un euphémisme.",
      "floranDescription": "Brillant, lissse et ssans âme.",
      "glitchDescription": "Répugné. Je ne pourrais jamais manger sur quelque chose d'aussi criard.",
      "humanDescription": "On dirait un jouet pour enfants.",
      "hylotlDescription": "Cette table est très... flamboyante.",
      "novakidDescription": "C'est une sacrée table brillante."
    }
  },
  "chestavian1": {
    "name": "Coffre Décoratif",
    "desc": "Un coffre orné d'art Avian ancien.",
    "metadata": {
      "apexDescription": "Quelqu'un a passé du temps à décorer ce coffre, il contient peut-être quelque chose de bien.",
      "avianDescription": "Les coffres décoratifs Avians comme celui-ci contiennent parfois de grands trésors.",
      "floranDescription": "Ce coffre essst ssi joli.",
      "glitchDescription": "Excité. Un coffre comme celui-ci pourrait contenir quelque chose de précieux.",
      "humanDescription": "Un coffre! Je devrais jeter un œil à l'intérieur.",
      "hylotlDescription": "Ce coffre est une œuvre d'art. Que pourrait-il y avoir dedans?",
      "novakidDescription": "Ce coffre est vraiment pas mal à r'garder."
    }
  },
  "chestavian2": {
    "name": "Vieux Coffre",
    "desc": "Un vieux coffre humide, façonné de bois et de fer.",
    "metadata": {
      "apexDescription": "Un coffre à l'aspect ancien. Je me demande ce qu'il y a dedans?",
      "avianDescription": "Ce coffre a l'air vieux, mais son contenu pourrait être précieux.",
      "floranDescription": "Très vieux coffre, contient peut-être trésssor.",
      "glitchDescription": "Excité. Un coffre à l'aspect ancien, espérons que le contenu soit utile.",
      "humanDescription": "Trouver un coffre est toujours excitant.",
      "hylotlDescription": "Ce vieux coffre pourrait contenir un trésor.",
      "novakidDescription": "Ce vieux coffre a connu des jours meilleurs."
    }
  },
  "chestmedavian1": {
    "name": "Grand Coffre Décoratif",
    "desc": "Un coffre orné d'art Avian ancien.",
    "metadata": {
      "apexDescription": "Un coffre! Je devrais jeter un œil à l'intérieur.",
      "avianDescription": "Souvent, ces coffres sont construits en grand pour stocker des objets de valeur.",
      "floranDescription": "Coffre géant! Floran va fouiller!",
      "glitchDescription": "Anticipation. Que pourrait-il y avoir dans un coffre aussi grand?",
      "humanDescription": "Un coffre assez grand! Ouvrons-le.",
      "hylotlDescription": "Il y a peu de choses aussi excitantes qu'un coffre non ouvert.",
      "novakidDescription": "Un grand coffre, p'têtre que j'pourrai y dégoter des provisions."
    }
  },
  "chestmedavian2": {
    "name": "Grand Vieux Coffre",
    "desc": "Un grand vieux coffre, façonné de bois et de fer.",
    "metadata": {
      "apexDescription": "Un coffre solide, qu'y a-t-il dedans?",
      "avianDescription": "Ces coffres sont construits sans décoration mais solides, pour protéger leur contenu.",
      "floranDescription": "Un grand coffre! Peut-être de la nourriture dedans.",
      "glitchDescription": "Impatient. Pas de temps à perdre, il y a peut-être des objets de valeur à l'intérieur!",
      "humanDescription": "Un coffre robuste est toujours une vue bienvenue.",
      "hylotlDescription": "Un grand coffre, on dirait qu'il pourrait contenir beaucoup de choses.",
      "novakidDescription": "J'pourrais en mettre des trucs dans un grand vieux coffre comme celui-là."
    }
  },
  "consoletribal1": {
    "name": "Console d'Oiseau Sculptée",
    "desc": "Un panneau d'accès avec un oiseau grossièrement gravé à la base.",
    "metadata": {
      "apexDescription": "Cette technologie est un mystère, mais elle semble avoir un lien avec les cristaux.",
      "avianDescription": "Une console alimentée par cristaux avec une sculpture d'oiseau traditionnelle.",
      "floranDescription": "Panneau d'homme-oiseau a des lumièresss clignotantesss.",
      "glitchDescription": "Curieux. La technologie alimentant cette console m'est inconnue, mais semble liée à ces cristaux.",
      "humanDescription": "Un panneau d'accès avec plein de symboles Avians dessus.",
      "hylotlDescription": "Il n'est pas rare que les Avians décorent leur technologie avec des gravures.",
      "novakidDescription": "Cette console a d'sacrées jolies lumières."
    }
  },
  "consoletribal2": {
    "name": "Console d'Œuf Sculptée",
    "desc": "Un panneau d'accès avec un œuf gravé sur sa base.",
    "metadata": {
      "apexDescription": "Cette mystérieuse console a un œuf sculpté dessus, qu'est-ce que cela signifie?",
      "avianDescription": "Cette console traditionnelle communique par vibrations de cristaux.",
      "floranDescription": "Hommess-oiseaux ont technologie étrange. Floran ne comprend passs.",
      "glitchDescription": "Analytique. Il semble y avoir une sorte d'énergie cristalline à l'œuvre ici que je ne comprends pas.",
      "humanDescription": "Ces panneaux d'accès Avians sont si étranges, où est-ce qu'on les branche?",
      "hylotlDescription": "La technologie Avian est aussi fonctionnelle qu'elle est belle.",
      "novakidDescription": "Tous ces boutons... J'me demande c'qui s'passerait si j'appuyais d'ssus."
    }
  },
  "consoletribal3": {
    "name": "Console de Flamme Sculptée",
    "desc": "Un panneau d'accès avec une flamme sculptée sur sa base.",
    "metadata": {
      "apexDescription": "Les cristaux à l'intérieur de cette console semblent importants, mais je ne comprends pas la technologie.",
      "avianDescription": "Cette console est capable d'interagir avec d'autres appareils grâce aux vibrations des cristaux.",
      "floranDescription": "Console d'homme-oiseau a flammes desss us. Floran détesste le feu.",
      "glitchDescription": "Fasciné. Les cristaux alimentant cette console sont capables de s'interfacer avec d'autres appareils.",
      "humanDescription": "Ce panneau d'accès a des symboles que je ne comprends pas.",
      "hylotlDescription": "Les lumières de cette console sont hypnotiques et magnifiques.",
      "novakidDescription": "Ça m'démange d'appuyer sur certains de ces boutons sophistiqués."
    }
  },
  "consoletribal4": {
    "name": "Grande Console Sculptée",
    "desc": "Un grand panneau de contrôle alimenté par des cristaux Avians.",
    "metadata": {
      "apexDescription": "Ce panneau de contrôle semble vieux, et pourtant je ne comprends pas la technologie.",
      "avianDescription": "Ce panneau peut envoyer des vibrations cristallines pour activer d'autres appareils.",
      "floranDescription": "Étrange technologie d'homme-oisseau. Peut-être Floran devrait prendre pour lui.",
      "glitchDescription": "Curieux. Cette technologie à base de cristaux n'est pas comprise.",
      "humanDescription": "Cette console semble alimentée par des cristaux, comment ça peut bien fonctionner?",
      "hylotlDescription": "On dirait un panneau de contrôle, le design est très plaisant.",
      "novakidDescription": "On dirait un panneau d'contrôle avec des lumières tape-à-l'œil."
    }
  },
  "consoletribalwall": {
    "name": "Panneau de Sécurité Sculpté",
    "desc": "Un petit panneau de sécurité.",
    "metadata": {
      "apexDescription": "Ce panneau d'accès contient une technologie que je ne comprends pas.",
      "avianDescription": "Ces panneaux envoient des vibrations cristallines à d'autres appareils à cristaux.",
      "floranDescription": "Étrange technologie d'homme-oisseau. Floran aimerait dévorer.",
      "glitchDescription": "Mystifié. Cette technologie est nouvelle, même pour mon créateur. Les cristaux à l'intérieur semblent capables de générer un courant électrique pour la compatibilité.",
      "humanDescription": "On dirait une sorte de panneau d'accès. Il ne semble pas nécessiter de source d'énergie.",
      "hylotlDescription": "Une si belle technologie. Je peux la sentir vibrer sous mes doigts.",
      "novakidDescription": "V'là de bien jolis boutons et lumières."
    }
  },
  "crystaltorch": {
    "name": "Torche de Cristal",
    "desc": "Un cristal lévite au-dessus de son support, émettant une lumière étrange.",
    "metadata": {
      "apexDescription": "Le cristal flotte sur place. Il semble générer la lumière.",
      "avianDescription": "Lorsqu'une lumière plus permanente est requise, les Avians utilisent des cristaux à la place des torches. Ils durent plusieurs milliers d'années.",
      "floranDescription": "Lueur étrange. Couleur du ssang.",
      "glitchDescription": "Intrigué. Ce cristal semble flotter, générant son propre champ gravitationnel et produisant également sa propre lumière.",
      "humanDescription": "Le cristal brille mais il est totalement froid au toucher.",
      "hylotlDescription": "Une si belle technologie. Comment les Avians ont-ils appris à la maîtriser?",
      "novakidDescription": "Ce caillou brillant qui flotte éclaire juste comme une torche."
    }
  },
  "cameronstatue": {
    "name": "Statue de Cameron York",
    "desc": "Une statue de Cameron \"KyeTheShy\" York. Aimait l'aventure, mais s'est égaré un peu trop loin... Dans l'espace."
  },
  "cider": {
    "name": "Boisson aux Fruits Chauds",
    "desc": "Acceptable, que vous portiez un jogging et un bonnet ou des pantalons bouffants.",
    "metadata": {
      "apexDescription": "L'odeur écœurante de cette boisson infâme me rappelle des souvenirs.",
      "avianDescription": "Une boisson aux fruits? Les Avians ne réagissent pas bien aux boissons épicées.",
      "floranDescription": "Beurk. Dégoûtantsss liquidesss chaudsss.",
      "glitchDescription": "Aventureux. Je peux imaginer que j'apprécierais une boisson comme celle-ci.",
      "humanDescription": "Une boisson savoureuse... J'en aurais bien besoin d'une là tout de suite.",
      "hylotlDescription": "Les Hylotls boivent du thé, et pas grand-chose d'autre.",
      "novakidDescription": "C'est pas du soda au pissenlit, mais ça fera l'affaire."
    }
  },
  "classicapestatue": {
    "name": "Monument de Big Ape",
    "desc": "Un monument d'une gloire appropriée dédié à un glorieux leader.",
    "metadata": {
      "apexDescription": "Notre glorieux leader...",
      "avianDescription": "Une statue construite pour inspirer la fierté? Ou peut-être la peur?",
      "floranDescription": "Un sssi grand et sssavoureux singe.",
      "glitchDescription": "Humble. L'échelle est-elle correcte?",
      "humanDescription": "C'est une grande statue. Il a l'air sévère.",
      "hylotlDescription": "Une démonstration de pouvoir inutile.",
      "novakidDescription": "Une grande statue d'un Apex à l'air sérieux."
    }
  },
  "classicapestatuenohead": {
    "name": "Statue de Big Ape sans Tête",
    "desc": "Statue de Big Ape dépourvue de tête.",
    "metadata": {
      "apexDescription": "Notre glorieux leader sans tête...",
      "avianDescription": "Une statue construite pour inspirer la fierté? Il semble qu'elle ait été vandalisée.",
      "floranDescription": "Floran préfère le ss singe sans tête.",
      "glitchDescription": "Impressionné. Il a dû falloir un certain effort pour dégrader cette statue.",
      "humanDescription": "Il semble manquer quelque chose à cette statue...",
      "hylotlDescription": "Une démonstration de pouvoir inutile. Quelqu'un d'autre semble être du même avis et a vandalisé cette statue.",
      "novakidDescription": "Une grande statue d'un Apex géant sans tête."
    }
  },
  "classicbardoor": {
    "name": "Porte à Barreaux Classique",
    "desc": "Cette porte est magnifiquement conçue.",
    "metadata": {
      "apexDescription": "Une porte lourde à barreaux. La poignée semble être en or pur.",
      "avianDescription": "Cette porte a été fabriquée avec beaucoup d'amour... ou de peur.",
      "floranDescription": "Porte sssolide. Mais rien n'empêche Floran d'entrer.",
      "glitchDescription": "Impressionné. Un savoir-faire expert est requis pour produire une porte de ce calibre.",
      "humanDescription": "C'est une grande porte de classe.",
      "hylotlDescription": "Un savoir-faire exquis.",
      "novakidDescription": "Grande vieille porte à barreaux avec une poignée brillante."
    }
  },
  "classicbed": {
    "name": "Lit Classique",
    "desc": "Un beau lit fait de bois riche et de soieries.",
    "metadata": {
      "apexDescription": "Est-ce ainsi que le Miniknog dort?",
      "avianDescription": "Je n'ai rien vu d'aussi confortable depuis que j'ai quitté le nid.",
      "floranDescription": "Douceur de sssoie.",
      "glitchDescription": "Confortable. Ce lit fait des merveilles sur mes capteurs.",
      "humanDescription": "Wow, quel lit. Je suis tenté de m'endormir tout de suite.",
      "hylotlDescription": "Une telle finesse, mais cela ne vaut pas l'artisanat Hylotl.",
      "novakidDescription": "Qui aurait besoin d'un lit avec autant de froufrous? Ça a l'air drôlement confortable par contre."
    }
  },
  "classicbookcase": {
    "name": "Bibliothèque Classique",
    "desc": "Une bibliothèque conçue pour être remplie de littérature classique.",
    "metadata": {
      "apexDescription": "Le Miniknog a restreint notre accès aux livres, et nous pensions qu'ils avaient tous été brûlés.",
      "avianDescription": "Ah, les prémices d'une glorieuse bibliothèque. Les livres sont vénérés par les Avians, bien que beaucoup ne sachent pas lire.",
      "floranDescription": "Les Florans partagent le ss savoir par le ss sang et les osss. Une odeur en dit plusss que n'importe quel livre.",
      "glitchDescription": "Curieux. Peut-être y a-t-il ici des connaissances que je pourrais utiliser.",
      "humanDescription": "Est-ce que la bibliothèque est décorée à l'or?",
      "hylotlDescription": "Ces livres devraient être partagés, le savoir devrait être libre.",
      "novakidDescription": "Juste un tas de bouquins dans une bibliothèque sophistiquée."
    }
  },
  "classicbowl": {
    "name": "Bol Classique",
    "desc": "Un bol en porcelaine fine.",
    "metadata": {
      "apexDescription": "Un bol en porcelaine fine. Les Apex reçoivent généralement des bols en plastique.",
      "avianDescription": "Les Avians ne mangent traditionnellement que dans des assiettes.",
      "floranDescription": "Floran esssaye de manger nourriture fraîche de la chasss e.",
      "glitchDescription": "Espiègle. Le son d'un bol qu'on lance est des plus satisfaisants.",
      "humanDescription": "Vaisselle de cuisine assez chic.",
      "hylotlDescription": "Les Hylotls sont également maîtres en porcelaine fine.",
      "novakidDescription": "Ce joli bol est si propre que je peux y voir mon reflet."
    }
  },
  "classiccandlestick": {
    "name": "Chandelier Classique",
    "desc": "Un chandelier doré à trois branches. La cire semble ne jamais fondre.",
    "metadata": {
      "apexDescription": "La base semble être en or massif, mais les flammes sont électroniques.",
      "avianDescription": "La cire ne fond pas et les flammes ne brûlent pas.",
      "floranDescription": "Floran a peur du feu. Mais ce feu-là ne brûle passs.",
      "glitchDescription": "Pensif. Si les flammes ne sont que des ampoules vacillantes, cela rend-il la bougie moins réelle?",
      "humanDescription": "Je pense que les bougies ne sont que des ampoules à effet scintillant.",
      "hylotlDescription": "Une fusion entre technologie et artisanat.",
      "novakidDescription": "C'est une bougie sophistiquée, mais les flammes sont même pas vraies."
    }
  },
  "classicchair": {
    "name": "Chaise Classique",
    "desc": "Une chaise de salle à manger digne de quelqu'un qui apprécie le caviar.",
    "metadata": {
      "apexDescription": "Bois riche et velours doux. Quel luxe...",
      "avianDescription": "Le velours est doux contre mes plumes.",
      "floranDescription": "Velours rouge ssang, la couleur préférée des Florans.",
      "glitchDescription": "Mélancolique. Notre château là-bas avait des chaises similaires.",
      "humanDescription": "Le tissu de cette chaise semble coûter cher.",
      "hylotlDescription": "Des tissus si riches...",
      "novakidDescription": "Cette chaise est un peu trop chic à mon goût."
    }
  },
  "classicchandelier": {
    "name": "Lustre Classique",
    "desc": "Ce lustre est fait de fer forgé. Il a l'air coûteux.",
    "metadata": {
      "apexDescription": "Un magnifique lustre classique.",
      "avianDescription": "Un ensemble de lumières très charmant.",
      "floranDescription": "Même Floran reconnaît la classs e quand il en voit.",
      "glitchDescription": "Admiration. Ils semblent similaires aux lustres Glitch, mais en bien mieux.",
      "humanDescription": "Un lustre électrique. Très joli.",
      "hylotlDescription": "Peut-être que les autres sont plus élégants que je ne le pensais.",
      "novakidDescription": "J'aime cette lampe. On dirait qu'elle devrait être accrochée dans un saloon."
    }
  },
  "classicchest": {
    "name": "Coffre Classique",
    "desc": "Un coffre de classe rempli de trésors de classe!",
    "metadata": {
      "apexDescription": "Un coffre! Qu'y a-t-il à l'intérieur?",
      "avianDescription": "Un coffre doré. Quelque chose d'utile là-dedans?",
      "floranDescription": "Beau coffre!",
      "glitchDescription": "Observateur. Il n'y a pas de serrure.",
      "humanDescription": "Je me sens comme un pirate avec un coffre au trésor.",
      "hylotlDescription": "Un coffre me remplit toujours d'excitation.",
      "novakidDescription": "Un coffre au trésor vraiment pas mal."
    }
  },
  "classicchina": {
    "name": "Vaisselier Classique",
    "desc": "La raison pour laquelle on ne joue pas au ballon dans la maison.",
    "metadata": {
      "apexDescription": "La vaisselle représente les Apex avant la corruption de notre ADN. Beaucoup d'entre nous aspirent à redevenir ce que nous étions.",
      "avianDescription": "Les Apex sur ces assiettes n'ont pas de poils. Je suppose bien sûr que ce sont des Apex.",
      "floranDescription": "Sssinges sstupides, pourquoi enfermer assiettes? Elless ne vont pass s'enfuir.",
      "glitchDescription": "Confus. Les Apex représentés sur ces assiettes semblent avoir évolué. Pourquoi de telles images existent-elles sur de vieilles assiettes?",
      "humanDescription": "La vaisselle ici est couverte d'images d'Apex sans aucune fourrure.",
      "hylotlDescription": "À en juger par les images sur ces pièces, les Apex étaient autrefois une race magnifique.",
      "novakidDescription": "Un tas d'assiettes exposées, je sais pas comment les sortir de là."
    }
  },
  "classiccupboard": {
    "name": "Buffet Classique",
    "desc": "Un grand meuble de rangement de classe.",
    "metadata": {
      "apexDescription": "Un buffet d'apparence coûteuse, peut-être utilisé pour stocker des secrets.",
      "avianDescription": "Un buffet d'une telle magnificence contient peut-être quelque chose d'aussi précieux à l'intérieur.",
      "floranDescription": "Jetons un œil à l'intérieur.",
      "glitchDescription": "Espiègle. Peut-être y a-t-il quelque chose d'utile à l'intérieur.",
      "humanDescription": "Voyons ce qui est rangé là-dedans.",
      "hylotlDescription": "Qu'est-ce qui se cache derrière ces portes somptueuses?",
      "novakidDescription": "On dirait une grande vieille armoire sophistiquée."
    }
  },
  "classiccurtain1": {
    "name": "Rideau Classique",
    "desc": "Le plus classe des rideaux.",
    "metadata": {
      "apexDescription": "Des rideaux riches et lourds.",
      "avianDescription": "Doux au toucher.",
      "floranDescription": "Apex fait rideau avec velours lourd, Floran fait rideau avec p sss eau.",
      "glitchDescription": "Ravi. Peu d'objets sont aussi agréables à caresser.",
      "humanDescription": "Ces rideaux auraient leur place dans un manoir.",
      "hylotlDescription": "Ces rideaux collent presque à la peau des Hylotls.",
      "novakidDescription": "Ces rideaux ont l'air d'être là juste pour la frime."
    }
  },
  "classiccurtain2": {
    "name": "Draperie Classique",
    "desc": "La plus classe des draperies.",
    "metadata": {
      "apexDescription": "Des rideaux riches et lourds.",
      "avianDescription": "Doux au toucher.",
      "floranDescription": "Apex fait rideau avec velours lourd, Floran fait rideau avec p sss eau.",
      "glitchDescription": "Ravi. Peu d'objets sont aussi agréables à caresser.",
      "humanDescription": "Ces rideaux auraient leur place dans un manoir.",
      "hylotlDescription": "Ces rideaux collent presque à la peau des Hylotls.",
      "novakidDescription": "Ces rideaux ont l'air d'être là juste pour la frime."
    }
  },
  "classiccurtain3": {
    "name": "Draperie Fine Classique",
    "desc": "De fines draperies suspendues. Très classe.",
    "metadata": {
      "apexDescription": "Des rideaux riches et lourds.",
      "avianDescription": "Doux au toucher.",
      "floranDescription": "Apex fait rideau avec velours lourd, Floran fait rideau avec p sss eau.",
      "glitchDescription": "Ravi. Peu d'objets sont aussi agréables à caresser.",
      "humanDescription": "Ces rideaux auraient leur place dans un manoir.",
      "hylotlDescription": "Ces rideaux collent presque à la peau des Hylotls.",
      "novakidDescription": "Ces rideaux ont l'air d'être là juste pour la frime."
    }
  },
  "classicdesk": {
    "name": "Bureau Classique",
    "desc": "Le genre de bureau utilisé exclusivement pour prendre des décisions importantes.",
    "metadata": {
      "apexDescription": "Quelles décisions atroces ont été prises à ce bureau?",
      "avianDescription": "Bien que les Avians n'accordent pas autant de valeur à l'or que certains, je suis émerveillé par l'artisanat exposé ici.",
      "floranDescription": "Un bureau sssi brillant. Peut-être que les hommess-singes sont aveuglés quand décisions sont prisess.",
      "glitchDescription": "Émerveillé. Les Glitchs accordent une grande valeur à l'or ; on pourrait acheter un petit donjon avec un tel bureau.",
      "humanDescription": "Je ne me sens pas assez important pour m'asseoir à un bureau comme celui-là.",
      "hylotlDescription": "Parfois, les humbles prennent les meilleures décisions.",
      "novakidDescription": "Ce bureau a l'air d'être fait pour être regardé, pas pour être utilisé."
    }
  },
  "classicdiningtable": {
    "name": "Table à Manger Classique",
    "desc": "Pour quand on veut affirmer son statut social via son mobilier.",
    "metadata": {
      "apexDescription": "Une table extravagante par rapport aux standards quotidiens des Apex.",
      "avianDescription": "Je n'ai jamais vu une table aussi grande. Les Avians ont tendance à dîner seuls.",
      "floranDescription": "Fessstin! Une table assez grande pour beaucoup de nourriturere.",
      "glitchDescription": "Nostalgique. Les Glitchs organisaient de grands banquets sur des tables comme celle-ci. Il y avait des chants, des danses et un bouffon pour amuser l'hôte.",
      "humanDescription": "Quelle table à manger. On dirait qu'elle est neuve, à peine utilisée.",
      "hylotlDescription": "Les Hylotls pensent qu'une table doit être pleine avant que le repas ne commence. Ici, il ne commencerait peut-être jamais.",
      "novakidDescription": "Cette table est immense! Sa forme rendrait l'jeu de cartes assez difficile, par contre."
    }
  },
  "classicdoor": {
    "name": "Porte Classique",
    "desc": "Une porte classique en bois infusé à la banane avec une poignée dorée.",
    "metadata": {
      "apexDescription": "La poignée est en or massif et le bois sent la banane.",
      "avianDescription": "Une telle porte n'est ouverte qu'à très peu de gens.",
      "floranDescription": "L'odeur du fruit jaune des Apex vient du boiss.",
      "glitchDescription": "Irrité. Mes capteurs détectent une odeur unique provenant de cette porte.",
      "humanDescription": "Est-ce que cette porte... sent la banane?",
      "hylotlDescription": "Du bois parfumé, une pratique courante dans l'artisanat Hylotl.",
      "novakidDescription": "Cette poignée est drôlement brillante."
    }
  },
  "classicfountain": {
    "name": "Fontaine d'Eau",
    "desc": "Une fontaine ornée - une grande partie de l'eau semble être gaspillée.",
    "metadata": {
      "apexDescription": "L'eau de cette fontaine a un goût... plus propre que l'eau pompée dans les foyers Apex.",
      "avianDescription": "Par mes plumes, enfin un bain!",
      "floranDescription": "Floran aime l'eau, l'eau donne la croissss ance et la vie.",
      "glitchDescription": "Curieux. Les scans montrent que cette eau est entièrement pure.",
      "humanDescription": "D'où vient toute cette eau? Elle ne semble pas être récupérée.",
      "hylotlDescription": "Ici, l'eau n'est ni collectée ni réutilisée, un tel gaspillage est monstrueux.",
      "novakidDescription": "Un bon endroit pour s'arrêter un instant et boire un coup."
    }
  },
  "classicglass": {
    "name": "Verre en Cristal",
    "desc": "Une douce odeur de jus de fruit persiste.",
    "metadata": {
      "apexDescription": "Un verre pour le jus. Ces jus ont été interdits pendant la prohibition.",
      "avianDescription": "Les Avians n'ont pas de méthode pour façonner le cristal de cette manière.",
      "floranDescription": "Odeur dégoûtante de fruit à l'intérieur.",
      "glitchDescription": "Analytique. Le verre semble avoir contenu un jus de fruit.",
      "humanDescription": "L'odeur me rappelle les jus de fruits tropicaux.",
      "hylotlDescription": "Le cristal nécessite des doigts agiles pour être façonné ainsi.",
      "novakidDescription": "Un verre sophistiqué pour des boissons sophistiquées, j'imagine."
    }
  },
  "classiclight": {
    "name": "Applique Classique",
    "desc": "Une jolie applique murale en fer.",
    "metadata": {
      "apexDescription": "L'éclat de cette lampe est chaud et réconfortant.",
      "avianDescription": "Le travail du fer surpasse celui des forgerons de lances Avians.",
      "floranDescription": "Pas de feu qui brûle à l'intérieur.",
      "glitchDescription": "Confus. Le design et la fonction ne correspondent pas. La lampe fournit de l'oxygène pour une flamme, pourtant, l'appareil est entièrement électrique.",
      "humanDescription": "Une lampe électrique. On dirait qu'elle a été construite pour accueillir une flamme.",
      "hylotlDescription": "La lampe semble conçue pour abriter une flamme mais elle est entièrement électrique.",
      "novakidDescription": "Cette lampe a l'air d'avoir sa place dans un saloon."
    }
  },
  "classiclightart": {
    "name": "Plafonnier Classique",
    "desc": "Un spot de plafond. Éclairage idéal pour les œuvres d'art raffinées.",
    "metadata": {
      "apexDescription": "Conçu pour diriger la lumière vers un tableau.",
      "avianDescription": "Une lumière bien faible, faite pour attirer l'attention sur un seul point.",
      "floranDescription": "Lumière pour gribouillisss peints.",
      "glitchDescription": "Inspiré. Une lumière inclinée de cette façon serait parfaite au-dessus des œuvres d'art Glitch.",
      "humanDescription": "Lumières de galerie. Parfait pour illuminer l'art.",
      "hylotlDescription": "Le jeu de lumière peut sublimer même le plus beau travail au pinceau.",
      "novakidDescription": "Cette lampe a l'air faite pour éclairer une peinture."
    }
  },
  "classicmug": {
    "name": "Chope Classique",
    "desc": "Une chope en porcelaine fine.",
    "metadata": {
      "apexDescription": "Une chope pour jus chaud. Ces jus ont été interdits pendant la prohibition.",
      "avianDescription": "Les Avians n'ont pas de tasses avec cette forme.",
      "floranDescription": "Odeur dégoûtante de fruit à l'intérieur.",
      "glitchDescription": "Analytique. Le verre semble avoir contenu un jus de fruit chauffé.",
      "humanDescription": "L'odeur me rappelle les jus de fruits tropicaux.",
      "hylotlDescription": "Les Hylotls ont adopté un format plus petit pour boire des boissons chaudes.",
      "novakidDescription": "Un verre assez massif pour les boissons chaudes, j'imagine."
    }
  },
  "classicpillarsmall": {
    "name": "Petit Pilier",
    "desc": "Pour exposer les objets les plus chics, ou soutenir les plus petits bâtiments.",
    "metadata": {
      "apexDescription": "Le pilier est une œuvre d'art en soi.",
      "avianDescription": "Un travail de la pierre qui rivalise avec celui des Avians.",
      "floranDescription": "Floran apprécie travail de la pierre avec un tel ssssavoir-faire.",
      "glitchDescription": "Appréciatif. Travail égal à celui des tailleurs de pierre Glitch.",
      "humanDescription": "Construit pour exposer des objets précieux.",
      "hylotlDescription": "Maçonnerie avancée. Les Apex possèdent de nombreuses compétences.",
      "novakidDescription": "Un joli présentoir en pierre. Pratique pour frimer."
    }
  },
  "classicplate": {
    "name": "Assiette Classique",
    "desc": "Une assiette en porcelaine fine.",
    "metadata": {
      "apexDescription": "Une assiette en porcelaine fine. Les Apex reçoivent généralement des assiettes en plastique.",
      "avianDescription": "Les Avians ne mangent traditionnellement que dans des bols.",
      "floranDescription": "Floran esssaye de manger nourriture fraîche de la chassse.",
      "glitchDescription": "Espiègle. Le son d'une assiette qu'on lance est des plus satisfaisants.",
      "humanDescription": "Vaisselle de cuisine assez chic.",
      "hylotlDescription": "Les Hylotls sont également maîtres en porcelaine fine.",
      "novakidDescription": "Cette jolie assiette est si propre que je peux y voir mon reflet."
    }
  },
  "classictable": {
    "name": "Table Classique",
    "desc": "Idéale pour organiser de petits dîners.",
    "metadata": {
      "apexDescription": "Une table en bois attrayante. L'Apex moyen ne pourrait pas se l'offrir en une vie entière.",
      "avianDescription": "Un excellent choix de bois.",
      "floranDescription": "Excellent travail. Apex doués pour le travail du boiss.",
      "glitchDescription": "Impressionné. Bien faite, avec un choix de matériaux exquis.",
      "humanDescription": "Le genre de table où on ne devrait pas poser les coudes.",
      "hylotlDescription": "Beau travail, bien que manquant de modestie.",
      "novakidDescription": "Cette table est à la hauteur parfaite pour s'adosser et reposer mes jambes."
    }
  },
  "challengedoor": {
    "name": "Porte de Défi",
    "desc": "Un portail mystérieux menant vers une dimension inconnue. Qu'est-ce qui pourrait mal se passer?",
    "metadata": {
      "apexDescription": "Une étrange porte à trouver par ici. Vers quelle dimension pourrait-elle me mener?",
      "avianDescription": "Une porte de mauvais augure qui pourrait mener vers n'importe quelle dimension.",
      "floranDescription": "Porte mysssterieuse. Où peut-elle mener?",
      "glitchDescription": "Prudent. Suis-je prêt à affronter ce qui se trouve de l'autre côté de ce portail?",
      "humanDescription": "Un portail mystérieux menant vers une dimension inconnue. Qu'est-ce qui pourrait mal se passer?",
      "hylotlDescription": "Un passage énigmatique vers une destination inconnue... ou une opportunité dissimulée?",
      "novakidDescription": "Qu'est-ce qu'une porte pareille fiche ici?"
    }
  },
  "challengereturndoor": {
    "name": "Porte de Défi",
    "desc": "J'espère vraiment que cette porte me ramènera à la réalité!",
    "metadata": {
      "apexDescription": "Ce portail doit être la sortie.",
      "avianDescription": "Merci Kluex. Je pense que c'est mon chemin vers la sortie.",
      "floranDescription": "Floran pense que c'essst la porte pour sortir.",
      "glitchDescription": "Espérant. Sûrement, cela doit être le chemin pour sortir d'ici.",
      "humanDescription": "J'espère vraiment que cette porte me ramènera à la réalité!",
      "hylotlDescription": "Tout ce qui a un commencement doit avoir une fin. Il est temps pour moi de quitter cet endroit.",
      "novakidDescription": "Il est temps pour moi d'quitter c'te endroit."
    }
  },
  "capricoataf": {
    "name": "Figurine de Capricoat",
    "desc": "L'étiquette indique: \"Son pelage épais le garde au chaud dans les climats les plus froids.\""
  },
  "cosmicintruderaf": {
    "name": "Figurine d'Intrus Cosmique",
    "desc": "L'étiquette indique: \"Une entité née en dehors de l'espace physique et du temps.\""
  },
  "crabcanoaf": {
    "name": "Figurine de Crabcano",
    "desc": "L'étiquette indique: \"Il est toujours sur les nerfs. Il marche de côté et entre en éruption à la moindre confrontation.\""
  },
  "crustoiseaf": {
    "name": "Figurine de Crustoise",
    "desc": "L'étiquette indique: \"Ses pointes acérées peuvent transpercer n'importe quelle botte spatiale.\""
  },
  "crutteraf": {
    "name": "Figurine de Crutter",
    "desc": "L'étiquette indique: \"Son poison est mortel, même à petite dose.\""
  }
