      "floranDescription": "Lance doit avoir appartenu à ssolide chasss eur Floran.",
      "glitchDescription": "Inspiré. Cette lance appartenait à un puissant guerrier Floran qui a remporté une sorte de grande chasse.",
      "humanDescription": "D'après l'inscription sur le socle, cette lance appartenait autrefois à un chasseur Floran victorieux.",
      "hylotlDescription": "Si l'on en croit les inscriptions, cette lance appartenait autrefois à un chasseur Floran victorieux.",
      "novakidDescription": "Cette lance bien aiguisée semble avoir appartenu à un vieux chasss eur."
    }
  },
  "cinderfly": {
    "name": "Mouche des Cendres",
    "desc": "S'épanouit dans des conditions désolées."
  },
  "cavebed": {
    "name": "Lit de Roche",
    "desc": "Un lit fait de roche.",
    "metadata": {
      "apexDescription": "Ce lit n'est pas conçu pour le confort.",
      "avianDescription": "C'est un lit froid et dur.",
      "floranDescription": "Un lit fait de pierresss.",
      "glitchDescription": "Confiant. Ce lit robuste durera de nombreuses générations.",
      "humanDescription": "C'est mieux que de dormir par terre j'imagine...",
      "hylotlDescription": "Apparemment, dormir sur une surface dure est bon pour le dos.",
      "novakidDescription": "Soudain, je ne me sens plus si fatigué."
    }
  },
  "cavechair": {
    "name": "Chaise de Roche",
    "desc": "Une chaise en roche.",
    "metadata": {
      "apexDescription": "Elle n'a pas l'air confortable.",
      "avianDescription": "On dirait qu'elle a été extraite directement de la nature.",
      "floranDescription": "Floran mettrait au moinsss de la mousse dessus.",
      "glitchDescription": "Contemplatif. Où s'arrête le rocher et où commence la chaise?",
      "humanDescription": "J'ai mal au derrière rien qu'en la regardant.",
      "hylotlDescription": "Une simple chaise sculptée dans la roche.",
      "novakidDescription": "Je pense que c'est pour s'asseoir."
    }
  },
  "cavechest": {
    "name": "Coffre de Roche",
    "desc": "Un coffre fait de roche.",
    "metadata": {
      "apexDescription": "Un coffre fait de roche ordinaire.",
      "avianDescription": "Il a l'air simple, mais il peut contenir des richesses.",
      "floranDescription": "Ça ssemble être un bon endroit pour ranger desss trucs.",
      "glitchDescription": "Impressionné. C'est un coffre habilement camouflé.",
      "humanDescription": "Je l'ai presque confondu avec un simple rocher.",
      "hylotlDescription": "C'est un coffre au design simple, mais il remplit bien son rôle.",
      "novakidDescription": "Le couvercle est lourd."
    }
  },
  "cavelamp": {
    "name": "Lampe Stalactite",
    "desc": "Une stalactite luminescente.",
    "metadata": {
      "apexDescription": "C'est une source de lumière primitive.",
      "avianDescription": "Je vais éviter de rester juste en dessous, par sécurité.",
      "floranDescription": "Une lampe qui a l'air de vouloir sssaigner.",
      "glitchDescription": "Curieux. Comment ont-ils mis la lumière à l'intérieur de cette stalactite?",
      "humanDescription": "J'espère qu'elle ne me tombera pas sur la tête.",
      "hylotlDescription": "Cela semble dangereux, mais cela fournit une source de lumière.",
      "novakidDescription": "C'est une stalactite qui brille."
    }
  },
  "ceilingstalactite1": {
    "name": "Stalactite de Roche",
    "desc": "C'est une vieille stalactite de roche.",
    "metadata": {
      "apexDescription": "Une pointe acérée, faite de roche.",
      "avianDescription": "Ce rocher ressemble à une lance.",
      "floranDescription": "Ssstalactite.",
      "glitchDescription": "Prudent. Une stalactite peut tomber et percer la carapace d'un Glitch.",
      "humanDescription": "Je ne sais plus jamais si c'est une stalactite ou une stalagmite.",
      "hylotlDescription": "Une stalactite magnifique et polie.",
      "novakidDescription": "Une stalactite. J'espère qu'elle est bien fixée."
    }
  },
