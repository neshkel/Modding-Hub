  "copperrock": {
    "name": "Rocher de Cuivre",
    "desc": "Un rocher fissuré rempli de cuivre.",
    "metadata": {
      "apexDescription": "Il semble y avoir du cuivre à l'intérieur de ce rocher fragile.",
