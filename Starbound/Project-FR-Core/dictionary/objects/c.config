  "caveart1": {
    "name": "Peinture Rupestre Animale",
    "desc": "Art rupestre représentant des animaux.",
    "metadata": {
      "apexDescription": "Peinture rudimentaire d'un animal.",
      "avianDescription": "Cette peinture maladroite pourrait être aussi vieille que les étoiles.",
      "floranDescription": "Peinture par les anciens Floransss.",
      "glitchDescription": "Neutre. Cette peinture semble représenter des bêtes organiques.",
      "humanDescription": "Pourquoi toutes les peintures rupestres se ressemblent? Soyez originaux!",
      "hylotlDescription": "Cette peinture n'est pas aussi élégante que l'art antique Hylotl.",
      "novakidDescription": "Une très vieille peinture à en juger par l'aspect."
    }
  },
  "caveart2": {
    "name": "Peinture Rupestre de Chasseurs",
    "desc": "Art rupestre représentant des chasseurs.",
    "metadata": {
      "apexDescription": "Un dessin d'anciens chasseurs.",
      "avianDescription": "Cette représentation de chasseurs semble être antique.",
      "floranDescription": "Chassseurs Floransss.",
      "glitchDescription": "Neutre. La peinture dépeint des figures avec des arcs, probablement des chasseurs Florans.",
      "humanDescription": "Les proportions sont toutes fausses. J'aurais pu faire mieux.",
      "hylotlDescription": "Encore des représentations artistiques rudimentaires des Florans.",
      "novakidDescription": "On dirait qu'ils chassent, si j'ne m'trompe pas."
    }
  },
  "caveart3": {
    "name": "Peinture Rupestre de Figure",
    "desc": "Art rupestre représentant une grande figure.",
    "metadata": {
      "apexDescription": "Une représentation d'une sorte de rituel ou de cérémonie?",
      "avianDescription": "Qui est cette figure géante? Elle brille comme le soleil lui-même.",
      "floranDescription": "Même Floran n'essst pas ssûr de ce que ça veut dire.",
      "glitchDescription": "Effrayé. Quelque chose dans ce dessin semble incroyablement ancien.",
      "humanDescription": "Cette peinture ressemble à une personne géante, brillant comme le soleil.",
      "hylotlDescription": "Peut-être que l'artiste voulait inspirer le spectateur à travers ce dessin.",
      "novakidDescription": "Qu'est-ce qui s'passe ici, par les étoiles?"
    }
  },
  "caveart4": {
    "name": "Peinture Rupestre Ambiguë",
    "desc": "Art rupestre représentant un être à tentacules.",
    "metadata": {
      "apexDescription": "Je suis soudainement envahi par l'effroi.",
      "avianDescription": "Est-ce que ça pourrait vraiment être une peinture de...? Oh mon Dieu.",
      "floranDescription": "Floran ne veut pluss jamais voir ça.",
      "glitchDescription": "Terrifié. Peut-être que je me trompe, mais... cette peinture m'est douloureusement familière.",
      "humanDescription": "Oh non... comment une image de ça a pu arriver ici?!",
      "hylotlDescription": "Cela rappelle de mauvais souvenirs.",
      "novakidDescription": "C'est pas c'que j'voulais voir aujourd'hui."
    }
  },
  "caveart5": {
    "name": "Peinture Rupestre Mystérieuse",
    "desc": "Art rupestre représentant une offrande.",
    "metadata": {
      "apexDescription": "Est-ce un être ancien donnant quelque chose aux Florans?",
      "avianDescription": "Cela semble montrer un être immense donnant quelque chose à des figures joyeuses.",
      "floranDescription": "Cette image montre une grande cho sse offrant un cadeau aux Florans.",
      "glitchDescription": "Intrigué. Cela semble être une reproduction rudimentaire d'un événement survenu il y a longtemps.",
      "humanDescription": "Je me demande de quand date cette peinture?",
      "hylotlDescription": "Cette peinture semble montrer un grand être offrant un cadeau d'une importance majeure à des gens en dessous de lui.",
      "novakidDescription": "Cette peinture montre quelqu'un de grand offrant un cadeau. Ça m'dit quelque chose."
    }
  },
  "checkpoint": {
    "name": "Point de Contrôle de Mission",
    "desc": "Si vous mourez, vous réapparaîtrez à cet endroit.",
    "metadata": {
      "apexDescription": "Ceci me permettra de continuer... si je devais échouer.",
      "avianDescription": "Il semble que si je péris, je reviendrai à ce point.",
      "floranDescription": "Ceci permet à Floran de revenir ici ssi les cho sses tournent mal!",
      "glitchDescription": "Pensif. Peut-on vraiment périr si nous réapparaissons toujours?",
      "humanDescription": "La technologie moderne est incroyable, si je meurs, je reviens ici!",
      "hylotlDescription": "Assez intéressant, je peux revivre si je péris grâce à cela.",
      "novakidDescription": "J'comprends pas tout, mais j'reviendrai ici si je casse ma pipe."
    }
  },
  "classicbanner1": {
    "name": "Haut de Bannière Classique",
    "desc": "Le rideau le plus élégant.",
    "metadata": {
      "apexDescription": "De riches et lourds rideaux.",
      "avianDescription": "Doux au toucher.",
      "floranDescription": "Hylotl fait rideaux avec velours épais, Floran fait rideaux avec ppeau.",
      "glitchDescription": "Appréciatif. Peu d'objets sont aussi agréables à caresser.",
      "humanDescription": "Ces rideaux auraient leur place dans un manoir.",
      "hylotlDescription": "Ces rideaux collent presque à la peau Hylotl.",
      "novakidDescription": "Très chic."
    }
  },
