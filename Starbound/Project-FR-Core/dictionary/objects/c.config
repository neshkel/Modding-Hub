{
  "countdowntimer": {
    "name": "Compte à rebours",
    "desc": "Un minuteur qui reste actif pendant une durée définie.",
    "metadata": {
      "floranDescription": "Un minuteur qui resssste actif pendant une durée définie.",
      "glitchDescription": "Impressionné. Un minuteur qui reste actif pendant une durée définie."
    }
  },
  "crystaltrap": {
    "name": "Piège en cristal sculpté",
    "desc": "Un piège en cristal conçu pour dissuader les envahisseurs.",
    "metadata": {
      "apexDescription": "Ce cristal forme un faisceau lumineux mortel.",
      "avianDescription": "Je ne voudrais pas me retrouver pris dans ce faisceau.",
      "floranDescription": "Faisceau de crissstal fait mal à Floran.",
      "glitchDescription": "Surpris. Un cristal qui projette des faisceaux de lumière mortels! J'ai tout vu maintenant.",
      "humanDescription": "Ce faisceau a l'air de faire mal.",
      "hylotlDescription": "Si je mémorise le motif du faisceau du cristal, je pourrai agir en conséquence.",
      "novakidDescription": "J'fais bien d'faire gaffe, ces rayons d'lumière pourraient m'griller."
    }
  },
  "coralmirror": {
    "name": "Miroir de corail",
    "desc": "Un miroir mural serti dans un cadre en corail.",
    "metadata": {
      "apexDescription": "La qualité de réflexion de ce miroir est médiocre.",
      "avianDescription": "Le reflet dans ce miroir est trouble, recèle-t-il des mystères?",
      "floranDescription": "Regarder dans le miroir essst comme être sssous l'eau.",
      "glitchDescription": "Insatisfait. La qualité de ce reflet est aussi trouble que de regarder à travers l'eau.",
      "humanDescription": "Le reflet dans ce miroir est trouble, comme si on regardait à travers de l'eau. Ou de la soupe.",
      "hylotlDescription": "Bien que j'apprécie la qualité décorative, le miroir s'est opacifié.",
      "novakidDescription": "L'reflet dans c'miroir est aussi trouble qu'un jour de cagnard dans l'désert."
    }
  },
  "cabinbunkbed": {
    "name": "Lits superposés de cabane",
    "desc": "Quoi de mieux qu'un lit? Deux lits!",
    "metadata": {
      "apexDescription": "Est-ce que le lit du haut sert à guetter les ennemis en approche? Je ne comprends pas.",
      "avianDescription": "Les lits superposés sont si utiles pour les espaces partagés!",
      "floranDescription": "Floran n'aime passs dormir sssi loin du sssol.",
      "glitchDescription": "Inquiet. J'espère qu'il ne va pas s'effondrer pendant qu'on l'utilise.",
      "humanDescription": "Le lit superposé est une invention magnifique. Je suis content qu'il ait résisté à l'épreuve du temps.",
      "hylotlDescription": "L'ingéniosité de ce meuble est gâchée par la literie rudimentaire.",
      "novakidDescription": "Moi, j'préférerais dormir sur l'lit du haut, plus près des étoiles."
    }
  },
  "cabinchair": {
    "name": "Chaise de cabane",
    "desc": "Un vieux fauteuil à bascule sculpté à la main.",
    "metadata": {
      "apexDescription": "Je crois que je préfère que mes meubles restent immobiles.",
      "avianDescription": "Des meubles sculptés à la main! Je peux apprécier cela.",
      "floranDescription": "Floran aime l'odeur de boisss de la chaise courbée.",
      "glitchDescription": "Inquiet. Une chaise qui ne reste pas immobile doit donner le tournis.",
      "humanDescription": "Ça me donne envie de me balancer d'avant en arrière tout en jouant du banjo.",
      "hylotlDescription": "C'est l'une des plus jolies chaises en bois que j'ai pu voir.",
      "novakidDescription": "Les chaises à bascule - C'est encore mieux qu'les chaises qui bougent pas."
    }
  },
  "cabinlamp": {
    "name": "Lampe de cabane",
    "desc": "Une lampe électrique avec un support en bois sculpté à la main.",
    "metadata": {
      "apexDescription": "Je suppose que la forme incurvée de cette lampe est censée être attrayante.",
      "avianDescription": "Une lampe plutôt agréable. Elle pourrait être plus belle si elle avait la forme d'un oiseau.",
      "floranDescription": "Floran préfère lesss plantesss luissssantesss.",
      "glitchDescription": "Confus. Si c'est du bois, comment peut-il s'éclairer?",
      "humanDescription": "Je suppose que c'est une lampe moderne qui fait semblant d'être vieille.",
      "hylotlDescription": "Cela semble être un gaspillage de ressources naturelles.",
      "novakidDescription": "J'préfère les lampes à gaz, mais ça fait l'affaire."
    }
  },
  "cabinornament": {
    "name": "Bois de Cerf Décoratifs",
    "desc": "Une paire de bois de cerf imposante. À quel genre de créature appartenaient-ils?",
    "metadata": {
      "apexDescription": "Accrocher des bois sur un mur est un gaspillage de ressources.",
      "avianDescription": "Quel étalage grossier.",
      "floranDescription": "Floran approuve le trophée de chassse.",
      "glitchDescription": "Surpris. En y regardant de plus près, ces bois semblent être de nature artificielle.",
      "humanDescription": "Les ornements en bois de cerf sont une décoration classique... je ne sais pas pourquoi.",
      "hylotlDescription": "Bien qu'il soit clairement artificiel, cela reste un ornement rudimentaire.",
      "novakidDescription": "Ces bois sont un étalage un peu effronté, n'est-ce pas?"
    }
  },
  "cabinstooltable": {
    "name": "Table Tabouret de Cabane",
    "desc": "Une petite table en bois à trois pieds.",
    "metadata": {
      "apexDescription": "Si c'était du métal, ce serait plus robuste.",
      "avianDescription": "Une petite table plutôt sympathique.",
      "floranDescription": "Floran sse demande jusqu'où Floran pourrait lancer ça.",
      "glitchDescription": "Ravi. Cette petite table sera utile pour poser des objets.",
      "humanDescription": "Une petite table en bois. Tout ce qu'il lui faut, c'est un livre, et peut-être une lampe.",
      "hylotlDescription": "Cette petite table semble inachevée. Peut-être qu'une couche de peinture aiderait.",
      "novakidDescription": "Je pourrais trouver une douzaine d'utilisations pour un vieux truc comme ça."
    }
  },
  "cabinstove": {
    "name": "Poêle de Cabane",
    "desc": "Un poêle en métal pittoresque, parfait pour cuisiner.",
    "metadata": {
      "interactData.paneLayoutOverride.windowtitle.title": " Poêle de Cabane",
      "interactData.paneLayoutOverride.windowtitle.subtitle": " Cuisine au feu de bois",
      "apexDescription": "Parfois, les méthodes les plus simples pour se chauffer sont les meilleures.",
      "avianDescription": "Je me demande si ce feu ouvert convient pour rôtir des noix?",
      "floranDescription": "Floran inquiète près des feux chaudsss...",
      "glitchDescription": "Paisible. Le feu est rudimentaire, mais apaisant.",
      "humanDescription": "Un vieux poêle à bois! Est-ce que quelqu'un a des guimauves?",
      "hylotlDescription": "Ce n'est pas la manière la plus efficace de produire de la chaleur.",
      "novakidDescription": "Y'a peu d'choses que j'aime plus que d'être assis près d'un vieux feu."
    }
  },
  "cabintable": {
    "name": "Table de Cabane",
    "desc": "Une table en bois classique, adaptée à tout environnement.",
    "metadata": {
      "apexDescription": "Il n'a fallu que quatre pièces de bois pour faire ça. Impressionnant.",
      "avianDescription": "Je pourrais graver mon nom dessus, mais ce serait impoli.",
      "floranDescription": "Floran préférerait que ce ssoit couvert d'épinesss.",
      "glitchDescription": "Ravi. C'est en fait une table plutôt jolie.",
      "humanDescription": "On dirait une table de pique-nique. Quelqu'un a apporté des snacks?",
      "hylotlDescription": "Je suppose que j'ai vu pire comme design de table...",
      "novakidDescription": "Ça ne me dérangerait pas de faire une partie de cartes à cette table."
    }
  },
  "colonydeed": {
    "name": "^yellow;Contrat de Colonie",
    "desc": "Placez-le dans un bâtiment clos avec au moins une porte et une source de lumière, et quelqu'un emménagera!",
    "metadata": {
      "apexDescription": "S'il est placé dans un bâtiment avec une porte et une lumière, cela encouragera quelqu'un à emménager.",
      "avianDescription": "Cet appareil invitera quelqu'un à emménager. Assurez-vous simplement qu'il y ait une porte et une lumière.",
      "floranDescription": "Écrrran à accrocher au mur. Fait emménager quelqu'un dans la maisson!",
      "glitchDescription": "Observateur. S'il est placé dans un bâtiment correctement structuré, ce contrat encouragera quelqu'un à emménager.",
      "humanDescription": "C'est génial pour agrandir une colonie. Placez-le avec une porte et une lumière et quelqu'un viendra.",
      "hylotlDescription": "Si accroché dans un bâtiment clos avec porte et lumière, quelqu'un s'y installera pour en faire son foyer.",
      "novakidDescription": "Avec un contrat de colonie, quelqu'un viendra habiter là. Faut juste une porte et d'la lumière."
    }
  },
  "coffeemachine": {
    "name": "Machine à Café",
    "desc": "Une machine à café, pour un remontant parfait.",
    "metadata": {
      "subtitle": "Une tasse de pur bonheur",
      "apexDescription": "Cette machine produit un liquide noir et amer.",
      "avianDescription": "J'aime bien l'odeur de ça.",
      "floranDescription": "Une machine à boissonsss qui ssent fort.",
      "glitchDescription": "Neutre. Une machine à café.",
      "humanDescription": "Un sacré bon café.",
      "hylotlDescription": "Une boisson amère et déplaisante.",
      "novakidDescription": "Noir, sans lait, sans sucre. Je dis pas non!"
    }
  },
  "customsign": {
    "name": "Enseigne",
    "desc": "Un panneau d'affichage personnalisé.",
    "metadata": {
      "apexDescription": "Une bonne signalisation publique est indispensable pour toute civilisation.",
      "avianDescription": "L'écriture Avian originale a été perdue au fil des âges.",
      "floranDescription": "Mots mots motsss",
      "glitchDescription": "Pensif. Un panneau est comme une interface primitive.",
      "humanDescription": "Les panneaux servent aux infos vitales, ou aux jeux de mots nuls.",
      "hylotlDescription": "Bien que cela ne soutienne pas la comparaison avec la calligraphie Hylotl, ça fera l'affaire.",
      "novakidDescription": "Une sorte de panneau."
    }
  },
  "ceilingspike1": {
    "name": "Stalactite",
    "desc": "Attention!",
    "metadata": {
      "apexDescription": "Des pointes de pierre acérées.",
      "avianDescription": "La pierre semble tranchante comme un rasoir.",
      "floranDescription": "Tranchant et pointu.",
      "glitchDescription": "Prudent. La roche tranchante pourrait pénétrer la carapace Glitch.",
      "humanDescription": "Je ferais mieux de ne pas toucher à ça.",
      "hylotlDescription": "Je vais les éviter avec grâce.",
      "novakidDescription": "Ça a l'air drôlement pointu, j'suis prêt à déguerpir d'ici!"
    }
  },
