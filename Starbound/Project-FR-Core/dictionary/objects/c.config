  "classicbannertattered": {
    "name": "Bannière Classique Lambeaux",
    "desc": "C'était le rideau le plus chic. Maintenant, il est un peu en lambeaux.",
    "metadata": {
      "apexDescription": "Qu'est-il arrivé à ce beau rideau?",
      "avianDescription": "Quelqu'un a ruiné ce rideau?",
      "floranDescription": "Vieux rideau casssé. Pluss trop ddoux.",
      "glitchDescription": "Déçu. C'était un beau rideau autrefois, j'en suis sûr.",
      "humanDescription": "Une usure assez agressive.",
      "hylotlDescription": "Ce vieux rideau a connu des jours meilleurs.",
      "novakidDescription": "Dommage. Ce rideau a connu des jours meilleurs."
    }
  },
  "clubceilinglights": {
    "name": "Lumières de Club Bleues",
    "desc": "Lumières de plafond colorées que l'on trouve en club.",
    "metadata": {
      "apexDescription": "Il manque juste une machine à fumée pour donner une ambiance de boîte de nuit.",
      "avianDescription": "Je me demande quel type de cristal pourrait donner une lumière bleue?",
      "floranDescription": "Lumière bleue, qui brille.",
      "glitchDescription": "Désintéressé. C'est une lumière bleue.",
      "humanDescription": "Des lumières d'ambiance. Quelle ambiance? Pas sûr.",
      "hylotlDescription": "Lumières d'ambiance bleues de club.",
      "novakidDescription": "Cette lumière bleue illumine bien la pièce."
    }
  },
