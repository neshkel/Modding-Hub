  "cropshipper": {
    "name": "Expéditeur Terramart",
    "desc": "Vendez de la nourriture et des produits à Terramart sans bouger de votre porte, en les propulsant simplement dans l'espace.",
    "metadata": {
      "apexDescription": "Mettez les produits dans la caisse, lancez la caisse dans l'espace, recevez des pixels. Très pratique.",
      "avianDescription": "Une caisse qu'on peut lancer dans l'espace? Pour vendre sa récolte, c'est la méthode idéale.",
      "floranDescription": "Vendre trucs est ennuyeux... Sssauf si on tire une caissse dans l'essspace pour le faire!",
      "glitchDescription": "Excité. Un système d'expédition spatiale! Je peux vendre des produits à Terramart en les tirant dans l'espace!",
      "humanDescription": "Je peux balancer des trucs dans l'espace avec ça! Et si c'est la bonne marchandise, on me paiera pour le faire!",
      "hylotlDescription": "Cet appareil lance des caisses dans l'espace. Une façon assez originale de vendre sa production...",
      "novakidDescription": "Les feux d'artifice, c'est rien à côté d'une caisse de livraison qu'on peut tirer dans l'espace."
    }
  },
  "chestfloran1": {
    "name": "Petit Coffre Primitif",
    "desc": "Un petit coffre fait de bâtons. Sa sécurité est discutable.",
    "metadata": {
      "apexDescription": "Ce coffre semble être fait de bâtons liés ensemble.",
      "avianDescription": "Ce coffre semble plus fait pour le rangement que pour la sécurité. Je pourrais presque le démonter à la main.",
      "floranDescription": "Floran sstocke beaucoup de cho sses excitantes dans coffre.",
      "glitchDescription": "Peu impressionné. Il serait peut-être plus rapide de démonter ce coffre que de l'ouvrir.",
      "humanDescription": "Un coffre soigneusement fabriqué avec des brindilles et des sortes de vignes séchées.",
      "hylotlDescription": "Ce coffre risque de pourrir avec le temps, exposant son contenu.",
      "novakidDescription": "Il n'y a même pas de vrai mécanisme de verrouillage. C'est pas sécurisé du tout."
    }
  },
  "chestfloran2": {
    "name": "Grand Coffre Primitif",
    "desc": "Un long coffre fait de bâtons. Sa sécurité est discutable.",
    "metadata": {
      "apexDescription": "Ce coffre semble être fait de bâtons liés ensemble.",
      "avianDescription": "Ce coffre semble plus fait pour le rangement que pour la sécurité. Je pourrais presque le démonter à la main.",
