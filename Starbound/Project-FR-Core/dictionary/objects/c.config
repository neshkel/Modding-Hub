  },
  "cultistchestlarge": {
    "name": "Coffre de Cultiste",
    "desc": "Un coffre en métal avec un emblème d'œil brillant dessus.",
    "metadata": {
      "apexDescription": "Ce coffre décoré a probablement été conçu pour contenir des objets de grande valeur.",
      "avianDescription": "Ce coffre a l'air assez flippant.",
      "floranDescription": "La boîte regarde Floran. Floran n'aime pas ça.",
      "glitchDescription": "Prudent. Ce coffre a l'air plutôt menaçant.",
      "humanDescription": "J'imagine que les cultistes sont fans des yeux brillants, hein?",
      "hylotlDescription": "Orange et violet? Une combinaison de couleurs assez laide.",
      "novakidDescription": "J'aime pas trop l'ambiance que dégage ce coffre."
    }
  },
  "cultistdoor": {
    "name": "Porte de Cultiste",
    "desc": "Une porte violette avec un œil, parfaite pour un culte maléfique.",
    "metadata": {
      "apexDescription": "Cet œil énorme... J'ai l'impression d'être observé.",
      "avianDescription": "L'œil sur cette porte est clairement un symbole de culte.",
      "floranDescription": "Floran n'aime pas cette porte à grand œil.",
      "glitchDescription": "Perturbé. Le grand symbole d'œil sur cette porte semble nous suivre du regard.",
      "humanDescription": "Un œil énorme est gravé sur cette porte.",
      "hylotlDescription": "Le symbole du grand œil sur cette porte est des plus dérangeants.",
      "novakidDescription": "J'ai l'sentiment que quelque chose tourne pas rond avec cette porte."
    }
  },
  "campfire": {
    "name": "^orange;Feu de camp^white;",
    "desc": "Des braises dansent au-dessus du feu de camp, réchauffant l'air. La chaleur peut servir à cuisiner.",
    "metadata": {
      "apexDescription": "Un bon feu de camp. Je pourrais cuisiner un peu de nourriture avec.",
      "avianDescription": "Un feu de camp. C'est utile pour la cuisine de base.",
      "floranDescription": "Floran détesste les flammes, mais aime cuisiner. Cuisiner mène à manger.",
      "glitchDescription": "Informé. Chauffer de la viande avec du feu est une forme de cuisine rudimentaire.",
      "humanDescription": "J'ai toujours aimé regarder les flammes d'un feu de camp danser.",
      "hylotlDescription": "Un feu de camp, j'apprécie la simplicité des aliments cuits à la flamme.",
      "novakidDescription": "Un feu de camp bien chaud pour cuisiner. Qu'est-ce qu'y faut d'plus?"
    }
  },
  "capturestation": {
    "name": "^orange;Station de Capture^white;",
    "desc": "Utilisée pour fabriquer des pods de capture, des stations de soin et d'autres objets liés aux familiers.",
