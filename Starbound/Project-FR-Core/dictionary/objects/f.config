  "foundryxor": {
    "name": "Interrupteur OU Exclusif de Fonderie",
    "desc": "Un interrupteur XOR. La sortie sera active si exactement une des entrées est active.",
    "metadata": {
      "apexDescription": "Un interrupteur XOR. La sortie sera active si exactement une des entrées est active.",
      "avianDescription": "Un interrupteur XOR. La sortie sera active si exactement une des entrées est active.",
      "floranDescription": "Interrupteur XOR. La ssortie ssera active ssi exactement une dess entréess essst active.",
      "glitchDescription": "Impressionné. Un interrupteur XOR. La sortie sera active si exactement une des entrées est active.",
      "humanDescription": "Un interrupteur XOR. La sortie sera active si exactement une des entrées est active.",
      "hylotlDescription": "Un interrupteur XOR. La sortie sera active si exactement une des entrées est active.",
      "novakidDescription": "Un interrupteur XOR. La sortie sera active si exactement une des entrées est active."
    }
  },
  "foundrysign": {
    "name": "Enseigne de Fonderie",
    "desc": "Un panneau lumineux avertissant de températures dangereusement élevées.",
    "metadata": {
      "apexDescription": "Un panneau indiquant de la chaleur ou du feu.",
      "avianDescription": "Oh oh! Je ferais mieux d'écouter ce panneau ou je vais me roussir les plumes.",
      "floranDescription": "Floranss ssont toujourss méfiantss face au feu.",
      "glitchDescription": "Curieux. Un panneau d'avertissement faisant allusion à du feu à proximité.",
      "humanDescription": "Attention aux risques de brûlures.",
      "hylotlDescription": "Le symbole de flamme sur ce panneau signifie des températures extrêmes.",
      "novakidDescription": "Zone de haute chaleur devant."
    }
  },
  "foundrysupport": {
    "name": "Support de Fonderie",
    "desc": "Une poutre métallique, généralement utilisée pour soutenir les plafonds.",
    "metadata": {
      "apexDescription": "Un support de plafond solide.",
      "avianDescription": "Idéal pour supporter des charges lourdes.",
      "floranDescription": "Ssolide ssupport en métal.",
      "glitchDescription": "Désintéressé. Une poutre.",
      "humanDescription": "Une poutre imposante.",
      "hylotlDescription": "Un support métallique robuste.",
      "novakidDescription": "Une poutre pour tenir le plafond."
    }
  },
  "foundryswitch": {
    "name": "Interrupteur de Fonderie",
    "desc": "Un interrupteur pour activer la machinerie de la fonderie.",
    "metadata": {
      "apexDescription": "Un interrupteur de machinerie industrielle.",
      "avianDescription": "Ce n'est probablement pas une bonne idée de jouer avec des interrupteurs mystérieux dans des fonderies abandonnées.",
      "floranDescription": "Interrupteur pour machiness.",
      "glitchDescription": "Neutre. Un interrupteur pour machinerie industrielle.",
      "humanDescription": "Juste un interrupteur pour une machine quelconque.",
      "hylotlDescription": "Cet interrupteur est graisseux.",
      "novakidDescription": "Un interrupteur de machine assez lourd."
    }
  },
  "fleshbed": {
    "name": "Lit de Chair",
    "desc": "Un lit fait de chair fraîche.",
    "metadata": {
      "apexDescription": "Une horreur digne du Miniknog.",
      "avianDescription": "Pourquoi?",
      "floranDescription": "Floran dort comme un loir et mange les drap_de_lit au petit-déjeuner.",
      "glitchDescription": "Pensif. Ce n'est pas pire pour un Glitch qu'un lit fait d'acier.",
      "humanDescription": "C'est quoi ce bordel?",
      "hylotlDescription": "Aucun niveau de méditation ne pourrait me préparer à passer une nuit dans ce lit.",
      "novakidDescription": "Ce lit a son propre pouls."
    }
  },
  "fleshbush1": {
    "name": "Buisson de Chair",
    "desc": "Un buisson charnu. Spongieux.",
    "metadata": {
      "apexDescription": "Un buisson grotesque.",
      "avianDescription": "Pas le genre de truc que je voudrais dans mon jardin.",
      "floranDescription": "Floran ssente qu'il devrait poignarder buissson.",
      "glitchDescription": "Mal à l'aise. Ce buisson est plutôt ignoble.",
      "humanDescription": "C'est un buisson ou une excroissance?",
      "hylotlDescription": "Parfois, la nature me répugne, moi aussi.",
      "novakidDescription": "C'est tout bonnement affreux."
    }
  },
