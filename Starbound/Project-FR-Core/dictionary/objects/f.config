      "hylotlDescription": "Un ascenseur industriel.",
      "novakidDescription": "Une sorte d'ascenseur, utile!"
    }
  },
  "foundrylight": {
    "name": "Lumière de Fonderie",
    "desc": "La lave de cette petite fontaine est surchauffée pour briller intensément.",
    "metadata": {
      "apexDescription": "Cette lave brille intensément et est recyclée à travers le dispositif.",
      "avianDescription": "Eh bien, je suppose que c'est une source de lumière naturelle.",
      "floranDescription": "Lave brûlante brille fort.",
      "glitchDescription": "Confus. Quel est l'intérêt d'une fontaine de lave?",
      "humanDescription": "Cette lave doit être vraiment chaude pour briller autant.",
      "hylotlDescription": "La lave est un rappel de la puissance de la nature. Il est rare de pouvoir l'observer de si près.",
      "novakidDescription": "Faut faire gaffe, cette lave est plus chaude qu'une botte cramée."
    }
  },
  "foundryand": {
    "name": "Interrupteur ET de Fonderie",
    "desc": "<Un interrupteur 'ET'. Nécessite que toutes les entrées soient 'actives' pour fonctionner.>"
  },
  "foundrycountdowntimer": {
    "name": "Compte à Rebours de Fonderie",
    "desc": "<Un minuteur qui reste actif pendant une durée déterminée.>"
  },
  "foundrydelay": {
    "name": "Relais à Retardement de Fonderie",
    "desc": "<Un circuit qui relaie les signaux après un délai défini.>"
  },
  "foundrydlatch": {
    "name": "Verrou de Fonderie",
    "desc": "<Un verrou. Vous n'aurez besoin d'utiliser ceci que si vous savez déjà ce que c'est.>"
  },
  "foundrynot": {
    "name": "Interrupteur NON de Fonderie",
    "desc": "<Un interrupteur 'NON'. Inverse l'entrée du circuit.>"
  },
  "foundryor": {
