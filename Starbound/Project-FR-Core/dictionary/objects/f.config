  "fancysnowman": {
    "name": "Bonhomme de Neige Élégant",
    "desc": "Un bonhomme de neige habillé avec style.",
    "metadata": {
      "apexDescription": "Un bonhomme de neige adorable. Comment allez-vous aujourd'hui?",
      "avianDescription": "Un bonhomme de neige. Je suis jaloux de son chapeau.",
      "floranDescription": "Floran chassse bonhomme de neige. Bonhomme de neige s'en fiche. Bonhomme de neige s'effondre.",
