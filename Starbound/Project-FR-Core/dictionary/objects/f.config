    "desc": "Marqueur de sol.",
    "metadata": {
      "apexDescription": "Panneau de sol.",
      "avianDescription": "Un panneau de sol.",
      "floranDescription": "Panneau de sssol.",
      "glitchDescription": "Avisé. Panneau de sol.",
      "humanDescription": "Un panneau de sol.",
