    "metadata": {
      "apexDescription": "Les modèles d'écoutilles comme celui-ci sont courants sur les vaisseaux.",
      "avianDescription": "Une écoutille de vaisseau spatial.",
      "floranDescription": "Écoutille de vaisssseau sspatial.",
      "glitchDescription": "Informé. Une écoutille de vaisseau standard.",
      "humanDescription": "Une écoutille de vaisseau spatial.",
      "hylotlDescription": "Une écoutille de vaisseau basique.",
      "novakidDescription": "Une écoutille, le genre qu'on trouve sur un vaisseau."
