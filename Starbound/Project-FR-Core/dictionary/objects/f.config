  "floranshipdoorBroken": {
    "name": "Porte de Vaisseau Floran",
    "desc": "Une porte adaptée à un vaisseau spatial.",
    "metadata": {
      "apexDescription": "Ces portes sont utilisées sur tous nos vaisseaux. Celle-ci ne coopère pas.",
      "avianDescription": "Une porte. Elle ne s'ouvre pas.",
      "floranDescription": "La porte ne s'ouvre passs!",
      "glitchDescription": "Déçu. Une porte. Elle semble être désactivée pour le moment.",
      "humanDescription": "Cool, la porte. Dommage qu'elle ne s'ouvre pas maintenant.",
      "hylotlDescription": "Une porte de vaisseau basique. Elle ne s'ouvre pas pour l'instant.",
      "novakidDescription": "La porte est cassée, elle n'est pas près de s'ouvrir."
    }
  },
  "floranshiplocker": {
    "name": "Casier de Bord",
    "desc": "Un casier. Stockez donc quelques trucs, pourquoi pas?",
    "metadata": {
      "apexDescription": "Un système de stockage. Certainement pas d'origine Florane.",
      "avianDescription": "Casier de stockage. Je ne pense pas que les Florans aient fabriqué cette unité.",
      "floranDescription": "Floran sstocke beaucoup de chosess utiless ici pour explorer l'universss.",
      "glitchDescription": "Curieux. Comment les Florans ont-ils obtenu cette technologie?",
      "humanDescription": "La plupart des technologies sur ce vaisseau ne semblent pas être d'origine Florane.",
      "hylotlDescription": "Ce système de stockage n'est pas d'origine Florane. Les Florans ont acquis cette technologie par d'autres moyens.",
      "novakidDescription": "Un casier, pour mettre des trucs dedans."
    }
  },
  "floranshiplockerTier0": {
    "name": "Casier de Bord",
    "desc": "Un casier. Stockez donc quelques trucs, pourquoi pas?",
    "metadata": {
      "apexDescription": "Un système de stockage cassé. Certainement pas d'origine Florane.",
      "avianDescription": "Casier de stockage cassé. Je ne pense pas que les Florans aient fabriqué cette unité.",
      "floranDescription": "Floran sstockera desss chosess utiless ici pour explorer l'universss, quand ce sssera réparé.",
      "glitchDescription": "Affligé. Le système de stockage du vaisseau dysfonctionne.",
      "humanDescription": "Un casier de stockage. Il ne semble pas fonctionner.",
      "hylotlDescription": "Stockage. Il n'est pas alimenté actuellement.",
      "novakidDescription": "Un casier. Pas très utile tant que c'est pas réparé."
    }
  },
  "florantechstation": {
    "name": "S.A.I.L",
    "desc": "Système Artificiel d'Information Liaisonné, ou S.A.I.L pour faire court.",
    "metadata": {
      "apexDescription": "Je peux parler à SAIL via cette console.",
      "avianDescription": "Je peux utiliser cette station pour parler à SAIL.",
      "floranDescription": "Floran utilisse ce panneau magique pour parler à SAIL!",
      "glitchDescription": "Heureux. Cette station me permet de parler à SAIL.",
      "humanDescription": "Cette station me permet de communiquer avec SAIL.",
      "hylotlDescription": "Cette console me permet de communiquer avec SAIL.",
      "novakidDescription": "Cette station-là me permet de causer avec SAIL."
    }
  },
  "florantechstationTier0": {
    "name": "S.A.I.L",
    "desc": "Système Artificiel d'Information Liaisonné, ou S.A.I.L pour faire court.",
    "metadata": {
      "apexDescription": "Quand elle fonctionne, je peux parler à SAIL via cette console.",
      "avianDescription": "Redémarrer cette station devrait me permettre de parler à SAIL.",
      "floranDescription": "Floran répare ce panneau pour réveiller le vaisssseau!",
      "glitchDescription": "Affligé. Je dois d'abord redémarrer cette station pour communiquer avec SAIL.",
      "humanDescription": "Si je peux redémarrer cette station, SAIL devrait revenir en ligne!",
      "hylotlDescription": "Cette console me permettra de communiquer avec SAIL. Je dois d'abord la redémarrer.",
      "novakidDescription": "Il est temps de redémarrer cette station pour que je puisse parler à SAIL."
    }
  },
  "floranteleporter": {
    "name": "Téléporteur",
    "desc": "Fidèle téléporteur, que ferions-nous sans toi?",
    "metadata": {
      "apexDescription": "Le téléporteur du vaisseau. Se téléporter donne l'impression de faire des montagnes russes à la vitesse de la lumière.",
      "avianDescription": "Le téléporteur! Se téléporter donne l'impression de voler.",
      "floranDescription": "Téléporteur du vaisssseau. Floran sse ssent confusss pendant la téléportation.",
      "glitchDescription": "Frimeur. Un téléporteur. Je suis capable d'entrer en mode veille pendant le processus de téléportation.",
      "humanDescription": "Le téléporteur! Se téléporter est une telle décharge d'adrénaline.",
      "hylotlDescription": "Un téléporteur. Se téléporter donne l'impression de plonger dans l'océan depuis le sommet d'une montagne.",
      "novakidDescription": "Téléporteur du vaisseau. Allons faire un tour!"
    }
  },
  "floranteleporterTier0": {
    "name": "Téléporteur",
    "desc": "Fidèle téléporteur, que ferions-nous sans toi?",
    "metadata": {
      "apexDescription": "Le téléporteur du vaisseau. Je dois l'alimenter.",
      "avianDescription": "Le téléporteur! Si seulement celui-là était alimenté.",
      "floranDescription": "Téléporteur du vaisssseau. Celui-ci essst mort.",
      "glitchDescription": "Déçu. Un téléporteur sans courant. Je dois l'alimenter.",
      "humanDescription": "Le téléporteur! Dommage qu'il ne soit pas alimenté.",
      "hylotlDescription": "Ce téléporteur est éteint.",
      "novakidDescription": "Téléporteur du vaisseau. Je dois lui redonner du jus!"
    }
  },
  "filingcabinet": {
    "name": "Classeur",
    "desc": "Un classeur. Pour tout ranger.",
    "metadata": {
      "apexDescription": "Un meuble utilisé pour ranger des dossiers.",
      "avianDescription": "Un meuble pour les dossiers.",
      "floranDescription": "Un meuble rempli de papiersss.",
      "glitchDescription": "Intrigué. Un classeur avec potentiellement des documents classifiés à l'intérieur.",
      "humanDescription": "Un classeur. Je vais peut-être y jeter un œil.",
      "hylotlDescription": "Une solution de rangement simple mais utile.",
      "novakidDescription": "Un meuble pour organiser sa paperasse."
    }
  },
  "fireextinguisher": {
    "name": "Extincteur",
    "desc": "Un extincteur. Pas pour s'amuser.",
    "metadata": {
      "apexDescription": "Un extincteur.",
      "avianDescription": "Un extincteur bien pratique.",
      "floranDescription": "Floran tue le feu avec de la mousssse!",
      "glitchDescription": "Alarmé. Cet extincteur ne respecte pas les normes de sécurité.",
      "humanDescription": "Un extincteur. J'espère que je n'en aurai pas besoin.",
      "hylotlDescription": "Une sorte d'appareil qui pulvérise de la mousse.",
      "novakidDescription": "Ce petit machin éteint les incendies."
    }
  },
