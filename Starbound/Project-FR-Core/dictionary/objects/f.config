  "frogfurnishing": {
    "name": "Ameublement Frögg",
    "desc": "Les plus beaux meubles de tout l'univers.",
    "metadata": {
      "apexDescription": "C'est l'un de ces marchands grenouilles. Celui-ci vend des meubles.",
      "avianDescription": "Qui est ce curieux marchand? Ses meubles sont charmants.",
      "floranDescription": "Floran un peu effrayé par grenouille ssilencieuse.",
      "glitchDescription": "Impressionné. Cette grenouille a des articles qui ont l'air confortables.",
      "humanDescription": "Cet étrange amphibien vend des meubles plutôt sympas.",
      "hylotlDescription": "Cette créature possède une impressionnante collection de meubles.",
      "novakidDescription": "On ne voit pas beaucoup de marchands grenouilles dans le coin!",
      "interactData.paneLayoutOverride.windowtitle.title": "Ameublement Frögg",
      "interactData.paneLayoutOverride.windowtitle.subtitle": "Meubles à thème, un ensemble différent chaque jour!"
    }
  },
  "frogfurnishingclosed": {
    "name": "Ameublement Frögg Fermé",
    "desc": "Ce serait un endroit sympa pour une boutique.",
    "metadata": {
      "apexDescription": "Quelle caisse étrangement décorée. Est-ce un canapé au sommet?",
      "avianDescription": "Cette caisse semble être en train d'être convertie en étal. Je me demande ce que ce sera?",
      "floranDescription": "Floran veut sss'cacher dans la boîte. Floran essspère que personne n'essst à l'intérieur.",
      "glitchDescription": "Curieux. Cette caisse semble être en cours de transformation en étalage.",
      "humanDescription": "Quelqu'un décore cette caisse - je me demande à quoi elle ressemblera une fois terminée?",
      "hylotlDescription": "Je ne sais pas en quoi cette boîte va être transformée, mais j'aime le choix de la peinture bleue.",
      "novakidDescription": "J'aime la finition en bois de cette caisse - je me demande ce que le proprio en fait."
    }
  },
  "frontierbed": {
    "name": "Lit de la Frontière",
    "desc": "Un lit en bois robuste avec des draps en peau de mooshi.",
    "metadata": {
      "apexDescription": "Je suis sûr que ces draps en peau tiennent chaud pendant le sommeil.",
      "avianDescription": "Dormir dans des draps en cuir? Je préférerais de loin un lit de paille.",
      "floranDescription": "Un lit fait avec desss trophéesss de chassse? Floran impresssionné, bonne idée.",
      "glitchDescription": "Confus. Ces draps sont-ils vraiment faits de peau d'animal?",
      "humanDescription": "Je... me demande si c'est de la vraie peau d'animal?",
      "hylotlDescription": "Je peux dire que peu de réflexion a été apportée à la confection de ce lit.",
      "novakidDescription": "Ça, c'est un lit où je peux vraiment piquer un bon roupillon."
    }
  },
  "frontierchair": {
    "name": "Chaise de la Frontière",
    "desc": "Une chaise en bois avec un rembourrage en peau de mooshi.",
    "metadata": {
      "apexDescription": "Cette chaise est assez confortable. Les coussins en peau d'animal lui donnent un peu de caractère.",
      "avianDescription": "Le rembourrage en peau d'animal gratte un peu les plumes.",
      "floranDescription": "La chaisse sssent encore un peu la proie. Bonne chaisse.",
      "glitchDescription": "Impressionné. Cette chaise peut paraître de basse qualité, mais les coussins en peau offrent un grand potentiel de confort.",
      "humanDescription": "Ce siège a l'air de gratter un peu quand on s'assoit dessus.",
      "hylotlDescription": "Je serais réticent à m'asseoir sur cette chaise. Le rembourrage en peau n'a pas l'air très confortable.",
      "novakidDescription": "La chaise parfaite. Je reposerais mes pieds sur une chaise comme ça n'importe quand."
    }
  },
  "frontierclock": {
    "name": "Horloge Comtoise de la Frontière",
    "desc": "Une horloge sur pied à l'ancienne, avec un balancier en laiton poli.",
    "metadata": {
      "apexDescription": "Cette belle horloge est de bien meilleure qualité que celles produites en masse par le Miniknog.",
      "avianDescription": "Cette horloge semble faite à la main. Je suis impressionné par le travail du bois!",
      "floranDescription": "Le truc en métal qui balançsse ressemble à une petite hache. Essst-ce une arme?",
      "glitchDescription": "Charmé. Cette horloge a dû demander beaucoup de soin pour être produite à la main.",
      "humanDescription": "Cette horloge m'attendait, juste pour moi. Mais je croyais que le temps n'attendait personne?",
      "hylotlDescription": "Je dois admettre que la construction de cette horloge a dû prendre énormément de temps. Je suis presque impressionné.",
      "novakidDescription": "Cette horloge-là ne fait que grignoter les heures qui passent."
    }
  },
  "frontiercoffin": {
    "name": "Cercueil de la Frontière",
    "desc": "Un cercueil en bois brut. Heureusement, il n'y a personne dedans!",
    "metadata": {
      "apexDescription": "Ce cercueil n'est pas le plus joli, mais je suppose que l'esthétique importe peu quand on est mort.",
      "avianDescription": "La culture traditionnelle Avian enterrerait ses morts dans des cercueils bien plus grandioses que celui-ci.",
      "floranDescription": "Cette boîte essst à la bonne taille pour sss'cacher. Floran pourrait l'utilisser pour desss embusscadess...",
      "glitchDescription": "Inquiet. Que se passerait-il si on était enfermé à l'intérieur par accident?",
      "humanDescription": "J'ai l'impression que je me prendrais une écharde rien qu'en touchant ce truc.",
      "hylotlDescription": "Est-ce pour enterrer les morts? Comme c'est... affreux.",
      "novakidDescription": "Ça me file un sentiment plutôt morbide."
    }
  },
  "frontierdoor": {
    "name": "Porte de la Frontière",
    "desc": "Une porte en bois, ornée d'un emblème en fer des deux côtés.",
    "metadata": {
      "apexDescription": "Cette porte en bois porte un grand et étrange symbole.",
      "avianDescription": "Je me demande si l'emblème sur cette porte a une signification.",
      "floranDescription": "Cette porte de la frontière essst sssèche et vieille.",
      "glitchDescription": "Impressionné. Les différents matériaux s'assemblent d'une manière esthétiquement plaisante.",
      "humanDescription": "Cette porte a une poignée très brillante. Je l'aime bien!",
      "hylotlDescription": "Le symbole sur cette porte ne m'est pas familier.",
      "novakidDescription": "Il n'est pas rare de voir des portes comme ça dans un bâtiment de la frontière."
    }
  },
  "frontierfurnace": {
    "name": "Fourneau de la Frontière",
    "desc": "Un vieux fourneau en cuivre et en laiton.",
    "metadata": {
      "interactData.paneLayoutOverride.windowtitle.title": "  Fourneau de la Frontière",
      "interactData.paneLayoutOverride.windowtitle.subtitle": "  Fonte à l'ancienne.",
      "apexDescription": "Un fourneau en cuivre plutôt archaïque.",
      "avianDescription": "J'ai l'impression que si je m'approche trop, ça va me roussir les plumes.",
      "floranDescription": "Le truc a l'air chaud. Floran un peu inquièt.",
      "glitchDescription": "Intrigué. Je me demande si tous ces tuyaux servent réellement à quelque chose?",
      "humanDescription": "Ce vieux fourneau en métal est en fait très chaud au toucher.",
      "hylotlDescription": "Ce vieux fourneau est très inefficace énergétiquement. Je pourrais penser à plusieurs façons de l'améliorer, si je le voulais.",
      "novakidDescription": "Cette odeur de charbon qui brûle... Il n'y a rien de tel."
    }
  },
  "frontiergramophone": {
    "name": "Gramophone de la Frontière",
    "desc": "Un charmant tourne-disque, jouant un vieil air.",
    "metadata": {
      "apexDescription": "La musique de ce tourne-disque m'inspire quelque chose. C'est une sensation excitante.",
      "avianDescription": "Ce simple appareil produit de la musique en faisant tourner un disque. Comme c'est fascinant!",
      "floranDescription": "Floran aime la mussique, ça cache le bruits de Floran quand il essst dissscret.",
      "glitchDescription": "Intrigué. Cet appareil fait tourner un disque qui produit inexplicablement une musique agréable.",
      "humanDescription": "Un gramophone à l'ancienne! Approchez, les enfants!",
      "hylotlDescription": "Ce lecteur de musique est étonnamment fonctionnel pour sa simplicité.",
      "novakidDescription": "La chanson qu'il joue est un vrai petit air qui donne envie de taper du pied!"
    }
  },
  "frontierhatrack": {
    "name": "Porte-chapeau de la Frontière",
    "desc": "Un ensemble décoratif de cornes en laiton.",
    "metadata": {
      "apexDescription": "Cela ressemble d'abord à des cornes montées, mais en fait, elles semblent être artificielles.",
      "avianDescription": "Cet ensemble artificiel de cornes montées a l'air très poli.",
      "floranDescription": "Floran pass impresssionné par un faux trophée de chassse.",
      "glitchDescription": "Confus. Est-ce une paire de cornes artificielle? Dans quel but?",
      "humanDescription": "Une vieille paire de cornes murale... Attendez, ce ne sont pas de vraies cornes!",
      "hylotlDescription": "S'agit-il d'une paire de cornes artificielle? Je n'en vois pas l'utilité.",
      "novakidDescription": "Ce ne sont pas de vraies cornes, elles sont juste faites pour y ressembler!"
    }
  },
  "frontierironsymbol": {
    "name": "Symbole en fer de la Frontière",
    "desc": "Un symbole décoratif en fer.",
    "metadata": {
      "apexDescription": "Un symbole en fer forgé, à accrocher au mur.",
      "avianDescription": "Je me demande ce que cela symbolise?",
      "floranDescription": "Floran ssse demande sssi le truc accroché ferait une arme efficacce.",
      "glitchDescription": "Intrigué. Cette décoration murale a-t-elle une signification plus profonde?",
      "humanDescription": "Je me demande si ce symbole veut dire quelque chose, ou s'il est juste joli?",
      "hylotlDescription": "Ce symbole en fer forgé semble décoratif, mais il est plutôt mal fabriqué.",
      "novakidDescription": "Ce vieux symbole est un signe certain que des gens comme moi sont dans le coin."
    }
  },
  "frontierlamp": {
    "name": "Lampe de la Frontière",
    "desc": "Une lampe à gaz suspendue avec un couvercle en verre rouge.",
    "metadata": {
      "apexDescription": "Cette lampe à huile en laiton diffuse une lueur rouge chaleureuse.",
      "avianDescription": "Cette lampe dégage une légère odeur de parfum. Peut-être que l'huile qu'elle brûle est parfumée?",
      "floranDescription": "La lumière rouge ssusspendue a du feu à l'intérieur. Floran nerveux.",
      "glitchDescription": "Impressionné. Le travail du métal sur cette lampe en laiton est assez orné. Elle a dû être fabriquée avec soin.",
      "humanDescription": "Cette lampe vacille avec une flamme douce. Le couvercle en verre rouge projette une lueur chaleureuse!",
      "hylotlDescription": "Le vacillement de cette lampe à huile est curieusement apaisant.",
      "novakidDescription": "Rien ne ssemble aussisi chaleureux qu'une vieille lampe à huile éclairant une pièce."
    }
  },
  "frontierlamppost": {
    "name": "Lampadaire de la Frontière",
    "desc": "Un lampadaire en fer forgé avec une flamme allumée au gaz.",
    "metadata": {
      "apexDescription": "Un robuste lampadaire en fer forgé.",
      "avianDescription": "Un grand lampadaire en fer forgé.",
      "floranDescription": "Floran veut utilisser la longue lampe comme une lance enflammée!",
      "glitchDescription": "Impressionné. C'est une lampe très grande.",
      "humanDescription": "Un lampadaire, pour garder les rues sûres la nuit!",
      "hylotlDescription": "Ce lampadaire est en fer forgé - je suis sûr qu'il pourrait résister à beaucoup de choses.",
      "novakidDescription": "Éclaire le chemin, lampadaire!"
    }
  },
  "frontierpainting1": {
    "name": "Peinture de Plaines de la Frontière",
    "desc": "Une peinture détaillée d'un magnifique paysage.",
    "metadata": {
      "apexDescription": "Une peinture d'un paysage plutôt pittoresque.",
      "avianDescription": "Une peinture d'une terre magnifique. J'aimerais visiter cet endroit!",
      "floranDescription": "Floran voit un petit monde. Floran peut pass aller dans le petit monde. Floran déççu.",
      "glitchDescription": "Inspiré. Quel magnifique paysage.",
      "humanDescription": "Une scène si magnifique! Je me demande ce qui l'a inspirée?",
      "hylotlDescription": "Cette peinture est presque aux standards artistiques Hylotl. J'aime particulièrement la rivière qui traverse l'image.",
      "novakidDescription": "C'est une bien belle peinture que voilà."
    }
  },
  "frontierpainting2": {
    "name": "Peinture de Chariot de la Frontière",
    "desc": "Une peinture étrange d'un chariot tiré.",
    "metadata": {
      "apexDescription": "Cette peinture semble représenter un chariot vert tiré par un animal. Je ne comprends pas.",
      "avianDescription": "Je ne suis pas tout à fait sûr de ce que cette peinture est censée représenter.",
      "floranDescription": "Floran ne comprend pass l'image.",
      "glitchDescription": "Confus. Je ne sais pas trop pourquoi cette peinture est verte.",
      "humanDescription": "Cela semble être une peinture d'un chariot, sauf qu'il est vert. Je ne comprends pas.",
      "hylotlDescription": "Je ne parviens pas à discerner le sens de cette curieuse peinture.",
      "novakidDescription": "C'est une peinture sacrément bizarre, je vous l'accorde."
    }
  },
  "frontierpainting3": {
    "name": "Peinture de Mooshi de la Frontière",
    "desc": "Une peinture d'un fier mooshi devant un soleil couchant.",
    "metadata": {
      "apexDescription": "Le mooshi sur cette peinture a l'air très fier.",
      "avianDescription": "Quelle noble bête!",
      "floranDescription": "Floran veut chassser la petite proie.",
      "glitchDescription": "Inspiré. Quelle créature majestueuse!",
      "humanDescription": "Le mooshi sur cette peinture est très majestueux pour un animal de ferme.",
      "hylotlDescription": "Cette peinture capture un élément de majesté chez cette bête sauvage.",
      "novakidDescription": "C'est un sacré beau mooshi que voilà."
    }
  },
  "frontiervault": {
    "name": "Coffre-fort de la Frontière",
    "desc": "Un énorme coffre-fort orné.",
    "metadata": {
      "apexDescription": "Un énorme coffre en fer. Heureusement, il n'est pas verrouillé.",
      "avianDescription": "Un grand coffre en fer, le genre où l'on garde des objets précieux.",
      "floranDescription": "Floran veut sss'cacher dans la grande boîte.",
      "glitchDescription": "Impressionné. Ce coffre est si solide que je ne suis pas sûr de pouvoir le forcer.",
      "humanDescription": "Vais-je devoir devenir un expert en serrurerie pour ouvrir ça? Non, attendez, c'est déjà ouvert.",
      "hylotlDescription": "Ce coffre-fort semble assez robuste.",
      "novakidDescription": "Un endroit idéal pour cacher son or."
    }
  },
  "frontierwaterpump": {
    "name": "Pompe à Eau de la Frontière",
    "desc": "Une pompe à eau en laiton qui servait à pomper l'eau, à l'époque où elle fonctionnait.",
    "metadata": {
      "apexDescription": "Une vieille pompe à eau. Elle ne semble plus fonctionner, elle n'est plus que décorative désormais.",
      "avianDescription": "Cette pompe semble avoir cessé de fonctionner il y a longtemps. C'est une belle pièce décorative, cependant!",
      "floranDescription": "Floran ne voit passs l'intérêt de ce truc.",
      "glitchDescription": "Observateur. Cette pompe semble avoir rouillé il y a longtemps. Je n'ai aucune confiance en sa capacité à pomper quoi que ce soit.",
      "humanDescription": "Ça a peut-être pompé de l'eau autrefois, mais maintenant ce n'est qu'un accessoire.",
      "hylotlDescription": "Les pompes à eau Hylotl ne rouilleraient et ne casseraient jamais de la sorte.",
      "novakidDescription": "Une vieille pompe à eau. Elle ne semble plus marcher par contre."
    }
  },
  "frontierwindmill": {
    "name": "Éolienne de la Frontière",
    "desc": "Une éolienne en laiton, bois et cuivre, qui tourne dans le sens du vent.",
    "metadata": {
      "apexDescription": "Cette simple éolienne tourne dans la direction du vent. Un indicateur utile.",
      "avianDescription": "L'hélice de cette éolienne peut m'indiquer la direction dans laquelle le vent souffle!",
      "floranDescription": "Floran sse demande ssi le truc qui tourne pourrait faire une arme efficacce...",
      "glitchDescription": "Observateur. L'hélice de cette éolienne semble indiquer la direction du vent.",
      "humanDescription": "Ce vieux machin a une hélice qui tourne selon le vent. Sympa!",
      "hylotlDescription": "Cette hélice rotative peut m'informer sur la direction du vent.",
      "novakidDescription": "Cette éolienne aide à voir la force et l'angle des coups de vent."
    }
  },
  "fallingrocks": {
    "name": "Vieux Panneau Chute de Pierres",
    "desc": "Un vieux panneau cabossé avertissant de chutes de pierres.",
    "metadata": {
      "apexDescription": "Cela pourrait être une empreinte à trois orteils, ou un rocher qui tombe.",
      "avianDescription": "Un signe que quelque chose tombe d'en haut.",
      "floranDescription": "Un sssigne pour plafond instable.",
      "glitchDescription": "Confus. Peut-être que cela signifie que la zone est dangereuse?",
      "humanDescription": "Chutes de pierres. Pourquoi les grottes ne peuvent-elles pas être sûres pour une fois?",
      "hylotlDescription": "L'artiste essayait peut-être d'avertir les autres.",
      "novakidDescription": "Mieux vaut surveiller les chutes de pierres devant."
    }
  },
  "fallingrocksmodern": {
    "name": "Panneau Chute de Pierres",
    "desc": "Un panneau d'avertissement montrant des chutes de pierres.",
    "metadata": {
      "apexDescription": "Ce panneau avertit clairement de roches instables.",
      "avianDescription": "Un panneau avertissant de chutes de pierres.",
      "floranDescription": "Un sssigne pour rochesss instablesss.",
      "glitchDescription": "Inquiet. Peut-être que cela signifie que la zone est dangereuse?",
      "humanDescription": "Chutes de pierres. Pourquoi les grottes ne peuvent-elles pas être sûres pour une fois?",
      "hylotlDescription": "Peut-être que l'artiste essayait d'avertir les autres.",
      "novakidDescription": "Vaut mieux faire gaffe aux pierres qui tombent devant."
    }
  },
  "floranartifactaltar": {
    "name": "Autel d'Artéfact Floran",
    "desc": "On dirait qu'il a été fabriqué pour contenir quelque chose d'important."
  },
  "fistlauncher": {
    "name": "Lance-Poing",
    "desc": "Cet appareil est méticuleusement conçu pour lancer des poings avec une grande force."
  },
  "floodlightsmall": {
    "name": "Petit Projecteur",
    "desc": "Une petite lampe qui peut fonctionner dans l'eau.",
    "metadata": {
      "apexDescription": "Une ampoule normale, protégée pour pouvoir fonctionner sous l'eau.",
      "avianDescription": "Cette lumière semble être étanche pour pouvoir fonctionner en eau libre.",
      "floranDescription": "Ampoule.",
      "glitchDescription": "Neutre. Une lumière étanche.",
      "humanDescription": "C'est une lampe conçue pour fonctionner lorsqu'elle est exposée à l'eau.",
      "hylotlDescription": "C'est juste une ampoule étanche.",
      "novakidDescription": "Cette lumière là est étanche. Ingénieux."
    }
  },
  "floodlightsmallflickering": {
    "name": "Petit Projecteur Vacillant",
    "desc": "Une petite lumière vacillante qui peut fonctionner dans l'eau.",
    "metadata": {
      "apexDescription": "Une ampoule vacillante normale, protégée pour fonctionner sous l'eau.",
      "avianDescription": "Cette lumière vacillante semble être étanche pour fonctionner en eau libre.",
      "floranDescription": "Ampoule qui vacille.",
      "glitchDescription": "Neutre. Une lumière étanche vacillante.",
      "humanDescription": "C'est une lampe vacillante conçue pour fonctionner dans l'eau.",
      "hylotlDescription": "C'est juste une ampoule vacillante étanche.",
      "novakidDescription": "Cette lumière est étanche. Quelque chose a quand même réussi à l'abîmer."
    }
  },
  "football": {
    "name": "Ballon de Football",
    "desc": "Un ballon de football classique.",
    "metadata": {
      "apexDescription": "Une sorte de ballon destiné au sport.",
      "avianDescription": "Une sorte de balle rebondissante.",
      "floranDescription": "Que fait Floran avec çça?",
      "glitchDescription": "Curieux. Pourquoi le ballon a-t-il des taches blanches et noires?",
      "humanDescription": "Un ballon de foot! Surpris d'en voir un par ici.",
      "hylotlDescription": "C'est un ballon de football. Ils sont devenus populaires chez les jeunes Hylotls récemment.",
      "novakidDescription": "Un genre d'objet décoratif, je suppose."
    }
  },
  "fridge": {
    "name": "Réfrigérateur",
    "desc": "Parfait pour stocker beaucoup de nourriture et la garder fraîche.",
    "metadata": {
      "apexDescription": "Un frigo. Espérons qu'il contient du milkshake à la banane.",
      "avianDescription": "Un frigo. Idéalement rempli de boissons et d'en-cas.",
      "floranDescription": "Floran peut sssentir la viande à l'intérieur.",
      "glitchDescription": "Ravi. Ce frigo fonctionne à la température optimale.",
      "humanDescription": "Je vibre d'excitation à l'idée de ce qu'il pourrait y avoir dedans.",
      "hylotlDescription": "Sous l'eau, la réfrigération est plus facile. Ces appareils sont un substitut ingénieux.",
      "novakidDescription": "Un bête vieux frigo."
    }
  },
  "farmtools": {
    "name": "Outils Agricoles",
    "desc": "Une bêche, un râteau et un balai pour toutes sortes de travaux agricoles épuisants.",
    "metadata": {
      "apexDescription": "Des outils pour quelqu'un qui vit du travail de la terre.",
      "avianDescription": "Un râtelier d'outils divers. La bêche est le seul que je reconnaisse.",
      "floranDescription": "Outilss pour contrôler les plantess.",
      "glitchDescription": "Sentimental. Beaucoup de Glitchs communs vivent comme fermiers. Ce sont les outils de leur métier.",
      "humanDescription": "Outils de ferme. Sur Terre, l'agriculture était largement automatisée.",
      "hylotlDescription": "Les Hylotls n'ont que faire d'outils comme ceux-ci sous l'océan.",
      "novakidDescription": "Outils de ferme. Rien ne vaut le fait de se salir les mains!"
    }
  },
  "fireplacetools": {
    "name": "Outils de Cheminée",
    "desc": "Outils utilisés pour tisonner les braises brûlantes ou le petit bois.",
    "metadata": {
      "apexDescription": "Outils utilisés pour entretenir un feu.",
      "avianDescription": "Des bâtons pointus. À quoi servent-ils?",
      "floranDescription": "Essst-ce que sse sssont dess armes?",
      "glitchDescription": "Content. Un ensemble d'outils en fer pour s'occuper d'un feu.",
      "humanDescription": "Je pense que ce sont des outils pour la cheminée.",
      "hylotlDescription": "À quoi servent ces outils?",
      "novakidDescription": "Outils en métal, pour attiser le feu."
    }
  },
  "fairylights": {
    "name": "Guirlande Lumineuse Jaune",
    "desc": "Une guirlande de petites lumières scintillantes.",
    "metadata": {
      "apexDescription": "Ces petites lumières sont très jolies.",
      "avianDescription": "Difficile de ne pas aimer ces jolies petites lumières.",
      "floranDescription": "Beaucoup de lumièress qui brillent.",
      "glitchDescription": "Contentement. Ces lumières scintillantes aident à créer une atmosphère détendue.",
      "humanDescription": "J'ai toujours eu un faible pour les guirlandes lumineuses.",
      "hylotlDescription": "Une beauté si simple.",
      "novakidDescription": "Un tas de petites lumières étincelantes toutes suspendues."
    }
  },
  "fireflowerpot": {
    "name": "Fleur de Feu",
    "desc": "Une fleur à l'aspect ardent dans un pot.",
    "metadata": {
      "apexDescription": "Les pétales de cette fleur ressemblent à des langues de feu.",
      "avianDescription": "Le mouvement de cette fleur dans la brise ressemble à du feu.",
      "floranDescription": "Vilaine fleur ressssemble à dess flammes.",
      "glitchDescription": "Émerveillé. La couleur et la forme de cette fleur ressemblent étroitement au feu.",
      "humanDescription": "Une belle fleur délicate, quel pouvoir cache-t-elle?",
      "hylotlDescription": "Les fleurs à la surface sont si éclatantes.",
      "novakidDescription": "Une fleur élégante poussant dans un pot."
    }
  },
  "fireflybush": {
    "name": "Buisson à Lucioles",
    "desc": "De petits insectes luisants semblent vivre dans ce buisson.",
    "metadata": {
      "apexDescription": "De magnifiques lucioles tournoient et dansent.",
      "avianDescription": "Ces minuscules créatures me donnent envie de m'envoler.",
      "floranDescription": "Floran mange dess mouchess qui brillent avec dess fruitss.",
      "glitchDescription": "Émerveillé. Ces lucioles volent selon un schéma hypnotique.",
      "humanDescription": "Des lucioles, elles sont attirées par ce buisson pour une raison quelconque.",
      "hylotlDescription": "Parfois, la beauté de la nature est accablante.",
      "novakidDescription": "Ces bestioles sont toutes éclairées comme des petites bougies."
    }
  },
  "flagapex": {
    "name": "Drapeau Apex",
    "desc": "Un drapeau Apex. Le symbole du Miniknog. Utilisez ^green;[E]^white; pour marquer un point de téléportation.",
    "metadata": {
      "apexDescription": "Un drapeau Apex. Je peux l'utiliser comme point de repère pour la téléportation.",
      "avianDescription": "Ce drapeau Apex peut être enregistré comme destination pour le téléporteur de mon vaisseau.",
      "floranDescription": "Drapeau Apex fait un bon point de retour pour le téléporteur!",
      "glitchDescription": "Observateur. Un petit module de localisation attaché à ce drapeau Apex permet de l'enregistrer pour la téléportation.",
      "humanDescription": "Ce drapeau Apex peut être sauvegardé comme emplacement pour mon téléporteur. Je pourrai y revenir n'importe quand.",
      "hylotlDescription": "Ce drapeau Apex peut servir de point de repère, me permettant de revenir ici via un téléporteur.",
      "novakidDescription": "Je peux marquer ce drapeau Apex pour me téléporter vite fait."
    }
  },
