{
  "flametrap": {
    "name": "Piège à flammes Avian",
    "desc": "Un piège à flammes conçu pour dissuader les envahisseurs.",
    "metadata": {
      "apexDescription": "Un piège à flammes, à éviter absolument.",
      "avianDescription": "Aïe! Les flammes et les plumes ne font pas bon ménage!",
      "floranDescription": "Le piège à feu essst le pire ennemi desss Floransss!",
      "glitchDescription": "Observateur. C'est juste un petit piège à flammes, rien d'insurmontable.",
      "humanDescription": "Un piège à flammes fidèle et fiable.",
      "hylotlDescription": "Le guerrier agile ne craint pas la flamme.",
      "novakidDescription": "Simple, mais mortel. Mon genre préféré."
    }
  },
  "floranbouldertrap": {
    "name": "Piège à rochers Floran",
    "desc": "Un piège qui lâche de lourds rochers sur les intrus imprudents.",
    "metadata": {
      "apexDescription": "Si je calcule bien mes mouvements, je peux éviter les rochers qui tombent.",
      "avianDescription": "Je ferais mieux de bien calculer mon coup, je n'ai pas envie qu'un rocher m'écrase.",
      "floranDescription": "De lourdesss rochess tombent de ce trou.",
      "glitchDescription": "Déçu. Qui fabriquerait un piège qui lâche des rochers avec un timing aussi prévisible?",
      "humanDescription": "Des rochers sortent de ce petit trou.",
      "hylotlDescription": "Un piège à rochers est facile à éviter avec des mouvements bien synchronisés.",
      "novakidDescription": "Ça roule, les rochers!"
    }
  },
  "freezetrap": {
    "name": "Blaster Cryogénique",
    "desc": "Cet appareil est utilisé pour geler rapidement des matériaux.",
    "metadata": {
      "apexDescription": "Le rayon émis par cet appareil glace jusqu'aux os.",
      "avianDescription": "Un mécanisme de congélation.",
      "floranDescription": "La glace peut être dangereussse.",
      "glitchDescription": "Prudent. C'est une unité de congélation à haute intensité.",
      "humanDescription": "Attention au souffle glacial.",
      "hylotlDescription": "La glace, l'eau sous sa forme la plus mortelle.",
      "novakidDescription": "Ce blaster cryogénique pourrait geler les moustaches d'un phoque."
    }
  },
  "futureteleporter": {
    "name": "Téléporteur Futuriste",
    "desc": "Un téléporteur personnel, se connecte aux emplacements favoris. \n^red;Détruit si brisé.",
    "metadata": {
      "apexDescription": "Un téléporteur personnel. Un équipement fonctionnel mais amusant.",
      "avianDescription": "J'adore le sifflement de mes plumes quand je me téléporte!",
      "floranDescription": "Le téléporteur perssonnel essst chic!",
      "glitchDescription": "Séduit. Un téléporteur personnel, avec un design personnalisé.",
      "humanDescription": "Un téléporteur personnel! Ça, c'est voyager avec style.",
      "hylotlDescription": "Un téléporteur personnel, il arbore un design personnalisé.",
      "novakidDescription": "Pour un téléporteur, il a sacrément fière allure!"
    }
  },
  "florancaptainschair": {
    "name": "Siège du Capitaine Floran",
    "desc": "Le Capitaine s'assoit ici pour piloter le vaisseau.",
    "metadata": {
      "apexDescription": "Ahh... La douce liberté. Je peux utiliser le navigateur du vaisseau depuis ce siège.",
      "avianDescription": "Le siège du Capitaine. C'est moi! Je peux utiliser le navigateur du vaisseau depuis ce siège.",
      "floranDescription": "Meilleur sssiège du vaisssseau. Floran s'asssoit ici pour utilisser navigateur et s'envoler!",
      "glitchDescription": "Excité. S'asseoir sur le siège du Capitaine me permet de piloter ce vaisseau. Où allons-nous?",
      "humanDescription": "Le siège du Capitaine. La personne assise ici décide de la destination du vaisseau!",
      "hylotlDescription": "S'asseoir sur le siège du Capitaine me permet de piloter ce vaisseau.",
      "novakidDescription": "Le siège du Capitaine. Le gars assis ici décide d'où va le vaisseau! Et c'est moi!"
    }
  },
  "floranfuelhatch": {
    "name": "Trappe à Carburant FTL",
    "desc": "Accepte l'Erchius Liquide comme carburant pour le saut FTL du vaisseau.",
    "metadata": {
      "apexDescription": "La trappe à carburant du moteur FTL. Convertit le carburant en liberté.",
      "avianDescription": "La trappe à carburant FTL. Remplissons-la et partons vers les étoiles!",
      "floranDescription": "Trappe à carburant pour moteur FTL. Remplisssons-la!",
      "glitchDescription": "Excité. Cette trappe alimente le moteur FTL pour que je puisse visiter des planètes hors de ce système.",
      "humanDescription": "La trappe à carburant du vaisseau. Avec du carburant pour le moteur FTL, je peux explorer au-delà de ce système.",
      "hylotlDescription": "L'humble trappe à carburant FTL. Le carburant est le sang de l'exploration.",
      "novakidDescription": "Le carburant FTL va là-dedans!"
    }
  },
