  "fleshchair": {
    "name": "Chaise de Chair",
    "desc": "Une chaise charnue. Aussi dégoûtante que son nom l'indique.",
    "metadata": {
      "apexDescription": "Je n'ai pas de mots.",
      "avianDescription": "Quel siège ignoble.",
      "floranDescription": "Floran ssaura pas ssi il doit s'asseoir ou poignarder.",
      "glitchDescription": "Hésitant. S'asseoir ici serait déconcertant.",
      "humanDescription": "Pourquoi suis-je si tenté de l'essayer?",
      "hylotlDescription": "Vulgaire.",
      "novakidDescription": "J'ai pas envie d'y toucher, et encore moins d'm'asseoir dessus."
    }
  },
  "fleshchest": {
    "name": "Coffre de Chair",
    "desc": "Un coffre spongieux et charnu. Pour ranger des trucs.",
    "metadata": {
      "apexDescription": "La nature répugnante de ce coffre est un excellent moyen de dissuasion contre les voleurs.",
      "avianDescription": "Je ne suis même pas sûr de vouloir l'ouvrir.",
      "floranDescription": "Floran poignarde coffre pour l'ouvrir.",
      "glitchDescription": "Répulsé. Quel coffre infect.",
      "humanDescription": "Beurk. Bon allez, ouvrons-le quand même.",
      "hylotlDescription": "Un coffre écoeurant.",
      "novakidDescription": "Ça ssent même la chair crue. C'est malsain, j'vous l'dis."
    }
  },
  "fleshdoor": {
    "name": "Porte de Chair",
    "desc": "Une porte spongieuse et charnue.",
    "metadata": {
      "apexDescription": "C'est cauchemardesque.",
      "avianDescription": "Une porte grotesque.",
      "floranDescription": "Floran poignarde porte pour l'ouvrir.",
      "glitchDescription": "Mal à l'aise. La porte la plus dégoûtante qui soit.",
      "humanDescription": "Je suppose que je ferais mieux de l'ouvrir.",
      "hylotlDescription": "Quelle porte écoeurante.",
      "novakidDescription": "J'vais la chatouiller pour qu'elle s'ouvre."
    }
  },
  "fleshtable": {
    "name": "Table de Chair",
    "desc": "Une table charnue. Parfaite pour les carnivores.",
    "metadata": {
      "apexDescription": "Qui choisirait de manger ici?",
      "avianDescription": "Quelle table peu attrayante.",
      "floranDescription": "Floran poignarde table par acccident.",
      "glitchDescription": "Dégoûté. Quelqu'un s'assoit vraiment ici pour manger.",
      "humanDescription": "J'ai l'impression que c'est le summum des choses bizarres que je verrai.",
      "hylotlDescription": "Oh, s'il vous plaît... Sérieusement?",
      "novakidDescription": "Imaginez manger un steak sur cette table."
    }
  },
  "feathers1": {
    "name": "Faisceau de Plumes Vibrantes",
    "desc": "De magnifiques plumes vibrantes disposées comme des fleurs.",
    "metadata": {
      "apexDescription": "Je n'ai jamais vu un oiseau avec des plumes aussi grandes.",
      "avianDescription": "Les temples Avians présentent souvent des bouquets de grandes plumes provenant d'oiseaux colorés.",
      "floranDescription": "Floran aime grandess plumess. Veut chassser l'oiseau d'où elless viennent.",
      "glitchDescription": "Observateur. L'oiseau qui possédait ces plumes devait être assez grand.",
      "humanDescription": "Je détesterais croiser l'oiseau qui a perdu ces plumes massives.",
      "hylotlDescription": "Ces plumes sont magnifiques et élégantes.",
      "novakidDescription": "Un bien joli bouquet de plumes."
    }
  },
  "feathers2": {
    "name": "Faisceau de Plumes Colorées",
    "desc": "De magnifiques plumes colorées disposées comme des fleurs.",
    "metadata": {
      "apexDescription": "De quel oiseau cela provient-il? Les plumes sont trop grandes pour être Avians.",
      "avianDescription": "Les Avians décorent les temples avec des plumes tombées des ailes d'oiseaux colorés.",
      "floranDescription": "Floran décore ausssi avec plumesss. Floran prend plumesss comme trophée.",
      "glitchDescription": "Curieux. De quelle créature proviennent ces plumes?",
      "humanDescription": "Elles ont dû appartenir à un sacré gros oiseau.",
      "hylotlDescription": "On ne peut nier la beauté de ces plumes.",
      "novakidDescription": "Ces plumes sont vraiment jolies."
    }
  },
  "featherybird": {
    "name": "Oiseau Décoratif",
    "desc": "D'énormes plumes germent de cette petite statue d'oiseau.",
    "metadata": {
      "apexDescription": "Est-ce que les plumes venaient d'un oiseau comme celui-ci?",
      "avianDescription": "Les Avians construisent ceci pour décorer leurs temples.",
      "floranDescription": "Petit oiseau a l'air ssavoureux.",
      "glitchDescription": "Appréciatif. Une belle statue emplumée.",
      "humanDescription": "Une jolie statue d'oiseau.",
      "hylotlDescription": "Les plumes sont plus belles que la statue.",
      "novakidDescription": "Cette statue a de sacrées belles plumes."
    }
  },
  "fireemblem": {
    "name": "Emblème de Feu Avian",
    "desc": "Cet emblème représente l'élément sauvage et destructeur du feu.",
    "metadata": {
      "apexDescription": "Un symbole utilisé pour avertir d'un incendie.",
      "avianDescription": "Un symbole traditionnel pour le feu.",
      "floranDescription": "Flammesss! La chose que Floran aime le moinss.",
      "glitchDescription": "Prudent. Un symbole pour avertir de la présence de feu devant.",
      "humanDescription": "Ce symbole doit signifier 'feu'.",
      "hylotlDescription": "Un symbole de flamme tourbillonnante, il indique généralement du feu plus loin.",
      "novakidDescription": "On dirait du feu, j'fais gaffe où j'mets les pieds."
    }
  },
  "flowerstatue": {
    "name": "Grande Statue de Fleur",
    "desc": "Une statue de fleur, importante pour les Florans.",
    "metadata": {
      "apexDescription": "Une majestueuse statue de fleur.",
      "avianDescription": "C'est une fleur vraiment géante.",
      "floranDescription": "Belle sstatue de fleur.",
      "glitchDescription": "Bienheureux. Je veux m'asseoir à côté de cette statue.",
      "humanDescription": "Est-ce une statue de coquelicot géant ou de rose?",
      "hylotlDescription": "Une grande fleur faite de pierre.",
      "novakidDescription": "Une statue de fleur sophistiquée. Sculpter ces pétales a dû être coton."
    }
  },
  "fantasyboardgame": {
    "name": "Jeu de Plateau Fantastique",
    "desc": "Un jeu de plateau, avec un château en carton et des pions.",
    "metadata": {
      "apexDescription": "Les jeux de plateau créatifs comme celui-ci sont de la contrebande sous le régime du Big Ape.",
      "avianDescription": "Un tout petit château pour jouer.",
      "floranDescription": "Même Floran aime jouer à dess jeux débiles de temps en temps.",
      "glitchDescription": "Confus. Ce jeu de plateau complexe semble utiliser des dés à 40 faces.",
      "humanDescription": "Que les réjouissances commencent!",
      "hylotlDescription": "J'ai de bons souvenirs de jeux comme celui-ci quand j'étais plus jeune.",
      "novakidDescription": "J'vais gagner la partie et l'château sera tout à moi!"
    }
  },
  "flowerbasket1": {
    "name": "Panier Suspendu",
    "desc": "Un charmant panier suspendu. Ne vous y balancez pas!",
    "metadata": {
      "apexDescription": "Un ravissant panier suspendu.",
      "avianDescription": "Quel magnifique assortiment de fleurs.",
      "floranDescription": "Floran sse balance au panier. S'envole, s'écrasse contre fenêtre. Amussant!",
      "glitchDescription": "Admiratif. Un panier suspendu magnifiquement cultivé.",
      "humanDescription": "L'un d'eux m'est tombé sur la tête une fois. De bons souvenirs.",
      "hylotlDescription": "Une décoration florale suspendue adéquate. J'ai vu des arrangements d'algues plus impressionnants.",
      "novakidDescription": "Un panier suspendu. Rien de tel pour rendre une maison accueillante."
    }
  },
