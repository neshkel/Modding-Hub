  "floodlights": {
    "name": "Projecteurs",
    "desc": "Si je regarde ces lumières plus longtemps, je vais probablement devenir aveugle.",
    "metadata": {
      "apexDescription": "Des lumières d'un éclat aveuglant.",
      "avianDescription": "Une lumière pareille pourrait transformer la nuit en jour!",
      "floranDescription": "Lumière brillante fait mal aux yeux de Floran.",
      "glitchDescription": "Observateur. Je peux voir clairement avec ces lumières allumées.",
      "humanDescription": "Des projecteurs qui portent bien leur nom.",
      "hylotlDescription": "Les Hylotls utilisent des lumières similaires pour éclairer les profondeurs de l'océan.",
      "novakidDescription": "Ces grosses lampes sont plus brillantes qu'un soleil d'été."
    }
  },
  "flickeringfluorescentlight": {
    "name": "Néon Endommagé",
    "desc": "Ce néon a connu des jours meilleurs.",
    "metadata": {
      "apexDescription": "Cette lumière n'a plus qu'un infime vacillement d'énergie. Peut-être peut-elle être réparée.",
      "avianDescription": "Cette lumière est presque complètement hors d'usage.",
      "floranDescription": "Lumière qui bourdonne et vacille.",
      "glitchDescription": "Mécontent. Ce néon est presque non fonctionnel.",
      "humanDescription": "Une lumière cassée qui vacille faiblement.",
      "hylotlDescription": "Cette lumière semble ne pas fonctionner correctement.",
      "novakidDescription": "Cette lumière pétée ne vacille pas plus qu'une bougie."
    }
  },
  "fluorescentlight": {
    "name": "Néon",
    "desc": "Néon brillant.",
    "metadata": {
      "apexDescription": "La lumière ici est artificielle et peu attrayante.",
      "avianDescription": "Cette lumière est crue et froide.",
      "floranDescription": "Vilaine lumière, Floran préfère la lumière du ssoleil.",
      "glitchDescription": "Irrité. La lumière bourdonne doucement lorsqu'elle est allumée.",
      "humanDescription": "J'ai toujours détesté les lumières comme celles-ci.",
      "hylotlDescription": "La lumière que cela dégage est très synthétique.",
      "novakidDescription": "Cette lumière de luxe bourdonne comme des mouches autour d'une mule."
    }
  },
  "fossilpod": {
    "name": "Capsule de Fossile",
    "desc": "Découvrons ce qu'était ce fossile! Posez-le et fracassez-le pour l'ouvrir!",
    "metadata": {
      "apexDescription": "-todo-",
      "avianDescription": "-todo-",
      "floranDescription": "-todo-",
      "glitchDescription": "-todo-",
      "humanDescription": "-todo-",
      "hylotlDescription": "-todo-"
    }
  },
  "fountain1": {
    "name": "Fontaine en Pierre à Étages",
    "desc": "Une magnifique fontaine en pierre. L'eau a l'air rafraîchissante.",
    "metadata": {
      "apexDescription": "Une jolie fontaine. Le bruit de l'eau est apaisant.",
      "avianDescription": "Une grande fontaine. Ça me rappelle un bain d'oiseaux.",
      "floranDescription": "L'eau apporte la vie pour Floran.",
      "glitchDescription": "Relaxé. Le bruit de cette eau est calmant.",
      "humanDescription": "Si j'avais une pièce, je la jetterais dedans.",
      "hylotlDescription": "Une belle eau claire. Parfois, l'océan me manque.",
      "novakidDescription": "Une sorte de statue qui éclabousse de la flotte."
    }
  },
  "fountain2": {
    "name": "Fontaine en Pierre",
    "desc": "Une fontaine en pierre paisible. L'eau s'écoule doucement.",
    "metadata": {
      "apexDescription": "Une fontaine faite de pierre.",
      "avianDescription": "Cette fontaine a de grands et magnifiques jets d'eau.",
      "floranDescription": "Floran aime l'eau claire dans la fontaine.",
      "glitchDescription": "Paisible. Le clapotis de l'eau s'écoule de cette fontaine.",
      "humanDescription": "Je me sens obligé de faire un vœu.",
      "hylotlDescription": "De la pierre façonnée et sculptée en fontaine.",
      "novakidDescription": "Une sorte de statue qui éclabousse de la flotte."
    }
  },
  "frogmerchant": {
    "name": "Marchand Grenouille",
    "desc": "Un marchand grenouille. Personne ne sait ce qu'il est réellement, ni ce qu'il veut.",
    "metadata": {
      "interactData.paneLayoutOverride.windowtitle.title": " Marchand Grenouille",
      "interactData.paneLayoutOverride.windowtitle.subtitle": " Un étrange colporteur amphibie",
      "apexDescription": "Un marchand grenouille silencieux. Inhabituel.",
      "avianDescription": "Qui est ce curieux marchand?",
      "floranDescription": "Floran un peu effrayé par la grenouille ssilencieuse.",
      "glitchDescription": "Inquiet. Cette grenouille semble refuser de communiquer.",
      "humanDescription": "Si je l'embrasse, vous croyez qu'il se transformera en prince marchand?",
      "hylotlDescription": "Cette créature silencieuse n'est pas l'un des nôtres.",
      "novakidDescription": "On ne voit pas beaucoup de marchands grenouilles par ici!"
    }
  },
  "frogstatue": {
    "name": "Statue de Grenouille",
    "desc": "Une statue de grenouille assise paisiblement.",
    "metadata": {
      "apexDescription": "Une statue de grenouille à l'air paisible.",
      "avianDescription": "Cette créature a l'air pensive et réfléchie.",
      "floranDescription": "Floran poignarderait bien cet homme-grenouille.",
      "glitchDescription": "Intéressé. Cette statue représente une espèce de grenouille que je ne connais pas.",
      "humanDescription": "S'il y en avait quelques-uns de plus, on pourrait faire une chorale.",
      "hylotlDescription": "C'est une imposante statue de grenouille.",
      "novakidDescription": "Comment cette grenouille peut rester assise comme ça? On dirait qu'elle va se briser les pattes."
    }
  },
  "futurelight": {
    "name": "Lampe Bon Marché",
    "desc": "Un néon bon marché.",
    "metadata": {
      "apexDescription": "Une lampe basique qui fait le travail.",
      "avianDescription": "Fournit de la luminosité.",
      "floranDescription": "Floran aime la lumière. La lumière fait de l'ombre, Floran sse faufile dans l'ombre.",
      "glitchDescription": "Ennuyé. Les composants de cette lampe sont de peu d'intérêt.",
      "humanDescription": "Une lampe pratique.",
      "hylotlDescription": "Lampes étanches.",
      "novakidDescription": "Un luminaire étanche."
    }
  },
  "fossildisplay1": {
    "name": "Petit Présentoir à Fossile",
    "desc": "Un support d'exposition pour petits fossiles.",
    "metadata": {
      "subtitle": "Exposer des fossiles",
      "apexDescription": "Un support d'exposition. Utilisé pour les fossiles.",
      "avianDescription": "Un support de fossile. Mais pas de fossile.",
      "floranDescription": "Sssupport vide? Où essst le fossstile?",
      "glitchDescription": "Intéressé. Un fossile sera exposé ici.",
      "humanDescription": "C'est un peu triste sans fossile à montrer.",
      "hylotlDescription": "Je serais plus intéressé s'il y avait un fossile exposé ici.",
      "novakidDescription": "C'est pas mal. Ce serait bien mieux avec un fossile..."
    }
  },
  "fossildisplay3": {
    "name": "Présentoir à Fossile Moyen",
    "desc": "Un support d'exposition pour fossiles de taille moyenne.",
    "metadata": {
      "subtitle": "Exposer des fossiles",
      "apexDescription": "Un support d'exposition. Utilisé pour les fossiles.",
      "avianDescription": "Un support de fossile. Mais il n'y a pas de fossile complet.",
      "floranDescription": "L'esspaccce d'exposition pour fossstile essst bien.",
      "glitchDescription": "Intéressé. Un fossile sera exposé ici.",
      "humanDescription": "C'est un peu triste sans fossile complet à montrer.",
      "hylotlDescription": "Je serais plus intéressé s'il y avait un fossile complet exposé ici.",
      "novakidDescription": "C'est pas mal. Ce serait bien mieux avec un fossile complet..."
    }
  },
  "fossildisplay5": {
    "name": "Grand Présentoir à Fossile",
    "desc": "Un support d'exposition pour les grands fossiles.",
    "metadata": {
      "subtitle": "Exposer des fossiles",
      "apexDescription": "Un support d'exposition. Utilisé pour les fossiles.",
      "avianDescription": "Un support de fossile. Mais il n'y a pas de fossile complet.",
      "floranDescription": "L'esspaccce d'exposition pour fossstile essst bien.",
      "glitchDescription": "Intéressé. Un fossile sera exposé ici.",
      "humanDescription": "C'est un peu triste sans fossile complet à montrer.",
      "hylotlDescription": "Je serais plus intéressé s'il y avait un fossile complet exposé ici.",
      "novakidDescription": "C'est pas mal. Ce serait bien mieux avec un fossile complet..."
    }
  },
  "floranarmchair": {
    "name": "Fauteuil Primitif",
    "desc": "C'est juste un fauteuil fait d'os. Rien de bien sorcier.",
    "metadata": {
      "apexDescription": "Une chaise construite à partir d'os et de cuir.",
      "avianDescription": "L'os de cette chaise est presque aussi lisse que du verre.",
      "floranDescription": "Floran polie l'osss de la proie pour faire une chaisse trophée.",
      "glitchDescription": "Terrifié. Cette chaise porte des traces de dents.",
      "humanDescription": "Les os ont été taillés en pointe.",
      "hylotlDescription": "Les Hylotls pensent que toutes les créatures sont sacrées. Elles ne devraient pas finir en fauteuils.",
      "novakidDescription": "Des os ou des briques, qu'importe en quoi une chaise est faite?"
    }
  },
  "floranbed": {
    "name": "Lit Primitif",
    "desc": "Le cadre en os est assez dérangeant, mais cette couverture en fourrure a l'air rudement confortable.",
    "metadata": {
      "apexDescription": "Un lit d'os et de fourrure. En ayant moi-même, cela me met mal à l'aise.",
      "avianDescription": "J'espère que le lit est chaud, à défaut d'autre chose.",
      "floranDescription": "Floran dort parmi les osss et la fourrure. L'odeur de la chassse fait faire de beaux rêvess à Floran.",
      "glitchDescription": "Dégoûté. De quoi aurait l'air un tel meuble s'il était fait avec les restes d'un Glitch?",
      "humanDescription": "L'odeur du sang imprègne les draps.",
      "hylotlDescription": "Quel manque de respect, réduire une créature vivante à un meuble.",
      "novakidDescription": "Ce lit a une odeur de pourri."
    }
  },
  "floranbench": {
    "name": "Banc Primitif",
    "desc": "Un banc fait de bois et d'os. Ça semble... accueillant?",
    "metadata": {
      "apexDescription": "De petits os semblent maintenir le bois ensemble au niveau des jointures.",
      "avianDescription": "Ce bois ne ressemble à rien de ce que j'ai pu voir. On dirait qu'il est encore vivant.",
      "floranDescription": "Floran fait n'importe quoi avec du bois et dess osss. Floran maîtri sse le bois vivant.",
      "glitchDescription": "Sceptique. Il y a une logique dans la construction de ce banc qu'on croirait hors de portée des Florans.",
      "humanDescription": "Le bois est solide. C'est comme s'il continuait de pousser.",
      "hylotlDescription": "Je sens de la vie dans ce banc.",
      "novakidDescription": "Ce banc semble être un endroit aussi bon qu'un autre pour poser mon derrière."
    }
  },
  "floranbonedisplay1": {
    "name": "Trophée en Os",
    "desc": "Le résultat d'une chasse Floran réussie.",
    "metadata": {
      "apexDescription": "Un os gigantesque exposé comme un trophée.",
      "avianDescription": "De quelle immense créature provient cet os?",
      "floranDescription": "Floran n'exposse que dess osss de créaturess tuée ss par Floran.",
      "glitchDescription": "Effrayé. Vu la taille de cet os, la créature dont il provient est probablement plus grande qu'un château Glitch entier.",
      "humanDescription": "C'est un sacrément gros os.",
      "hylotlDescription": "Quelle créature les Florans ont-ils tuée pour obtenir ce... Trophée?",
      "novakidDescription": "Il a dû falloir un sacré talent pour abattre ce gaillard."
    }
  },
  "floranbonedisplay2": {
    "name": "Gravure sur Os",
    "desc": "Des contes barbares Florans sont gravés dans l'os.",
    "metadata": {
      "apexDescription": "Des récits de chasses Florans sont gravés dans l'os.",
      "avianDescription": "Les marques sur cet os suggèrent une histoire de chasse héroïque.",
      "floranDescription": "Quand Floran meurt à la chassse, l'hisstoire de sa bataille finale essst gravée ssur l'os de la proie.",
      "glitchDescription": "Troublé. Les marques sur cet os racontent l'histoire d'une chasse. Il semble qu'un Floran ait été tué.",
      "humanDescription": "Les marques suggèrent qu'une chasse épique a eu lieu. Cet os provient-il de la proie?",
      "hylotlDescription": "Les marques suggèrent qu'au moins un Floran a été tué pendant la chasse de cette pauvre créature.",
      "novakidDescription": "Je ne pige pas pourquoi quelqu'un garderait ce truc. Les marques dessus racontent un truc à propos d'une chasse."
    }
  },
  "floranbonerack": {
    "name": "Râtelier d'Os",
    "desc": "Un râtelier de 3 os non identifiés.",
    "metadata": {
      "apexDescription": "Ces os sont posés là comme des outils. Mais à quoi pourraient-ils servir?",
      "avianDescription": "Sont-ce des armes? Des outils? Des trophées?",
      "floranDescription": "Oss ici utilissés pour polir d'autress osss.",
      "glitchDescription": "Impressionné. Les os ici semblent avoir été utilisés comme outils.",
      "humanDescription": "Est-ce que ces os sont des armes ou des outils?",
      "hylotlDescription": "Accrocher des os comme des outils me remplit de dégoût.",
      "novakidDescription": "Exposer des os comme ça me file la chair de poule."
    }
  },
  "floranbonestool": {
    "name": "Tabouret Primitif",
    "desc": "Un minuscule tabouret sculpté dans l'os.",
    "metadata": {
      "apexDescription": "Un siège façonné dans l'os.",
      "avianDescription": "Un tabouret construit à partir d'os.",
      "floranDescription": "Floran s'assoit ssur les osss dess proiess de Floran.",
      "glitchDescription": "Amusé. Peut-être que ce tabouret a été construit pour un tout petit Floran.",
      "humanDescription": "Ce tabouret est en os poli. Il brille presque.",
      "hylotlDescription": "Quel genre de monstre irait se reposer sur les os d'une autre créature?",
      "novakidDescription": "Je parie qu'une sacrée bagarre a eu lieu pour obtenir cette chaise."
    }
  },
  "floranbonetable1": {
    "name": "Grande Table Primitive",
    "desc": "Cette table entière semble avoir été sculptée dans un seul os énorme.",
    "metadata": {
      "apexDescription": "Une table faite d'os. Les normes d'hygiène ici sont discutables.",
      "avianDescription": "Les Florans ont des goûts particuliers en matière de tables.",
      "floranDescription": "Parfoiss, ssi Floran n'a plus de nourriture, Floran mange la table.",
      "glitchDescription": "Surpris. Cette table semble avoir été traitée thermiquement pour tuer les bactéries.",
      "humanDescription": "Cette table en os est lisse et froide.",
      "hylotlDescription": "Manger à une telle table me retournerait l'estomac.",
      "novakidDescription": "Je ne suis pas fan des meubles en os, mais ça a l'air assez solide."
    }
  },
  "floranbonetable2": {
    "name": "Petite Table Primitive",
    "desc": "Une table fabriquée à partir de nombreux petits os.",
    "metadata": {
      "apexDescription": "Une table faite d'os. L'hygiène ici est douteuse.",
      "avianDescription": "Les Florans ont des goûts de décoration étranges.",
      "floranDescription": "Parfoiss, ssi Floran n'a plus de nourriture, Floran mange la table.",
      "glitchDescription": "Surpris. Cette table semble avoir été traitée par la chaleur pour éliminer les bactéries.",
      "humanDescription": "Cette table en os est lisse et froide.",
      "hylotlDescription": "Manger sur une table pareille me rendrait malade.",
      "novakidDescription": "C'est du solide, même si c'est fait d'ossements."
    }
  },
  "floranbookcase": {
    "name": "Bibliothèque Primitive",
    "desc": "Une bibliothèque fabriquée à partir des restes des proies Florans.",
    "metadata": {
      "apexDescription": "Y a-t-il quelque chose que les Florans ne décorent pas avec des os?",
      "avianDescription": "J'ai du mal à imaginer un Floran écrire un livre.",
      "floranDescription": "Floran ne lit passs de livress. Sseul Greenfinger utilisse une bibliothèque.",
      "glitchDescription": "Observateur. Cette bibliothèque n'a pas été touchée depuis longtemps.",
      "humanDescription": "Les Florans ne semblent pas être de grands lecteurs.",
      "hylotlDescription": "Les Florans semblent incorporer la mort dans chaque objet, même cette bibliothèque.",
      "novakidDescription": "Je n'ai jamais pris les Florans pour des lecteurs. Je suis surpris qu'ils aient besoin d'une bibliothèque."
    }
  },
  "florancabinet1": {
    "name": "Grand Buffet Primitif",
    "desc": "Un buffet orné d'énormes crocs acérés.",
    "metadata": {
      "apexDescription": "Qu'est-ce qui se trouve à l'intérieur d'un meuble Floran? J'ai peur de le découvrir.",
      "avianDescription": "Ce sont soit de grandes dents, soit des os pointus au-dessus de ce buffet.",
      "floranDescription": "Floran décore les meubless avec dess crocss. Plusss c'est pointu, mieux c'est.",
      "glitchDescription": "Effrayé. Les crocs sur ce meuble sont tranchants comme des rasoirs.",
      "humanDescription": "Ce meuble a des crocs.",
      "hylotlDescription": "Les crocs de quelque pauvre créature ornent ce buffet.",
      "novakidDescription": "Les Florans aiment vraiment les meubles pointus."
    }
  },
  "florancabinet2": {
    "name": "Petit Buffet Primitif",
    "desc": "Un buffet orné d'énormes crocs acérés.",
    "metadata": {
      "apexDescription": "Qu'est-ce qu'on peut bien ranger là-dedans? J'ai peur de savoir.",
      "avianDescription": "Des dents géantes ou des os aiguisés décorent ce meuble.",
      "floranDescription": "Floran décore les meubless avec dess crocss. Plusss c'est pointu, mieux c'est.",
      "glitchDescription": "Effrayé. Ces crocs sont acérés.",
      "humanDescription": "Une armoire avec des dents. Super.",
      "hylotlDescription": "Encore des restes d'animaux pour décorer un meuble...",
      "novakidDescription": "Plutôt piquant comme déco."
    }
  },
  "florancabinet3": {
    "name": "Buffet Primitif Immense",
    "desc": "Un meuble fait de cuir tendu entre quatre grandes défenses.",
    "metadata": {
      "apexDescription": "Un meuble fait de peau tannée et de défenses.",
      "avianDescription": "Ce meuble est fait de cuir étiré. Il se déforme quand on appuie dessus.",
      "floranDescription": "Floran aime le buffet en cuir. Le meuble s'étire quand il essst plein.",
      "glitchDescription": "Inspiré. Un design innovant, le cuir s'étire si nécessaire.",
      "humanDescription": "Le placard lui-même est en cuir. C'est une idée sympa.",
      "hylotlDescription": "Le design innovant de ce meuble est gâché par la boucherie.",
      "novakidDescription": "Ce sont des défenses assez impressionnantes pour un simple buffet."
    }
  },
  "floranceilingbones1": {
    "name": "Grand Carillon en Os",
    "desc": "Une guirlande d'os à suspendre au plafond, comme un carillon éolien morbide.",
    "metadata": {
      "apexDescription": "Ces os s'entrechoquent au gré du vent.",
      "avianDescription": "Le cliquetis que font ces os est dérangeant.",
      "floranDescription": "Floran aime le sson dess oss du vent.",
      "glitchDescription": "Troublé. Le son que produisent ces os est similaire à celui d'insectes qui stridulent.",
      "humanDescription": "D'inquiétants carillons en os. Enfin, c'est plus un fracas qu'un carillon.",
      "hylotlDescription": "Le son des os dans le vent me donne la chair de poule.",
      "novakidDescription": "Un genre de carillon bien glauque."
    }
  },
  "floranceilingbones2": {
    "name": "Petit Carillon en Os",
    "desc": "Une guirlande d'os à suspendre au plafond, comme un carillon éolien morbide.",
    "metadata": {
      "apexDescription": "Ces os s'entrechoquent au gré du vent.",
      "avianDescription": "Le cliquetis que font ces os est dérangeant.",
      "floranDescription": "Floran aime le sson dess oss du vent.",
      "glitchDescription": "Troublé. Le son que produisent ces os est similaire à celui d'insectes qui stridulent.",
      "humanDescription": "D'inquiétants carillons en os. Enfin, c'est plus un fracas qu'un carillon.",
      "hylotlDescription": "Le son des os dans le vent me donne la chair de poule.",
      "novakidDescription": "Un genre de carillon bien glauque."
    }
  },
  "floranchair": {
    "name": "Chaise Primitive",
    "desc": "Une simple chaise en bois avec des ornements en os.",
    "metadata": {
      "apexDescription": "Une chaise basique faite de bois et d'os.",
      "avianDescription": "Je me demande si les os des meubles Florans proviennent parfois d'un Floran. Est-ce que les Florans ont seulement des os?",
      "floranDescription": "Floran ne gasspille jamais d'osss. Même les petitess piècess font tenir la chaisse.",
      "glitchDescription": "Indifférence. Design Floran typique.",
      "humanDescription": "Les parties en os ont l'air pointues. Je détesterais m'asseoir dessus.",
      "hylotlDescription": "Les os sur cette chaise... La mort semble s'être tissée jusque dans les plus petits aspects de la vie Floran.",
      "novakidDescription": "Je ne pense pas que les chaises soient censées être aussi pointues."
    }
  },
  "floranchandelier": {
    "name": "Lustre Primitif",
    "desc": "Des torches ont été fixées à un jeune arbre en guise de lustre élégant.",
    "metadata": {
      "apexDescription": "On dirait qu'un jeune arbre a été suspendu à l'envers avec des torches attachées dessus.",
      "avianDescription": "Un lustre fabriqué à partir d'un petit arbre.",
      "floranDescription": "Floran fait une lumière ssuspendue avec un petit arbre. Floran attache torche avec osss, pour ne pass sse brûler les mainss.",
      "glitchDescription": "Amusé. Il semble qu'un petit arbre soit suspendu au plafond.",
      "humanDescription": "On dirait que les Florans ont utilisé un jeune plant pour fabriquer un lustre.",
      "hylotlDescription": "C'est l'une des rares créations Florans qui n'est pas faite d'os. Attendez... C'est quoi ce truc qui tient les torches?",
      "novakidDescription": "On dirait que des torches ont été sanglées à un arbre. Ça a un côté rustique sympa."
    }
  },
  "florancorner": {
    "name": "Support en Cuir",
    "desc": "Un morceau de cuir fin est tendu depuis le plafond.",
    "metadata": {
      "apexDescription": "Un morceau de cuir tendu.",
      "avianDescription": "On dirait du cuir étiré. Je ne suis pas sûr de son utilité.",
      "floranDescription": "Floran ssuspend le cuir pour créer une odeur agréable.",
      "glitchDescription": "Confus. Du cuir tendu. Est-ce décoratif?",
      "humanDescription": "On dirait un morceau de cuir étiré. Ça a l'odeur typique du cuir.",
      "hylotlDescription": "De la peau décorative...",
      "novakidDescription": "Ça m'a tout l'air d'être du cuir tendu, si je ne m'abuse."
    }
  },
  "florancouch": {
    "name": "Canapé Primitif",
    "desc": "Un canapé fait de peaux de cuir et de gros os.",
    "metadata": {
      "apexDescription": "Un canapé construit avec des os et du cuir.",
      "avianDescription": "Ces os sont aussi doux qu'ils sont tranchants.",
      "floranDescription": "Floran avec gros gibier fait canapé en osss. Autre Floran s'assoit ssur canapé. Admire la chassse de Floran.",
      "glitchDescription": "Dégoûté. Il y a des taches de sang sur le cuir.",
      "humanDescription": "Ce canapé semble appartenir à un Floran particulièrement assoiffé de sang.",
      "hylotlDescription": "S'imaginer un Floran assis sur les os d'un être vivant me remplit de dégoût.",
      "novakidDescription": "Je ne vois vraiment pas comment on peut se détendre sur un canapé aussi piquant."
    }
  },
  "florancrate": {
    "name": "Caisse Primitive",
    "desc": "Une caisse de rangement faite de bois brut et d'os.",
    "metadata": {
      "apexDescription": "Une simple caisse de bois et d'os.",
      "avianDescription": "Le bois et l'os font une caisse rudimentaire.",
      "floranDescription": "Floran utilisse dess osss et du bois en trop pour le sstockage.",
      "glitchDescription": "Curieux. Quelles sont les chances qu'un objet de valeur soit dans une caisse aussi modeste?",
      "humanDescription": "Les coins en os permettent de la déplacer facilement sur le sol.",
      "hylotlDescription": "Je redoute d'imaginer ce que les Florans stockent à l'intérieur de cette caisse.",
      "novakidDescription": "Je n'ai presque pas envie de savoir ce qu'il y a dedans. Presque."
    }
  },
  "florancurtain": {
    "name": "Rideau Primitif",
    "desc": "Un rideau, ou une plaque de viande à moitié séchée et à moitié mangée. L'un des deux.",
    "metadata": {
      "apexDescription": "Ce rideau semble avoir peu d'utilité.",
      "avianDescription": "Il y a des trous dans ce rideau.",
      "floranDescription": "Floran utilisse la viande pour cacher le ssoleil quand le ssoleil est chaud.",
      "glitchDescription": "Surpris. Ce rideau est fait de viande.",
      "humanDescription": "Je ne sais pas si c'est un rideau ou de la viande qui pend à une tringle...",
      "hylotlDescription": "Je ne souhaite pas toucher ce... rideau.",
      "novakidDescription": "Eh bien, c'est une façon comme une autre de faire de la viande séchée."
    }
  },
  "florandesk": {
    "name": "Bureau Primitif",
    "desc": "Un bureau, appartenant probablement au Greenfinger d'une tribu Floran.",
    "metadata": {
      "apexDescription": "Un bureau Floran. Quel travail les Florans font-ils qui nécessite un bureau?",
      "avianDescription": "Je n'avais jamais imaginé un Floran travaillant à un bureau jusqu'à présent.",
      "floranDescription": "Floran utilisse le bureau pour préparer prochaine chassse. Pass d'osss dans bureau Floran. Floran ne doit pass être dissstrait.",
      "glitchDescription": "Indifférent. Un simple bureau en bois.",
      "humanDescription": "Ce bureau ne semble pas être fait d'os, ce qui est rare pour un meuble Floran.",
      "hylotlDescription": "Un meuble Floran sans os en vue? Et un secrétaire, en plus! Je dois avoir des hallucinations.",
      "novakidDescription": "Est-ce qu'un bureau Floran servirait à quelqu'un d'autre qu'à un Greenfinger?"
    }
  },
  "florandoor": {
    "name": "Porte Primitive",
    "desc": "Cette porte n'est guère adaptée pour protéger des intempéries.",
    "metadata": {
      "apexDescription": "Une mince porte en bois. Elle oscille au vent.",
      "avianDescription": "Une porte inutile.",
      "floranDescription": "Floran ne ferme pass la porte. Floran ne vole pass les autress Floranss.",
      "glitchDescription": "Confus. Cette porte n'a pas lieu d'être, elle est totalement inutile.",
      "humanDescription": "Je ne suis pas sûr que ce soit une porte très efficace.",
      "hylotlDescription": "Une porte en bois brut et laid.",
      "novakidDescription": "Pas vraiment d'intérêt à avoir cette porte."
    }
  },
  "florandrum1": {
    "name": "Bongo Moyen",
    "desc": "Un bongo façonné à partir de cuir et de bois.",
    "metadata": {
      "apexDescription": "Un bongo. Les Apex apprécient les percussions.",
      "avianDescription": "Les Avians préfèrent le son d'un gong.",
      "floranDescription": "Floranss sson les meilleurss batteurss de tout l'universs.",
      "glitchDescription": "Peu impressionné. Un instrument rudimentaire. Il semble ne produire qu'un seul son.",
      "humanDescription": "Un bongo!",
      "hylotlDescription": "La musique Floran semble être brute à en juger par ce tambour.",
      "novakidDescription": "Un bongo. Les bongos, c'est rigolo!"
    }
  },
  "florandrum2": {
    "name": "Grand Bongo",
    "desc": "Un bongo façonné à partir de cuir et de bois.",
    "metadata": {
      "apexDescription": "Un bongo. Les Apex apprécient les percussions.",
      "avianDescription": "Les Avians préfèrent le son d'un gong.",
      "floranDescription": "Floranss sson les meilleurss batteurss de tout l'universs.",
      "glitchDescription": "Peu impressionné. Un instrument rudimentaire. Il semble ne produire qu'un seul son.",
      "humanDescription": "Un bongo!",
      "hylotlDescription": "La musique Floran semble être brute à en juger par ce tambour.",
      "novakidDescription": "Un bongo. C'est toujours fun les bongos!"
    }
  },
  "florandrum3": {
    "name": "Petit Bongo",
    "desc": "Un bongo façonné à partir de cuir et de bois.",
    "metadata": {
      "apexDescription": "Un bongo. Les Apex apprécient les percussions.",
      "avianDescription": "Les Avians préfèrent le son d'un gong.",
      "floranDescription": "Floranss sson les meilleurss batteurss de tout l'universs.",
      "glitchDescription": "Peu impressionné. Un instrument rudimentaire. Il semble ne produire qu'un seul son.",
      "humanDescription": "Un bongo!",
      "hylotlDescription": "La musique Floran semble être brute à en juger par ce tambour.",
      "novakidDescription": "Un bongo. C'est amusant les bongos!"
    }
  },
  "florandrum4": {
    "name": "Minuscule Bongo",
    "desc": "Un bongo façonné à partir de cuir et de bois.",
    "metadata": {
      "apexDescription": "Un bongo. Les Apex apprécient les percussions.",
      "avianDescription": "Les Avians préfèrent le son d'un gong.",
      "floranDescription": "Floranss sson les meilleurss batteurss de tout l'universs.",
      "glitchDescription": "Peu impressionné. Un instrument rudimentaire. Il semble ne produire qu'un seul son.",
      "humanDescription": "Un bongo!",
      "hylotlDescription": "La musique Floran semble être brute à en juger par ce tambour.",
      "novakidDescription": "Un bongo. Les bongos, c'est sympa!"
    }
  },
  "floranlamp1": {
    "name": "Lampe Cosse à Lianes",
    "desc": "Une étrange cosse lumineuse verte pend lâchement à un poteau en bois courbé.",
    "metadata": {
      "apexDescription": "Il semble que ce soit une sorte de plante lumineuse.",
      "avianDescription": "La plante dégage une lueur verte.",
      "floranDescription": "Greenfinger Floran fait pousser plante pour faire lumière. Beaucoup moinss de feux, moinss de Floran brûléss.",
      "glitchDescription": "Émerveillé. La plante semble absorber les rayons du soleil pendant la journée, ce qui la fait briller.",
      "humanDescription": "Elle a une lueur verte inquiétante. Je me demande ce qu'il y a à l'intérieur de la cosse.",
      "hylotlDescription": "Quelque chose dans cette plante semble contre nature.",
      "novakidDescription": "Comment cet arbre peut-il aussi être une lampe?"
    }
  },
  "floranlight": {
    "name": "Applique Murale à Lianes",
    "desc": "La cosse émet une lumière verte naturelle.",
    "metadata": {
      "apexDescription": "Une lumière verte spectrale.",
      "avianDescription": "Je me demande comment on peut contrôler l'endroit où pousse l'éclairage végétal.",
      "floranDescription": "Lumière Floran gagne puissance du ssoleil. Relâche puissance doucement quand ssoleil est parti.",
      "glitchDescription": "Impressionné. La croissance de ces cosses semble être strictement contrôlée.",
      "humanDescription": "Cette lueur verte me met mal à l'aise.",
      "hylotlDescription": "Ces cosses semblent tout sauf naturelles.",
      "novakidDescription": "Cette lumière pousse directement hors du mur."
    }
  },
  "floranopenpod1": {
    "name": "Cosse Fongique Ouverte",
    "desc": "Une sorte de cosse bizarre. On dirait qu'elle a éclos.",
    "metadata": {
      "apexDescription": "Qu'est-ce qui a grandi là-dedans?",
      "avianDescription": "Quelque chose semble avoir éclos de cette cosse.",
      "floranDescription": "Floran renifle drôle de cossse. Odeur familière. Floran a peur.",
      "glitchDescription": "Analyse. Cette cosse est d'origine Floran, et il n'y a rien à l'intérieur.",
      "humanDescription": "Je n'ai pas envie de rencontrer ce qui a rampé hors d'ici.",
      "hylotlDescription": "Je t'attends, vile bête.",
      "novakidDescription": "Je suis prêt pour toi, sale vermine."
    }
  },
  "floranopenpod2": {
    "name": "Cosse Fongique Ouverte",
    "desc": "Une sorte de cosse bizarre. On dirait qu'elle a éclos.",
    "metadata": {
      "apexDescription": "Qu'est-ce qui a grandi là-dedans?",
      "avianDescription": "Quelque chose semble avoir éclos de cette cosse.",
      "floranDescription": "Floran renifle drôle de cossse. Odeur familière. Floran a peur.",
      "glitchDescription": "Analyse. Cette cosse est d'origine Floran, et il n'y a rien à l'intérieur.",
      "humanDescription": "Je n'ai pas envie de rencontrer ce qui a rampé hors d'ici.",
      "hylotlDescription": "Je suis prêt pour toi, monstre infect.",
      "novakidDescription": "Ramène-toi, bestiole, je t'attends."
    }
  },
  "floranpainting1": {
    "name": "Art du Feu Primitif",
    "desc": "Cette peinture semble illustrer comment allumer un feu.",
    "metadata": {
      "apexDescription": "S'agit-il d'instructions?",
      "avianDescription": "Est-ce de la fumée et du feu?",
      "floranDescription": "Jeune Floran apprend à faire feu comme ça. Beaucoup de jeuness Florans brûlent.",
      "glitchDescription": "Inquiet. Il semble que ce soient des instructions pour faire du feu.",
      "humanDescription": "Une illustration éducative sur la façon de construire un feu.",
      "hylotlDescription": "Les Florans rendent peut-être service aux Hylotls en apprenant à leurs petits à faire du feu.",
      "novakidDescription": "Un dessin qui montre comment on fait du feu."
    }
  },
  "floranpainting2": {
    "name": "Art Glyphe Primitif",
    "desc": "On dirait que quelqu'un a peint des glyphes sur un morceau de cuir.",
    "metadata": {
      "apexDescription": "La langue écrite des Florans semble rudimentaire, au mieux.",
      "avianDescription": "Ceci... ressemble beaucoup à un glyphe Avian. Est-ce que les Florans tentent d'adapter la langue Avian?",
      "floranDescription": "Un Floran a commencé à marquer papier avec dess motss.",
      "glitchDescription": "Confus. J'ai du mal à traduire ce glyphe. Le plus proche que je connaisse est un mot Avian.",
      "humanDescription": "Ce n'est pas ainsi que j'imaginais la langue Floran.",
      "hylotlDescription": "Les Florans se mettent-ils à l'écriture? C'est peut-être le début d'un changement.",
      "novakidDescription": "Un gribouillis grossier sur une peau tannée. Rien de spécial."
    }
  },
  "floranpainting3": {
    "name": "Tableau de Chasse Primitif",
    "desc": "Il semble que ce soit un tableau de pointage.",
    "metadata": {
      "apexDescription": "Un tableau de pointage sans étiquette. Il y a beaucoup de marques ici.",
      "avianDescription": "Un tableau qui semble être utilisé pour compter.",
      "floranDescription": "Un Floran a noté sess proiess sur papier. Mémoire de Floran pas très bonne.",
      "glitchDescription": "Peu impressionné. Un simple système de numérotation en base 10.",
      "humanDescription": "Un vieux tableau de pointage. J'en utilise parfois.",
      "hylotlDescription": "Un tableau de pointage. J'espère que ces marques ne sont pas des victimes.",
      "novakidDescription": "Une sorte de graphique, c'est p'tête un registre de chasse."
    }
  },
  "floranpainting4": {
    "name": "Peinture de Feuille Primitive",
    "desc": "Il semble que ce soit une peinture d'une feuille qui tombe.",
    "metadata": {
      "apexDescription": "Une peinture de feuille.",
      "avianDescription": "Est-ce un symbole ou une peinture?",
      "floranDescription": "Floran fait image de feuille. Feuille trèss ssemblable à Floran.",
      "glitchDescription": "Fier. Le sujet de cette peinture est manifestement une feuille.",
      "humanDescription": "Une peinture Floran d'une feuille. C'est assez logique, j'imagine.",
      "hylotlDescription": "Les Florans aspirent-ils à produire de l'art?",
      "novakidDescription": "L'image d'une feuille emportée par le vent."
    }
  },
  "floranpainting5": {
    "name": "Art Abstrait Primitif",
    "desc": "L'idée qu'un Floran se fait de l'art abstrait.",
    "metadata": {
      "apexDescription": "On dirait de l'art abstrait.",
      "avianDescription": "De l'art, de type abstrait.",
      "floranDescription": "Tentative d'un Floran pour desssiner lever de ssoleil.",
      "glitchDescription": "Arrogant. Une pièce abstraite glorieuse. C'est l'art personnifié.",
      "humanDescription": "On dirait une de ces œuvres abstraites.",
      "hylotlDescription": "Les Hylotls ont brièvement expérimenté l'art abstrait pendant une période. Nous sommes passés à autre chose.",
      "novakidDescription": "On dirait un de ces trucs abstraits."
    }
  },
  "floranpelt1": {
    "name": "Grande Peau Brune",
    "desc": "Une grande peau avec une fourrure épaisse et lustrée.",
    "metadata": {
      "apexDescription": "Une peau épaisse, peut-être utilisée comme isolant.",
      "avianDescription": "Une peau aussi épaisse pourrait faire une belle cape. Les Florans semblent les accrocher aux murs.",
      "floranDescription": "Village Floran ssouvent froid. Floran réchauffe maisson avec peau. Bouche trou dans mur.",
      "glitchDescription": "Sceptique. J'ai entendu dire que la créature dont elle provient avait plus de 200 ans.",
      "humanDescription": "Une peau si grande. Les Florans chassent-ils des créatures de cette taille?",
      "hylotlDescription": "Cette peau devrait réchauffer l'animal auquel elle appartenait.",
      "novakidDescription": "Une peau de bête. Utile pour isoler le mur."
    }
  },
  "floranpelt2": {
    "name": "Petite Peau Noire",
    "desc": "Cette peau sert de trophée à un chasseur Floran.",
    "metadata": {
      "apexDescription": "Une petite peau, peut-être une décoration ou un trophée.",
      "avianDescription": "Le rappel d'une chasse, je suppose.",
      "floranDescription": "Floran montre trophée de chassse aux autress Florans. Gagne resspect.",
      "glitchDescription": "Séduit. La fourrure est douce. Les Florans doivent écorcher leurs conquêtes avec soin.",
      "humanDescription": "Pauvre animal.",
      "hylotlDescription": "Brutalité Floran.",
      "novakidDescription": "Une peau d'un petit animal."
    }
  },
  "floranpelt3": {
    "name": "Longue Peau Noire",
    "desc": "Une peau de fourrure en lambeaux, suspendue à deux grandes défenses.",
    "metadata": {
      "apexDescription": "Cette peau semble avoir connu des jours meilleurs.",
      "avianDescription": "Cette peau ferait un rideau convenable.",
      "floranDescription": "Floran accroche fourruress avec osss de la proie.",
      "glitchDescription": "Intrigué. Les os et la fourrure appartenaient probablement à la même créature.",
      "humanDescription": "Chasser pour le simple plaisir d'un trophée. Je ne peux pas cautionner cela.",
      "hylotlDescription": "Malgré son âge, cette peau dégage encore une forte odeur musquée.",
      "novakidDescription": "Une peau impressionnante, malgré l'usure."
    }
  },
  "floranpelt4": {
    "name": "Grande Peau Enneigée",
    "desc": "La peau d'un grand animal vivant dans la neige.",
    "metadata": {
      "apexDescription": "Une magnifique fourrure à motifs. Je parie que la créature était un spectacle à voir.",
      "avianDescription": "La fourrure d'une bête rayée noire et blanche.",
      "floranDescription": "Fourrure de couleurss et motifss raress. Précieux pour Floran.",
      "glitchDescription": "Sursautant. La coloration suggère que cet animal provenait d'un environnement froid. Rien ne semble freiner la soif de sang des Florans.",
      "humanDescription": "Ça me rappelle un tigre blanc. Ils ont disparu il y a quelques siècles.",
      "hylotlDescription": "Chasser une si belle créature. C'est barbare.",
      "novakidDescription": "C'est une belle peau à motifs."
    }
  },
  "floranpelt5": {
    "name": "Petite Peau Enneigée",
    "desc": "La peau d'un petit animal vivant dans la neige.",
    "metadata": {
      "apexDescription": "Cette fourrure semble avoir appartenu à un petit.",
      "avianDescription": "La fourrure d'une jeune et belle bête.",
      "floranDescription": "Peau de jeune bête des neigess est sspéciale pour Floran.",
      "glitchDescription": "Alarmé. La peau d'un jeune animal, chassé par un Floran.",
      "humanDescription": "Une peau d'animal à motifs. On dirait que l'animal était assez jeune.",
      "hylotlDescription": "Cette peau Floran semble provenir d'un nourrisson. C'est d'autant plus alarmant.",
      "novakidDescription": "C'était une jolie bête. Enfin, avant."
    }
  },
  "floranpod1": {
    "name": "Cosse Fongique",
    "desc": "Une sorte de cosse bizarre. Quelque chose en sort.",
    "metadata": {
      "apexDescription": "Quelles sont ces excroissances ignobles?",
      "avianDescription": "Quelque chose semble être en gestation dans cette cosse.",
      "floranDescription": "Floran renifle drôle de cossse. Odeur familière. Floran a peur.",
      "glitchDescription": "Analyse. Cette cosse est d'origine Floran, mais... quelque chose cloche.",
      "humanDescription": "Beurk, c'est dégoûtant!",
      "hylotlDescription": "Quelles nouvelles horreurs les Florans ont-ils encore inventées?!",
      "novakidDescription": "Y'a un truc carrément louche qui se trame ici."
    }
  },
  "floranpod2": {
    "name": "Cosse Fongique",
    "desc": "Une sorte de cosse bizarre. Quelque chose en sort.",
    "metadata": {
      "apexDescription": "Quelles sont ces excroissances ignobles?",
      "avianDescription": "Quelque chose semble être en gestation dans cette cosse.",
      "floranDescription": "Floran renifle drôle de cossse. Odeur familière. Floran a peur.",
      "glitchDescription": "Analyse. Cette cosse est d'origine Floran, mais... quelque chose cloche.",
      "humanDescription": "Beurk, c'est dégoûtant!",
      "hylotlDescription": "Quelles nouvelles horreurs les Florans ont-ils encore imaginées?!",
      "novakidDescription": "Un truc pas net est en train de pousser là."
    }
  },
  "floranpod3": {
    "name": "Cosse Fongique",
    "desc": "Une sorte de cosse bizarre. Quelque chose en sort.",
    "metadata": {
      "apexDescription": "Quelles sont ces excroissances ignobles?",
      "avianDescription": "Quelque chose semble être en gestation dans cette cosse.",
      "floranDescription": "Floran renifle drôle de cossse. Odeur familière. Floran a peur.",
      "glitchDescription": "Analyse. Cette cosse est d'origine Floran, mais... quelque chose cloche.",
      "humanDescription": "Pouah, c'est immonde!",
      "hylotlDescription": "De quel cauchemar cette cosse provient-elle encore?",
      "novakidDescription": "C'est franchement bizarre ce truc."
    }
  },
  "floranpodapex": {
    "name": "Cosse d'Apex Piégé",
    "desc": "On dirait que les Apex et les Agarans ne sont pas compatibles.",
    "metadata": {
      "apexDescription": "C'est quoi ce... quelle horreur a frappé cet Apex?",
      "avianDescription": "Quelle fin tragique.",
      "floranDescription": "Floran ne veut pass parler de ça.",
      "glitchDescription": "Perplexité. Cet Apex est sain et sauf, et semble avoir grimpé ici de son plein gré.",
      "humanDescription": "Je crois qu'il est... encore en vie.",
      "hylotlDescription": "Quel endroit étrange pour un Apex pour se cacher.",
      "novakidDescription": "Cet Apex est toujours vivant?"
    }
  },
  "floranscreen1": {
    "name": "Paravent en Bois",
    "desc": "Un paravent en bois, parfait pour se changer derrière.",
    "metadata": {
      "apexDescription": "Un paravent qui offre une intimité limitée.",
      "avianDescription": "Un paravent pour s'habiller derrière.",
      "floranDescription": "Floran utilisse paravent pour recueillir éclaboussuress de ssang quand il écorche la viande.",
      "glitchDescription": "Neutre. Un simple paravent.",
      "humanDescription": "Un paravent pour s'habiller... ou se déshabiller.",
      "hylotlDescription": "Un simple paravent.",
      "novakidDescription": "Un écran pour se planquer quand on a des trucs louches à faire."
    }
  },
  "floranscreen2": {
    "name": "Paravent en Cuir",
    "desc": "Un paravent en cuir, utilisé pour la préparation de la nourriture Floran.",
    "metadata": {
      "apexDescription": "Les paravents sont proscrits sous le règne du Miniknog, tout comme l'intimité de toute sorte.",
      "avianDescription": "Le cuir de ce paravent semble avoir absorbé beaucoup de sang.",
      "floranDescription": "Floran ssurprend autress Florans avec nourriture préparée derrière paravent. Plus grosse ssurprise veut dire plus d'amiss.",
      "glitchDescription": "Dégoûté. Les taches de sang sur ce paravent suggèrent qu'il cache la préparation de nourriture.",
      "humanDescription": "Il y a des restes d'animaux stockés dans des poches derrière ce paravent.",
      "hylotlDescription": "Quelle boucherie se déroule derrière ces paravents en cuir?",
      "novakidDescription": "Y'a une forte odeur de sang et de tripes qui traîne autour de ce paravent."
    }
  },
  "floranshelf": {
    "name": "Étagère Primitive",
    "desc": "Une étagère en bois et en os utilisée pour ranger les fournitures et les souvenirs.",
    "metadata": {
      "apexDescription": "Une simple étagère de bois et d'os.",
      "avianDescription": "L'étagère elle-même est probablement un trophée. Pas besoin de la décorer.",
      "floranDescription": "Floran fait étagère pour trophéess mais trophéess trop gros pour étagère. Alors Floran utilisse étagère comme trophée.",
      "glitchDescription": "Impressionné. Les os semblent être des côtes provenant d'une créature immense.",
      "humanDescription": "Cette étagère est vide. Les Florans seraient-ils à court de choses à chasser?",
      "hylotlDescription": "Au moins, l'étagère est vide.",
      "novakidDescription": "Faite d'os et de bois, l'étagère est une sorte de trophée en soi."
    }
  },
  "floransmalltable": {
    "name": "Petite Table Primitive",
    "desc": "Une table façonnée à partir d'un petit arbre surmonté d'une dalle de bois.",
    "metadata": {
      "apexDescription": "Une table construite à partir d'un jeune plant. La plus simple des créations.",
      "avianDescription": "Les Florans construisent des meubles avec les restes de créatures et de plantes, semble-t-il.",
      "floranDescription": "Floran fait petite table avec arbre.",
      "glitchDescription": "Affligé. La base de cette table est un jeune arbre mort.",
      "humanDescription": "La base de cette table ressemble beaucoup à un petit arbre.",
      "hylotlDescription": "Les Florans semblent avoir façonné une table à partir d'un arbre.",
      "novakidDescription": "Une utilisation ingénieuse d'un arbre comme table."
    }
  },
  "floranstoragelocker": {
    "name": "Casier de Rangement Floran",
    "desc": "Une solution de rangement murale, agréable et spacieuse.",
    "metadata": {
      "apexDescription": "Un casier en métal.",
      "avianDescription": "Un endroit pour garder vos affaires.",
      "floranDescription": "Floran peut fourrer dess trucs dans le cassier.",
      "glitchDescription": "Neutre. Un casier de rangement métallique.",
      "humanDescription": "C'est un casier de rangement au look industriel.",
      "hylotlDescription": "Quelque part pour ranger ses effets personnels.",
      "novakidDescription": "Un casier dans le mur."
    }
  },
  "floranstove": {
    "name": "Poêle Primitif",
    "desc": "Une marmite très basique suspendue au-dessus d'un feu de camp.",
    "metadata": {
      "interactData.paneLayoutOverride.windowtitle.title": " Poêle Primitif",
      "interactData.paneLayoutOverride.windowtitle.subtitle": " Pour ce goût rustique authentique",
      "apexDescription": "Un poêle. Une marmite pend à des os noircis par les flammes.",
      "avianDescription": "Le poêle lui-même semble être fait d'os.",
      "floranDescription": "Floran cuit nourriture, profite du jusss sssucré.",
      "glitchDescription": "Prudent. Ce poêle n'a pas l'air particulièrement hygiénique.",
      "humanDescription": "Qui sait ce qui a été cuisiné dans cette marmite.",
      "hylotlDescription": "Je préférerais ne pas manger de nourriture cuisinée sur cet engin.",
      "novakidDescription": "Tout ce qu'il faut pour préparer un repas."
    }
  },
  "florantable1": {
    "name": "Table Primitive",
    "desc": "Les Florans se réunissent autour de tables comme celles-ci pour manger du ragoût de chair.",
    "metadata": {
      "apexDescription": "Une table Floran. Peut-être qu'ils dînent dessus.",
      "avianDescription": "Une simple table Floran.",
      "floranDescription": "Floran crée meubless. Attache bois avec corde.",
      "glitchDescription": "Avertissement. Si la corde s'use, cette table s'effondrera.",
      "humanDescription": "On dirait que la table est maintenue par de la corde au niveau des jointures.",
      "hylotlDescription": "La plus simple des tables. Un enfant Hylotl construit mieux.",
      "novakidDescription": "Rien de mal à avoir une table simple."
    }
  },
  "florantable2": {
    "name": "Comptoir Primitif",
    "desc": "Un comptoir de cuisine utilisé pour couper la viande.",
    "metadata": {
      "apexDescription": "La surface de cette table semble avoir été endommagée par une lame.",
      "avianDescription": "Le sang tache la surface de cette table.",
      "floranDescription": "Floran coupe viande ici. Partage avec autress Floranss.",
      "glitchDescription": "Intéressé. Peut-être que d'autres repas pourraient être préparés en utilisant ce bloc de boucher Floran.",
      "humanDescription": "Les rainures à la surface lui donnent l'air d'une table de boucher.",
      "hylotlDescription": "Les Florans semblent utiliser cette table pour la préparation de la viande.",
      "novakidDescription": "Un billot de boucher utilisé pour couper la viande."
    }
  },
  "florantanningrack": {
    "name": "Métier à Tanner Primitif",
    "desc": "Une peau d'animal tendue et séchée entre deux grands os.",
    "metadata": {
      "apexDescription": "Est-ce un métier à tanner, ou une sorte de chevalet Floran?",
      "avianDescription": "Un dispositif Floran primitif pour traiter le cuir.",
      "floranDescription": "Floran étire peau et tanne le cuir. Les osss tiennent le cuir bien sserré.",
      "glitchDescription": "Confus. Le but de ce support est-il d'exposer une peau d'animal?",
      "humanDescription": "Je pense que ce processus tanne et durcit le cuir.",
      "hylotlDescription": "C'est ainsi que les Florans obtiennent du cuir tanné.",
      "novakidDescription": "Une sorte de peau d'animal toute tendue."
    }
  },
  "florantoilet": {
    "name": "Toilettes Primitives",
    "desc": "Ces toilettes n'ont pas l'air très étanches.",
    "metadata": {
      "apexDescription": "Il semble que ce soit une sorte de toilette faite de bric et de broc.",
      "avianDescription": "Il est difficile d'imaginer un Floran utiliser des toilettes.",
      "floranDescription": "Floran n'a pass bessoin de toilettess luxueussess.",
      "glitchDescription": "Suspicieux. Ces toilettes semblent impossibles à garder propres à cause de leur conception.",
      "humanDescription": "Des toilettes. Ça n'a pas l'air très propre.",
      "hylotlDescription": "Je suis étonné que les Florans soient assez civilisés pour construire des toilettes.",
      "novakidDescription": "Ces toilettes iraient parfaitement dans une cabane au fond du jardin."
    }
  },
  "feathercrownseed": {
    "name": "Graine de Couronne de Plumes",
    "desc": "Des plumes poussent au sommet de la couronne et s'envolent au vent.",
    "metadata": {
      "apexDescription": "On dirait un croisement entre une carotte et un Avian. Inhabituel pour dire le moins.",
      "avianDescription": "Un délice Avian. Seuls les plats les plus fins contiennent de la couronne de plumes.",
      "floranDescription": "Ressemble à un homme-oiseau, a le goût de terre. Hommess-oiseaux plus ssavoureux.",
      "glitchDescription": "Philosophique. Peut-être qu'un jour une couronne de plumes deviendra consciente et s'envolera dans les cieux.",
      "humanDescription": "Une carotte avec une plume. C'est bon à manger, ou pour faire des chatouilles.",
      "hylotlDescription": "Les plumes ne s'épanouissent pas sous l'eau. Les couronnes de plumes non plus.",
      "novakidDescription": "Le fruit avec une surprise plumeuse."
    }
  },
  "flowerblue": {
    "name": "Fleur Bleue",
    "desc": "Une fleur aux pétales d'un bleu éclatant. Utile pour fabriquer de la teinture.",
    "metadata": {
      "apexDescription": "Une fleur bleue. Elle a une utilité.",
      "avianDescription": "Une jolie fleur bleue, je peux l'utiliser pour faire des teintures colorées.",
      "floranDescription": "Cette fleur bleue peut être utilissée pour colorer les vêtementss!",
      "glitchDescription": "Pensif. Une fleur bleue. Elle a une utilité pratique pour la création de teinture.",
      "humanDescription": "Une fleur verte. Attendez, non, elle est bleue.",
      "hylotlDescription": "Une ravissante fleur bleue, belle et utile.",
      "novakidDescription": "Une fleur bleue? Ça doit sûrement servir à kek chose."
    }
  },
  "flowerred": {
    "name": "Fleur Rouge",
    "desc": "Une fleur aux pétales d'un rouge éclatant. Utile pour fabriquer de la teinture.",
    "metadata": {
      "apexDescription": "Une fleur rouge, utilisée pour faire de la teinture rouge. La meilleure couleur!",
      "avianDescription": "Les pétales de cette fleur peuvent être utilisés pour faire de la teinture rouge, une couleur polyvalente et puissante.",
      "floranDescription": "Cette fleur est d'un rouge profond. Ça rappelle un ami à Floran.",
      "glitchDescription": "Respectueux. Les pétales de fleurs rouges sont utilisés pour la création de teinture rouge, une couleur royale.",
      "humanDescription": "À partir de cette minuscule fleur, je peux faire une riche teinture rouge.",
      "hylotlDescription": "Une fleur rouge. Vibrante, riche, magnifique.",
      "novakidDescription": "Une fleur rouge, j'ai toujours envie de m'arrêter pour les ssentir. Je m'demande bien pourquoi?"
    }
  },
  "flowerspring": {
    "name": "Fleur de Printemps",
    "desc": "Une fleur de printemps au parfum sucré.",
    "metadata": {
      "apexDescription": "Une fleur de printemps.",
      "avianDescription": "Une jolie fleur de printemps.",
      "floranDescription": "Floran peut utilisser cette fleur pour changer la couleur dess vêtementss.",
      "glitchDescription": "Joyeux. Une jolie fleur de printemps.",
      "humanDescription": "Une fleur de printemps, le climat doit être tempéré pour qu'elle puisse pousser.",
      "hylotlDescription": "Une fleur de printemps pleine de grâce.",
      "novakidDescription": "Une poignée de ces pétales et j'ai tout c'qu'il faut pour faire une teinture!"
    }
  },
  "floweryellow": {
    "name": "Fleur Jaune",
    "desc": "Une fleur aux pétales d'un jaune éclatant. Utile pour fabriquer de la teinture.",
    "metadata": {
      "apexDescription": "Avec cette fleur, je peux enfin teindre tous mes vêtements en jaune.",
      "avianDescription": "La teinture des fleurs jaunes est très utilisée dans la culture Avian.",
      "floranDescription": "La fleur jaune ssymbolisse la jeunesse dans la culture Floran.",
      "glitchDescription": "Enthousiaste. Une fleur jaune vibrante.",
      "humanDescription": "Une fleur jaune d'une espèce inconnue.",
      "hylotlDescription": "Une ravissante fleur jaune.",
      "novakidDescription": "Une fleur jaune toute simple."
    }
  },
  "firefluffaloegg": {
    "name": "Œuf de Fluffalo de Feu",
    "desc": "Donne naissance à un vulnérable petit fluffalo de feu - une bonne source de noyaux brûlants une fois adulte.",
    "metadata": {
      "apexDescription": "L'œuf d'un fluffalo de feu - ce bétail produit des noyaux brûlants.",
      "avianDescription": "C'est un œuf de fluffalo de feu. Les adultes produisent des noyaux brûlants, utiles pour l'artisanat.",
      "floranDescription": "Œuf de fluffalo de feu. Floran n'aime pass trop le feu, mais cess bêtess sont utiless.",
      "glitchDescription": "Captivé. Ceci donnera naissance à un fluffalo de feu ; une bête adorable qui produit des noyaux brûlants.",
      "humanDescription": "Un œuf de fluffalo de feu! Il y a un petit fluffalo de feu tout mignon à l'intérieur.",
      "hylotlDescription": "L'œuf d'un fluffalo de feu. Ces animaux pastoraux paisibles produisent des noyaux brûlants pour l'artisanat.",
      "novakidDescription": "Un œuf de fluffalo de feu. Y'a un petit gars poilu là-dedans."
    }
  },
  "fluffaloegg": {
    "name": "Œuf de Fluffalo",
    "desc": "Donne naissance à un vulnérable petit fluffalo commun - une bonne source de fibres végétales une fois adulte.",
    "metadata": {
      "apexDescription": "L'œuf d'un fluffalo commun, l'animal adulte produit des fibres végétales.",
      "avianDescription": "Un œuf de fluffalo - c'est la variété commune.",
      "floranDescription": "Ce gros œuf a une grosse bête à l'intérieur - une grosse bête fluffalo trèss amicale!",
      "glitchDescription": "Nostalgique. Le fluffalo est un choix courant de bétail pour les fermiers Glitchs.",
      "humanDescription": "Un œuf de fluffalo! Il y a un petit fluffalo tout mignon à l'intérieur.",
      "hylotlDescription": "L'œuf d'un fluffalo commun, une créature affable.",
      "novakidDescription": "C'est un œuf de fluffalo commun."
    }
  },
  "fossilstation": {
    "name": "^orange;Station de Fossiles^white;",
    "desc": "Utilisée pour fabriquer des outils d'excavation de fossiles et des vitrines d'exposition.",
    "metadata": {
      "interactData.paneLayoutOverride.windowtitle.title": " Station de Fossiles",
      "interactData.paneLayoutOverride.windowtitle.subtitle": " Pinceaux à fossiles et présentoirs",
      "apexDescription": "Je peux fabriquer des outils d'excavation de fossiles ici.",
      "avianDescription": "Un poste d'artisanat où je peux fabriquer des outils de chasse aux fossiles.",
      "floranDescription": "Floran essst curieux de voir fossiles dans la roche. Ici Floran peut faire outilss pour trouver fossiles!",
      "glitchDescription": "Émerveillé. Pour la fabrication d'outils permettant d'identifier les fossiles. J'ai hâte de m'en servir.",
      "humanDescription": "Les outils de restauration de fossiles, c'est cool. Apprenons-en plus sur l'histoire de ces mondes!",
      "hylotlDescription": "Pour fabriquer des appareils de nettoyage de fossiles, afin de scruter le passé.",
      "novakidDescription": "J'en sais pas des masses sur les trucs du passé. Mais p'tête que je pourrais apprendre avec ces outils."
    }
  },
  "floranhunterpainting": {
    "name": "Art du Chasseur Primitif",
    "desc": "Une peinture rudimentaire d'un chasseur Floran maniant une lance.",
    "metadata": {
      "apexDescription": "Cela semble être une peinture de Floran pendant une chasse.",
      "avianDescription": "Cette peinture rupestre semble montrer un Floran avec une lance pendant une chasse.",
      "floranDescription": "Le Floran ssur la peinture court trèss vite. Il doit être en train de chassser.",
      "glitchDescription": "Intrigué. Cette image dépeint grossièrement ce qui semble être un Floran en pleine chasse.",
      "humanDescription": "Le Floran qui a peint ce chasseur aurait bien besoin de prendre quelques cours d'art.",
      "hylotlDescription": "L'art Floran ne pourrait pas être plus éloigné des thèmes de l'art Hylotl. Cette image montre un chasseur ou un guerrier.",
      "novakidDescription": "Cette peinture montre c'que j'pense être un guerrier qui court avec une lance à la main."
    }
  },
  "floranspinneret": {
    "name": "Trophée de Filière",
    "desc": "Ce trophée est la filière d'une grande créature tisseuse de toiles.",
    "metadata": {
      "apexDescription": "Ce trophée est la filière d'une grande créature tisseuse de toiles.",
      "avianDescription": "Ce trophée de chasse est la filière d'une bête inconnue.",
      "floranDescription": "Cette partie de la bête tirait dess toiless, avant de devenir un trophée de chassse.",
      "glitchDescription": "Intrigué. Ce trophée est la filière d'une grande créature inconnue.",
      "humanDescription": "Ce trophée est la filière d'une créature lanceuse de toiles. J'imagine que c'était dur à obtenir.",
      "hylotlDescription": "Un trophée de chasse rudimentaire. C'est la filière d'une grande créature tisseuse.",
      "novakidDescription": "Un trophée intéresstant, j'dirais. Sûrement une grosse et vilaine tisseuse."
    }
  },
  "floranwebbing": {
    "name": "Présentoir de Toiles",
    "desc": "Ce présentoir à trophées est recouvert d'une toile infecte.",
    "metadata": {
      "apexDescription": "Beurk... c'est une sorte de toile infecte.",
      "avianDescription": "C'est une sorte de toile immonde. Je ferais mieux de ne pas y toucher!",
      "floranDescription": "Cette toile fait un bon trophée. Maisss c'est affreux.",
      "glitchDescription": "Terrifié. Juste une énorme toile collante, rien de quoi avoir peur. Enfin j'espère.",
      "humanDescription": "On dirait une sorte de toile d'araignée. Dégueu!",
      "hylotlDescription": "Une toile infecte produite par une créature étrange.",
      "novakidDescription": "Un tas de glu de toile dégoûtante."
    }
  },
