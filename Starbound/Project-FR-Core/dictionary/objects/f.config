      "apexDescription": "Une console d'apparence rudimentaire.",
      "avianDescription": "À quoi servent toutes ces ampoules?",
      "floranDescription": "Ampouless brillantes et boutonss.",
      "glitchDescription": "Fasciné. Je serais curieux de savoir ce que ces ampoules signifient.",
      "humanDescription": "Cette console a toutes les options imaginables.",
      "hylotlDescription": "Une pièce de technologie rudimentaire.",
      "novakidDescription": "Une console qui en jette."
    }
  },
  "foundrydoor": {
    "name": "Porte Lourde",
    "desc": "Une lourde porte métallique souvent utilisée dans les fonderies.",
    "metadata": {
      "apexDescription": "Une porte à l'aspect pesant.",
      "avianDescription": "Je peux à peine pousser cette porte tellement elle est lourde.",
      "floranDescription": "Floran claque la porte pour faire un gros ssont.",
      "glitchDescription": "Espiègle. Je me demande si je pourrais produire un écho puissant en claquant cette porte lourde...",
      "humanDescription": "Une porte avec un hublot!",
      "hylotlDescription": "Une porte similaire à celles que l'on trouve sous l'océan, assez lourde pour être étanche.",
      "novakidDescription": "Une porte lourde avec un hublot bien pratique."
    }
  },
  "foundryelevatorlong": {
    "name": "Long Ascenseur Industriel",
    "desc": "Ce design d'ascenseur est couramment vu dans les fonderies.",
    "metadata": {
      "apexDescription": "Un ascenseur robuste.",
      "avianDescription": "Le moyen le plus simple de se déplacer dans une installation à plusieurs niveaux.",
      "floranDescription": "L'asccensseur monte et desscend.",
      "glitchDescription": "Ennuyé. Un ascenseur sans inspiration.",
      "humanDescription": "Un ascenseur pour monter et descendre les étages.",
      "hylotlDescription": "Un ascenseur industriel.",
      "novakidDescription": "Une sorte d'ascenseur, utile!"
    }
  },
  "foundryelevatorshort": {
    "name": "Petit Ascenseur Industriel",
    "desc": "Ce design d'ascenseur est couramment vu dans les fonderies.",
    "metadata": {
      "apexDescription": "Un ascenseur robuste.",
      "avianDescription": "Le moyen le plus simple de se déplacer dans une installation à plusieurs niveaux.",
