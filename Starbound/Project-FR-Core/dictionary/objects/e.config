{
  "executivebed": {
    "name": "Lit de Cadre",
    "desc": "Un lit de luxe. Pour le sommeil de votre vie.",
    "metadata": {
      "apexDescription": "Le lit le plus confortable de l'univers.",
      "avianDescription": "Une fois allongé ici, vous ne voudrez plus vous lever.",
      "floranDescription": "Floran sss'enfonce dans le lit, oublie de poignarder jusssqu'à demain.",
      "glitchDescription": "Heureux. Vraiment, il n'y a pas de meilleur lit que celui-ci.",
      "humanDescription": "Le meilleur moment passé dans un lit depuis que j'ai mangé du fromage avant de dormir.",
      "hylotlDescription": "Je suisss s ans voix devant le confort de ce lit.",
      "novakidDescription": "Ça doit être le meilleur fichu lit dans lequel j'aie jamais dormi."
    }
  },
  "executivechair": {
    "name": "Chaise de Cadre",
    "desc": "Une chaise de bureau de luxe. Vous ne voudrez plus jamais rester debout.",
    "metadata": {
      "apexDescription": "S'asseoir dans cette chaise fait fondre tous mes soucis.",
      "avianDescription": "S'asseoir ici suffit à me faire oublier que je suis cloué au sol.",
      "floranDescription": "Sss'asseoir est agréable dans cette chaise.",
      "glitchDescription": "Relaxé. Tout le monde devrait avoir une chaise comme celle-ci.",
      "humanDescription": "Le summum du confort.",
      "hylotlDescription": "Une chaise magistralement conçue. Si confortable.",
      "novakidDescription": "C'te chaise est parfaite pour s'poser un instant."
    }
  },
  "executivedoor": {
    "name": "Porte de Cadre",
    "desc": "Une porte de bureau impénétrable.",
    "metadata": {
      "apexDescription": "Cette porte est entièrement sécurisée.",
      "avianDescription": "Une porte totalement robuste.",
      "floranDescription": "Floran se cache derrière porte. Bondit. Plante!",
      "glitchDescription": "Approbateur. Une porte sans faille.",
      "humanDescription": "Une porte de luxe impénétrable.",
      "hylotlDescription": "Une porte de luxe robuste.",
      "novakidDescription": "Cette porte a vraiment de la gueule."
    }
  },
  "executivelight": {
    "name": "Luminaire de Cadre",
    "desc": "Une lumière de bureau éblouissante.",
    "metadata": {
      "apexDescription": "Une source lumineuse bien conçue.",
      "avianDescription": "Cette lampe utile éclairera même la pièce la plus sombre.",
      "floranDescription": "Lampe chic sssans danger pour Floran.",
      "glitchDescription": "Ravi. Une lampe élégante et efficace.",
      "humanDescription": "Une jolie lampe de bureau.",
      "hylotlDescription": "Une source de lumière au look futuriste.",
      "novakidDescription": "C'te lumière chic en jette un max."
    }
  },
  "executiveswitch": {
    "name": "Console de Cadre",
    "desc": "Une console de luxe. Si exquise qu'on ne peut s'empêcher de la traiter avec respect.",
    "metadata": {
      "apexDescription": "Cette console offre un grand degré de contrôle.",
      "avianDescription": "Une console utile avec une large interface holographique.",
      "floranDescription": "Floran appuie sur boutonsss . Fait arriver chosss es!",
      "glitchDescription": "Impressionné. Une seule console peut contrôler tant de mécanismes à la fois.",
      "humanDescription": "Une console de commande, c'est obligé que je joue avec.",
      "hylotlDescription": "Cette console de contrôle a un design élégant et stylé.",
      "novakidDescription": "C'te console est vraiment quelque chose, j'ai juste envie de m'en servir."
    }
  },
  "executivetable": {
    "name": "Table de Cadre",
    "desc": "Une magnifique table de bureau de luxe.",
    "metadata": {
      "apexDescription": "Cette table de luxe est exceptionnellement profilée.",
      "avianDescription": "Une table de luxe immensément robuste.",
      "floranDescription": "Table asssez bonne pour que Floran découpe viandesss.",
      "glitchDescription": "Approbateur. Une table de luxe sans faille.",
      "humanDescription": "Une table de luxe très cool.",
      "hylotlDescription": "Une table qui surpasse même l'artisanat Hylotl.",
      "novakidDescription": "Je pourrais organiser de sacrées fêtes avec une table pareille."
    }
  },
  "egyptianbed": {
    "name": "Lit Égyptien",
    "desc": "Un lit richement décoré conçu pour la détente.",
    "metadata": {
      "apexDescription": "Ce lit semble mieux adapté pour paresser que pour dormir.",
      "avianDescription": "Ce lit ressemble un peu au style Avian.",
      "floranDescription": "Lit brillant a l'air doux sss.",
      "glitchDescription": "Soulagé. Ce lit semble parfait pour se reposer.",
      "humanDescription": "Ce lit a sa place dans un musée.",
      "hylotlDescription": "Ce lit a clairement été fabriqué par un maître artisan.",
      "novakidDescription": "Un peu chic pour moi, mais ça fera l'affaire!"
    }
  },
  "egyptianchair": {
    "name": "Chaise Égyptienne",
    "desc": "Une chaise dorée décorée de symboles.",
    "metadata": {
      "apexDescription": "Il y a d'étranges symboles gravés sur cette chaise.",
      "avianDescription": "Cette chaise est très impressionnante.",
      "floranDescription": "Chaise en métal aurait besoin de peau douce sss.",
      "glitchDescription": "Intéressé. Cette chaise ressemble un peu à un trône dans un château Glitch.",
      "humanDescription": "On dirait que cette chaise n'est pas très confortable.",
      "hylotlDescription": "Cette chaise semble presque trop belle pour qu'on s'y assoie.",
      "novakidDescription": "Un gars s'sentirait vraiment important assis là-dessus."
    }
  },
  "egyptiancrest": {
    "name": "Blason Égyptien",
    "desc": "Un blason décoratif avec des ailes colorées.",
    "metadata": {
      "apexDescription": "Des couleurs fortes et audacieuses - j'aime ça.",
      "avianDescription": "Ce n'est pas Avian, mais ça me parle vraiment!",
      "floranDescription": "Ailessss géantesss - un oiseau comme ça ferait une grande chassse.",
      "glitchDescription": "Observateur. Ce ne sont pas de vraies ailes, mais une représentation artistique détaillée.",
      "humanDescription": "Un blason avec des ailes aux couleurs vives.",
      "hylotlDescription": "Ce blason est puissant et frappant.",
      "novakidDescription": "J'pense que c'est de l'art, on dirait des ailes géantes."
    }
  },
  "egyptianlamp": {
    "name": "Lampe Égyptienne",
    "desc": "Une grande lampe à huile ornée qui brûle d'une douce flamme bleue.",
    "metadata": {
      "apexDescription": "Une torche en bois surélevée.",
      "avianDescription": "Une grande torche vacillante.",
      "floranDescription": "Grande torche garde le feu.",
      "glitchDescription": "Serein. Une grande torche, la flamme vacille.",
      "humanDescription": "Une torche crépitante.",
      "hylotlDescription": "Une torche surélevée éclaire une vaste zone.",
      "novakidDescription": "La flamme crépite joyeusement."
    }
  },
  "egyptianpillar": {
    "name": "Pilier Égyptien",
    "desc": "Un pilier ornemental décoré d'or.",
    "metadata": {
      "apexDescription": "Ce pilier privilégie clairement la forme sur la fonction.",
      "avianDescription": "Ce pilier semble appartenir à un temple.",
      "floranDescription": "Un grand pilier couvert de métaux sss.",
      "glitchDescription": "Curieux. Ce pilier semble être purement décoratif et non porteur.",
      "humanDescription": "Ce pilier sophistiqué a l'air lourd.",
      "hylotlDescription": "Un bel exemple d'art décoratif ancien.",
      "novakidDescription": "On dirait que ça vient d'un palais ou un truc du genre."
    }
  },
  "egyptianstatuette": {
    "name": "Statuette Égyptienne",
    "desc": "Une statue délicatement décorée d'une petite créature.",
    "metadata": {
      "apexDescription": "On dirait que cette statue est décorée avec de l'or pur.",
      "avianDescription": "La créature que cette statue représente me met mal à l'aise.",
      "floranDescription": "Ssstatue d'une créature qui a l'air sssavoureuse.",
      "glitchDescription": "Curieux. Le créateur de cette statue devait admirer cette créature.",
      "humanDescription": "Cette statue montre beaucoup de respect pour cet animal.",
      "hylotlDescription": "La finesse des détails de cette statue est impressionnante!",
      "novakidDescription": "Eh bien, c'est une bestiole qui a d'la classe."
    }
  },
  "egyptiantable": {
    "name": "Table Égyptienne",
    "desc": "Une table lourde faite de bois et d'or.",
    "metadata": {
      "apexDescription": "La surface de cette table semble de construction très solide.",
      "avianDescription": "Cette table est clairement destinée à un usage important.",
      "floranDescription": "Cette table a l'air lourde.",
      "glitchDescription": "Confus. Il semble que le métal sur cette table n'ait aucune fonction pratique.",
      "humanDescription": "On dirait que cette table n'est pas en or massif, elle est juste recouverte d'une fine couche.",
      "hylotlDescription": "Cette table a été soigneusement décorée.",
      "novakidDescription": "Belle grande table, y'a d'la place pour une partie de cartes."
    }
  },
  "earthmodel": {
    "name": "Modèle de la Terre",
    "desc": "Un modèle détaillé de la planète Terre du système Sol, le monde natal de l'humanité.",
    "metadata": {
      "apexDescription": "La Terre, foyer du Protectorat Terrien, et le mien pendant un temps.",
      "avianDescription": "La Terre, ma deuxième patrie. J'oublie parfois qu'elle n'est plus là...",
      "floranDescription": "Trissste de se souvenir de mon temps sssur Terre. Ça manque à Floran.",
      "glitchDescription": "Nostalgique. J'ai apprécié mon séjour à l'académie sur Terre.",
      "humanDescription": "La maison... Je frissonne à l'idée de ce qu'il en reste aujourd'hui.",
      "hylotlDescription": "La Terre. Une si petite planète, pourtant le vide que je resss ens dans mon cœur est immense.",
      "novakidDescription": "La Terre. Je te tire mon chapeau."
    }
  },
  "exitteleporter": {
    "name": "Téléporteur de Sortie",
    "desc": "Ce téléporteur vous ramènera au vaisseau quand vous serez prêt à partir.",
    "metadata": {
      "apexDescription": "Ceci me permettra de retourner facilement à mon vaisseau.",
      "avianDescription": "Je peux retourner à mon vaisseau en utilisant ça!",
      "floranDescription": "Téléporteur permet à Floran de retourner au vaissseau.",
      "glitchDescription": "Soulagé. Ce téléporteur me permettra de retourner à mon vaisseau.",
      "humanDescription": "Je peux utiliser ceci une fois que je serai prêt à retourner au vaisseau.",
      "hylotlDescription": "Un moyen utile de retourner rapidement à mon vaisseau.",
      "novakidDescription": "Un moyen pratique de retourner au vaisseau et de filer vers la prochaine aventure!"
    }
  },
