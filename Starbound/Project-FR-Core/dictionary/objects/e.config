  "escaperadar": {
    "name": "Antenne Radar de Secours",
    "desc": "Une antenne radar. À ne pas confondre avec un plat à salade.",
    "metadata": {
      "apexDescription": "Une superbe antenne radar.",
      "avianDescription": "Belle antenne.",
      "floranDescription": "Floran aime fracassser les platsss!",
      "glitchDescription": "Curieux. Une antenne radar.",
      "humanDescription": "C'est un joli plat.",
      "hylotlDescription": "Une antenne radar plutôt imposante.",
      "novakidDescription": "J'ai déjà vu des plats plus grands."
    }
  },
  "eventlight": {
    "name": "Petit Projecteur",
    "desc": "Une lumière destinée à attirer l'attention sur une zone.",
    "metadata": {
      "apexDescription": "C'est un petit projecteur.",
      "avianDescription": "C'est un petit projecteur.",
      "floranDescription": "Projecteursss.",
      "glitchDescription": "Neutre. Un projecteur.",
      "humanDescription": "Un projecteur parfaitement ordinaire.",
      "hylotlDescription": "Un projecteur ordinaire.",
      "novakidDescription": "Un projecteur."
    }
  },
  "eggchair": {
    "name": "Fauteuil Œuf",
    "desc": "Cette chaise a une forme d'œuf. Je ne sais pas trop à qui on doit cette idée.",
    "metadata": {
      "apexDescription": "C'est le design poussé jusqu'à la folie.",
      "avianDescription": "Une chaise en forme d'œuf. Je me sens très à l'aise dedans.",
      "floranDescription": "Chaise œuf a l'air sssavoureussse.",
      "glitchDescription": "Inquiet. La conception de ce siège ne permet pas une posture correcte.",
      "humanDescription": "Ce n'est pas très pratique, mais c'est cool!",
      "hylotlDescription": "Le style prime sur la substance.",
      "novakidDescription": "Une grosse chaise qui ressemble à un œuf."
    }
  },
  "electricdoor": {
    "name": "Barrière Électrique",
    "desc": "C'est une sorte de barrière électrique. Ça a l'air dangereux...",
    "metadata": {
      "apexDescription": "Ce courant forme un bouclier pour empêcher les choses de passer.",
      "avianDescription": "Une porte faite d'électricité ? Remarquable.",
      "floranDescription": "Porte grésssille, Floran n'aime pas les portesss électriquesss .",
      "glitchDescription": "Indifférent. Le courant ici est complètement relié à la terre, il n'y a aucun danger.",
      "humanDescription": "C'est un portail fait d'électricité. Qui fabrique une porte pareille ?",
      "hylotlDescription": "Les Hylotls sont très prudents avec les courants électriques.",
      "novakidDescription": "Une grosse étincelle d'énergie électrique turbulente."
    }
  },
  "electriclight": {
    "name": "Lampe Électrique",
    "desc": "Une lampe électrique bon marché.",
    "metadata": {
      "apexDescription": "Une petite lampe électrique.",
      "avianDescription": "L'électricité domestiquée pour produire une simple lumière.",
      "floranDescription": "Petite lumière sssans flamme.",
      "glitchDescription": "Approbateur. Cette lampe basique peut être montée sur presque n'importe quelle surface.",
      "humanDescription": "Une lampe basique fixée au mur.",
      "hylotlDescription": "Juste une lampe d'aspect ordinaire.",
      "novakidDescription": "Juste une petite lampe électrique suspendue."
    }
  },
  "eggshootseed": {
    "name": "Graine d'Eggshoot",
    "desc": "L'Eggshoot, plein de bonnes choses coulantes.",
    "metadata": {
      "apexDescription": "L'eggshoot est connu pour déclencher des dilemmes existentiels chez les oiseaux.",
      "avianDescription": "L'eggshoot: pour quand les Avians veulent des omelettes.",
      "floranDescription": "Resssemble à un œuf, mais n'éclot passs.",
      "glitchDescription": "Curieux. Les Avians en mangent volontiers malgré leur apparence d'œuf.",
      "humanDescription": "Un œuf végétarien.",
      "hylotlDescription": "Un substitut acceptable pour ceux d'entre nous qui ne mangent pas d'œufs.",
      "novakidDescription": "L'eggshoot ressemble à un œuf, a le goût d'un œuf, mais n'est pas un œuf."
    }
  },
  "electricfluffaloegg": {
    "name": "Œuf de Fluffalo Électrique",
    "desc": "Éclot en un vulnérable veau fluffalo électrique - une bonne source de cellules statiques une fois adulte.",
    "metadata": {
      "apexDescription": "C'est un œuf de fluffalo électrique. Il donnera naissance à un fluffalo électrique docile.",
      "avianDescription": "C'est un œuf de fluffalo électrique. Les adultes produisent des cellules statiques.",
      "floranDescription": "Œuf de fluffalo électrique! Floran aime fluffalo électrique - leur duvet fait desss étincellesss.",
      "glitchDescription": "Intéressé. Je me demande si le petit fluffalo électrique va bientôt éclore ?",
      "humanDescription": "C'est un œuf de fluffalo électrique. Ce sont de vrais amours.",
      "hylotlDescription": "Un œuf de fluffalo électrique. Ce sont des créatures douces.",
      "novakidDescription": "Un œuf de fluffalo électrique! On peut récupérer des cellules statiques sur les adultes."
    }
  },
  "explosivebarrel": {
    "name": "Baril Explosif",
    "desc": "Un baril métallique explosif. Il a l'air dangereux.",
    "metadata": {
      "apexDescription": "Un baril explosif. Je devrais garder mes distances.",
      "avianDescription": "Conteneur explosif. Je n'arrive pas à entrer dedans.",
      "floranDescription": "L'étiquette ressemble au feu. Floran sss'éloigne.",
      "glitchDescription": "En alerte. L'étiquette de ce baril avertit d'une substance hautement explosive à l'intérieur.",
      "humanDescription": "L'étiquette explosive sur le devant implique que je ne devrais probablement pas essayer de l'ouvrir.",
      "hylotlDescription": "On dirait un conteneur en métal plein d'explosifs. Il est scellé pour une bonne raison.",
      "novakidDescription": "On dirait de la dynamite moderne, sous forme de baril."
    }
  },
  "erchiuscrystalsample": {
    "name": "Échantillon de Cristal d'Erchius",
    "desc": "\"Un échantillon parfait de carburant de Cristal d'Erchius - des quantités plus importantes sont utilisées pour alimenter les moteurs FTL des vaisseaux.\""
  },
  "eyebed": {
    "name": "Lit-Œil",
    "desc": "Un lit orné d'yeux. Idéal pour les cauchemars.",
    "metadata": {
      "apexDescription": "Ce lit me donne la chair de poule.",
      "avianDescription": "Un lit plutôt inquiétant.",
      "floranDescription": "Floran sss'endormira profondément ici.",
      "glitchDescription": "Curieux. Est-ce que ces yeux veillent sur vous, ou se contentent-ils de vous regarder ?",
      "humanDescription": "On dirait un truc qu'on trouverait dans une maison hantée.",
      "hylotlDescription": "Artisanat vulgaire. On n'est pas censé dormir sur des morts.",
      "novakidDescription": "Un lit qui voit tout. Pourquoi voudrait-on ça ?"
    }
  },
  "eyechair": {
    "name": "Chaise-Œil",
    "desc": "Une chaise-œil. À ne pas confondre avec une chaise haute.",
    "metadata": {
      "apexDescription": "J'ai l'impression que je devrais vérifier si cet œil ne cache pas des caméras du Miniknog.",
      "avianDescription": "Cette chaise semble presque... vivante.",
      "floranDescription": "Floran fixe la chaise, attend que la chaise cligne desss s yeux. Se fatigue. S s s'assoit.",
      "glitchDescription": "Observateur. Malgré les apparences, cette chaise ne peut pas réellement voir.",
      "humanDescription": "S'asseoir ici me donne l'impression que la chaise regarde dans mon cerveau. J'espère qu'elle ne me juge pas.",
      "hylotlDescription": "Une chaise bizarre mais confortable. Elle a un œil dessus.",
      "novakidDescription": "Impossible d'être tranquille sur cette chaise. On s'sent constamment observé..."
    }
  },
  "eyechest": {
    "name": "Coffre-Œil",
    "desc": "Un coffre scellé par un œil perçant. Ça vaut le coup d'œil.",
    "metadata": {
      "apexDescription": "Ce coffre vous met presque au défi de regarder à l'intérieur.",
      "avianDescription": "Peut-être que l'œil est censé être une sorte de moyen de dissuasion pour les voleurs. Ça marche presque sur moi.",
      "floranDescription": "Floran donne coup de pied dans l'œil du coffre, puis ouvre. Voler.",
      "glitchDescription": "Curieux. L'œil est en fait une serrure très sophistiquée. Heureusement, elle est cassée.",
      "humanDescription": "C'est comme si l'œil me regardait voler. Désolé, mon pote.",
      "hylotlDescription": "Une méthode rudimentaire pour décourager les voleurs. Il faudrait être très superstitieux pour ne pas regarder à l'intérieur.",
      "novakidDescription": "Si j'lui fourre un doigt dans l'œil, peut-être qu'il s'ouvrira."
    }
  },
  "eyedoor": {
    "name": "Porte-Œil",
    "desc": "Une porte couverte d'yeux. Ne clignez pas des paupières.",
    "metadata": {
      "apexDescription": "Le regard perçant de cette porte me met au défi d'entrer.",
      "avianDescription": "Cet œil émane de la malveillance. Quelles horreurs se cachent derrière ?",
      "floranDescription": "Floran pense que porte regarde Floran bizarrement. Floran sss'approprie le territoire.",
      "glitchDescription": "Contemplatif. Avec un seul œil, cette porte doit voir le monde comme un espace unidimensionnel.",
      "humanDescription": "Cette porte n'a pas l'air très accueillante. Je crois que c'était un genre de jeu de mots.",
      "hylotlDescription": "Une porte excessivement dramatique décorée d'un grand œil. Les Hylotls préfèrent la beauté dépouillée pour exprimer l'importance.",
      "novakidDescription": "C'te porte me garde à l'œil."
    }
  },
  "eyetable": {
    "name": "Table-Œil",
    "desc": "Une table-œil. Déconseillée aux personnes portant des jupes.",
    "metadata": {
      "apexDescription": "Je n'aime pas l'idée d'une table qui peut étudier mes pieds.",
      "avianDescription": "S'asseoir ici pour manger rendrait n'importe qui nerveux.",
      "floranDescription": "Floran sss'asssoit sssous la table et partage la viande avec l'œil.",
      "glitchDescription": "Observateur. Ce globe oculaire semblait permettre à la table de pivoter. Peut-être pour partager les plats ?",
      "humanDescription": "Cette table effrayante serait parfaite pour n'importe quelle fête d'Halloween.",
      "hylotlDescription": "Une table trop décorée. L'œil n'apporte rien. L'artisan s'est laissé emporter.",
      "novakidDescription": "Ces yeux sont plus gros que mon ventre."
    }
  },
  "embercoral1": {
    "name": "Corail de Braise",
    "desc": "Un arbuste de corail croustillant.",
    "metadata": {
      "apexDescription": "Un corail avec une lueur dorée.",
      "avianDescription": "Un morceau de corail brillant et charmant.",
      "floranDescription": "Croussstillant.",
      "glitchDescription": "Cupide. Un arbuste de corail doré.",
      "humanDescription": "Je me demande si ce corail est chaud pour briller comme ça.",
      "hylotlDescription": "L'une des nombreuses et magnifiques espèces de corail.",
      "novakidDescription": "Y'a d'l'or dans ces océans-là."
    }
  },
