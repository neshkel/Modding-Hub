  "earthemblem": {
    "name": "Emblème de Terre Avian",
    "desc": "Cet emblème représente l'élément fort et résilient de la terre.",
    "metadata": {
      "apexDescription": "Un symbole Avian signifiant la terre.",
      "avianDescription": "L'emblème de la Terre, un symbole courant dans les tombes.",
      "floranDescription": "On dirait une pointe de lance, maisss cet emblème sssignifie la terre.",
      "glitchDescription": "Intrigué. Il s s emblait que ce sssoit l'emblème de la terre.",
      "humanDescription": "Quelques triangles. Ça veut dire la terre.",
      "hylotlDescription": "Une représentation symbolique, emblématique de l'élément terre.",
      "novakidDescription": "Je parie que c'est un emblème Avian pour la terre."
    }
  },
  "electricsign": {
    "name": "Panneau d'Avertissement Électrique",
    "desc": "Attention! Éclairs!",
    "metadata": {
      "apexDescription": "Je me demande quelle quantité d'énergie le Miniknog utilise pour ssses expériences. Souvent, des villes Apex entièresss s ont privées de courant.",
      "avianDescription": "Cela sss emble être un avertisss ement. Mauvais temps ?",
      "floranDescription": "L'éclair fait du feu. Floran a peur du feu.",
      "glitchDescription": "Prudent. Un courant fort peut endommager même lesss s circuits des Glitchs.",
      "humanDescription": "Haute tension! Mieux vaut faire attention.",
      "hylotlDescription": "Quand les Hylotls ont commencé à explorer les océans, il y a eu beaucoup d'accidents avec le courant électrique.",
      "novakidDescription": "Un panneau d'alerte pour l'électricité. J'ferais mieux d'ouvrir l'œil."
    }
  },
  "essencechest": {
    "name": "Coffre d'Essence Ancienne",
    "desc": "Un redoutable coffre ancien orné d'un œil sss ans paupière.",
    "metadata": {
      "apexDescription": "Ce coffre a l'air très vieux et effrayant.",
      "avianDescription": "Ce coffre a l'air très vieux et effrayant.",
      "floranDescription": "Coffre effrayant rend Floran nerveussse.",
      "glitchDescription": "Inquiet. L'œil qui orne ce coffre sss emble me juger.",
      "humanDescription": "Un vieux coffre glauque. Oserais-je l'ouvrir ?",
      "hylotlDescription": "On m'a appris à me méfier des coffres mysss térieux.",
      "novakidDescription": "J'aime pas trop la façon dont ce coffre me regarde."
    }
  },
  "erchiushorroraf": {
    "name": "Figurine d'Horreur d'Erchius",
    "desc": "L'étiquette indique: \"Une aberration parasitaire ayant grandi à l'intérieur de cristaux d'Erchius.\""
  }
