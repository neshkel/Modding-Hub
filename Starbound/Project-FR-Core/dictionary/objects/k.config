{
  "keypad": {
    "name": "Clavier Numérique",
    "desc": "Un clavier de sécurité numérique qui nécessite une combinaison spécifique."
  },
  "kitchencabinet1": {
    "name": "Placard de Cuisine",
    "desc": "Un placard de cuisine robuste.",
    "metadata": {
      "apexDescription": "Ce placard de cuisine semble avoir été fabriqué à la main avec amour.",
      "avianDescription": "Ce meuble rustique est d'une sobriété pleine de goût.",
      "floranDescription": "Floran va remplir placard avec nourriture délisssieuse!",
      "glitchDescription": "Satisfait. Un système de rangement de cuisine bien conçu.",
      "humanDescription": "Un vieux placard de cuisine, exactement comme chez Grand-mère.",
      "hylotlDescription": "L'apparence simple de ce placard cache la qualité de sa fabrication.",
      "novakidDescription": "Un placard de cuisine bien pratique pour les gens de la campagne."
    }
  },
  "kitchencabinet2": {
