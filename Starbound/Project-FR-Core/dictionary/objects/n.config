{
  "not": {
    "name": "Interrupteur NON",
    "desc": "<Un interrupteur /'NON'/. Inverse le signal d'entrée du circuit.>"
  },
  "neptunemodel": {
    "name": "Modèle de Neptune",
    "desc": "Un modèle détaillé de la planète la plus lointaine du système Sol, Neptune.",
    "metadata": {
      "apexDescription": "C'est Neptune. Sa Grande Tache Sombre ressemble à la Grande Tache Rouge de Jupiter, plus connue.",
      "avianDescription": "Neptune porte le nom d'un ancien dieu de la mer de la Terre, et ses lunes portent le nom de divinités marines mineures.",
      "floranDescription": "Neptune essst la deuzième géante de glace du sssystème Sol.",
      "glitchDescription": "Tristesse. Un transport Glitch s'est écrasé sur Neptune à cause d'une défaillance système il y a quelques années. Tous ont péri.",
      "humanDescription": "Neptune est la planète la plus éloignée de mon système d'origine, le système Sol.",
      "hylotlDescription": "Neptune possède la Grande Tache Sombre et la Petite Tache Sombre. S'il y en avait une troisième, ce serait parfait.",
      "novakidDescription": "Les légendes d'un grand bandit cachant son vaisseau dans les nuages neptuniens persistent à cause de disparitions de navires étrangement fréquentes."
    }
  },
  "novakidcaptainschair": {
    "name": "Siège de Capitaine Novakid",
    "desc": "Le capitaine s'assoit ici pour piloter le vaisseau.",
    "metadata": {
      "apexDescription": "Ahh... La douce liberté. Je peux utiliser le navigateur du vaisseau depuis ce siège.",
      "avianDescription": "Le siège du capitaine. C'est moi! Je peux utiliser le navigateur du vaisseau depuis ce siège.",
      "floranDescription": "Meilleur ssiège du vaisssseau. Floran s'as s ssoit ici pour utilisser navigateur et piloter!",
      "glitchDescription": "Excité. S'asseoir sur le siège du capitaine me permet de piloter ce vaisseau. Où allons-nous maintenant?",
      "humanDescription": "Le siège du capitaine. La personne assise ici décide de la destination du vaisseau!",
      "hylotlDescription": "S'asseoir sur le siège du capitaine me permet de piloter ce vaisseau.",
      "novakidDescription": "Le siège du capitaine. Le gars assis ici décide d'où va l'vaisseau! Et c'est moi!"
    }
  },
  "novakidfuelhatch": {
    "name": "Trappe à Carburant DLM",
    "desc": "Accepte l'Erchius Liquide comme carburant pour les sauts DLM du vaisseau.",
    "metadata": {
      "apexDescription": "La trappe à carburant du moteur DLM. Convertit le carburant en liberté.",
      "avianDescription": "La trappe à carburant DLM. Remplissons-la et partons vers les étoiles!",
      "floranDescription": "Trappe à carburant pour moteur DLM. Remplisssonss-la!",
      "glitchDescription": "Excité. Cette trappe alimente le moteur DLM pour que je puisse visiter des planètes hors de ce système.",
      "humanDescription": "La trappe à carburant du vaisseau. Avec du carburant pour le moteur DLM, je peux explorer au-delà de ce système.",
      "hylotlDescription": "L'humble trappe à carburant DLM. Le carburant est le moteur de l'exploration.",
      "novakidDescription": "L'carburant DLM va là-dedans!"
    }
  },
  "novakidshipdoor": {
    "name": "Porte de Vaisseau Novakid",
    "desc": "Une porte adaptée à un vaisseau spatial.",
    "metadata": {
      "apexDescription": "Les portes comme celle-ci sont courantes sur les vaisseaux.",
      "avianDescription": "Une porte de vaisseau spatial.",
      "floranDescription": "Porte de vaisssseau sspatial.",
      "glitchDescription": "Informé. Une porte de vaisseau standard.",
      "humanDescription": "Une porte de vaisseau spatial.",
      "hylotlDescription": "Une porte de vaisseau basique.",
      "novakidDescription": "Une porte, l'genre qu'on trouve sur un vaisseau."
    }
  },
  "novakidshiphatch": {
    "name": "Écoutille de Vaisseau Novakid",
    "desc": "Une écoutille adaptée à un vaisseau spatial.",
    "metadata": {
      "apexDescription": "Les modèles d'écoutilles comme celui-ci sont courants sur les vaisseaux.",
      "avianDescription": "Une écoutille de vaisseau spatial.",
      "floranDescription": "Écoutille de vaisssseau sspatial.",
      "glitchDescription": "Informé. Une écoutille de vaisseau standard.",
      "humanDescription": "Une écoutille de vaisseau spatial.",
      "hylotlDescription": "Une écoutille de vaisseau basique.",
      "novakidDescription": "Une écoutille, l'genre qu'on trouve sur un vaisseau."
    }
  },
  "novakidshipdoorBroken": {
    "name": "Porte de Vaisseau Cassée",
    "desc": "Une porte adaptée à un vaisseau spatial.",
    "metadata": {
      "apexDescription": "Ces portes sont utilisées sur tous nos vaisseaux. Celle-ci ne coopère pas.",
      "avianDescription": "Une porte. Elle ne s'ouvre pas.",
      "floranDescription": "Porte veut pas s'ouvrir!",
      "glitchDescription": "Déçu. Une porte. Elle semble être désactivée pour le moment.",
      "humanDescription": "Chouette porte. Dommage qu'elle ne s'ouvre pas pour l'instant.",
      "hylotlDescription": "Une porte de vaisseau basique. Elle ne veut pas s'ouvrir pour le moment.",
      "novakidDescription": "La porte est cassée, elle va pas s'ouvrir d'ssi tôt."
    }
  },
  "novakidshiplocker": {
    "name": "Casier de Vaisseau",
    "desc": "Un casier. Pourquoi ne pas y stocker quelques trucs?",
    "metadata": {
      "apexDescription": "Je me demande s'il y a des secrets à l'intérieur de ce casier?",
      "avianDescription": "Pourrait-il y avoir quelque chose de valeur dans ce casier?",
      "floranDescription": "Floran fouille casier Novakid pour objetss de valeur.",
      "glitchDescription": "Excité. Je me demande s'il y a des objets intéressants à l'intérieur?",
      "humanDescription": "Un casier de vaisseau.",
      "hylotlDescription": "Peut-être que quelque chose d'utile se trouve dans ce casier.",
      "novakidDescription": "Un endroit sûr pour ranger mon butin."
    }
  },
  "novakidshiplockerTier0": {
    "name": "Casier de Vaisseau",
    "desc": "Un casier. Pourquoi ne pas y stocker quelques trucs?",
    "metadata": {
      "apexDescription": "Le système de stockage du vaisseau. Il n'est pas fonctionnel pour le moment.",
      "avianDescription": "Un appareil qui contient de nombreux objets en toute sécurité. Il est cassé pour l'instant.",
      "floranDescription": "Sstockage. Sça marche pas.",
      "glitchDescription": "Désolé. Le système de stockage de ce vaisseau est en panne.",
      "humanDescription": "Un casier de stockage. Il ne semble pas fonctionner.",
      "hylotlDescription": "Une solution de stockage élégante. Elle n'est pas alimentée pour le moment.",
      "novakidDescription": "Un casier. Pas très utile tant qu'il est pas réparé."
    }
  },
  "novakidtechstation": {
    "name": "S.A.I.L",
    "desc": "Structure Artificielle d'Intelligence Logée, ou S.A.I.L pour faire court.",
    "metadata": {
      "apexDescription": "Je peux parler à SAIL via cette console.",
      "avianDescription": "Je peux utiliser cette station pour parler à SAIL.",
      "floranDescription": "Floran utilise ce panneau magique pour parler à SAIL!",
      "glitchDescription": "Heureux. Cette station me permet de parler à SAIL.",
      "humanDescription": "Cette station me permet de communiquer avec SAIL.",
      "hylotlDescription": "Cette console me permet de communiquer avec SAIL.",
      "novakidDescription": "C'te station m'permet d'causer avec SAIL."
    }
  },
  "novakidtechstationTier0": {
    "name": "S.A.I.L",
    "desc": "Structure Artificielle d'Intelligence Logée, ou S.A.I.L pour faire court.",
    "metadata": {
      "apexDescription": "Quand elle fonctionne, je peux parler à SAIL via cette console.",
      "avianDescription": "Redémarrer cette station devrait me permettre de parler à SAIL.",
      "floranDescription": "Floran répare ce panneau pour réveiller vaisssseau!",
      "glitchDescription": "Désolé. Je dois d'abord redémarrer cette station pour communiquer avec SAIL.",
      "humanDescription": "Si je peux redémarrer cette station, SAIL devrait revenir en ligne!",
      "hylotlDescription": "Cette console me permettra de communiquer avec SAIL. Je dois d'abord la redémarrer.",
      "novakidDescription": "C'est l'heure d'redémarrer c'te station pour pouvoir parler à SAIL."
    }
  },
  "novakidteleporter": {
    "name": "Téléporteur",
    "desc": "Fidèle téléporteur, que ferions-nous sans toi?",
    "metadata": {
      "apexDescription": "Le téléporteur du vaisseau. Se téléporter donne l'impression de faire des montagnes russes à la vitesse de la lumière.",
      "avianDescription": "Le téléporteur! Se téléporter donne l'impression de voler.",
      "floranDescription": "Téléporteur de vaisssseau. Floran sse ssent conffus pendant téléportation.",
      "glitchDescription": "Prétentieux. Un téléporteur. Je suis capable d'entrer en mode veille pendant le processus de téléportation.",
      "humanDescription": "Le téléporteur! Se téléporter est une telle montée d'adrénaline.",
      "hylotlDescription": "Un téléporteur. Se téléporter ressemble à un plongeon dans l'océan depuis le sommet d'une montagne.",
      "novakidDescription": "Téléporteur du vaisseau. Allonss faire un tour!"
    }
  },
  "novakidteleporterTier0": {
    "name": "Téléporteur",
    "desc": "Fidèle téléporteur, que ferions-nous sans toi?",
    "metadata": {
      "apexDescription": "Le téléporteur du vaisseau. Je dois l'alimenter en énergie.",
      "avianDescription": "Le téléporteur! Si seulement celui-ci était alimenté.",
      "floranDescription": "Téléporteur de vaisssseau. Celui-là essst mort.",
      "glitchDescription": "Déçu. Un téléporteur sans courant. Je dois l'alimenter.",
      "humanDescription": "Le téléporteur! Dommage qu'il ne soit pas alimenté.",
      "hylotlDescription": "Ce téléporteur est éteint.",
      "novakidDescription": "Téléporteur du vaisseau. J'dois l'remettre en marche!"
    }
  },
