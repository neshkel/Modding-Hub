  "novakidstoragelocker": {
    "name": "Casier de Rangement Novakid",
    "desc": "Une solution de rangement murale, spacieuse et élégante.",
    "metadata": {
      "apexDescription": "Un casier fabriqué en métal.",
      "avianDescription": "Un endroit pour garder vos affaires.",
      "floranDescription": "Floran peut fourrer des chosess dans le casier.",
      "glitchDescription": "Neutre. Un casier de rangement métallique.",
      "humanDescription": "C'est un casier de rangement au look industriel.",
      "hylotlDescription": "Quelque part où ranger ses effets personnels.",
      "novakidDescription": "Un casier dans le mur."
    }
  },
  "neonhologram": {
    "name": "Hologramme Néon",
    "desc": "Un hologramme magenta représentant un palmier.",
    "metadata": {
      "apexDescription": "C'est un arbre rendu de façon impressionnante... Mais il est regrettable que les hologrammes ne puissent être que d'une seule couleur.",
      "avianDescription": "Un arbre suspendu dans les airs, une formation de lumière figée dans l'espace! Comme c'est merveilleux.",
      "floranDescription": "Floran voit un arbre, mais ne peut pas le ssentir. Ssuspect.",
      "glitchDescription": "Impressionné. Cet arbre est fait de lumière, mais il dégage une telle présence...",
      "humanDescription": "Des arbres holographiques! Qui a besoin de partir en vacances au bord de la mer?",
      "hylotlDescription": "Les représentations artificielles de la nature ne font pas le poids face à la réalité.",
      "novakidDescription": "C'est une invention drôlement chouette!"
    }
  },
  "neonlamppost": {
    "name": "Lampadaire Néon",
    "desc": "Un lampadaire urbain magenta. Pas la meilleure couleur pour la visibilité, mais il a du style.",
    "metadata": {
      "apexDescription": "La coloration de cette lampe me met en état d'alerte maximale.",
      "avianDescription": "Ce lampadaire est plutôt désagréable esthétiquement, si je puis me permettre.",
      "floranDescription": "Floran pourrait grimper au poteau pour un avantage tactique.",
      "glitchDescription": "Inquiet. Si cette lampe est destinée à la visibilité dans la rue, pourquoi est-elle rose?",
      "humanDescription": "Ouaip, c'est bien un lampadaire classique. Je ne sais pas si la lumière rose aide vraiment à y voir clair, par contre.",
      "hylotlDescription": "Un design tellement inélégant.",
      "novakidDescription": "Des lampadaires comme ça doivent être monnaie courante pour les citadins!"
    }
  },
  "neonlight": {
    "name": "Néon Magenta",
    "desc": "Une lumière magenta élégante et discrète.",
    "metadata": {
      "apexDescription": "Ces lumières dégagent une teinte magenta chaleureuse.",
      "avianDescription": "Cette lumière néon me rappelle un coucher de soleil brillant à travers des nuages de diamant.",
      "floranDescription": "Rose essst une couleur forte! Couleur d'une fleur forte et s s saine!",
      "glitchDescription": "Calme. Cette lumière crée une atmosphère agréable.",
      "humanDescription": "Des néons, pour quand on veut donner une ambiance cool à une pièce.",
      "hylotlDescription": "Ce néon me rappelle un rayon de soleil filtré par des océans de saphir.",
      "novakidDescription": "C'te lumière est comme une étoile qui brûle à froid, bien qu'un peu plus petite."
    }
  },
  "neonpeacekeeperemblem": {
    "name": "Emblème de Peacekeeper Néon",
    "desc": "Cet ornement mural brille d'une vive lumière magenta.",
    "metadata": {
      "apexDescription": "Cette grande enseigne au néon semble particulièrement bien conçue.",
      "avianDescription": "Cet emblème mural brille aux couleurs d'un coucher de soleil tropical!",
      "floranDescription": "Grand emblème. Il essst grand.",
      "glitchDescription": "Impressionné. Cet emblème brille comme s'il abritait un feu intérieur!",
      "humanDescription": "C'est comme l'emblème ordinaire des Peacekeepers, mais... en plus cool.",
      "hylotlDescription": "C'est un objet assez criard.",
      "novakidDescription": "Sacrée plaque murale!"
    }
  },
  "neonstore": {
    "name": "Magasin Néon",
    "desc": "Un magasin proposant un assortiment de meubles de Peacekeeper Néon.",
    "metadata": {
      "interactData.paneLayoutOverride.windowtitle.title": " Mobilier Néon",
      "interactData.paneLayoutOverride.windowtitle.subtitle": " Décorez comme un Peacekeeper!",
      "apexDescription": "L'individu qui tient cet étal ne semble pas être un Glitch. Peut-être est-ce une autre sorte d'automate?",
      "avianDescription": "L'esthétique néon de ce magasin est vraiment intrigante!",
      "floranDescription": "Floran pense que Floran pourrait battre vendeur dans combat à mainss nues.",
      "glitchDescription": "Intrigué. Ce marchand semble mécanique, mais il ne ressemble pas à un Glitch.",
      "humanDescription": "Ce gars n'a pas l'air de dire grand-chose, mais sa boutique est plutôt stylée.",
      "hylotlDescription": "Si cette boutique doit insister sur le fait qu'elle est « cool », alors mes attentes sont déjà basses.",
      "novakidDescription": "J'aimerais bien jeter un œil à c'te boutique!"
    }
  },
  "neontriangle": {
    "name": "Triangle Néon",
    "desc": "Cet ornement mural brille d'une vive lumière magenta.",
    "metadata": {
      "apexDescription": "Un triangle de tubes de verre, rempli d'un filament néon.",
      "avianDescription": "Cette applique murale rayonne d'une lueur apaisante!",
      "floranDescription": "Floran veut utilisser truc mural comme arme de jet.",
      "glitchDescription": "Curieux. Le design de cet emblème mural est très minimaliste.",
      "humanDescription": "Cette applique donne vraiment un côté cool à la pièce, prête pour faire la fête.",
      "hylotlDescription": "Quelle couleur criarde.",
      "novakidDescription": "J'dois dire que j'ai un faible pour tout c'qui est néon et brillant!"
    }
  },
  "nowayout": {
    "name": "Pas d'issue",
    "desc": "Un graffiti d'avertissement.",
    "metadata": {
      "apexDescription": "Hmm, dois-je faire confiance à un graffiti?",
      "avianDescription": "Et si ce n'était pas un mensonge?",
      "floranDescription": "Floran ssait.",
      "glitchDescription": "Inquiet. Si ce graffiti dit vrai, je suis mal barré.",
      "humanDescription": "Qui a déjà cru ce qu'il lisait sur un mur?",
      "hylotlDescription": "Je ne fais pas grand cas des présages tagués.",
      "novakidDescription": "Hmm, c'est sérieux c'truc?"
    }
  },
  "neonhylotlhead": {
    "name": "Enseigne Tête d'Hylotl Néon",
    "desc": "Une enseigne au néon représentant une tête de Hylotl.",
    "metadata": {
      "apexDescription": "Une enseigne néon en forme de tête de Hylotl. Dans quel but?",
      "avianDescription": "Une enseigne représentant une tête de Hylotl. Ça ne semble servir à rien.",
      "floranDescription": "L'homme-poissson s'affiche sur panneau lumineux maintenant?",
      "glitchDescription": "Curieux. C'est une enseigne au néon en forme de tête de Hylotl. Pourquoi?",
      "humanDescription": "Je me demande si les Hylotl adorent vraiment se prendre en selfie.",
      "hylotlDescription": "C'est une enseigne au néon en forme de tête de Hylotl.",
      "novakidDescription": "Les Novakid n'ont pas besoin d'enseignes néon à leur effigie, on brille déjà!"
    }
  },
  "numiplush": {
    "name": "Peluche de Numi",
    "desc": "Une peluche de Numi, la mascotte d'un dessin animé Hylotl pour enfants du même nom.",
    "metadata": {
      "apexDescription": "Une peluche Hylotl. C'est mignon, mais je vais m'en passer.",
      "avianDescription": "Je ne sais pas si je veux une peluche de Hylotl.",
      "floranDescription": "Peluche d'homme-poissson.",
      "glitchDescription": "Tempté. C'est très mignon...",
      "humanDescription": "C'est une peluche de Numi, un personnage de dessin animé. Je passe mon tour.",
      "hylotlDescription": "C'est un jouet en peluche mignon, mais j'avoue être fatigué de voir Numi partout.",
      "novakidDescription": "Trop mignon pour moi."
    }
  },
  "numiposter": {
    "name": "Affiche de Numi",
    "desc": "Une affiche montrant Numi, mascotte d'un dessin animé Hylotl pour enfants.",
    "metadata": {
      "apexDescription": "C'est quoi un Numi? Un genre de personnage de dessin animé?",
      "avianDescription": "Numi? On dirait un croisement entre un Hylotl et un ours. Glacial...",
      "floranDescription": "Un dessin animé d'homme-poissson quelconque.",
      "glitchDescription": "Désintéressé. C'est une publicité pour un dessin animé d'enfants.",
      "humanDescription": "Numi semble être la mascotte d'un dessin animé Hylotl pour enfants.",
      "hylotlDescription": "Ah, j'avoue être fatigué de voir Numi partout.",
      "novakidDescription": "Un genre de personnage de dessin animé pour gosses."
    }
  },
  "numisign": {
    "name": "Panneau Numi",
    "desc": "Un panneau publicitaire pour Numi, une célèbre mascotte d'un dessin animé Hylotl pour enfants.",
    "metadata": {
      "apexDescription": "C'est quoi un Numi? Un genre de personnage de dessin animé?",
      "avianDescription": "Numi? On dirait un croisement entre un Hylotl et un ours. Glacial...",
      "floranDescription": "Un dessin animé d'homme-poissson quelconque.",
