  "mechplatform": {
    "name": "Plateforme pour Mech",
    "desc": "Une plateforme de téléportation qui invoque le Mech d'un joueur.",
    "metadata": {
      "apexDescription": "Cette plateforme permet d'invoquer un Mech.",
      "avianDescription": "Un socle de téléportation pour déployer un Mech.",
      "floranDescription": "Ce téléporteur invoquera une armure de mech.",
      "glitchDescription": "Informé. Il s'agit d'un téléporteur spécial utilisé pour invoquer une armure Mech.",
      "humanDescription": "Ce socle de téléportation invoquera un Mech.",
      "hylotlDescription": "Cette plateforme permet de téléporter une armure Mech.",
      "novakidDescription": "C'est un socle fait pour téléporter une armure Mech."
    }
  },
  "miningbelt": {
    "name": "Convoyeur de Mine",
    "desc": "Une machine utilisée pour déplacer de grandes quantités de matériaux extraits.",
    "metadata": {
      "apexDescription": "Un convoyeur, pour déplacer des charges lourdes sur une courte distance.",
      "avianDescription": "Un tapis roulant, actuellement à l'arrêt.",
      "floranDescription": "Floran s'ennuie avec lesss barrièresss.",
      "glitchDescription": "Indifférent. Le convoyeur semble non fonctionnel.",
      "humanDescription": "Un petit convoyeur pour déplacer des charges lourdes.",
      "hylotlDescription": "Une construction humaine sans intérêt.",
      "novakidDescription": "Un appareil pour transporter des trucs lourds d'un endroit à un autre."
    }
  },
  "miningchest": {
    "name": "Coffre de Mineur",
    "desc": "Parfait pour y ranger des outils et de l'équipement!",
    "metadata": {
      "apexDescription": "Un coffre! Regardons ce qu'il y a dedans.",
      "avianDescription": "Ces coffres contenaient souvent des objets de valeur. J'ai hâte!",
      "floranDescription": "Coffre! Floran doit fouiller!",
      "glitchDescription": "Curieux. Que pourrait-il y avoir à l'intérieur?",
      "humanDescription": "Un coffre! Ouvrons-le.",
      "hylotlDescription": "Ce coffre a un aspect industriel.",
      "novakidDescription": "Un solide vieux coffre contenant des trésors... j'espère."
    }
  },
  "miningcrusher": {
    "name": "Concasseur de Mine",
    "desc": "Une machine utilisée pour broyer des roches.",
    "metadata": {
      "apexDescription": "Une machine industrielle, utilisée pour broyer des roches.",
      "avianDescription": "Une machine utilisée pour briser des roches.",
      "floranDescription": "Machine pour brissser les os... Floran a dit os? Floran voulait dire rochesss!",
      "glitchDescription": "Observateur. Cette machine sert à concasser la roche.",
      "humanDescription": "Une machine utilisée pour briser des roches.",
      "hylotlDescription": "Une construction métallique inesthétique.",
      "novakidDescription": "Vaudrait mieux pass tomber dans cet engin."
    }
  },
  "miningdoor": {
    "name": "Porte de Mineur",
    "desc": "Une porte métallique au look industriel.",
    "metadata": {
      "apexDescription": "Cette porte pourrait résister à une sacrée puissance de feu.",
      "avianDescription": "Une porte métallique robuste.",
      "floranDescription": "Grosse porte en métal ssemble imposssible à pénétrer.",
      "glitchDescription": "Approbateur. Une porte faite de métal résistant.",
      "humanDescription": "Une porte robuste d'origine humaine.",
      "hylotlDescription": "Une porte laide conçue uniquement pour sa fonction.",
      "novakidDescription": "Cette porte ne plaisante pass."
    }
  },
  "miningfence": {
    "name": "Garde-corps de Mine",
    "desc": "Une barrière métallique avec des bandes d'avertissement rouges et noires.",
    "metadata": {
      "apexDescription": "Un garde-corps métallique peint avec des bandes rouges et noires.",
      "avianDescription": "Un garde-corps métallique.",
      "floranDescription": "Floran s'ennuie avec lesss barrièresss.",
      "glitchDescription": "Observateur. Le garde-corps est installé pour la sécurité.",
      "humanDescription": "Un garde-corps métallique pour empêcher les gens de tomber des plateformes.",
      "hylotlDescription": "Une construction humaine à l'aspect ordinaire.",
      "novakidDescription": "Juste une barrière ennuyeuse."
    }
  },
  "mininghazardsign": {
    "name": "Panneau de Danger Minier",
    "desc": "Un panneau métallique qui dit \"DANGER!\"",
    "metadata": {
      "apexDescription": "Un panneau indiquant \"Danger\".",
      "avianDescription": "Le panneau est un avertissement pour quelque chose.",
      "floranDescription": "Quoi que ça di sse, Floran s'en fiche.",
      "glitchDescription": "Inquiet. Un danger? Où ça?!",
      "humanDescription": "Le panneau se soucie de ma sécurité. C'est attentionné.",
      "hylotlDescription": "Un panneau pour avertir les gens d'un danger proche évitable.",
      "novakidDescription": "J'ai pass peur d'un peu d'grabuge."
    }
  },
  "miningpowersign": {
    "name": "Indicateur d'Énergie",
    "desc": "Un panneau qui indique soit hors ligne, soit en ligne.",
    "metadata": {
      "apexDescription": "Un panneau lumineux rouge.",
      "avianDescription": "Un appareil électronique simpliste.",
      "floranDescription": "Une sssorte de panneau.",
      "glitchDescription": "Observateur. Ce panneau à faible consommation possède deux états.",
      "humanDescription": "Un panneau très informel.",
      "hylotlDescription": "Un panneau à la lueur douce.",
      "novakidDescription": "Un panneau qui va droit au but. J'apprécie ça."
    }
  },
  "miningskip": {
    "name": "Benne de Chantier",
    "desc": "Une grande benne métallique remplie de gravats.",
    "metadata": {
      "apexDescription": "Une grande benne peinte, remplie de gravats et de terre.",
      "avianDescription": "Un vilain conteneur métallique, rempli de gravats et peint en rouge.",
      "floranDescription": "Floran veut dormir dans la boîte rouge.",
      "glitchDescription": "Observateur. Le conteneur semble contenir des gravats indésirables.",
      "humanDescription": "Une grande benne, remplie de gravats et de terre.",
      "hylotlDescription": "Un vilain conteneur métallique, rempli de matériaux gaspillés.",
      "novakidDescription": "Un endroit où jeter les bricoles dont on ne veut plus."
    }
  },
  "miningverticaldoor": {
    "name": "Trappe de Mine",
    "desc": "Une trappe d'accès verticale.",
    "metadata": {
      "apexDescription": "Une porte verticale.",
      "avianDescription": "Une trappe de conception rudimentaire.",
      "floranDescription": "La trappe s'ouvre... La trappe sse ferme.",
      "glitchDescription": "Observateur. Cette trappe sert à l'accès vertical.",
      "humanDescription": "Une trappe pour quand l'horizontal ne suffit plus.",
      "hylotlDescription": "Une trappe rouillée, conçue pour être fonctionnelle.",
      "novakidDescription": "Une trappe dans le sol. Je peux grimper à travers."
    }
  },
  "miniknogoldsign": {
    "name": "Enseigne du Ministère du Savoir",
    "desc": "Une vieille enseigne provenant d'un laboratoire Apex.",
    "metadata": {
      "apexDescription": "Ministère du Savoir? Est-ce... Est-ce que cet endroit est à l'origine du Miniknog?",
      "avianDescription": "Quelle enseigne plaisante. Je me demande de quand elle date?",
      "floranDescription": "Floran ne s'intéressse pas beaucoup aux vieux endroitsss.",
      "glitchDescription": "Appréciatif. Quelles agréables nuances de gris et d'argent.",
      "humanDescription": "Quelque chose dans cette enseigne me rend nerveux.",
      "hylotlDescription": "Quel lettrage hideux. Si seulement j'avais un pinceau de calligraphie...",
      "novakidDescription": "J'ai l'impression que cette découverte est très importante pour quelqu'un quelque part..."
    }
  },
  "microformeralpine": {
    "name": "Microformeur Montagneux",
    "desc": "Transforme une zone de la planète en hauts plateaux rocheux."
  },
  "microformerbioluminescence": {
    "name": "Microformeur Luminescent",
    "desc": "Transforme une zone de la planète en jardin bioluminescent."
  },
  "microformerbones": {
    "name": "Microformeur Squelettique",
    "desc": "Transforme une zone de la planète en un désert aride d'ossements dispersés."
  },
  "microformereyepatch": {
    "name": "Microformeur Oculaire",
    "desc": "Transforme une zone de la planète en amas de globes oculaires sans paupières."
  },
  "microformerflesh": {
    "name": "Microformeur Charnu",
    "desc": "Transforme une zone de la planète en une abomination de chair."
  },
  "microformergeode": {
    "name": "Microformeur Cristallin",
    "desc": "Transforme une zone de la planète en un magnifique jardin de roches cristallines."
  },
  "microformergiantflowers": {
    "name": "Microformeur Floral",
    "desc": "Transforme une zone de la planète en un parterre de fleurs géantes."
  },
  "microformerhive": {
    "name": "Microformeur de Ruche",
    "desc": "Transforme une zone de la planète en une ruche d'invertébrés extraterrestres."
  },
  "microformerluminouscaves": {
    "name": "Microformeur de Champignons Lumineux",
    "desc": "Transforme une zone de la planète en un amas visqueux de champignons phosphorescents."
  },
  "microformermushrooms": {
    "name": "Microformeur Fongique",
    "desc": "Transforme une zone de la planète en un amas de champignons spongieux et de crapaudines géantes."
  },
  "microformerrust": {
    "name": "Microformeur Rouillé",
    "desc": "Transforme une zone de la planète en un bosquet métallique oxydé."
  },
  "microformerslimecaves": {
    "name": "Microformeur de Glu",
    "desc": "Transforme une zone de la planète en une fosse de boue gluante."
  },
  "microformersteamspring": {
    "name": "Microformeur de Sources de Vapeur",
    "desc": "Transforme une zone de la planète en une nappe glaciaire parsemée d'étranges tuyaux de vapeur."
  },
  "microformertar": {
    "name": "Microformeur de Goudron",
    "desc": "Transforme une zone de la planète en un marasme de goudron collant."
  },
  "microformerwilderness": {
    "name": "Microformeur de Nature Sauvage",
    "desc": "Transforme une zone de la planète en une étendue sauvage envahie par la végétation."
  },
  "mindwurmplush": {
    "name": "Peluche de Ver Cérébral",
    "desc": "Une peluche de Ver Cérébral à la mignonnerie discutable.",
    "metadata": {
      "apexDescription": "Je ne suis pas sûr que cette peluche soit très mignonne...",
      "avianDescription": "Les Vers Cérébraux sont trop effrayants pour être mignons.",
      "floranDescription": "Ver Cérébral trop agaçant pour que Floran le trouve mignon.",
      "glitchDescription": "Détressé. Je n'aime pas les Vers Cérébraux, même en peluche.",
      "humanDescription": "Même sous forme de peluche, les Vers Cérébraux font un peu peur.",
      "hylotlDescription": "Les Vers Cérébraux sont des créatures au look très intéressant. Je ne suis pas sûr d'en vouloir un en peluche.",
      "novakidDescription": "Bien plus mignon qu'un vrai Ver Cérébral, c'est certain!"
    }
  },
  "molemanposter": {
    "name": "Affiche de l'Homme-Taupe",
    "desc": "Une affiche encadrée pour le film culte, \"La Prophétie de l'Homme-Taupe\".",
    "metadata": {
      "apexDescription": "Est-ce l'antagoniste sur l'affiche? Il a l'air terrifiant...",
      "avianDescription": "Ce film a l'air très effrayant... Surtout ce monstre sur l'affiche.",
      "floranDescription": "Homme-taupe? C'est juste un humain très sssemi-effrayant.",
      "glitchDescription": "Fasciné. Qui est l'Homme-Taupe et quelle est sa prophétie?",
      "humanDescription": "Les Hylotls ont des idées bizarres sur les films d'horreur...",
      "hylotlDescription": "C'est peut-être le film le plus terrifiant que j'aie jamais vu.",
      "novakidDescription": "Un film qui a l'air de flanquer la frousse, si vous voulez mon avis."
    }
  },
  "marinesign": {
    "name": "Enseigne de l'USCM",
    "desc": "Que signifie USCM, déjà?",
    "metadata": {
      "apexDescription": "Une enseigne faisant la promotion de l'USCM, une faction militaire humaine dissoute.",
      "avianDescription": "Cette zone a manifestement connu une présence militaire humaine autrefois.",
      "floranDescription": "Enseigne sstupide et voyante. Les Floransss essaient d'être plus discrets sur leur présence.",
      "glitchDescription": "Pensif. Les tactiques militaires humaines impliquent beaucoup de fanfaronnade.",
      "humanDescription": "L'USCM, hein? Ces gars-là n'aimaient pas beaucoup le Terrene Protectorate.",
      "hylotlDescription": "Les militaires humains aiment certainement faire sentir leur présence.",
      "novakidDescription": "Je n'ai jamais entendu parler de ces gars, mais à en juger par l'état de ce panneau, ils sont partis depuis un bail."
    }
  },
  "microwave": {
    "name": "Micro-ondes",
    "desc": "Atomisez toute la nourriture!",
    "metadata": {
      "interactData.paneLayoutOverride.windowtitle.title": " Micro-ondes",
      "interactData.paneLayoutOverride.windowtitle.subtitle": " Cuisine rapide",
      "apexDescription": "Un appareil pour cuire rapidement la nourriture.",
      "avianDescription": "Un peu comme un four, mais plus rapide.",
      "floranDescription": "Machine pour chauffer les en-casss. Floran a déjà utilisé ça.",
      "glitchDescription": "Inconfortable. Les micro-ondes peuvent être dommageables pour les circuits des Glitchs.",
      "humanDescription": "Une fois, j'ai passé une salade au micro-ondes. Ce n'était pas si mauvais, en fait!",
      "hylotlDescription": "Une méthode de cuisson pour ceux qui ne se soucient pas de la qualité de leur préparation.",
      "novakidDescription": "Je ne sais pas trop ce que fait cette machine... Mais on dirait que quelque chose est mort là-dedans."
    }
  },
  "menorah": {
    "name": "Menorah",
    "desc": "Une lueur festive et chaleureuse.",
    "metadata": {
      "apexDescription": "Un ensemble de bougies à la lueur chaleureuse.",
      "avianDescription": "Cette lueur chaleureuse me rappelle les temples Avians.",
      "floranDescription": "Bougies qui brûlent! Floran aime.",
      "glitchDescription": "Déclaration. Une menorah.",
      "humanDescription": "Une ravissante menorah.",
      "hylotlDescription": "Ces bougies dégagent une lueur chaleureuse et joyeuse.",
      "novakidDescription": "Ça dégage une jolie lueur."
    }
  },
  "mysteriouslight": {
    "name": "Projecteur Doré",
    "desc": "Un petit projecteur doré.",
    "metadata": {
      "apexDescription": "De tels projecteurs sont utilisés par le Miniknog pour forcer les gens à parler. Des projecteurs, et pire encore...",
      "avianDescription": "Une lumière agaçante et aveuglante.",
      "floranDescription": "Floran se ssent comme le centre de l'attention.",
      "glitchDescription": "Furtif. En analysant les cycles de ce projecteur, il serait facile de se faufiler autour.",
      "humanDescription": "J'ai toujours voulu être sous les projecteurs.",
      "hylotlDescription": "Un projecteur puissant et perçant.",
      "novakidDescription": "Cette lumière est presque aussi brillante que moi!"
    }
  },
  "medievalarmor": {
    "name": "Armure d'Exposition",
    "desc": "Une armure étincelante qui se tient résolue.",
    "metadata": {
      "apexDescription": "Une magnifique armure.",
      "avianDescription": "Cela semble être une armure de combat.",
      "floranDescription": "L'homme de métal porte-t-il une armure de métal?",
      "glitchDescription": "Pas impressionné. Cette armure est purement décorative. Une vraie armure de combat est bien plus robuste.",
      "humanDescription": "Une belle armure.",
      "hylotlDescription": "Cette armure semble n'avoir jamais connu le combat.",
      "novakidDescription": "Ça semble inutile de porter un truc pareil pour s'battre."
    }
  },
  "medievalarmorarmed": {
    "name": "Armure d'Exposition Armée",
    "desc": "Une armure étincelante, armée et résolue.",
    "metadata": {
      "apexDescription": "Une magnifique armure.",
      "avianDescription": "Cela semble être une armure de combat.",
      "floranDescription": "L'homme de métal porte-t-il une armure de métal?",
      "glitchDescription": "Pas impressionné. Cette armure est purement décorative. Une vraie armure de combat est bien plus robuste.",
      "humanDescription": "Une belle armure.",
      "hylotlDescription": "Cette armure semble n'avoir jamais connu le combat.",
      "novakidDescription": "Ça semble inutile de porter un truc pareil pour s'battre."
    }
  },
  "medievalarmorswitch": {
    "name": "Armure d'Exposition Suspecte",
    "desc": "Une armure étincelante qui se tient résolue. Hmm... Le bouclier semble mal fixé.",
    "metadata": {
      "apexDescription": "Une magnifique armure. Le bouclier semble mal fixé.",
      "avianDescription": "Cela semble être une armure de combat. Le bouclier a l'air étrange.",
      "floranDescription": "L'homme de métal porte-t-il une armure de métal? Floran sssent quelque chose d'étrange ici.",
      "glitchDescription": "Curieux. Cette armure cache un mécanisme d'interrupteur sous le bouclier.",
      "humanDescription": "Une belle armure. Si c'était un film, le bouclier serait un interrupteur secret.",
      "hylotlDescription": "Cette armure semble n'avoir jamais connu le combat. Le bouclier a l'air particulièrement fragile.",
      "novakidDescription": "Ça semble inutile de porter un truc pareil pour s'battre. C'est quoi l'problème avec l'bouclier?"
    }
  },
  "medievalaxedisplay": {
    "name": "Présentoir de Haches",
    "desc": "Ces haches d'exposition ont l'air très tranchantes.",
    "metadata": {
      "apexDescription": "Quelques haches décoratives. Elles ont l'air assez tranchantes pour être utilisées.",
      "avianDescription": "Des haches au look brutal. Elles sont effectivement très affûtées.",
      "floranDescription": "Sssupide! Les hachess ne sont pas faites pour être au mur.",
      "glitchDescription": "Vanteux. Une hache tranchante est une œuvre d'art pour un Glitch.",
      "humanDescription": "Deux haches courtes et tranchantes.",
      "hylotlDescription": "Les Hylotls voient aussi une valeur artistique dans leurs armes.",
      "novakidDescription": "Des objets d'apparat. Rien de comparable à un bon vieux favori."
    }
  },
  "medievalbed": {
    "name": "Lit Médiéval",
    "desc": "Un lit ferme avec des draps soyeux.",
    "metadata": {
      "apexDescription": "Le lit est dur mais les draps sont soyeux.",
      "avianDescription": "Les draps sont agréablement doux au toucher.",
      "floranDescription": "Floran apprécie le toucher d'un lit ssoyeux.",
      "glitchDescription": "Ravi. Les draps des Glitchs ont tendance à rester soyeux, car notre enveloppe de métal ne les use pas.",
      "humanDescription": "Des draps soyeux sur un lit rude.",
      "hylotlDescription": "De beaux draps en soie. Les Hylotls font bon usage de la soie.",
      "novakidDescription": "C'est pas de jolis draps qui font un bon lit."
    }
  },
  "medievalbookcase": {
    "name": "Bibliothèque Médiévale",
    "desc": "Une bibliothèque pour ranger les contes et légendes populaires...",
    "metadata": {
      "apexDescription": "Une bibliothèque joliment décorée.",
      "avianDescription": "Une vieille demeure poussiéreuse pour les livres.",
      "floranDescription": "Bibliothèque vieille et pousssiéreuse.",
      "glitchDescription": "Intrigué. Les Glitchs n'ont pas produit beaucoup de livres. Je me demande s'il y en a ici.",
      "humanDescription": "Je me demande quel âge ont certains de ces livres.",
      "hylotlDescription": "Il y a peut-être de grandes légendes dans ces vieux livres.",
      "novakidDescription": "C'te bibliothèque a l'air rudement vieille!"
    }
  },
  "medievalbookcaseswitch": {
    "name": "Interrupteur Bibliothèque Médiévale",
    "desc": "L'un de ces livres semble déplacé... Je me demande...",
    "metadata": {
      "apexDescription": "Certains de ces livres n'ont pas l'air tout à fait normaux.",
      "avianDescription": "Une vieille demeure poussiéreuse pour les livres. Certains ne semblent pas réels...",
      "floranDescription": "Livress vieux et pousssiéreux. Ceux-là ont l'air étrange.",
      "glitchDescription": "Suspicieux. Certains livres semblent placés bizarrement.",
      "humanDescription": "Je me demande quel âge ont ces livres. Ceux-là ne sont pas pareils que les autres...",
      "hylotlDescription": "Il y a définitivement quelque chose d'étrange avec cette bibliothèque.",
      "novakidDescription": "J'ai l'pressentiment qu'y a un truc avec ces bouquins!"
    }
  },
  "medievalbowl": {
    "name": "Bol Médiéval",
    "desc": "Un bol. Il n'a pas l'air très propre.",
    "metadata": {
      "apexDescription": "Un bol simple et sale.",
      "avianDescription": "Il semble que l'on mange là-dedans.",
      "floranDescription": "Bol trop petit pour l'appétit de Floran.",
      "glitchDescription": "Neutre. Un bol simple. Probablement fait d'argile.",
      "humanDescription": "Un petit bol, on dirait de l'argile.",
      "hylotlDescription": "Que mange-t-on dans ce bol, je me demande...",
      "novakidDescription": "Un bol simple pour un repas simple."
    }
  },
  "medievalbucket": {
    "name": "Seau Médiéval",
    "desc": "Il y a un trou dans ce seau.",
    "metadata": {
      "apexDescription": "Un seau en bois.",
      "avianDescription": "Utilisé pour transporter de l'eau, je crois.",
      "floranDescription": "Petit sseau utile.",
      "glitchDescription": "Humble. Ce seau a été utilisé pour puiser de l'eau dans les puits et les ruisseaux.",
      "humanDescription": "Le genre de seau qu'on trouverait dans un puits.",
      "hylotlDescription": "Quelqu'un utilise-t-il ce seau pour transporter de l'eau? Je ne peux imaginer un monde où l'eau manque.",
      "novakidDescription": "Un bête vieux seau."
    }
  },
  "medievalcabinet": {
    "name": "Buffet Médiéval",
    "desc": "Un buffet en bois charmant et bien fait.",
    "metadata": {
      "apexDescription": "Un grand buffet en bois. Beaucoup de rangement.",
      "avianDescription": "Un buffet spacieux. À ne pas confondre avec des toilettes sèches.",
      "floranDescription": "Grande boîte en bois. Bien pour que Floran ss'y cache.",
      "glitchDescription": "Reconnaissant. Un buffet en bois finement réalisé.",
      "humanDescription": "Je me demande s'il y a un passage vers un autre monde là-dedans.",
      "hylotlDescription": "Un buffet attrayant fait d'un bois au grain complexe.",
      "novakidDescription": "Un bien beau buffet."
    }
  },
  "medievalcandle": {
    "name": "Bougie",
    "desc": "Une petite bougie en cire dans son support.",
    "metadata": {
      "apexDescription": "Une petite bougie.",
      "avianDescription": "Les prêtres Avians travaillent souvent à la lueur des bougies.",
      "floranDescription": "Les flammmes nues sont trop dangereu s sses!",
      "glitchDescription": "Sentimental. La lueur d'une bougie, comme cela m'avait manqué.",
      "humanDescription": "Une jolie petite bougie.",
      "hylotlDescription": "Peu de choses sont aussi belles que le vacillement de la flamme d'une bougie.",
      "novakidDescription": "Une chouette p'tite bougie."
    }
  },
  "medievalcellbed": {
    "name": "Lit de Paille Médiéval",
    "desc": "Un lit de paille extrêmement rudimentaire.",
    "metadata": {
      "apexDescription": "Un lit qui semble inconfortable avec seulement de la paille pour se réchauffer.",
      "avianDescription": "Aussi proche d'un nid qu'on puisse l'être.",
      "floranDescription": "Lit trop dur. Floran a mal au dosss.",
      "glitchDescription": "Inquiet. Je ne peux imaginer que quelqu'un puisse passer une bonne nuit ici.",
      "humanDescription": "Un lit de paille. Je n'imagine pas dormir là-dessus nuit après nuit.",
      "hylotlDescription": "Un lit inconfortable fait de paille et de bois dur.",
      "novakidDescription": "C'te couche doit être une forme de punition."
    }
  },
  "medievalchair": {
    "name": "Chaise Médiévale",
    "desc": "Une chaise dure, elle deviendrait vite inconfortable.",
    "metadata": {
      "apexDescription": "Une chaise de salle à manger en bois dur.",
      "avianDescription": "Un siège en bois inconfortable. Décoré avec modestie.",
      "floranDescription": "Siège pointu ferait une bonne arme.",
      "glitchDescription": "Ravi. Une chaise de salle à manger commune, de style médiéval typique.",
      "humanDescription": "Une chaise de salle à manger élégante. Elle est dure et inconfortable.",
      "hylotlDescription": "Un siège en bois inconfortable, décoré modestement.",
      "novakidDescription": "Une chaise en bois dur."
    }
  },
  "medievalchandelier": {
    "name": "Lustre Médiéval",
    "desc": "Un lustre en fer. Un bon moyen d'éclairer une grande pièce.",
    "metadata": {
      "apexDescription": "Un lustre en métal. Il semble projeter de longues ombres.",
      "avianDescription": "Un moyen de suspendre des lumières au plafond pour qu'elles éclairent toute la pièce.",
      "floranDescription": "Le feu ssuspendu rend Floran nerveux.",
      "glitchDescription": "Réconforté. Un lustre, cette source de lumière simple me rappelle mon foyer.",
      "humanDescription": "Si c'était un jeu vidéo, il pourrait tomber et écraser quelqu'un.",
      "hylotlDescription": "Ce lustre baigne son environnement d'une lueur chaleureuse.",
      "novakidDescription": "Qui a l'temps d'allumer toutes ces bougies là-haut?"
    }
  },
  "medievalchest": {
    "name": "Coffre Médiéval",
    "desc": "Un vieux coffre en bois, toujours aussi solide.",
    "metadata": {
      "apexDescription": "Un vieux coffre. Il a l'air solide.",
      "avianDescription": "Un coffre-fort en bois dur. Que peut-il y avoir dedans?",
      "floranDescription": "Floran fouille coffre ssolide.",
      "glitchDescription": "Excité. Les Glitchs rangent souvent des armes dans des coffres comme celui-ci. Y en a-t-il une là?",
      "humanDescription": "Ce coffre sort tout droit d'un conte de fées.",
      "hylotlDescription": "Un coffre robuste. Bien pour ranger des objets tranchants.",
      "novakidDescription": "L'genre de coffre qu'on s'attendrait à trouver dans un château."
    }
  },
  "medievalclock": {
    "name": "Horloge Murale Médiévale",
    "desc": "Une petite horloge à balancier. Elle fait tic-tac mais les aiguilles ne bougent jamais.",
