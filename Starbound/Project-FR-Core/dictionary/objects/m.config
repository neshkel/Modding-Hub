      "novakidDescription": "C't'un œuf de mooshi. Si tu veux du lait, t'as intérêt à avoir un mooshi."
    }
  },
  "mechcraftingtable": {
    "name": "^orange;Table de Fabrication de Pièces de Mech^white;",
    "desc": "Utilisée pour produire des composants de mech modulaires.",
    "metadata": {
      "apexDescription": "Cette table peut être utilisée pour produire des composants de mech modulaires.",
      "avianDescription": "Avec cette table, je peux assembler des composants de mech modulaires.",
      "floranDescription": "Une sstation de fabrication pour faire desss piècess de mech.",
      "glitchDescription": "Excité. Cette station est conçue pour assembler des composants de mech modulaires.",
      "humanDescription": "Je peux assembler des composants de mech modulaires à cette station.",
      "hylotlDescription": "Cette table à l'aspect industriel produit des composants de mech modulaires.",
      "novakidDescription": "Avec c'te table, j'pourrais fabriquer des pièces de mech."
    }
  },
  "manipulatoraddon": {
    "name": "^orange;Module de Manipulation^white;",
    "desc": "Un module qui ajoute de l'équipement de combat de haute technologie et des armures au réplicateur.",
    "metadata": {
      "apexDescription": "Quelle utilité, cela ajoutera de l'équipement de combat de haute technologie et des armures au réplicateur.",
      "avianDescription": "Je peux utiliser ceci pour ajouter de l'équipement et des armures supplémentaires au réplicateur.",
      "floranDescription": "Floran utilise sça pour ajouter pluss de chosess au réplicateur.",
      "glitchDescription": "Excité. L'utilisation de ce module ajoutera de l'équipement de combat de haute technologie et des armures au réplicateur.",
      "humanDescription": "Utiliser ceci ajoute de l'équipement de combat de haute technologie et des armures supplémentaires au réplicateur!",
      "hylotlDescription": "Ce module utile ajoutera de l'équipement de combat de haute technologie et des armures au réplicateur.",
      "novakidDescription": "Ce vieux module bien pratique va en ajouter encore plus au réplicateur."
    }
  },
  "minidronerack": {
    "name": "Console de Données de Mini-drone",
    "desc": "Un ordinateur affichant les informations téléchargées depuis le drone au sommet.",
    "metadata": {
      "apexDescription": "Cet ordinateur semble télécharger des données depuis un drone de surveillance du Miniknog.",
      "avianDescription": "Cet ordinateur est relié au drone robotique. Je me demande quelles informations il a trouvées?",
      "floranDescription": "Écran d'ordinateur montrant desss chosess venant de la machine.",
      "glitchDescription": "Attiré. Cet écran d'ordinateur affiche des informations provenant du petit robot auquel il est attaché.",
      "humanDescription": "Cet ordinateur est branché au drone du dessus. Je me demande qui l'a fabriqué et quelles informations on peut y trouver?",
      "hylotlDescription": "Cet ordinateur fait défiler des données curieuses provenant du petit drone argenté auquel il est attaché.",
      "novakidDescription": "Je m'demande c'que c'te installation est en train de mijoter?"
    }
  },
  "miniknogintel1": {
    "name": "Écran de Renseignements du Miniknog",
    "desc": "Un écran faisant défiler des informations sur les bastions du Miniknog.",
    "metadata": {
      "apexDescription": "Cet écran semble montrer des informations sur divers bastions du Miniknog.",
      "avianDescription": "Cet écran montre des informations sur les bastions politiques Apex. Est-ce le visage de Big Ape?",
      "floranDescription": "Le verre montre desss motss et desss imagesss.",
      "glitchDescription": "Fasciné. Cet écran fait défiler des informations sur des sites militaires Apex.",
      "humanDescription": "Cet écran semble faire défiler beaucoup d'infos du Miniknog - il y a aussi une photo de la grosse tête de Big Ape!",
      "hylotlDescription": "Cet écran renferme de froids mots bleus décrivant des informations précieuses sur le Miniknog.",
      "novakidDescription": "Cet écran a l'air d'avoir un tas d'infos militaires et une planète. Plutôt pas mal."
    }
  },
  "miniknognewspaper": {
    "name": "Journal du Miniknog",
    "desc": "Un grand journal de propagande, destiné à être affiché à la vue de tous.",
    "metadata": {
      "apexDescription": "Ce journal est fait pour être lu par quiconque passe devant. Il parle de Big Ape et du Miniknog.",
      "avianDescription": "Ce journal est assez grand pour être lu en passant, mais je suppose que c'est le but.",
      "floranDescription": "Floran sse demande combien d'arbress détruitss pour faire panneau de papier.",
      "glitchDescription": "Intimidé. Avec son gros titre et sa photographie imposante, ce journal semble exister pour maintenir les gens dociles par la peur.",
      "humanDescription": "Ce journal n'est pas aussi informatif qu'il veut le faire croire. C'est encore de la propagande de Big Ape et du Miniknog.",
      "hylotlDescription": "Ce journal peut sembler au premier abord exister pour informer, mais il est clair qu'il sert plutôt à intimider.",
      "novakidDescription": "Je s'rais plus intéressé si c'était une affiche de mise à prix, mais ça l'est pas."
    }
  },
  "muddancer": {
    "name": "Danseur de Boue",
    "desc": "On peut voir ces insectes danser au crépuscule."
  },
  "mudstag": {
    "name": "Cerf de Boue",
    "desc": "Cet insecte est incroyablement collant. Il possède deux longues cornes sur la tête."
  },
  "movingsunflower": {
    "name": "Tournesol Mobile",
    "desc": "Un tournesol qui cherche simplement le soleil.",
    "metadata": {
      "apexDescription": "Ce grand tournesol semble être perdu.",
      "avianDescription": "J'ai envie d'aider cette fleur à trouver un soleil.",
      "floranDescription": "Tournesssol.",
      "glitchDescription": "Inquiet. Cette fleur cherche quelque chose, ou quelqu'un.",
      "humanDescription": "Un grand tournesol. Évidemment, il cherche le soleil.",
      "hylotlDescription": "Une grande fleur jaune. Elle bouge quand je la touche.",
      "novakidDescription": "C'te fleur a une âme vagabonde. Je t'comprends, l'ami."
    }
  },
  "manholedoor": {
    "name": "Plaque d'Égout",
    "desc": "Un couvercle de trou d'homme.",
    "metadata": {
      "apexDescription": "Une plaque d'égout. Pour éviter que les idiots ne tombent dans un trou.",
      "avianDescription": "Une plaque d'égout.",
      "floranDescription": "Plaque d'égout, y a-t-il quelque chose qui sse cache en desssous?",
      "glitchDescription": "Surpris. Une plaque d'égout.",
      "humanDescription": "Une plaque d'égout, qui n'attend que quelqu'un pour tomber dedans de façon comique.",
      "hylotlDescription": "Une plaque d'égout, qu'est-ce qui rôde en dessous?",
      "novakidDescription": "Une sorte de plaque d'égout, qu'esst-ce qu'elle cache?"
    }
  },
  "metallictrapdoor": {
    "name": "Trappe Métallique",
    "desc": "Une trappe déguisée en plateforme métallique.",
    "metadata": {
      "apexDescription": "Marcher sur cette plateforme la fait se rétracter dans le mur.",
      "avianDescription": "Je ne fais pas confiance à cette plateforme métallique pour supporter mon poids.",
      "floranDescription": "Floran n'a pas confiance en la plateforme métallique.",
      "glitchDescription": "Alarmé. Il est dangereux de se tenir sur cette plateforme.",
      "humanDescription": "Dès que je marcherai dessus, elle disparaîtra.",
      "hylotlDescription": "Une plateforme piégée! Très sournois en effet.",
      "novakidDescription": "J'ferais mieux d'surveiller mes pas sur c'te plateforme."
    }
  },
  "magmalamp": {
    "name": "Lampe Magma",
    "desc": "Une lampe éclairée par des globules de lave en suspension.",
    "metadata": {
      "apexDescription": "Un champ de suspension à l'intérieur de cette lampe maintient la lave incandescente en place.",
      "avianDescription": "Ces petits globes de lave sont chauffés à l'extrême pour briller intensément.",
      "floranDescription": "La lampe contient de la lave brillante.",
      "glitchDescription": "Hypnotisé. Le mouvement de la lave dans cette lampe est difficile à quitter des yeux.",
      "humanDescription": "J'ai entendu parler des lampes à lave, mais j'en avais jamais vu une faite avec de la vraie lave.",
      "hylotlDescription": "La lave à l'intérieur de cette lampe offre une ambiance douce et lumineuse.",
      "novakidDescription": "Y'a de la lave brillante enfermée dans c'te p'tite lampe."
    }
  },
  "mistprimer": {
    "name": "Pile de Pierres Moussues",
    "desc": "Un tas de cailloux couverts de mousse.",
    "metadata": {
      "apexDescription": "Quelques pierres.",
      "avianDescription": "Juste des pierres moussues.",
      "floranDescription": "Pierress.",
      "glitchDescription": "Neutre. Quelques pierres moussues.",
      "humanDescription": "Des pierres couvertes de mousse.",
      "hylotlDescription": "Un groupe de pierres couvertes de mousse.",
      "novakidDescription": "Juste des pierres."
    }
  },
  "marketstall1": {
    "name": "Étal de Fruits du Marché",
    "desc": "Je me demande quels fruits ils vendent sur cette planète.",
    "metadata": {
      "apexDescription": "Une large sélection de fruits succulents.",
      "avianDescription": "De tels fruits sont rarement goûtés par les Avians de la foi.",
      "floranDescription": "Quelle horrible nourriture d'homme-oiseau.",
      "glitchDescription": "Envieux. Si j'étais capable de produire de la salive, je saliverais.",
      "humanDescription": "Je meurs d'envie de goûter certains de ces fruits.",
      "hylotlDescription": "La nourriture de surface est si riche et pleine de saveur.",
      "novakidDescription": "Des fruits, j'm'demande quel goût ça aurait cuit sur un feu d'camp."
    }
  },
  "marketstall2": {
    "name": "Étal de Vêtements du Marché",
    "desc": "De magnifiques tissus et vêtements ornent ce charmant petit étal.",
    "metadata": {
      "apexDescription": "Une sélection de vêtements aux couleurs vives.",
      "avianDescription": "Les Terrestres privilégient les vêtements éclatants qui flottent au gré du vent.",
      "floranDescription": "Hommess-oiseaux faciless à repérer avec vêtements brillantss. Ne ssurvivraient jamais dans jungle Florane.",
      "glitchDescription": "Incertain. Je n'ai aucune connaissance en matière de mode.",
      "humanDescription": "Des vêtements tellement colorés.",
      "hylotlDescription": "Ces vêtements sont magnifiques. De telles couleurs perdent de leur éclat sous les vagues.",
      "novakidDescription": "C'est des fringues sacrément classes."
    }
  },
  "marketstall3": {
    "name": "Étal d'Armes du Marché",
    "desc": "Un assortiment d'objets pointus.",
    "metadata": {
      "apexDescription": "Cet armement est rudimentaire.",
      "avianDescription": "Peu de Terrestres sont des guerriers. Cet armement est de mauvaise facture.",
      "floranDescription": "Armess d'homme-oiseau rudimentairess. Cssse comme une brindille.",
      "glitchDescription": "Observateur. Cet armement a besoin d'être affûté.",
      "humanDescription": "Les armes sur cet étal ont l'air de ne pouvoir servir qu'une seule fois.",
      "hylotlDescription": "À en juger par cet étal, ces pauvres gens peuvent à peine se défendre.",
      "novakidDescription": "Ces armes sont tout simplement mauvaises."
    }
  },
  "marketstall4": {
    "name": "Petit Étal de Marché Vide",
    "desc": "Un petit étal vide. Il a l'air triste.",
    "metadata": {
      "apexDescription": "Un étal vide.",
      "avianDescription": "Cet étal est vide. Les Terrestres ont parfois du mal à s'approvisionner en marchandises.",
      "floranDescription": "Étal vide.",
      "glitchDescription": "Déçu. Cet étal est vide.",
      "humanDescription": "Les étals vides sont toujours un peu tristes.",
      "hylotlDescription": "Cet étal a besoin de stock.",
      "novakidDescription": "Un étal vide. Rien à acheter ici."
    }
  },
  "marketstall5": {
    "name": "Grand Étal de Marché Vide",
    "desc": "Un grand étal vide. Je parie que les affaires sont calmes.",
    "metadata": {
      "apexDescription": "Un étal vide.",
      "avianDescription": "Cet étal est vide. Les Terrestres ont parfois du mal à s'approvisionner en marchandises.",
      "floranDescription": "Étal vide.",
      "glitchDescription": "Déçu. Cet étal est vide.",
      "humanDescription": "Les étals vides sont toujours un peu tristes.",
      "hylotlDescription": "Cet étal a besoin de stock.",
      "novakidDescription": "Un étal vide. Rien à acheter ici."
    }
  },
  "mask1": {
    "name": "Masque Humain Décoratif",
    "desc": "Ce gars a l'air surpris de me voir!",
    "metadata": {
      "apexDescription": "On dirait un masque d'humain.",
      "avianDescription": "Ce masque est un avertissement destiné aux humains.",
      "floranDescription": "Hommess-oiseaux font paraître humain sstupide.",
      "glitchDescription": "Observateur. Il est probable que ce masque soit censé représenter un humain.",
      "humanDescription": "Est-ce que c'est... un humain?",
      "hylotlDescription": "Ce masque d'humain n'est pas très fidèle.",
      "novakidDescription": "Un masque d'humain. C'est pas très flatteur pour la race humaine."
    }
  },
  "mask2": {
    "name": "Masque de Crâne Décoratif",
    "desc": "Ce gars a l'air affamé. Ses yeux me mettent mal à l'aise.",
    "metadata": {
      "apexDescription": "On dirait un masque de Floran.",
      "avianDescription": "Ce masque est un avertissement destiné aux Florans.",
      "floranDescription": "Hommess-oiseaux rendent Floran effrayant.",
      "glitchDescription": "Observateur. Il est probable que ce masque soit censé représenter un Floran.",
      "humanDescription": "Je pense que c'est un Floran.",
      "hylotlDescription": "Ce masque de Floran n'est pas très fidèle.",
      "novakidDescription": "C'est probablement censé être un Floran."
    }
  },
  "mask3": {
    "name": "Masque d'Alien Décoratif",
    "desc": "Ce masque a l'air en colère.",
    "metadata": {
      "apexDescription": "Attendez une minute, est-ce un Apex?",
      "avianDescription": "Ce masque est un avertissement destiné aux Apex.",
      "floranDescription": "Hommess-oiseaux font paraître Apex ridicule.",
      "glitchDescription": "Observateur. Il est probable que ce masque soit censé représenter un Apex.",
      "humanDescription": "Je pense que c'est censé être un Apex.",
      "hylotlDescription": "Ce masque d'Apex n'est pas très fidèle.",
      "novakidDescription": "Une représentation peu flatteuse d'un Apex."
    }
  },
  "mask4": {
    "name": "Masque d'Oiseau Décoratif",
    "desc": "Un oiseau à l'air plutôt sérieux.",
    "metadata": {
      "apexDescription": "On dirait un masque d'Avian.",
      "avianDescription": "Ce masque est un avertissement destiné aux Terrestres.",
      "floranDescription": "Hommess-oiseaux se donnent un air en colère.",
      "glitchDescription": "Pensif. Il est probable que ce masque soit censé représenter un Avian.",
      "humanDescription": "Je pense que c'est un Avian.",
      "hylotlDescription": "Ce masque d'Avian n'est pas très fidèle. C'est presque un exploit.",
      "novakidDescription": "C'est une tête d'Avian, ça? J'ai jamais vu un Avian ressembler à ça."
    }
  },
  "mask5": {
    "name": "Masque de Sage Décoratif",
    "desc": "Ce gars semble... sage.",
    "metadata": {
      "apexDescription": "On dirait un masque de Glitch.",
      "avianDescription": "Ce masque est un avertissement destiné aux Glitchs.",
      "floranDescription": "Hommess-oiseaux font paraître Glitch frusstré.",
      "glitchDescription": "Observateur. Ce masque ressemble à un Glitch.",
      "humanDescription": "Je pense que c'est un Glitch.",
      "hylotlDescription": "Ce masque de Glitch n'est pas très fidèle.",
      "novakidDescription": "Je reconnais bien là un visage de Glitch."
    }
  },
  "mask6": {
    "name": "Masque de Prêtre Décoratif",
    "desc": "Ce masque ressemble à mon ex-femme.",
    "metadata": {
      "apexDescription": "On dirait un masque d'Avian.",
      "avianDescription": "Ce masque est un message de bienvenue pour les observateurs d'étoiles.",
      "floranDescription": "Hommess-oiseaux se donnent un air en colère.",
      "glitchDescription": "Neutre. Il est probable que ce masque soit censé représenter un Avian.",
      "humanDescription": "Je pense que c'est un Avian.",
      "hylotlDescription": "Étonnamment, ce masque d'Avian n'est pas très fidèle.",
      "novakidDescription": "C'est une tête d'Avian, ça? J'ai jamais vu un Avian ressembler à ça."
    }
  },
  "midjar1": {
    "name": "Vieux Pot",
    "desc": "Un vieux pot s'effritant avec des motifs gravés. Il a l'air fragile.",
    "metadata": {
      "apexDescription": "Un pot à motifs. Il n'est pas très beau. Je devrais le briser.",
      "avianDescription": "Ce pot est bon marché et commun. Je devrais le briser.",
      "floranDescription": "Pot s'effrite, facile à cra s sser.",
      "glitchDescription": "Violent. Brisez-le, réduisez-le en poussière.",
      "humanDescription": "Le pot tombe en morceaux. Je pourrais tout aussi bien accélérer le processus.",
      "hylotlDescription": "La décoration est médiocre et le pot tombe en ruine.",
      "novakidDescription": "Un vieux pot inutile. Je suis sûr que personne n'y verrait d'inconvénient si on le brisait."
    }
  },
  "moonemblem": {
    "name": "Emblème Lunaire Avian",
    "desc": "Cet emblème commémore le premier vol des Avians vers les étoiles.",
    "metadata": {
      "apexDescription": "Un oiseau et un croissant de lune.",
      "avianDescription": "Ceci honore notre premier voyage dans l'espace. Les Avians croient que dans l'au-delà, ils voleront librement parmi les étoiles avec de vastes ailes emplumées.",
      "floranDescription": "Les hommess-oiseaux aiment auss si la lumière de la lune?",
      "glitchDescription": "Intrigué. Un emblème. Dépeignant peut-être un événement historique Avian.",
      "humanDescription": "Est-ce que ce sont les Avians parmi les étoiles?",
      "hylotlDescription": "Nous rêvons tous d'une telle liberté. Déployer ses ailes et prendre son envol.",
      "novakidDescription": "Un emblème dépeignant la lune. J'ai eu ma part de bons moments sous la lune moi aussi."
    }
  },
  "memorialstatue": {
    "name": "Mémorial de l'Imagination",
    "desc": "La plaque indique: \"Pour un père qui a ouvert un nouveau monde pour moi. À la mémoire de Tracy Dietrich 1963-2003\"."
  },
  "microscope": {
    "name": "Microscope",
    "desc": "Tout a l'air nettement plus terrifiant sous un microscope.",
    "metadata": {
      "apexDescription": "Sont-ce des cellules Apex?",
      "avianDescription": "Les Avians ont un appareil similaire pour observer au loin avec la précision d'un faucon.",
      "floranDescription": "D'appétissantess celluless de chair.",
      "glitchDescription": "Lugubre. Les cellules sous cet appareil sont mortes depuis longtemps.",
      "humanDescription": "Je ne sais pas ce que je regarde.",
      "hylotlDescription": "Les cellules Apex présentes ici sont remarquablement similaires aux cellules d'un humain.",
      "novakidDescription": "Un appareil délicat pour voir les toutes petites choses avec plus de clarté."
    }
  },
  "monolithgate": {
    "name": "Porte du Monolithe",
    "desc": "Une mystérieuse porte ancienne.",
    "metadata": {
      "apexDescription": "C'est une porte aux proportions magnifiques. Qu'y a-t-il de l'autre côté?",
      "avianDescription": "Cette porte glorieuse ne ressemble à rien de ce que j'ai vu auparavant. Mais où mène-t-elle?",
      "floranDescription": "La grande porte fait que Floran sse ssent tout petit. Floran veut ssavoir où elle mène.",
      "glitchDescription": "Émerveillé. C'est une porte aux proportions époustouflantes. Qui l'a construite? Et où mène-t-elle?",
      "humanDescription": "Une porte majestueuse comme je n'en ai jamais rencontré. Qui a créé cette merveille? Et qu'est-ce qui se trouve de l'autre côté?",
      "hylotlDescription": "C'est rien de moins qu'une création magnifique. Cette porte a dû être construite dans un but très spécial.",
      "novakidDescription": "Les mots me manquent pour décrire cette porte magnifique. Je vais l'admirer en silence...",
      "interactData.destinations.1.name": "Le Ruin",
      "interactData.destinations.1.planetName": "Le Ruin"
    }
  },
  "monolithstatue1": {
    "name": "Statue du Monolithe",
    "desc": "Une mystérieuse statue ancienne.",
    "metadata": {
      "apexDescription": "Cette statue semble exister pour délivrer un message d'il y a longtemps.",
      "avianDescription": "Une grande représentation d'un être. Peut-être un faux dieu d'autrefois?",
      "floranDescription": "Floran est tenté de dessssiner un visage sstupide sur la sstatue!",
      "glitchDescription": "Curieux. Cette statue existe-t-elle pour délivrer un message?",
      "humanDescription": "J'aime mes ruines antiques avec des statues antiques géantes!",
      "hylotlDescription": "Rudimentaire mais distincte dans sa conception. Une statue Hylotl aurait mieux vieilli.",
      "novakidDescription": "Une vieille statue, comme un fantôme du passé, éveillant des souvenirs lointains."
    }
  },
  "monolithstatue2": {
    "name": "Statue du Monolithe",
    "desc": "Une mystérieuse statue ancienne.",
    "metadata": {
      "apexDescription": "Cette statue semble exister pour délivrer un message d'il y a longtemps.",
      "avianDescription": "Une grande représentation d'un être. Peut-être un faux dieu d'autrefois?",
      "floranDescription": "Floran est tenté de dessssiner un visage sstupide sur la sstatue!",
      "glitchDescription": "Curieux. Cette statue existe-t-elle pour délivrer un message?",
      "humanDescription": "J'aime mes ruines antiques avec des statues antiques géantes!",
      "hylotlDescription": "Rudimentaire mais distincte dans sa conception. Une statue Hylotl aurait mieux vieilli.",
      "novakidDescription": "Une vieille statue, comme un fantôme du passé, éveillant des souvenirs lointains."
    }
  },
  "mandrafloraaf": {
    "name": "Figurine de Mandraflora",
    "desc": "L'étiquette indique: \"Son mode de vie léthargique lui permet de s'épanouir sous terre et d'atteindre des tailles impressionnantes.\""
  },
  "miasmopaf": {
    "name": "Figurine de Miasmop",
    "desc": "L'étiquette indique: \"Une exposition prolongée à ses fumées âcres vous assommera.\""
  },
  "monopusaf": {
    "name": "Figurine de Monopus",
    "desc": "L'étiquette indique: \"Une espèce ancienne, connue pour être agile et malicieuse. Ils ont un regard intelligent.\""
