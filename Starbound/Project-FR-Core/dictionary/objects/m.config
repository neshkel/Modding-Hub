      "apexDescription": "Une commode simple, probablement pleine de vêtements simples.",
      "avianDescription": "Un meuble de rangement et une table tout-en-un.",
      "floranDescription": "Floran renifle le vieux meuble. Floran a le nez plein de pouss s sière.",
      "glitchDescription": "Satisfait. Une vieille commode.",
      "humanDescription": "Une vieille commode en bois toute poussiéreuse.",
      "hylotlDescription": "Un vieux meuble de rangement, possiblement pour des vêtements.",
      "novakidDescription": "Un vieux buffet poussiéreux, sans doute pour les fringues."
    }
  },
  "medievalfireplace": {
    "name": "Cheminée Médiévale",
    "desc": "Une cheminée en pierre. Un bon moyen de réchauffer un château glacial.",
