  "medievaldiningtable": {
    "name": "Table de Banquet Royale",
    "desc": "Une table de festin élégante.",
    "metadata": {
      "apexDescription": "L'atout principal de cette table semble être cette nappe attrayante.",
      "avianDescription": "Quelqu'un a posé une nappe sur cette table chic pour la garder propre.",
      "floranDescription": "Esst-ce un lit ou une table? C'esst élégant.",
      "glitchDescription": "Gourmand. Cela fait longtemps que je n'ai pas assisté à un banquet Glitch. Peu de gens dans l'univers sont capables d'une telle allégresse.",
      "humanDescription": "Une table à manger géante. Parfaite pour un festin.",
      "hylotlDescription": "On dirait une table où la royauté se réunit pour socialiser. La nappe suggère un banquet.",
