      "apexDescription": "Une petite horloge. Le balancement du pendule est apaisant.",
      "avianDescription": "Cela semble être un appareil pour lire l'heure. Les Avians utilisent plutôt le soleil.",
      "floranDescription": "Tic, tac, tic, tac.",
      "glitchDescription": "Compatissant. L'heure sur cette horloge ne change jamais.",
      "humanDescription": "Une jolie petite horloge à pendule. Le balancier bouge mais l'heure ne semble pas changer.",
      "hylotlDescription": "Cette pièce d'horlogerie semble cassée, bien que le balancier oscille encore...",
      "novakidDescription": "L'heure change jamais sur c't'horloge."
    }
  },
  "medievalcodex": {
    "name": "Codex Médiéval",
    "desc": "Ce livre est rempli d'illustrations étranges.",
    "metadata": {
      "apexDescription": "Un livre. Il est entièrement rempli de portraits.",
      "avianDescription": "Il y a des images de beaucoup de gens différents dans ce livre.",
      "floranDescription": "C'esst plein d'imagess.",
      "glitchDescription": "Intrigué. Un recueil de vieilles illustrations.",
      "humanDescription": "Cela semble être une sorte d'almanach. Il y a des illustrations de tas de gens différents.",
      "hylotlDescription": "Ce livre donne l'impression d'être important. Chaque page contient des portraits d'inconnus.",
      "novakidDescription": "Un livre d'images, en quelque sorte."
    }
  },
  "medievalcounter": {
    "name": "Comptoir Médiéval",
    "desc": "Un bon vieux comptoir d'antan.",
    "metadata": {
      "apexDescription": "Ce comptoir semble bien adapté pour exposer des articles.",
      "avianDescription": "Ce comptoir semble robuste.",
      "floranDescription": "Comptoir a desss vers de bois, miam!",
      "glitchDescription": "Nostalgique. Les comptoirs artisanaux comme celui-ci sont très courants dans les échoppes Glitchs.",
      "humanDescription": "Un comptoir rudimentaire, mais d'apparence solide.",
