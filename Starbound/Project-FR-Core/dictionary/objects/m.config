{
  "monsterspawner": {
    "name": "Générateur de Monstres",
    "desc": "Génère des monstres de diverses manières configurables."
  },
  "marsmodel": {
    "name": "Maquette de Mars",
    "desc": "Une maquette détaillée de Mars, la planète rouge du système Sol.",
    "metadata": {
      "apexDescription": "Mars est la quatrième planète du système Sol. Elle était en cours de terraformation jusqu'à ce que la Terre soit détruite.",
      "avianDescription": "Mars porte le nom d'un ancien dieu de la guerre terrestre. On l'appelle aussi la 'Planète rouge'.",
      "floranDescription": "Marsss avait beaucoup d'habitantsss jusqu'à la desstruction de la Terre...",
      "glitchDescription": "Tristesse. Mars abritait des milliers de personnes. Je me demande ce qu'elles sont devenues.",
      "humanDescription": "Mars comptait plusieurs colonies et des milliers d'habitants. Elle a été évacuée suite à la destruction de la Terre...",
      "hylotlDescription": "Mars était en pleine phase de terraformation majeure lorsque la Terre a été détruite...",
      "novakidDescription": "Mars abritait une colonie de vagabonds Novakids. Je me demande s'ils sont toujours là-bas..."
    }
  },
  "mercurymodel": {
    "name": "Maquette de Mercure",
    "desc": "Une maquette détaillée de Mercure, la plus petite planète du système Sol.",
    "metadata": {
      "apexDescription": "Mercure est la première planète du système Sol ; sa rotation synchrone entraîne des journées extrêmement longues.",
      "avianDescription": "Mercure, la première planète du système Sol. Nommée d'après un ancien dieu du commerce terrestre connu pour sa rapidité.",
      "floranDescription": "Petite planète du sssystème Sol. La plus proche du ssoleil. Inho sspitalière.",
      "glitchDescription": "Fasciné. La journée sur Mercure dure presque 59 jours terrestres et son année environ 88 jours terrestres.",
      "humanDescription": "C'est la plus petite planète de mon système d'origine et la plus proche du Soleil.",
      "hylotlDescription": "La planète Mercure. En plus d'être une planète du système Sol, elle est surtout connue pour une série d'horribles accidents miniers il y a quelques décennies.",
      "novakidDescription": "Mercure est une minuscule petite canaille de planète dans le système Sol."
    }
  },
  "mechsign": {
    "name": "Enseigne de Mech",
    "desc": "Ce panneau métallique indique une station de travail pour Mechs.",
    "metadata": {
      "apexDescription": "Ce panneau représente un imposant véhicule de type Mech.",
      "avianDescription": "Ce panneau affiche une grande armure de combat Mech.",
      "floranDescription": "Il y a une armure de mech ssur ce panneau.",
      "glitchDescription": "Observateur. Ce panneau indique un poste de travail pour l'assemblage de Mechs.",
      "humanDescription": "Ce panneau rond représente une grande armure Mech.",
      "hylotlDescription": "Un panneau coloré avec l'image d'une armure Mech.",
      "novakidDescription": "Un panneau avec un bon gros mech imprimé desssus."
    }
  },
  "magmaceilingspike1": {
    "name": "Pointes Aiguisées",
    "desc": "Faites attention!",
    "metadata": {
      "apexDescription": "Des pointes de pierre acérées.",
      "avianDescription": "La pierre semble tranchante comme un rasoir.",
      "floranDescription": "Tranchant et pointu.",
      "glitchDescription": "Prudent. La roche tranchante pourrait pénétrer la carapace d'un Glitch.",
      "humanDescription": "Je ferais mieux de ne pas toucher à ça.",
      "hylotlDescription": "Je vais éviter cela avec élégance.",
      "novakidDescription": "Ça a l'air drôlement tranchant, je suis prêt à décamper d'ici!"
    }
  },
