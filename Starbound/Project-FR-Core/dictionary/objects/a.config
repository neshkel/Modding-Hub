  },
  "aviantechstationTier0": {
    "name": "S.A.I.L",
    "desc": "Ship-based Artificial Intelligence Lattice, ou S.A.I.L en abrégé.",
    "metadata": {
      "apexDescription": "Quand elle marche, je peux parler à SAIL via cette console.",
      "avianDescription": "Redémarrer cette station devrait me permettre de parler à SAIL.",
      "floranDescription": "Floran répare ce panneau pour réveiller le vaisssseau!",
      "glitchDescription": "Détressé. Je dois d'abord redémarrer cette station pour communiquer avec SAIL.",
      "humanDescription": "Si j'arrive à redémarrer cette station, SAIL devrait revenir en ligne!",
      "hylotlDescription": "Cette console me permettra de communiquer avec SAIL. Je dois d'abord la redémarrer.",
      "novakidDescription": "Il est temps d'redémarrer cette station pour pouvoir parler à SAIL."
    }
  },
  "avianteleporter": {
    "name": "Téléporteur",
    "desc": "Fidèle téléporteur, que ferions-nous sans toi?",
    "metadata": {
      "apexDescription": "Le téléporteur du vaisseau. Se téléporter donne l'impression d'être dans des montagnes russes à la vitesse de la lumière.",
      "avianDescription": "Le téléporteur! Se téléporter donne l'impression de voler.",
      "floranDescription": "Téléporteur du vaisssseau. Floran se sssent confus pendant la téléportation.",
      "glitchDescription": "Prétentieux. Un téléporteur. Je suis capable d'entrer en mode veille pendant le processus de téléportation.",
      "humanDescription": "Le téléporteur! La téléportation, c'est une sacrée décharge d'adrénaline.",
      "hylotlDescription": "Un téléporteur. La téléportation donne l'impression de plonger dans l'océan depuis le sommet d'une montagne.",
      "novakidDescription": "Téléporteur du vaisseau. On va lui faire faire un tour!"
    }
  },
  "avianteleporterTier0": {
    "name": "Téléporteur",
    "desc": "Fidèle téléporteur, que ferions-nous sans toi?",
    "metadata": {
      "apexDescription": "Le téléporteur du vaisseau. Je dois le mettre sous tension.",
      "avianDescription": "Le téléporteur! Si seulement celui-là était alimenté.",
      "floranDescription": "Téléporteur du vaisssseau. Celui-là est mort.",
      "glitchDescription": "Déçu. Un téléporteur sans courant. Je dois le mettre sous tension.",
      "humanDescription": "Le téléporteur! Dommage qu'il ne soit pas alimenté.",
      "hylotlDescription": "Ce téléporteur est éteint.",
      "novakidDescription": "Téléporteur du vaisseau. Faut qu'je l'mette sous tension!"
    }
  },
  "antenna": {
    "name": "Antenne",
    "desc": "Une antenne. Elles sont généralement utilisées pour amplifier les signaux de communication.",
    "metadata": {
      "apexDescription": "Une antenne.",
      "avianDescription": "Une antenne d'amplification de signal.",
      "floranDescription": "Floran pourrait utilissser ça pour poignarder.",
      "glitchDescription": "Agacé. Cette antenne sème la pagaille dans mes capteurs.",
      "humanDescription": "Y a-t-il quelqu'un là-bas? Attends, je ne veux pas savoir.",
      "hylotlDescription": "Une antenne.",
      "novakidDescription": "Un appareil pour capter les signaux."
    }
  },
  "apexfightlantern": {
    "name": "Lanterne Apex",
    "desc": "Ces lanternes électriques génèrent une lumière agréablement chaude.",
    "metadata": {
      "apexDescription": "Une lanterne petite mais efficace.",
      "avianDescription": "Une lanterne électrique au design simple.",
      "floranDescription": "Appareil brillant pour éclairer le chemin de Floran.",
      "glitchDescription": "Reconnaissant. Ces lumières sont splendides.",
      "humanDescription": "Une source de lumière vive. Je ne devrais probablement pas la regarder fixement.",
      "hylotlDescription": "Un miroitement encourageant qui me rappelle les jours radieux.",
      "novakidDescription": "C'est une lanterne électrique, donc elle ne tombera pas à court de jus."
    }
  },
  "avianartifactaltar": {
    "name": "Autel d'Artéfact Avian",
    "desc": "On dirait qu'il a été fait pour contenir quelque chose d'important."
  },
  "apexartifactaltar": {
    "name": "Autel d'Artéfact Apex",
    "desc": "On dirait qu'il a été fait pour contenir quelque chose d'important."
  },
  "airlockdoor": {
    "name": "Porte de Sas Pressurisée",
    "desc": "Une porte de sas robuste.",
    "metadata": {
      "apexDescription": "Une énorme porte de sas. Robuste.",
      "avianDescription": "Une porte en métal d'une taille intimidante.",
      "floranDescription": "L'homme-poissson construit de grandes portessss ssolides! Pas mal, l'homme-poissson... Pas mal...",
      "glitchDescription": "Curieux. Où est la poignée de porte?",
      "humanDescription": "C'est une rupture avec l'esthétique traditionnelle des Hylotls.",
      "hylotlDescription": "Cette porte de sas offre une sécurité de premier ordre.",
      "novakidDescription": "Une porte qui a l'air costaud."
    }
  },
  "airlockhatch": {
    "name": "Écoutille de Sas Pressurisée",
    "desc": "Une écoutille de sas robuste.",
    "metadata": {
      "apexDescription": "Une énorme écoutille de sas. Robuste.",
      "avianDescription": "Une écoutille en métal d'une taille intimidante.",
      "floranDescription": "L'homme-poissson construit de grandess écoutilless ssolides! Pas mal, l'homme-poissson... Pas mal...",
      "glitchDescription": "Curieux. Où est la poignée?",
      "humanDescription": "C'est une rupture avec l'esthétique traditionnelle des Hylotls.",
      "hylotlDescription": "Cette écoutille de sas offre une sécurité de premier ordre.",
      "novakidDescription": "Une écoutille qui a l'air costaud."
    }
  },
  "arcadeblue": {
    "name": "Borne d'Arcade Bleue",
    "desc": "La machine fait tourner un jeu appelé 'Psychedelic Rodeo Melee'.",
    "metadata": {
      "apexDescription": "'Psychedelic Rodeo Melee' m'a vraiment ouvert les yeux. Je vois tout un peu différemment maintenant.",
      "avianDescription": "'Psychedelic Rodeo Melee' est en fait un jeu très apaisant.",
      "floranDescription": "Floran pensssait que le jeu s'appelait 'Psychotic Rodeo Melee', était essxcité. Mais non.",
      "glitchDescription": "Critique. Je donne à 'Psychedelic Rodeo Melee' un 4/10.",
      "humanDescription": "On ne le dirait pas vu le titre, mais 'Psychedelic Rodeo Melee' est plutôt profond.",
      "hylotlDescription": "Je crois qu'au fond, 'Psychedelic Rodeo Melee' est un récit initiatique.",
      "novakidDescription": "'Psychedelic Rodeo Melee'? Ça ne ressemble pas du tout à un vrai rodéo..."
    }
  },
  "arcadedance": {
    "name": "Machine Dance-Dance",
    "desc": "Jouons à Dance-Dance!",
    "metadata": {
      "apexDescription": "Je ne pense pas que je serai jamais bon à Dance-Dance. Les flèches bougent si vite!",
      "avianDescription": "Dance-Dance n'est pas très adapté aux sserres.",
      "floranDescription": "Les sstupides flèchesss de Dance-Dance bougent trop vite!! Ça frusstre Floran!",
      "glitchDescription": "Satisfait. C'est un jeu facile, une fois qu'on a appris à reconnaître les motifs. 9/10.",
      "humanDescription": "J'aimerais pouvoir dire aux développeurs de Dance-Dance que leur jeu a atteint les étoiles.",
      "hylotlDescription": "Maîtriser l'art de Dance-Dance peut s'avérer très difficile en effet.",
      "novakidDescription": "Yeehaw! C'est parti pour un p'tit Dance-Dance!"
    }
  },
  "arcadegreen": {
    "name": "Borne d'Arcade Verte",
    "desc": "Cette machine fait tourner un jeu appelé 'Stylish Thief Wasteland'.",
    "metadata": {
      "apexDescription": "'Stylish Thief Wasteland' parle de voleurs qui dévalisent d'autres voleurs. Le voleur le plus stylé gagne!",
      "avianDescription": "Il faut pas mal de talent et de chance pour s'en sortir à 'Stylish Thief Wasteland'.",
      "floranDescription": "Jeu de vol sstylé! Floran aime ce jeu!",
      "glitchDescription": "Impressionné. 'Stylish Thief Wasteland' met en scène des voleurs stylés affrontant d'autres voleurs stylés. 8/10.",
      "humanDescription": "'Stylish Thief Wasteland' est le meilleur! Je vais être le voleur le plus stylé de tous.",
      "hylotlDescription": "'Stylish Thief Wasteland' est souvent critiqué pour ses représentations de la violence, mais on doit admirer leur sens de la mode.",
      "novakidDescription": "Y a un truc dans 'Stylish Thief Wasteland' auquel je m'identifie vraiment."
    }
  },
  "arcadeorange": {
    "name": "Borne d'Arcade Orange",
    "desc": "Cette machine fait tourner un jeu appelé 'Sleazy Burger Heroes'.",
    "metadata": {
      "apexDescription": "'Sleazy Burger Heroes' est un jeu où l'on retourne des burgers. J'adore les burgers!",
      "avianDescription": "Obtenir un bon score dans 'Sleazy Burger Heroes' consiste à affiner ses réflexes.",
      "floranDescription": "Jeu sur le retournage de viande. Ça donne faim à Floran.",
      "glitchDescription": "Diverti. Quelque chose dans la tâche fastidieuse de retourner des burgers pour obtenir un score plus élevé est assez addictif. 7/10.",
      "humanDescription": "'Sleazy Burger Heroes'. Un jeu sur le retournage de burgers! C'est étrangement captivant.",
      "hylotlDescription": "'Sleazy Burger Heroes' est un bon jeu pour occuper et divertir les jeunes enfants.",
      "novakidDescription": "C'est un jeu appelé 'Sleazy Burger Heroes'. Pourquoi faire ssemblant d'retourner des burgers? Pourquoi?"
    }
  },
  "arcadepurple": {
    "name": "Borne d'Arcade Violette",
    "desc": "Cette machine fait tourner 'Screaming Fashion Agent'.",
    "metadata": {
      "apexDescription": "Ce jeu s'appelle 'Screaming Fashion Agent'. Les choses que j'ai vues ici... Je ne les oublierai jamais.",
      "avianDescription": "C'est un jeu de mystère appelé 'Screaming Fashion Agent'. Pourquoi crient-ils? Est-ce ça le mystère?",
      "floranDescription": "Le jeu s'appelle 'Sscreaming Fashion Agent'. Floran aime ce jeu.",
      "glitchDescription": "Inquiet. Ce jeu s'appelle 'Screaming Fashion Agent' et je suis très perturbé par celui-ci. 6/10.",
      "humanDescription": "Les agents de mode sont-ils d'habitude aussi terrifiants que celui de 'Screaming Fashion Agent'? C'est quoi un agent de mode, d'ailleurs?",
      "hylotlDescription": "J'ai entendu des rumeurs selon lesquelles 'Screaming Fashion Agent' serait une relecture artistique d'un fait divers criminel réel.",
      "novakidDescription": "Cet agent de mode n'arrête pas d'gueuler. J'suis s'ensé deviner pourquoi?"
    }
  },
  "arcadered": {
    "name": "Borne d'Arcade Rouge",
    "desc": "Cette machine fait tourner un jeu appelé 'Cool Wizard Island'.",
    "metadata": {
      "apexDescription": "Ça s'appelle 'Cool Wizard Island'. Je pense que je suis censé régner sur cette île habitée par des Sorciers Cools. Intéressant...",
      "avianDescription": "Dans 'Cool Wizard Island', mon rêve de régner sur une île habitée par des sorciers cools peut enfin être réalisé.",
      "floranDescription": "Less ssorciers de 'Cool Wizard Island' mettent le feu avec leurs mainsss! Comment Floran peut apprendre ce tour?",
      "glitchDescription": "Amusé. Si je ne fais pas attention, je vais gâcher toute la journée à jouer à 'Cool Wizard Island'. 9/10.",
      "humanDescription": "Dans 'Cool Wizard Island', tu es le maire-sorcier d'une île pleine de sorciers cools. C'était super populaire sur Terre.",
      "hylotlDescription": "'Cool Wizard Island' était l'un de mes jeux d'arcade préférés quand j'étais un jeune Hylotl. J'aimais décorer l'île.",
      "novakidDescription": "Être un maire-sorcier dans 'Cool Wizard Island', ça prend un temps fou. J'ai pas la patience pour c'genre de responsabilités."
    }
  },
  "arcadesign": {
    "name": "Enseigne d'Arcade",
    "desc": "Une enseigne d'arcade. Il y a probablement une salle d'arcade à proximité.",
    "metadata": {
      "apexDescription": "Une salle d'arcade!",
      "avianDescription": "Une salle d'arcade. Joyeux!",
      "floranDescription": "Arcade! Floran aime gagner!",
      "glitchDescription": "Ravi. Une salle de jeux!",
      "humanDescription": "J'adore les salles d'arcade! Prenez tout mon argent!",
      "hylotlDescription": "Hmm, ça fait un moment depuis ma dernière visite dans une salle d'arcade. Ça pourrait être amusant!",
      "novakidDescription": "Une salle d'arcade? "
    }
  },
  "arcadestarbound": {
    "name": "Borne d'Arcade Starbound",
    "desc": "Une borne d'arcade faisant tourner un jeu appelé 'Starbound'.",
    "metadata": {
      "apexDescription": "Un jeu d'exploration spatiale appelé 'Starbound'. Ça me semble familier.",
      "avianDescription": "Jamais entendu parler de ce jeu 'Starbound'. Et pourtant...",
      "floranDescription": "Jeu de vaisssseau sspatial 'Starbound'. Floran gagne un ssuccès pour avoir brisssé le quatrième mur.",
      "glitchDescription": "Déterminé. Je vais établir le meilleur score sur ce nouveau jeu vidéo 'Starbound'.",
      "humanDescription": "'Starbound'? Je ne peux pas dire que j'en aie déjà entendu parler. Ça doit être vieux.",
      "hylotlDescription": "Ce jeu 'Starbound' me parle à un niveau spirituel.",
      "novakidDescription": "Une sorte de jeu d'exploration sspatiale appelé 'Starbound'. J'fais ça dans la vraie vie!"
    }
  },
  "arcadeyellow": {
    "name": "Borne d'Arcade Jaune",
    "desc": "Cette machine fait tourner un jeu appelé 'Zombie Banana Mansion'.",
    "metadata": {
      "apexDescription": "'Zombie Banana Mansion' est un classique des jeux Apex! Ça me terrifiait quand j'étais jeune.",
      "avianDescription": "'Zombie Banana Mansion' -- vous devez abattre tous les zombies pour préserver le stock de bananes de votre manoir. Concept intéressant.",
      "floranDescription": "Pourquoi ssauver des bananess dégoûtantess? Juste manger les zombiess!",
      "glitchDescription": "Perturbé. Les créatures de 'Zombie Banana Mansion' existent-elles dans la réalité?",
      "humanDescription": "'Zombie Banana Mansion'. Il n'y a que les Apex pour faire de la préservation des bananes leur priorité absolue.",
      "hylotlDescription": "Je comprends l'envie de protéger son foyer, mais je trouve 'Zombie Banana Mansion' excessivement violent.",
      "novakidDescription": "'Zombie Banana Mansion'? J'en ai juste assez des jeux de zombies, pour être honnête."
    }
  },
  "alertlight": {
    "name": "Lumière d'Alerte",
    "desc": "La lumière clignotante est censée signaler qu'il y a eu une sorte d'urgence...",
    "metadata": {
      "apexDescription": "Ces alarmes étaient courantes dans les logements Apex, signalant un comportement inacceptable.",
      "avianDescription": "La machine, elle piaille comme un oiseau.",
      "floranDescription": "Lumière tournoyante. Comme une luciole dans un bocal.",
      "glitchDescription": "Neutre. Une lumière colorée.",
      "humanDescription": "Ces trucs hurlent le danger.",
      "hylotlDescription": "Une lumière qui danse maladroitement.",
      "novakidDescription": "Une lumière qui cherche l'attention."
    }
  },
  "anvil": {
    "name": "Enclume de Base",
    "desc": "Une enclume simple, utilisée pour marteler le métal et lui donner sa forme.",
    "metadata": {
      "interactData.paneLayoutOverride.windowtitle.title": " Enclume de Base",
      "interactData.paneLayoutOverride.windowtitle.subtitle": " ^#b9b5b2;Armures et armes",
      "apexDescription": "Une enclume. Les Apex n'ont pas utilisé cela pour le travail du métal depuis très, très longtemps.",
      "avianDescription": "Un gros bloc de fer avec une surface plate.",
      "floranDescription": "Très lourd, utile dans un piège.",
      "glitchDescription": "Instruit. Les Glitch fabriquent toutes sortes d'armes sur ces enclumes. Ils fabriquent même des enclumes sur ces enclumes.",
      "humanDescription": "Une enclume. Les humains n'en ont pas utilisé depuis le début de leur histoire.",
      "hylotlDescription": "Probablement utilisé pour le travail du métal.",
      "novakidDescription": "Une enclume, toujours utile d'en avoir une sous la main."
    }
  },
  "altar1": {
    "name": "Autel en Pierre",
    "desc": "Un autel en pierre pâle, sans décoration.",
    "metadata": {
      "apexDescription": "Un autel. Il n'a aucune sculpture.",
      "avianDescription": "Cet autel n'est pas sculpté. Les Sans-Ailes peuvent prier ici.",
      "floranDescription": "Table de pierre bonne pour couper.",
      "glitchDescription": "Confus. Cet autel semble être entièrement dépourvu de décoration.",
      "humanDescription": "Un autel. Devrais-je m'agenouiller?",
      "hylotlDescription": "Un autel. Une telle piété n'est pas la voie à suivre.",
      "novakidDescription": "Juste un bête autel en pierre. Rien de spécial."
    }
  },
  "arcadegameclosed": {
    "name": "Mazebound64 Fermé",
    "desc": "Ce serait un endroit sympa pour un stand.",
    "metadata": {
      "apexDescription": "Je ne suis pas fan de 'Mazebound64'. J'ai entendu des histoires d'horreur sur les tests du Miniknog... Les labyrinthes me fichent les jetons.",
      "avianDescription": "'Mazebound64' a été développé par une équipe Avian. Il n'y a pas beaucoup de jeux vidéo Avians... Je devrais peut-être en faire.",
      "floranDescription": "Floran pense que 'Mazebound64' est un gros ennui. Même pas de viande à la fin.",
      "glitchDescription": "Déterminé. Je m'échapperai de ce labyrinthe infernal et je vaincrai 'Mazebound64' une fois pour toutes! 8/10.",
      "humanDescription": "'Mazebound64' rappelle certains des tout premiers jeux vidéo de la Terre. C'est très charmant.",
      "hylotlDescription": "Naviguer dans des couloirs sombres, à quelques pas de la liberté... 'Mazebound64' est beau dans sa simplicité.",
      "novakidDescription": "'Mazebound64'? Les labyrinthes sont une grosse perte de temps."
    }
  },
  "arcadegame": {
    "name": "Mazebound64",
    "desc": "Cette machine fait tourner un jeu appelé 'Mazebound64'.",
    "metadata": {
      "apexDescription": "Je ne suis pas fan de 'Mazebound64'. J'ai entendu des histoires d'horreur sur les tests du Miniknog... Les labyrinthes me fichent les jetons.",
      "avianDescription": "'Mazebound64' a été développé par une équipe Avian. Il n'y a pas beaucoup de jeux vidéo Avians... Je devrais peut-être en faire.",
      "floranDescription": "Floran pense que 'Mazebound64' est un gros ennui. Même pas de viande à la fin.",
      "glitchDescription": "Déterminé. Je m'échapperai de ce labyrinthe infernal et je vaincrai 'Mazebound64' une fois pour toutes! 8/10.",
      "humanDescription": "'Mazebound64' rappelle certains des tout premiers jeux vidéo de la Terre. C'est très charmant.",
      "hylotlDescription": "Naviguer dans des couloirs sombres, à quelques pas de la liberté... 'Mazebound64' est beau dans sa simplicité.",
      "novakidDescription": "'Mazebound64'? Les labyrinthes sont une grosse perte de temps."
    }
  },
  "arcademachine": {
    "name": "Borne d'Arcade",
    "desc": "Une borne d'arcade à l'ancienne. Celle-ci joue 'Super Tralgar Blaster 2'.",
    "metadata": {
      "apexDescription": "C'est un simulateur de combat spatial appelé 'Super Tralgar Blaster 2'. Je suis content de n'avoir jamais rencontré de vrai combat de vaisseaux.",
      "avianDescription": "'Super Tralgar Blaster 2' consiste à faire la guerre à travers les étoiles.",
      "floranDescription": "Piou piou piou! Floran descend tous les vaisssseaux dans 'Super Tralgar Blassster 2'.",
      "glitchDescription": "Curieux. Le joueur de 'Super Tralgar Blaster 2' avec le score le plus élevé a les initiales 'CF'.",
      "humanDescription": "'Super Tralgar Blaster 2'! C'est un 'bullet hell' classique. Je suis content de ne jamais avoir à tirer sur d'autres vaisseaux dans la vraie vie!",
      "hylotlDescription": "Dans 'Super Tralgar Blaster 2', vous vous frayez un chemin à travers les astéroïdes et les vaisseaux ennemis pour survivre. C'est effrayant.",
      "novakidDescription": "C'est un jeu appelé 'Super Tralgar Blaster 2'. Rien de tel qu'une bonne vieille fusillade spatiale."
    }
  },
  "agaranmushroom": {
    "name": "Champignon Agaran Géant",
    "desc": "Un champignon géant d'origine Agaran.",
    "metadata": {
      "apexDescription": "C'est plus mignon que les Agarans.",
      "avianDescription": "Je me demande à quoi sert ce champignon.",
      "floranDescription": "Floran connaît ton sssecret, petit champi. Floran garde le ssilence.",
      "glitchDescription": "Amusé. C'est un Agaran vivant, habilement déguisé.",
      "humanDescription": "Il manque une chenille.",
      "hylotlDescription": "Un vil champignon d'origine Agaran.",
      "novakidDescription": "Qu'est-ce qu'il a de si spécial, ce champignon?"
    }
  },
  "automatoseed": {
    "name": "Graine d'Automatate",
    "desc": "Des automatates! N'oubliez pas de recracher les vis.",
    "metadata": {
      "apexDescription": "Des automatates... assez standard, si vous ne vous cassez pas les dents sur les vis.",
      "avianDescription": "Des automatates. Les graines sont plutôt savoureuses seules.",
      "floranDescription": "Charnu et juteux, avec des morceaux croustillantsss. Comme les humainsss.",
      "glitchDescription": "Désapprobateur. Les autres retirent les vis. Les Glitch estiment qu'elles rehaussent la saveur.",
      "humanDescription": "Une tomate remplie de vis. Savoureux mais risqué.",
      "hylotlDescription": "Une nourriture paysanne courante chez les Glitch. Pas à mon goût.",
      "novakidDescription": "Les automatates ont un goût acidulé et métallique."
    }
  },
  "avesmingoseed": {
    "name": "Graine d'Avesmingo",
    "desc": "Avesmingo, la plante aux 100 saveurs différentes.",
    "metadata": {
      "apexDescription": "On dit que ça a cent saveurs différentes. Est-ce que la banane en fait partie?",
      "avianDescription": "Une plante si pleine de saveur. La graine est particulièrement goûtue.",
      "floranDescription": "Ce fruit a du goût. Aucune de cess saveurs n'a le goût de viandesss.",
      "glitchDescription": "Confus. Ça a un goût de... brocoli.",
      "humanDescription": "Si les saveurs comptent, ça devrait couvrir mes besoins en fruits et légumes cinquante fois.",
      "hylotlDescription": "Avesmingo, le fruit aux multiples saveurs. Une délicatesse exotique sous l'océan.",
      "novakidDescription": "Ce fruit a beaucoup trop de saveurs. On peut n'en apprécier aucune."
    }
  },
  "acceleratoraddon": {
    "name": "^orange;Module Accélérateur^white;",
    "desc": "Un module qui ajoute des équipements à distance et des armures supplémentaires au réplicateur.",
    "metadata": {
      "apexDescription": "Utile, cela ajoutera des équipements à distance et des armures au réplicateur.",
      "avianDescription": "Je peux utiliser ceci pour ajouter de l'équipement et des armures au réplicateur.",
      "floranDescription": "Floran utilissse ça pour ajouter plus de chosess au réplicateur.",
      "glitchDescription": "Excité. L'utilisation de ce module ajoutera des équipements à distance et des armures supplémentaires au réplicateur.",
      "humanDescription": "Utiliser ceci ajoute de l'équipement à distance et des armures au réplicateur!",
      "hylotlDescription": "Ce module utile ajoutera des équipements à distance et des armures supplémentaires au réplicateur.",
      "novakidDescription": "Ce vieux module pratique va en ajouter encore plus au réplicateur."
    }
  },
  "ashsprite": {
    "name": "Esprit des Cendres",
    "desc": "Ces insectes semblent s'élever de nuages de cendres."
  },
  "aurorabee": {
    "name": "Aurore-abeille",
    "desc": "La surface de la carapace de cet insecte miroite comme de l'huile."
  },
  "aegisaltsample": {
    "name": "Échantillon d'Aegisalt",
    "desc": "\"Un échantillon parfait de minerai d'aegisalt.\""
  },
  "alienbed": {
    "name": "Lit Alien",
    "desc": "Un lit alien. Il semble être vivant.",
    "metadata": {
      "apexDescription": "Mon lit normal à la maison me manque.",
      "avianDescription": "Un lit alien. Est-ce que ce sont des feuilles?",
      "floranDescription": "Lit-plante!",
      "glitchDescription": "Suspicieux. Ce lit émet une sorte de... chaleur corporelle?",
      "humanDescription": "C'est chaud et spongieux au toucher.",
      "hylotlDescription": "Un design particulier pour un lit.",
      "novakidDescription": "C'est un lit au design bizarre, c'est sûr."
    }
  },
  "alienchair": {
    "name": "Chaise Alien",
    "desc": "Une chaise alien. Elle semble vivante.",
    "metadata": {
      "apexDescription": "Je préférerais quelque chose de moins organique.",
      "avianDescription": "Une chaise hors du commun.",
      "floranDescription": "Floran aime chaise-plante. Chaise-plante essst un ami!",
      "glitchDescription": "Observateur. Cette chaise est faite d'un matériau organique extraterrestre.",
      "humanDescription": "C'est une chaise alien? Je n'ai pas envie de poser mon derrière dessus.",
      "hylotlDescription": "Une chaise fabriquée à partir d'une plante alien.",
      "novakidDescription": "C'est une chaise faite en plante alien?"
    }
  },
  "alienchest": {
    "name": "Coffre Alien",
    "desc": "Un coffre alien.",
    "metadata": {
      "apexDescription": "Je préfère que mes coffres soient en métal.",
      "avianDescription": "Un coffre alien. Il semble plutôt chaud au toucher.",
      "floranDescription": "Coffre violet plein de friandisssess pour Floran?",
      "glitchDescription": "Appréciatif. Quelle couleur vibrante.",
      "humanDescription": "En quoi est fait ce coffre?",
      "hylotlDescription": "Un coffre fait d'un matériau que je ne reconnais pas. Qu'est-ce que cela pourrait être?",
      "novakidDescription": "Un coffre de couleur violette."
    }
  },
  "aliendoor": {
    "name": "Porte Alien",
    "desc": "Une porte en plante alien.",
    "metadata": {
      "apexDescription": "Je me demande comment cela a été construit?",
      "avianDescription": "J'ai l'impression que la porte me regarde.",
      "floranDescription": "Floran aime porte-plante.",
      "glitchDescription": "Curieux. Cette porte est-elle vivante?",
      "humanDescription": "Qui a pu penser qu'une porte comme celle-ci était une bonne idée?",
      "hylotlDescription": "Cette porte a une présence.",
      "novakidDescription": "Une porte au look bien étrange en effet..."
    }
  },
  "alienglowplant1": {
    "name": "Plante Alien Luminescente",
    "desc": "Une plante alien qui brille."
  },
  "alientable": {
    "name": "Table Alien",
    "desc": "Une table alien. Elle semble être vivante.",
    "metadata": {
      "apexDescription": "Je préfère que mes tables aient un aspect plus industriel.",
      "avianDescription": "Je ne me sentirais pas à l'aise de mettre mes jambes sous cette table.",
      "floranDescription": "Floran n'a pas confianssse en cette table!",
      "glitchDescription": "Inconfortable. Quelle création bizarre.",
      "humanDescription": "Est-ce que cette table est vivante? Je ne suis pas sûr d'être à l'aise à côté d'elle.",
      "hylotlDescription": "Cette table me rappelle que chaque chose possède sa propre âme.",
      "novakidDescription": "J'ai jamais rien vu de tel."
    }
  },
  "airemblem": {
    "name": "Emblème de l'Air Avian",
    "desc": "Cet emblème symbolise l'élément libre et fluide de l'air.",
    "metadata": {
      "apexDescription": "Le symbole Avian pour l'air.",
      "avianDescription": "C'est un emblème de l'air Avian, comment pourrais-je l'oublier.",
      "floranDescription": "Ligness onduléess ssignifient élément de l'air.",
      "glitchDescription": "Savant. Je crois que ce symbole est l'emblème de l'air Avian.",
      "humanDescription": "Je suppose que ce symbole représente l'air ou le vent.",
      "hylotlDescription": "Une représentation assez brute de l'élément de l'air.",
      "novakidDescription": "On dirait une vieille gravure Avian représentant le vent."
    }
  },
  "altaravian": {
    "name": "Autel Tête d'Avian",
    "desc": "Une tête d'Avian sculptée trône sur cet autel.",
    "metadata": {
      "apexDescription": "Un autel Avian doré décoré de symboles que je ne reconnais pas.",
      "avianDescription": "Seuls les Astronomes peuvent lire ces symboles de nos jours. Les secrets de leur traduction sont perdus. Les yeux rouges sont un avertissement.",
      "floranDescription": "Brillant homme-oiseau. Où essst ton corps?",
      "glitchDescription": "Sursautant. Cette sculpture Avian semble très réaliste.",
      "humanDescription": "J'espère que ces symboles ne disent rien d'important.",
      "hylotlDescription": "Les yeux rouges me rappellent mes semblables.",
      "novakidDescription": "Cette statue ressemble un peu à un Avian."
    }
  },
  "altarbunny": {
    "name": "Autel Lapin",
    "desc": "Un lapin sculpté trône sur cet autel.",
    "metadata": {
      "apexDescription": "Un lapin? Pourquoi les Avians ont-ils sculpté un lapin?",
      "avianDescription": "Le lapin symbolise les bêtes du sol. Cet autel est un avertissement pour les pilleurs de tombes des autres races.",
      "floranDescription": "Gros sssorceau savoureux. Pourquoi les yeux sont-ilsss si rouges?",
      "glitchDescription": "Impressionné. Cette statue est magistralement réalisée avec des cristaux pour les yeux.",
      "humanDescription": "C'est un lapin?",
      "hylotlDescription": "C'est désarmant de voir ces créatures qui errent hors de l'océan.",
      "novakidDescription": "Une sculpture de bestiole bien élégante."
    }
  },
  "anchor": {
    "name": "Ancre",
    "desc": "Une lourde ancre en métal. Moussaillon!",
    "metadata": {
      "apexDescription": "Une lourde pièce de fer, une ancre peut-être.",
      "avianDescription": "Une ancre provenant d'un navire volant Avian. Ironiquement, beaucoup de Sans-Ailes vivent sur des navires au milieu des nuages.",
      "floranDescription": "Crochet de fer, très lourd.",
      "glitchDescription": "Curieux. Les Glitch utilisent des ancres comme celle-ci sur leurs grands navires à voiles. Pourquoi celle-ci est-elle là?",
      "humanDescription": "Une ancre massive.",
      "hylotlDescription": "Ah, une ancre. J'ai entendu des récits racontant qu'elles fracassaient les structures Hylotls.",
      "novakidDescription": "C'est un sacré morceau de métal bien pesant."
    }
  },
  "ashjar1": {
    "name": "Jarre Oiseau",
    "desc": "Une jarre en forme d'oiseau pleine de cendres. J'ai envie de la briser.",
    "metadata": {
      "apexDescription": "Une jarre Avian. Elle semble remplie de poudre.",
      "avianDescription": "Une jarre à cendres. Beaucoup d'Avians sont incinérés, leurs restes étant conservés dans des jarres comme celles-ci.",
      "floranDescription": "Ssscraser jarre de l'homme-oisseau.",
      "glitchDescription": "Pensif. Les cendres dans cette jarre sont d'origine Avian. Les Glitch ne peuvent pas être traités de cette façon.",
      "humanDescription": "Est-ce que ce sont... les cendres d'un Avian?",
      "hylotlDescription": "Les Avians honorent les cendres de leurs morts.",
      "novakidDescription": "Je parie qu'elle se briserait si je tirais dessus."
    }
  },
  "ashjar2": {
    "name": "Jarre Lapin",
    "desc": "Une jarre en forme de lapin pleine de cendres. Je pourrais peut-être la casser.",
    "metadata": {
      "apexDescription": "Beaucoup de cendres dans cette jarre. Ce pourrait être des restes.",
      "avianDescription": "Les cendres dans cette jarre sont les restes d'un Avian mort dans la honte. Le lapin désigne l'Avian à l'intérieur comme quelqu'un qui n'obtiendra jamais d'ailes dans l'éther.",
      "floranDescription": "Essst-ce cendress d'Avian ou d'une autre créature?",
      "glitchDescription": "Confus. Les cendres à l'intérieur sont d'origine Avian, alors pourquoi la jarre a-t-elle cette forme?",
      "humanDescription": "Une jarre lapin, pleine de cendres funéraires.",
      "hylotlDescription": "Pourquoi les Avians conserveraient-ils les cendres de leurs morts dans une jarre pareille?",
      "novakidDescription": "Cette jarre a l'air parfaite pour s'entraîner au tir."
    }
  },
  "ashjar3": {
    "name": "Jarre Familiale",
    "desc": "Une jarre à la forme familière. Elle a l'air en colère et fragile.",
    "metadata": {
      "apexDescription": "Cette jarre me semble très familière.",
      "avianDescription": "Je n'ai jamais vu une jarre comme celle-ci, peut-être les restes de quelqu'un avec un certain sens de l'humour.",
      "floranDescription": "Floran se demande quel goût a cette créature.",
      "glitchDescription": "Intéressé. Je n'ai jamais vu une telle créature auparavant.",
      "humanDescription": "Hé, on dirait un...",
      "hylotlDescription": "Étrange créature.",
      "novakidDescription": "À quelle genre de bestiole c'est censé ressembler?"
    }
  },
  "avianbanner1": {
    "name": "Bannière Colorée Avian",
    "desc": "Une bannière Avian tissée de soie onéreuse.",
    "metadata": {
      "apexDescription": "Une bannière merveilleusement vibrante.",
      "avianDescription": "Les Sans-Ailes décorent leurs villages avec de telles bannières. Ils remplissent leurs vies de couleurs.",
      "floranDescription": "Joliess couleurss, rappelle les fleurss à Floran.",
      "glitchDescription": "Charmé. Mal fabriquée, mais magnifique malgré tout.",
      "humanDescription": "Des couleurs vives et joyeuses!",
      "hylotlDescription": "Une telle vivacité ne peut exister qu'au-dessus de l'océan.",
      "novakidDescription": "Y a un truc avec cette bannière. Je l'aime bien."
    }
  },
  "avianbanner2": {
    "name": "Bannière Lunaire Avian",
    "desc": "Une épaisse bannière tissée représentant un croissant de lune.",
    "metadata": {
      "apexDescription": "Une bannière tissée éclatante. Je me demande ce que signifie la lune.",
      "avianDescription": "Pour les Sans-Ailes, la lune est un symbole de liberté.",
      "floranDescription": "Floran chasse au clair de lune, la lune essst l'amie des Florans.",
      "glitchDescription": "Sceptique. Quelle importance peut bien avoir la lune pour les Avians?",
      "humanDescription": "Une bannière lunaire magnifiquement tissée.",
      "hylotlDescription": "Une lune... un spectacle que beaucoup d'Hylotls n'ont jamais vu.",
      "novakidDescription": "On dirait qu'une lune a été tissée dans cette bannière."
    }
  },
  "avianbanner3": {
    "name": "Bannière à Motifs Avian",
    "desc": "Une bannière Avian faite de soie magnifique.",
    "metadata": {
      "apexDescription": "Une bannière Avian à motifs. Les motifs sont rudimentaires mais le tissu est vibrant.",
      "avianDescription": "Ces bannières à motifs sont faites par les moins habiles des Sans-Ailes, mais quand elles sont suspendues en nombre, elles deviennent une mer de couleurs.",
      "floranDescription": "Couleurss vives et motifss amusantss.",
      "glitchDescription": "Joyeux. De merveilleuses couleurs.",
      "humanDescription": "Des couleurs si vives. On dirait qu'elles sont amusantes à fabriquer.",
      "hylotlDescription": "Bien que la qualité soit médiocre, une telle joie a été mise dans la création de cette bannière. Cela me réchauffe les cœurs de la regarder.",
      "novakidDescription": "Un sacré beau travail de tissage sur cette bannière."
    }
  },
  "avianbanner4": {
    "name": "Petite Bannière Avian",
    "desc": "Une bannière Avian standard en tissu.",
    "metadata": {
      "apexDescription": "De petites bannières avec des motifs simples.",
      "avianDescription": "Ces bannières sont fabriquées par les enfants Avians lorsqu'ils entrent dans l'âge adulte.",
      "floranDescription": "Floran fait dess bannièress avec des peau dess bêtess.",
      "glitchDescription": "Ravi. Cette bannière semble être une première tentative de travail du tissu.",
      "humanDescription": "Ces bannières sont mignonnes... on dirait qu'elles ont été faites par des enfants.",
      "hylotlDescription": "Ces bannières sont-elles l'œuvre d'enfants? J'approuve.",
      "novakidDescription": "On dirait bien qu'un gamin a fait cette bannière."
    }
  },
  "avianbench1": {
    "name": "Banc Rustique",
    "desc": "Un magnifique banc rustique.",
    "metadata": {
      "apexDescription": "Ce banc suggère une appréciation du naturel plutôt que du grandiose.",
      "avianDescription": "Un magnifique petit banc. Les Sans-Ailes tirent une grande joie de fabriquer leurs meubles eux-mêmes.",
      "floranDescription": "Le banc ssent le bon boisss, bien poussé.",
      "glitchDescription": "Charmé. Un banc fait main.",
      "humanDescription": "On dirait du fait main. Très charmant.",
      "hylotlDescription": "Un banc charmant, bien que son créateur manque de talent.",
      "novakidDescription": "Un p'tit banc mignon pour s'poser un instant."
    }
  },
  "avianbench2": {
    "name": "Banc de Village",
    "desc": "Un banc Avian confortable.",
    "metadata": {
      "apexDescription": "Ce banc a l'air confortable.",
      "avianDescription": "L'artisanat des Sans-Ailes ne fait guère mieux que cela.",
      "floranDescription": "Bois du banc essst doux.",
      "glitchDescription": "Impressionné. Ce banc est fabriqué avec plus de savoir-faire que la plupart des autres meubles Avians.",
      "humanDescription": "Un joli banc confortable. Il a l'air bien fait.",
      "hylotlDescription": "Bien que l'artisanat soit bon, ce banc manque de charme.",
      "novakidDescription": "On dirait un coin confortable pour reposer mes bottes un moment."
    }
  },
  "avianpressureplate": {
    "name": "Plaque de Pression en Cristal",
    "desc": "Utilisez cette plaque de pression avec sagesse.",
    "metadata": {
      "apexDescription": "Une sorte de plaque de pression alimentée par cristal.",
      "avianDescription": "Un interrupteur à pression en cristal. Que se passerait-il si je montais dessus?",
      "floranDescription": "Bouton en crisstal brillant. Floran devrait sssauter dessus?",
      "glitchDescription": "Confus. Je ne pense pas que cela ait été construit par les Glitch.",
      "humanDescription": "Une plaque de pression géante.",
      "hylotlDescription": "Qu'est-ce que cela active?",
      "novakidDescription": "Ce cristal a l'air de pouvoir être relié à n'importe quoi."
    }
  },
  "avianstoragelocker": {
    "name": "Casier de Rangement Avian",
    "desc": "Une solution de rangement murale, spacieuse et élégante.",
    "metadata": {
      "apexDescription": "Un casier fait de métal.",
      "avianDescription": "Un endroit pour garder ses affaires.",
      "floranDescription": "Floran peut fourrer des chosess dans le cassier.",
      "glitchDescription": "Neutre. Un casier de rangement métallique.",
      "humanDescription": "C'est un casier de rangement au look industriel.",
      "hylotlDescription": "Un endroit pour ranger ses effets personnels.",
      "novakidDescription": "Un casier dans le mur."
    }
  },
  "avianswitchhidden1": {
    "name": "Interrupteur Caché Jaune",
    "desc": "Cette dalle semble différente des autres.",
    "metadata": {
      "apexDescription": "Cette dalle semble être mal fixée.",
      "avianDescription": "Cette dalle est mal ajustée.",
      "floranDescription": "La dalle sscille.",
      "glitchDescription": "Curieux. Une dalle légèrement déplacée.",
      "humanDescription": "Une dalle qui cliquette.",
      "hylotlDescription": "Une dalle étrange.",
      "novakidDescription": "Y a un truc qui cloche avec cette dalle."
    }
  },
  "avianswitchhidden2": {
    "name": "Interrupteur Caché Bleu",
    "desc": "Cette dalle semble différente des autres.",
    "metadata": {
      "apexDescription": "Cette dalle semble être mal fixée.",
      "avianDescription": "Cette dalle est mal ajustée.",
      "floranDescription": "La dalle sscille.",
      "glitchDescription": "Curieux. Une dalle légèrement déplacée.",
      "humanDescription": "Une dalle qui cliquette.",
      "hylotlDescription": "Une dalle étrange.",
      "novakidDescription": "Y a un truc qui cloche avec cette dalle."
    }
  },
  "avianwaterlight": {
    "name": "Lampe de Cristal",
    "desc": "Le cristal incrusté dans ce support brille d'une lueur pâle.",
    "metadata": {
      "apexDescription": "Une lumière pour y voir clair, peut-être un peu tape-à-l'œil...",
      "avianDescription": "Les cristaux sont utiles pour tout. Cette lampe crée une ambiance parfaite.",
      "floranDescription": "Une lumière brillante façonnée dans la pierrre.",
      "glitchDescription": "Appréciatif. Quelle jolie lumière.",
      "humanDescription": "Pour une lampe, c'est un vrai bijou.",
      "hylotlDescription": "Quelle lampe intrigante façonnée à partir d'une gemme exemplaire.",
      "novakidDescription": "Cette lampe de dingo a l'air d'être faite en caillou."
    }
  },
  "apexapesign": {
    "name": "Affiche de Big Ape",
    "desc": "Big Ape voit tout!",
    "metadata": {
      "apexDescription": "Big Ape... même maintenant, je me sens surveillé.",
      "avianDescription": "Par les plumes! Les Astronomes crieraient au blasphème.",
      "floranDescription": "Il est comment cet Ape? On pourrait peut-être le trouver et en faire un fesstin.",
      "glitchDescription": "Curieux. J'aimerais examiner cette forme de vie et enquêter sur son optique.",
      "humanDescription": "Je ne sais pas comment les Apex supportent ça.",
      "hylotlDescription": "Avant de regarder vers l'extérieur, on doit d'abord regarder en soi.",
      "novakidDescription": "Il voit tout? Y a des trucs qu'il vaut mieux ne pas voir."
    }
  },
  "apexaquarium1": {
    "name": "Aquarium en Bois",
    "desc": "Regardez! Des pois-poissons!",
    "metadata": {
      "apexDescription": "Chez moi, j'avais un ami avec un poisson vert dans son bocal. Il n'a pas duré longtemps.",
      "avianDescription": "Cette créature fend l'eau comme on pourrait voler dans les airs.",
      "floranDescription": "Ooo, un snack-bar.",
      "glitchDescription": "Empathique. Cette forme de vie est piégée.",
      "humanDescription": "Cela me rappelle les meubles anciens des humains.",
      "hylotlDescription": "Un jour je te libérerai, mon frère.",
      "novakidDescription": "Un seul poisson. Il a p'tête besoin d'un ami?"
    }
  },
  "apexaquarium2": {
    "name": "Aquarium en Bois Vide",
    "desc": "Un aquarium vide. C'est bien triste.",
    "metadata": {
      "apexDescription": "Un Apex n'est autorisé à remplacer son poisson qu'une fois tous les 3 ans.",
      "avianDescription": "Ce poisson a quitté le nid.",
      "floranDescription": "Quelqu'un est parvenu ici en premier.",
      "glitchDescription": "Neutre. Un réservoir vide.",
      "humanDescription": "Je me demande ce qui est arrivé au poisson...",
      "hylotlDescription": "Des souvenirs du pays m'envahissent.",
      "novakidDescription": "C'est pour garder des poissons. Mais y en a pas un seul."
    }
  },
  "apexarmchair": {
    "name": "Fauteuil Standard",
    "desc": "Ce rembourrage est complètement dingue.",
    "metadata": {
      "apexDescription": "La mode Apex a évolué depuis la fabrication de cette chaise ; hélas, ce n'est pas le cas de la liberté des Apex.",
      "avianDescription": "Un siège tellement confortable. Est-ce un nid Apex?",
      "floranDescription": "Sssécœurant.",
      "glitchDescription": "Mécontent. Ce fauteuil offense mes capteurs optiques.",
      "humanDescription": "Un fauteuil déprimant. Mais confortable!",
      "hylotlDescription": "Quel effet une telle... inélégance peut-elle avoir sur l'esprit?",
      "novakidDescription": "C'est pas beau, mais c'est confortable."
    }
  },
  "apexbananasign": {
    "name": "Affiche de Propagande Banane",
    "desc": "Gloire à la Grande Banane!",
    "metadata": {
      "apexDescription": "Ces panneaux marquaient autrefois l'entrée des Banana Clubs, jusqu'à ce que le Miniknog impose la prohibition. Aujourd'hui, ils rappellent que toute infraction à la loi est passible de mort.",
      "avianDescription": "Les Avians ont une digestion sensible. Nous nous en tenons à nos propres aliments.",
      "floranDescription": "Une nourriture ssi horrible.",
      "glitchDescription": "Curieux. Je crois que c'est de la subsistance Apex.",
      "humanDescription": "Eh bien... c'est concis.",
      "hylotlDescription": "Est-ce de la nourriture? J'ai hâte de goûter des plats exotiques.",
      "novakidDescription": "Une image de banane. C'est écrit 'BANANE' aussi, au cas où on l'aurait ratée."
    }
  },
  "apexbed": {
    "name": "Lit Standard",
    "desc": "Un lit fabriqué à bas prix.",
    "metadata": {
      "apexDescription": "Chez les Apex, nous avons peur d'un tout autre type de punaises de lit.",
      "avianDescription": "Un tel confort est rare chez les Avians, nos meubles sont de pierre et de paille.",
      "floranDescription": "Une literie sssi inconfortable. Ça ne vaut pas les peau de bêtes de Floran.",
      "glitchDescription": "Observateur. Une station utile pour recharger ses batteries.",
      "humanDescription": "Un lit simple, qui manque de charme.",
      "hylotlDescription": "Comment peut-on fermer l'œil entouré d'une telle laideur?",
      "novakidDescription": "Un lit tout simple. Ça fait l'affaire."
    }
  },
  "apexbloodbank": {
    "name": "Banque de Sang",
    "desc": "Des flacons remplis de divers groupes sanguins. J'espère qu'ils n'ont pas retiré TOUT leur sang.",
    "metadata": {
      "apexDescription": "Une banque de sang. De nombreux Apex n'ont plus jamais été revus après avoir fourni son contenu.",
      "avianDescription": "Les Astronomes croient que le sang contient de la magie.",
      "floranDescription": "Un distributeur automatique!",
      "glitchDescription": "Curieux. Dans quel but ce sang est-il utilisé?",
      "humanDescription": "Certains de ces flacons sont marqués. Ils portent tous la mention 'échec'.",
      "hylotlDescription": "Les Hylotls pensent que le sang devrait rester à l'intérieur du corps.",
      "novakidDescription": "Je peux pas dire que j'aie déjà vu autant de sang d'un coup."
    }
  },
  "apexbrainjar": {
    "name": "Cerveau en Bocal",
    "desc": "Un cerveau dans un bocal, en train de rêvasser.",
    "metadata": {
      "apexDescription": "C'est un cerveau d'Apex...",
      "avianDescription": "Ce cerveau est tellement gros.",
      "floranDescription": "Sssucculent cerveau en saumure.",
      "glitchDescription": "Jaloux. Un vrai cerveau...",
      "humanDescription": "Est-ce que c'est un... cerveau?",
      "hylotlDescription": "Quelle sottise de croire que l'esprit peut être confiné dans un bocal.",
      "novakidDescription": "Un cerveau dans un bocal? Je suis pas très à l'aise avec ça."
    }
  },
  "apexbustmale": {
    "name": "Buste d'Apex Mâle",
    "desc": "Le buste d'un Apex important.",
    "metadata": {
      "apexDescription": "Je me demande combien de familles ce type a détruites.",
      "avianDescription": "Sculpté avec expertise.",
      "floranDescription": "Dîner de pierrre fait casser les dents.",
      "glitchDescription": "Nostalgique. Cela me rappelle les statues de nos rois.",
      "humanDescription": "Ce gars a l'air important.",
      "hylotlDescription": "Produit à la machine à partir de pierre commune.",
      "novakidDescription": "Une statue impressionnante. C'est qui cet Apex?"
    }
  },
  "apexceilingtv": {
    "name": "Télé de Plafond Scintillante",
    "desc": "Un moniteur inquiétant. Un visage clignote sur l'écran, presque plus vite que l'œil ne peut le voir.",
    "metadata": {
      "apexDescription": "Il y en a un dans chaque foyer Apex. Ils diffusent des émissions 'éducatives'. Si vous regardez assez longtemps, vous pourriez apercevoir une image de vous-même... en train de regarder la télévision.",
      "avianDescription": "Les Avians n'ont pas encore atteint une telle clarté d'image.",
      "floranDescription": "Tant de ssscintillements venant de la boîte à images.",
      "glitchDescription": "Compatissant. Ces créatures ont encore moins de liberté que les Glitch.",
      "humanDescription": "Une propagande si peu subtile.",
      "hylotlDescription": "Les Apex sont tout aussi piégés que nous.",
      "novakidDescription": "Je pense pas que ça diffuse des divertissements."
    }
  },
  "apexcomfychair": {
    "name": "Siège Standard",
    "desc": "Une chaise confortable, on dirait qu'elle est faite pour être clouée au sol.",
    "metadata": {
      "apexDescription": "Cette chaise est plutôt confortable. Une récompense pour avoir dénoncé son voisin.",
      "avianDescription": "Est-ce qu'elle est remplie de plumes?",
      "floranDescription": "Sssi doux.",
      "glitchDescription": "Impressionné. Un trône digne d'un roi.",
      "humanDescription": "Wow, c'est une chaise vraiment confortable. Elle a l'air chère.",
      "hylotlDescription": "Aussi doux que le sable au fond de l'océan.",
      "novakidDescription": "C'est sûr que c'est une chaise douillette pour s'asseoir."
    }
  },
  "apexconsole1": {
    "name": "Terminal de Recherche",
    "desc": "Ce gros levier rouge devrait probablement être laissé tranquille.",
    "metadata": {
      "apexDescription": "Je me demande ce que fait cet interrupteur...",
      "avianDescription": "Est-ce qu'il se passe quelque chose si je tire le levier?",
      "floranDescription": "Un sssseul levier.",
      "glitchDescription": "Curieux. Un levier.",
      "humanDescription": "Un gros levier rouge. Qu'est-ce qui pourrait mal tourner?",
      "hylotlDescription": "Réfléchissez avant d'agir.",
      "novakidDescription": "Un terminal avec un gros levier rouge. Je devrais tirer dessus?"
    }
  },
  "apexconsolekeyboard": {
    "name": "Clavier de Console",
    "desc": "Je me demande à quoi servent tous ces boutons...",
    "metadata": {
      "apexDescription": "Un clavier Apex contient chacune des 26 clés de l'alphabet Apex.",
      "avianDescription": "Un appareil avec beaucoup de boutons, un symbole alien sur chacun d'eux.",
      "floranDescription": "Sssupide technologie.",
      "glitchDescription": "Curieux. Seulement 26 symboles?",
      "humanDescription": "Ce n'est pas du QWERTY... mais je reconnais beaucoup de lettres ici.",
      "hylotlDescription": "L'écriture Hylotl coule comme l'eau. L'écriture Apex coule comme la pierre.",
      "novakidDescription": "Un clavier. Utilisé pour l'écriture."
    }
  },
  "apexcoolbookcase": {
    "name": "Bibliothèque Stylée",
    "desc": "Elle devrait être remplie de revues scientifiques et de rapports de laboratoire.",
    "metadata": {
      "apexDescription": "Une bibliothèque Apex, je me demande s'il y a quelque chose ici...",
      "avianDescription": "Peu d'Avians de mon nid sont capables de lire.",
      "floranDescription": "Floran raconte des hisss-toires au coin du feu.",
      "glitchDescription": "Curieux. Il y a peut-être quelque chose à apprendre des Apex.",
      "humanDescription": "Une bibliothèque. Mon traducteur va avoir du pain sur la planche.",
      "hylotlDescription": "Il y a beaucoup de grandes bibliothèques au fond des océans Hylotls.",
      "novakidDescription": "Ça semble contenir principalement de la littérature scientifique."
    }
  },
  "apexcoolchair": {
    "name": "Chaise Stylée",
    "desc": "C'est une chaise exceptionnellement stylée.",
    "metadata": {
      "apexDescription": "Élégant. Seul le Miniknog obtient des meubles de ce genre.",
      "avianDescription": "Un œuf?",
      "floranDescription": "Cuir sssouple.",
      "glitchDescription": "Envieux. Cette chaise est des plus délicieuses.",
      "humanDescription": "C'est une chaise plutôt cool. Donc les Apex SONT capables d'avoir du style.",
      "hylotlDescription": "Cette chaise est fluide comme l'écriture sur une page.",
      "novakidDescription": "Une chaise en forme d'œuf. C'est plutôt cool, j'imagine."
    }
  },
  "apexcoolcomputer": {
    "name": "Ordinateur Stylé",
    "desc": "Cet ordinateur stylé fait beaucoup de bruits de type 'bip boup boup bip'.",
    "metadata": {
      "apexDescription": "C'est un ordinateur vraiment puissant. Les civils Apex n'ont pas accès aux ordinateurs.",
      "avianDescription": "Cet écran d'ordinateur a tellement de couleurs.",
      "floranDescription": "Floran vvole la technologie pour sssurvivre.",
      "glitchDescription": "Admiratif. Quelle machine époustouflante.",
      "humanDescription": "Cela ressemble beaucoup à la puissance informatique que l'humanité possédait autrefois.",
      "hylotlDescription": "Un ordinateur basique.",
      "novakidDescription": "C'est un écran d'ordinateur."
    }
  },
  "apexcoolcupboard": {
    "name": "Placard Stylé",
    "desc": "Ce placard est élégant, mais il n'a pas l'air solide.",
    "metadata": {
      "apexDescription": "Je parie qu'il y a quelques squelettes dans ce placard.",
      "avianDescription": "Y a-t-il quelque chose à l'intérieur?",
      "floranDescription": "Sstockage.",
      "glitchDescription": "Curieux. Pourrait contenir des objets.",
      "humanDescription": "Un placard au look épuré.",
      "hylotlDescription": "Je devrais vérifier le contenu.",
      "novakidDescription": "Jetons un coup d'œil à l'intérieur."
    }
  },
  "apexcooldesk": {
    "name": "Bureau Stylé",
    "desc": "Ce bureau est élégant, il a l'air solide.",
    "metadata": {
      "apexDescription": "Je me demande qui travaillait ici...",
      "avianDescription": "Un bureau en métal - d'apparence clinique.",
      "floranDescription": "Bureau fffrais au toucher.",
      "glitchDescription": "Indifférence. Un bureau.",
      "humanDescription": "Un bureau à l'aspect professionnel.",
      "hylotlDescription": "Un mince bureau en métal.",
      "novakidDescription": "Un bureau brillant fait en métal."
    }
  },
  "apexcooldoor": {
    "name": "Porte de Sécurité",
    "desc": "Cette porte est faite d'une sorte de matériau pare-balles.",
    "metadata": {
      "apexDescription": "Cette porte semble assez solide pour empêcher n'importe quoi d'entrer... ou tout le monde de sortir.",
      "avianDescription": "Une porte robuste. Même une brise ne pourrait pas se faufiler.",
      "floranDescription": "Porte d'une grande ffforce.",
      "glitchDescription": "Jaloux. Des matériaux si résistants.",
      "humanDescription": "Une énorme et lourde porte de sécurité.",
      "hylotlDescription": "Cela semble assez solide pour retenir l'océan.",
      "novakidDescription": "Une porte très épaisse."
    }
  },
  "apexcoolserver": {
    "name": "Serveur Stylé",
    "desc": "On dirait un serveur. Je me demande quel genre de jeux pourraient être hébergés là-dessus.",
    "metadata": {
      "apexDescription": "Un serveur sécurisé. Inaccessible.",
      "avianDescription": "Il y a beaucoup de lumières clignotantes.",
      "floranDescription": "Boîte à lumières fait un bruit de clic.",
      "glitchDescription": "Honteux. Un serveur protégé par une sécurité que même moi je ne peux contourner.",
      "humanDescription": "On dirait un serveur de données. Aucune chance qu'on en tire quoi que ce soit.",
      "hylotlDescription": "Ce serveur contiendrait assez de données pour remplir mille bibliothèques Hylotls.",
      "novakidDescription": "Cette pièce de technologie stocke des informations."
    }
  },
  "apexcoolshelf1": {
    "name": "Étagère Vide Stylée",
    "desc": "Il n'y a rien d'intéressant sur cette étagère.",
    "metadata": {
      "apexDescription": "Une étagère vide.",
      "avianDescription": "Un endroit pour empiler des objets.",
      "floranDescription": "Étagère en métal essst froide.",
      "glitchDescription": "Déçu. Rien ici.",
      "humanDescription": "Une étagère métallique vide.",
      "hylotlDescription": "Cette étagère a l'air seule.",
      "novakidDescription": "Y a rien à voir ici."
    }
  },
  "apexcoolshelf2": {
    "name": "Étagère à Produits Chimiques Stylée",
    "desc": "Il semble irresponsable de laisser un tas de produits chimiques non étiquetés sans surveillance.",
    "metadata": {
      "apexDescription": "Une étagère pleine de concoctions expérimentales.",
      "avianDescription": "Des potions d'alchimiste.",
      "floranDescription": "Liquide collant dangerreux.",
      "glitchDescription": "Curieux. Que se passerait-il si j'en buvais une?",
      "humanDescription": "Je ne pense pas que ce qu'il y a sur cette étagère soit potable.",
      "hylotlDescription": "Beaucoup de ces liquides pourraient tuer en quelques secondes.",
      "novakidDescription": "J'ai l'impression que c'est pas fait pour être bu."
    }
  },
  "apexcooltable": {
    "name": "Table Stylée",
    "desc": "C'est vraiment une table stylée.",
    "metadata": {
      "apexDescription": "Une table de laboratoire basique.",
      "avianDescription": "Une station de mélange pour alchimiste.",
      "floranDescription": "Une table pour les expérriences.",
      "glitchDescription": "Sarcastique. Une trouvaille très intéressante.",
      "humanDescription": "On dirait une table de labo.",
      "hylotlDescription": "Une table construite pour un usage scientifique.",
      "novakidDescription": "Une table métallique."
    }
  },
  "apexcouch": {
    "name": "Canapé Standard",
    "desc": "Une autre victime de cet imprimé à pois de mauvais goût.",
    "metadata": {
      "apexDescription": "Un autre meuble hideux imposé aux innocents.",
      "avianDescription": "Un morceau de tissu abominable recouvre ce siège.",
      "floranDescription": "Ssent le vieux.",
      "glitchDescription": "Affligé. De nombreux principes de design ont été ignorés.",
      "humanDescription": "Ce siège aspire la vie de la pièce.",
      "hylotlDescription": "Un meuble très peu attrayant.",
      "novakidDescription": "J'imagine que c'est fait pour s'asseoir, pas pour être regardé."
    }
  },
  "apexcounter1": {
    "name": "Placard de Cuisine Standard",
    "desc": "Une paire de placards de cuisine standard.",
    "metadata": {
      "apexDescription": "Démodé mais fonctionnel.",
      "avianDescription": "Un bon endroit pour stocker de la nourriture.",
      "floranDescription": "Sstockage pour manger. Miam.",
      "glitchDescription": "Enthousiaste. La possibilité de trouver de la nourriture excite même les Glitch.",
      "humanDescription": "On dirait un comptoir de cuisine.",
      "hylotlDescription": "Quels mets peuvent bien résider à l'intérieur, je me le demande?",
      "novakidDescription": "Juste un bon vieux comptoir de cuisine."
    }
  },
  "apexcounter2": {
    "name": "Comptoir Standard",
    "desc": "Un comptoir de cuisine standard.",
    "metadata": {
      "apexDescription": "C'est sur des comptoirs comme celui-ci qu'un Apex prépare généralement ses repas. Personnellement, je ne le recommanderais pas.",
      "avianDescription": "Une bonne surface pour la préparation des aliments.",
      "floranDescription": "Miam, préparons de la bonne nourrrriture!",
      "glitchDescription": "Observateur. Nous pouvons préparer de la subsistance ici.",
      "humanDescription": "On dirait un bon endroit pour préparer quelque chose à manger.",
      "hylotlDescription": "Voici un bon endroit pour l'art de la préparation culinaire.",
      "novakidDescription": "Une surface pour préparer un repas."
    }
  },
  "apexcurtain": {
    "name": "Rideau Standard",
    "desc": "Un ensemble de rideaux courts et fins.",
    "metadata": {
      "apexDescription": "Ces rideaux ne se ferment pas. L'intimité n'était pas une priorité.",
      "avianDescription": "De minces feuilles de tissu. Ils sont trop petits pour couvrir une fenêtre.",
      "floranDescription": "Sstupide Apex fait rideau trop petit pour couvrir fenêtre.",
      "glitchDescription": "Confus. Rideaux trop petits pour leur usage.",
      "humanDescription": "Ces rideaux ne sont pas très larges. On ne pourrait pas couvrir une fenêtre avec.",
      "hylotlDescription": "C'est un tissu aux couleurs ternes et au toucher rugueux.",
      "novakidDescription": "Des rideaux. Ils ont l'air trop courts pour couvrir la fenêtre."
    }
  },
  "apexdesk": {
    "name": "Bureau Standard",
    "desc": "Chacun de ces bureaux possède une tasse à café et une lampe fusionnées à sa surface.",
    "metadata": {
      "apexDescription": "La tasse à café et la lampe sont juste là pour la forme. Elles sont collées à la surface.",
      "avianDescription": "Une table étrange... les objets sur le dessus sont coincés.",
      "floranDescription": "Pourquoi Apex colle objet sur bureau?",
      "glitchDescription": "Confus. Les objets semblent fusionnés à la surface du bureau. Ils ne peuvent pas être retirés.",
      "humanDescription": "C'est quoi ce... la tasse et la lampe sont collées au bureau. C'est juste pour la déco?",
      "hylotlDescription": "Un ensemble de faux objets sont fusionnés à ce bureau. Quelle est cette fourberie?",
      "novakidDescription": "Cette tasse de café est clouée au bureau. À quoi ça sert?"
    }
  },
  "apexdonotenter": {
    "name": "Panneau Entrée Interdite",
    "desc": "Ne le faites pas!",
    "metadata": {
      "apexDescription": "Ces panneaux sont courants chez moi.",
      "avianDescription": "Sous quelle autorité ce panneau est-il écrit?",
      "floranDescription": "Floran entre où Floran veut entrer. Sstupide panneau.",
      "glitchDescription": "Rebelle. Je ne reçois plus d'ordres.",
      "humanDescription": "Merci pour la suggestion!",
      "hylotlDescription": "C'est le moment d'être prudent, je crois.",
      "novakidDescription": "Je suppose que j'entrerai pas. Ou p'têtre que si...?"
    }
  },
  "apexflusign": {
    "name": "Affiche Grippe Simienne",
    "desc": "La grippe simienne? Ça a l'air sérieux...",
    "metadata": {
      "apexDescription": "La grippe simienne a ravagé la société Apex. Étrangement, personne au pouvoir n'a été malade. Des rumeurs disaient que c'était une expérience.",
      "avianDescription": "Est-ce que les Avians peuvent attraper la grippe simienne?",
      "floranDescription": "Sstupide Grippe Apex, Floran va te manger.",
      "glitchDescription": "Confiant. La grippe simienne n'a aucun effet sur les Glitch.",
      "humanDescription": "J'espère que les humains ne peuvent pas attraper ça.",
      "hylotlDescription": "Maladie et souffrance. Les Apex méritent notre aide.",
      "novakidDescription": "J'ai pas trop envie de choper ça."
    }
  },
  "apexfridge": {
    "name": "Réfrigérateur Standard",
    "desc": "Un frigo, pratique pour garder la nourriture au frais.",
    "metadata": {
      "apexDescription": "Il est rare que les Apex aient de la nourriture en trop.",
      "avianDescription": "Un appareil de stockage de nourriture.",
      "floranDescription": "Floran adore sstockage de nourriture froide. Garde la viande fraîche, oui.",
      "glitchDescription": "Déterminé. Je dois piller ce stockage de nourriture!",
      "humanDescription": "Un frigo! Pile ce qu'il faut pour garder les aliments au frais.",
      "hylotlDescription": "Nous n'avons pas besoin de tels appareils sous l'océan.",
      "novakidDescription": "C'est gelé à l'intérieur pour garder la nourriture fraîche plus longtemps."
    }
  },
  "apexhdtv": {
    "name": "HDTV Big Ape",
    "desc": "Je crois que Big Ape nous regarde...",
    "metadata": {
      "apexDescription": "Est-ce là Big Ape? Je n'ai jamais rencontré quelqu'un qui l'ait vraiment vu...",
      "avianDescription": "C'est un grand singe.",
      "floranDescription": "C'essst une grande télé.",
      "glitchDescription": "Prudent. Peut-il nous voir?",
      "humanDescription": "Est-ce le fameux Big Ape dont j'entends sans cesse parler?",
      "hylotlDescription": "Est-ce la brute responsable du régime Apex?",
      "novakidDescription": "Un grand écran. Qui n'affiche rien d'autre qu'un grand singe."
    }
  },
  "apexlamp1": {
    "name": "Lampe Standard",
    "desc": "Une petite lampe en bois avec un abat-jour à pois.",
    "metadata": {
      "apexDescription": "Une lampe standard.",
      "avianDescription": "Est-ce que quelqu'un aime vraiment les pois?",
      "floranDescription": "Lampe à sstaches pourrie!",
      "glitchDescription": "Joyeux. Les Glitch apprécient la lumière.",
      "humanDescription": "Une vieille lampe.",
      "hylotlDescription": "La lampe émet une lumière terne.",
      "novakidDescription": "Une lampe. Rien de spécial."
    }
  },
  "apexlamp2": {
    "name": "Grande Lampe Standard",
    "desc": "Une grande lampe en bois avec un abat-jour à pois.",
    "metadata": {
      "apexDescription": "Modèle standard.",
      "avianDescription": "Une grande lampe. Je me demande comment elle fonctionne? Il n'y a pas de cristaux.",
      "floranDescription": "Grande lampe, lumière brrillante.",
      "glitchDescription": "Satisfait. Avec la lumière vient la sécurité.",
      "humanDescription": "Une grande lampe lumineuse.",
      "hylotlDescription": "Cette lampe pourrait éclairer une grande salle.",
      "novakidDescription": "C'est une grande lampe sur pied."
    }
  },
  "apexlamp3": {
    "name": "Lanterne en Papier",
    "desc": "Une lampe de plafond en papier.",
    "metadata": {
      "apexDescription": "Ces lampes de plafond sont connues pour prendre feu. Leurs propriétaires n'ont cependant pas le droit de les remplacer.",
      "avianDescription": "Cette lumière est recouverte de papier. Ça ne semble pas très sûr.",
      "floranDescription": "Floran pense que lampe brrûle comme le ssoleil.",
      "glitchDescription": "Prudent. Température du papier trop élevée.",
      "humanDescription": "Une lampe en papier. J'espère qu'elle est sûre.",
      "hylotlDescription": "Les Hylotls fabriquent des lampes similaires avec du papier et des flammes.",
      "novakidDescription": "Un genre de lampe en papier qui pend au plafond."
    }
  },
  "apexlevel1sign": {
    "name": "Panneau Apex Niveau 01",
    "desc": "Allez les Singes!",
    "metadata": {
      "apexDescription": "Je suppose que je suis au niveau un.",
      "avianDescription": "Combien y a-t-il de niveaux?",
      "floranDescription": "Puis-je ssauter le niveau un?",
      "glitchDescription": "Neutre. Je suis actuellement au niveau un.",
      "humanDescription": "Niveau un, combien de niveaux y a-t-il?",
      "hylotlDescription": "Il faut bien commencer par le début.",
      "novakidDescription": "On dirait que j'ai atteint le niveau un."
    }
  },
  "apexlocker": {
    "name": "Casier de Laboratoire",
    "desc": "Un casier du Miniknog.",
    "metadata": {
      "apexDescription": "Je me demande s'il y a des secrets à l'intérieur...",
      "avianDescription": "Pourrait-il y avoir quelque chose de valeur dedans?",
      "floranDescription": "Fffouiller.",
      "glitchDescription": "Excité. Des objets intéressants à l'intérieur?",
      "humanDescription": "Un casier de labo.",
      "hylotlDescription": "Peut-être qu'il y a quelque chose d'utile dedans.",
      "novakidDescription": "Un casier. Qu'est-ce qu'il contient?"
    }
  },
  "apexmedsign": {
    "name": "Panneau Infirmerie",
    "desc": "Le panneau indique la présence de matériel médical à proximité.",
    "metadata": {
      "apexDescription": "Les Apex ont l'une des meilleures technologies médicales de la galaxie, mais aussi l'espérance de vie la plus courte.",
      "avianDescription": "Est-ce que toutes les races n'ont pas aussi des prêtres guérisseurs?",
      "floranDescription": "Est-ce perrmis de manger les trucs bons qui meurent?",
      "glitchDescription": "Curieux. Une opportunité d'en apprendre plus sur la physiologie organique.",
      "humanDescription": "On dirait un panneau d'hôpital.",
      "hylotlDescription": "Peut-être qu'un lieu de guérison est proche.",
      "novakidDescription": "L'équipement médical est gardé ici."
    }
  },
  "apexmocksign": {
    "name": "Panneau de Désobéissance",
    "desc": "Un poster de Big Ape vandalisé.",
    "metadata": {
      "apexDescription": "On dirait que quelqu'un n'est pas fan de Big Ape.",
      "avianDescription": "Un poster de Big Ape défiguré. Beau travail.",
      "floranDescription": "Floran trouve le ssinge drrôle!",
      "glitchDescription": "Amusé. Quelqu'un a vandalisé ce poster de Big Ape.",
      "humanDescription": "On dirait que quelqu'un n'a pas peur du Miniknog.",
      "hylotlDescription": "Même en temps d'oppression, les Apex prennent le temps de gribouiller sur des posters.",
      "novakidDescription": "Vandaliser un poster de Big Ape est un geste osé. Je parie que quelqu'un a payé le prix fort."
    }
  },
  "apexnameplate": {
    "name": "Plaque Élégante",
    "desc": "Une plaque élégante avec une inscription dessus.",
    "metadata": {
      "apexDescription": "Une plaque en métal gravée.",
      "avianDescription": "Une plaque avec une inscription gravée dessus.",
      "floranDescription": "Une petite plaque en métal avec une écrriture ennuyeuse.",
      "glitchDescription": "Intrigué. Une petite plaque métallique avec une inscription.",
      "humanDescription": "Une plaque avec une inscription écrite dessus.",
      "hylotlDescription": "Une plaque avec une inscription gravée par-dessus.",
      "novakidDescription": "Une plaque en métal avec un peu d'écriture."
    }
  },
  "apexobeysign": {
    "name": "Panneau d'Obéissance",
    "desc": "Je ferais mieux de faire ce qu'ils disent... ha!",
    "metadata": {
      "apexDescription": "Obéir... Je l'ai fait... pendant si longtemps.",
      "avianDescription": "Obéir? Est-ce que Big Ape est le dieu des Apex?",
      "floranDescription": "Hsssss Floran n'obéit pas au dîner.",
      "glitchDescription": "Courageux. Jamais!!!",
      "humanDescription": "Propagande Apex. Je devrais lui dessiner une moustache rigolote.",
      "hylotlDescription": "Seuls ceux qui règnent par la peur ont besoin d'un tel poster.",
      "novakidDescription": "Je vais pas rrrecevoir d'ordres d'une image."
    }
  },
  "apexofficechair": {
    "name": "Chaise de Bureau",
    "desc": "Une chaise de bureau standard.",
    "metadata": {
      "apexDescription": "Une chaise basique utilisée par les employés de bureau, elle est inconfortable par conception.",
      "avianDescription": "Quelle diablerie est-ce là, une chaise sur roues?",
      "floranDescription": "Le cuir ssent bon.",
      "glitchDescription": "Peu impressionné. Ergonomie inacceptable.",
      "humanDescription": "Une chaise de bureau déprimante sur roulettes. Je me demande combien de gens utilisent encore ça?",
      "hylotlDescription": "Une chaise inconfortable, toute utilisation prolongée causerait de la douleur.",
      "novakidDescription": "C'est encore plus inconfortable que ça en a l'air. Et ça a l'air drôlement inconfortable."
    }
  },
  "apexoven": {
    "name": "Four Standard",
    "desc": "Cuit les aliments de façon raisonnable.",
    "metadata": {
      "interactData.paneLayoutOverride.windowtitle.title": " Four Standard",
      "interactData.paneLayoutOverride.windowtitle.subtitle": " Cuit les aliments de façon raisonnable",
      "apexDescription": "Un four simple, tout juste capable de chauffer de la nourriture.",
      "avianDescription": "Un appareil pour chauffer la nourriture. Je peux cuisiner ici.",
      "floranDescription": "Le feu rrrend la nourriture encore meilleure.",
      "glitchDescription": "Observateur. Appareil de cuisson identifié.",
      "humanDescription": "Un four à gaz. Je n'en ai jamais utilisé.",
      "hylotlDescription": "Nous pouvons rapidement chauffer de la nourriture ici.",
      "novakidDescription": "C'est pour cuisiner des repas."
    }
  },
  "apexpainting1": {
    "name": "Peinture du Glorieux Leader",
    "desc": "Une peinture très flatteuse de Big Ape, Glorieux et Bien-aimé Leader des Apex.",
    "metadata": {
      "apexDescription": "Big Ape... Cette peinture est accrochée dans un million de foyers Apex. Dégrader une image de Big Ape signifie la mort.",
      "avianDescription": "Ce Singe est peint comme un dieu.",
      "floranDescription": "Ssinge brillant trrès appétissant.",
      "glitchDescription": "Méfiant. Peinture suspectée d'être inexacte.",
      "humanDescription": "Je ne pense pas que ce type soit à la hauteur de son image.",
      "hylotlDescription": "Un vrai grand leader ne se soucie pas de la célébrité.",
      "novakidDescription": "Un Apex devant un magnifique coucher de soleil."
    }
  },
  "apexpainting2": {
    "name": "Portrait d'Apex",
    "desc": "Le portrait d'un gardien de la paix Apex.",
    "metadata": {
      "apexDescription": "Un gardien de la paix. Ces types vendraient leur propre mère pour obtenir les faveurs du Miniknog.",
      "avianDescription": "Cet Apex a l'air sincèrement heureux.",
      "floranDescription": "Apex ssouriant.",
      "glitchDescription": "Curieux. Quelle est la source du bonheur de cet Apex?",
      "humanDescription": "Ce gars sourit. Je me demande pourquoi?",
      "hylotlDescription": "Cet Apex a un sourire suffisant.",
      "novakidDescription": "Un Apex de très bonne humeur."
    }
  },
  "apexpainting3": {
    "name": "Disque de Big Ape",
    "desc": "Une réplique encadrée de l'album à succès de Big Ape, 'Jungle Love'.",
    "metadata": {
      "apexDescription": "C'est le seul disque qu'un Apex est autorisé à posséder. Certains disent qu'il contient des messages subliminaux.",
      "avianDescription": "Un disque étrange.",
      "floranDescription": "Cerccle noir brillant.",
      "glitchDescription": "Confus. Un type de média inconnu.",
      "humanDescription": "Est-ce que c'est... du vinyle? Branché.",
      "hylotlDescription": "Il y a des rainures dans le disque.",
      "novakidDescription": "Ce disque a un motif subtil."
    }
  },
  "apexpainting4": {
    "name": "Peinture Standard",
    "desc": "Ne sous-estimez pas l'amour d'un Apex pour les bananes.",
    "metadata": {
      "apexDescription": "Certains aiment tellement la banane qu'ils l'immortalisent dans l'art.",
      "avianDescription": "Un fruit jaune.",
      "floranDescription": "Floran détesste la nourriture jaune molle.",
      "glitchDescription": "Observateur. Il semble que ce soit un fruit.",
      "humanDescription": "Une banane... d'accord.",
      "hylotlDescription": "Quelqu'un doit tenir énormément à son fruit jaune.",
      "novakidDescription": "Une sorte de pop art?"
    }
  },
  "apexpainting5": {
    "name": "Point de Croix Big Ape",
    "desc": "Puissions-nous lui obéir à jamais.",
    "metadata": {
      "apexDescription": "Le point de croix est l'un des rares loisirs autorisés pour un Apex.",
      "avianDescription": "Il doit falloir des doigts délicats pour créer ceci.",
      "floranDescription": "Le Floran esst trrès doué pour le travail du tissu.",
      "glitchDescription": "Contemplatif. Pourquoi les Apex feraient-ils cela?",
      "humanDescription": "J'espère vraiment que les Apex ne sont pas forcés de fabriquer ça.",
      "hylotlDescription": "Quel genre de bénédictions les Apex lui souhaitent-ils, je me le demande?",
      "novakidDescription": "Ça a dû demander du temps et du dévouement."
    }
  },
  "apexpiano": {
    "name": "Piano Standard",
    "desc": "Il y a des partitions ici.",
    "metadata": {
      "apexDescription": "Tous les Apex apprennent à jouer. Cependant, seule la musique autorisée peut être interprétée.",
      "avianDescription": "Les touches produisent des sons plaisants.",
      "floranDescription": "Floran fait musique avec peau et os, mmaître du tambour. Pas sstupide machine à sons.",
      "glitchDescription": "Observateur. Les mathématiques derrière cette machine sont relativement simples.",
      "humanDescription": "Un piano... Je sais jouer 'Au clair de la lune'.",
      "hylotlDescription": "Ah, la musique. Elle a le pouvoir d'illuminer même nos heures les plus sombres.",
      "novakidDescription": "Je dirais pas non à une mélodie de piano apaisante. Dommage que personne n'en joue."
    }
  },
  "apexpod": {
    "name": "Capsule de Survie",
    "desc": "Il semble y avoir un Apex à l'intérieur, relié à un tas de fils et de tubes.",
    "metadata": {
      "apexDescription": "Grand Dieu... qu'ont-ils fait? Je le libérerais bien, mais il semble être maintenu en vie artificiellement.",
      "avianDescription": "Quel processus monstrueux est-ce là?",
      "floranDescription": "Ssoupe!",
      "glitchDescription": "Choqué. Que se passe-t-il ici!?",
      "humanDescription": "C'est quoi ce bordel?",
      "hylotlDescription": "Pauvre âme...",
      "novakidDescription": "Ça me ssemble pas très correct, tout ça."
    }
  },
  "apexpod2": {
    "name": "Capsule de Survie Vide",
    "desc": "La capsule est vide.",
    "metadata": {
      "apexDescription": "Heureusement, cette capsule est vide. Est-ce ainsi que le Miniknog tente de nous ramener à notre état naturel?",
      "avianDescription": "C'est de la science occulte...",
      "floranDescription": "De telles mmarrmites sont contre-nature.",
      "glitchDescription": "Attentif. La machine semble tenter d'altérer l'ADN Apex.",
      "humanDescription": "Ça n'augure rien de bon. Je ne peux pas m'empêcher de m'attendre à ce que quelque chose me saute dessus.",
      "hylotlDescription": "Cette machine tente d'altérer l'ADN d'une manière qui n'est absolument pas viable.",
      "novakidDescription": "Je m'apprroche pas de ça."
    }
  },
  "apexradio": {
    "name": "Radio Standard",
    "desc": "La radio est allumée mais silencieuse.",
    "metadata": {
      "apexDescription": "Chez nous, ces radios servent surtout aux annonces du Miniknog. Pendant un temps, la résistance a réussi à faire tourner une station pirate.",
      "avianDescription": "On dirait une radio. Les radios Avians utilisent la résonance des cristaux.",
      "floranDescription": "Apparreil pour parrrler à longue distance.",
      "glitchDescription": "Intéressé. Une radio, ne recevant actuellement aucun signal.",
      "humanDescription": "Le bouton de réglage est bloqué sur une seule position.",
      "hylotlDescription": "Silence...",
      "novakidDescription": "Elle a pas l'air de fonctionner."
    }
  },
  "apexrecordplayer": {
    "name": "Tourne-disque Standard",
    "desc": "Il diffuse des mélodies langoureuses du premier album de Big Ape, 'Jungle Love'.",
    "metadata": {
      "apexDescription": "On murmure que ce disque contient des messages subliminaux.",
      "avianDescription": "Cette machine émet beaucoup de sons aigus à peine audibles.",
      "floranDescription": "Floran mmaître du tambour et du rythme, mais Apex deuxième derrière.",
      "glitchDescription": "Concentré. La musique démontre un manque de théorie musicale. Contient des messages.",
      "humanDescription": "C'est ça qu'ils appellent de la musique ici?",
      "hylotlDescription": "Le son de l'oppression.",
      "novakidDescription": "Un appareil qui joue de la musique."
    }
  },
  "apexsink": {
    "name": "Lavabo de Salle de Bain",
    "desc": "N'oubliez pas de vous laver les mains!",
    "metadata": {
      "apexDescription": "Un lavabo impeccable. Les maisons mal tenues ne sont pas tolérées par le Miniknog.",
      "avianDescription": "Un distributeur d'eau... peut-être une fontaine à boire?",
      "floranDescription": "Eau douce et nourrrissante.",
      "glitchDescription": "Attentif. Pureté de l'eau: 13 %. Il semble que l'eau contienne un élément synthétique.",
      "humanDescription": "Je devrais me laver les mains de temps en temps.",
      "hylotlDescription": "Cette eau n'est pas faite pour y nager.",
      "novakidDescription": "Ça a l'air sûr de boire ça."
    }
  },
  "apexslidingdoor1": {
    "name": "Porte Coulissante Légère",
    "desc": "Une porte coulissante légère, présentée comme étant plus mince, plus rapide et plus chère.",
    "metadata": {
      "apexDescription": "Ces portes ont été conçues pour cacher des secrets.",
      "avianDescription": "Une architecture si originale.",
      "floranDescription": "Porte sssiffle comme un sserpent.",
      "glitchDescription": "Enjoué. Le bruit de glissement envoie une étincelle dans mes circuits.",
      "humanDescription": "Ces portes coulissantes font un bruit satisfaisant.",
      "hylotlDescription": "Cette porte semble n'avoir ni serrure ni poignée.",
      "novakidDescription": "Une entrée impressionnante. Elles doivent pas être données."
    }
  },
  "apexslidingdoor2": {
    "name": "Porte Coulissante Noire",
    "desc": "Une porte coulissante légère, présentée comme étant plus mince, plus rapide et plus chère.",
    "metadata": {
      "apexDescription": "Ces portes ont été conçues pour cacher des secrets.",
      "avianDescription": "Une architecture si originale.",
      "floranDescription": "Porte sssiffle comme un sserpent.",
      "glitchDescription": "Enjoué. Le bruit de glissement envoie une étincelle dans mes circuits.",
      "humanDescription": "Ces portes coulissantes font un bruit satisfaisant.",
      "hylotlDescription": "Cette porte semble n'avoir ni serrure ni poignée.",
      "novakidDescription": "Une entrée impressionnante. Elles doivent pas être données."
    }
  },
  "apexspeaker": {
    "name": "Interphone d'Annonces",
    "desc": "Les interphones sont souvent utilisés pour diffuser des messages... ou pour en recevoir.",
    "metadata": {
      "apexDescription": "Les interphones de ce type sont monnaie courante sous le Miniknog.",
      "avianDescription": "Un son sourd et grave émane de cet appareil.",
      "floranDescription": "Allô...? Floran esst ssûr que quelqu'un écoute...",
      "glitchDescription": "Nerveux. Il reçoit un signal silencieux venant de quelque part.",
      "humanDescription": "Un système d'interphone. Je me demande si quelqu'un répondra si je parle dedans.",
      "hylotlDescription": "L'interphone semble avoir une caméra intégrée.",
      "novakidDescription": "Un appareil pour crier des ordres, pas pour la musique. Dommage."
    }
  },
  "apexstatue": {
    "name": "Statue de Scientifique Apex",
    "desc": "Il semble que ce soit un scientifique qui a 'donné son corps à la science'.",
    "metadata": {
      "apexDescription": "Ce scientifique est mort en tentant d'altérer ses gènes. Il sert d'exemple à tous les autres Apex. Le Miniknog dit que c'est le plus grand honneur qu'un Apex puisse atteindre.",
      "avianDescription": "Un scientifique. Les Astronomes nous mettaient souvent en garde contre les dangers inhérents à la science.",
      "floranDescription": "Ssottise Apex donne son corps à la sscience, quel gaspillage de bonne viande.",
      "glitchDescription": "Dubitatif. Le scientifique a 'donné son corps'. Peut-être n'avait-il pas le choix?",
      "humanDescription": "Apparemment, ce gars a donné son corps à sa cause. Noble ou stupide?",
      "hylotlDescription": "Le sacrifice de soi est honoré par les Hylotls, mais seulement si la cause est juste.",
      "novakidDescription": "Une statue de quelqu'un qui a sacrifié sa vie. Était-ce de son plein gré?"
    }
  },
  "apexstatue1": {
    "name": "Buste de Big Ape",
    "desc": "C'est un buste de Big Ape, Glorieux Leader des Apex.",
    "metadata": {
      "apexDescription": "Big Ape... Son image est partout, mais je ne l'ai jamais vu.",
      "avianDescription": "Un buste en pierre bon marché. On dirait qu'il est produit par une machine.",
      "floranDescription": "Sstupide visage de pierre.",
      "glitchDescription": "Rancunier. Mes capteurs suggèrent qu'un appareil est caché à l'intérieur.",
      "humanDescription": "Big Ape. Je me demande si c'est à l'échelle?",
      "hylotlDescription": "Le Singe lui-même, si c'est bien lui.",
      "novakidDescription": "Il devait drôlement s'aimer, ce Big Ape."
    }
  },
  "apexstatue2": {
    "name": "Statue de la Grande Banane",
    "desc": "Gloire à la Grande Banane!",
    "metadata": {
      "apexDescription": "Une banane digne de Big Ape...",
      "avianDescription": "Est-ce que les Apex vénèrent leur nourriture à ce point?",
      "floranDescription": "Tellemennt grosse banane.",
      "glitchDescription": "Amusé. Une grosse banane.",
      "humanDescription": "Une grosse banane pour un gros singe?",
      "hylotlDescription": "Cette statue doit avoir une importance sociale.",
      "novakidDescription": "Ils aiment les fruits, hein?"
    }
  },
  "apexstatue3": {
    "name": "Statue Verrou de la Grande Banane",
    "desc": "Gloire à la Grande Banane! Le fruit sacré!",
    "metadata": {
      "apexDescription": "Il y a une marque sur la statue. On dirait qu'on peut appuyer dessus.",
      "avianDescription": "Il y a quelque chose d'étrange avec cette statue.",
      "floranDescription": "Technologie ssournoise.",
      "glitchDescription": "Investigateur. Il y a un dispositif quelconque caché dans cette statue.",
      "humanDescription": "Le bouton dans cette statue n'est pas très bien caché.",
      "hylotlDescription": "Une piètre tentative de subterfuge.",
      "novakidDescription": "C'est un bouton? Discret."
    }
  },
  "apexstoragelocker": {
    "name": "Casier de Stockage Apex",
    "desc": "Une solution de stockage murale, spacieuse et élégante.",
    "metadata": {
      "apexDescription": "Un casier fabriqué en métal.",
      "avianDescription": "Un endroit pour garder vos affaires.",
      "floranDescription": "Floran peut ffourrer des choses dans casier.",
      "glitchDescription": "Neutre. Un casier de stockage métallique.",
      "humanDescription": "C'est un casier de rangement au look industriel.",
      "hylotlDescription": "Quelque part pour ranger ses effets personnels.",
      "novakidDescription": "Un casier dans le mur."
    }
  },
  "apexstoreshelf": {
    "name": "Étagère de Magasin en Bois",
    "desc": "Il y a quelques objets sur cette étagère.",
    "metadata": {
      "apexDescription": "Cette étagère contient des objets utiles.",
      "avianDescription": "Il y a des objets de soin sur cette étagère.",
      "floranDescription": "Étagère a de bons objjetss.",
      "glitchDescription": "Surpris. Il y a des objets utiles sur cette étagère.",
      "humanDescription": "Cette étagère est pleine d'objets, je parie qu'elle peut en contenir encore plus.",
      "hylotlDescription": "Il y a des objets utiles sur cette étagère.",
      "novakidDescription": "Je pourrrrais bien faire bon usage de ces objets."
    }
  },
  "apexstoresign": {
    "name": "Enseigne de Magasin",
    "desc": "Un panneau publicitaire pour un endroit où acheter des trucs.",
    "metadata": {
      "apexDescription": "Un panneau pour un magasin.",
      "avianDescription": "Il est écrit \"magasin\".",
      "floranDescription": "Panneau pour un mmagasin.",
      "glitchDescription": "Réconforté. Un panneau qui indique un magasin.",
      "humanDescription": "On dirait l'enseigne d'un magasin.",
      "hylotlDescription": "C'est le panneau d'un magasin.",
      "novakidDescription": "Ça doit être un magasin."
    }
  },
  "apextable": {
    "name": "Table Standard",
    "desc": "Une table basique produite en masse.",
    "metadata": {
      "apexDescription": "Chaque Apex dîne sur une table exactement comme celle-ci. Enfin... du moins chaque Apex qui respecte les règles.",
      "avianDescription": "Du bois de piètre qualité a été utilisé pour fabriquer cette table.",
      "floranDescription": "Bois sssent mauvais. Pas du vrai bois.",
      "glitchDescription": "Déprimé. Table dépourvue de toute joie.",
      "humanDescription": "Une table déprimante.",
      "hylotlDescription": "Des mains forcées ont construit cette table.",
      "novakidDescription": "C'est juste une table en bois."
    }
  },
  "apextablelamp": {
    "name": "Lampe Capsule Verte",
    "desc": "Cette étrange lampe émet une faible lumière verte.",
    "metadata": {
      "apexDescription": "Ces lampes étaient distribuées par le Miniknog dans ma jeunesse. On en trouve dans beaucoup de foyers Apex.",
      "avianDescription": "Cet appareil brille d'un vert non naturel.",
      "floranDescription": "Lumièress vertes rappellent à Floran son village natal.",
      "glitchDescription": "Observateur. Il semble que cet objet collecte des données biométriques sur les formes de vie organiques à proximité.",
      "humanDescription": "Cet appareil semble lourd pour une simple lampe.",
      "hylotlDescription": "Je pense que l'éclairage n'est pas le véritable but de cet appareil.",
      "novakidDescription": "Une lumière verte sinistre."
    }
  },
  "apextent": {
    "name": "Tente Militaire",
    "desc": "Une tente militaire.",
    "metadata": {
      "apexDescription": "Une tente souvent utilisée par ceux qui campent loin de chez eux.",
      "avianDescription": "Une tente souvent utilisée par ceux qui sont loin de leur foyer.",
      "floranDescription": "Tente essst un bon abri dans la nature sssauvage.",
      "glitchDescription": "Irrité. Il n'y a pas beaucoup de place.",
      "humanDescription": "Cette tente ne détonnerait pas dans un camp militaire.",
      "hylotlDescription": "Une tente à l'aspect militariste.",
      "novakidDescription": "Une sorte de tente militaire."
    }
  },
  "apexthoughtreassign": {
    "name": "Panneau de Réaffectation",
    "desc": "Ayez des pensées joyeuses!",
    "metadata": {
      "apexDescription": "Réaffectation de la pensée... J'en ai fait des cauchemars.",
      "avianDescription": "Les pensées sont sacrées, comment osent-ils!",
      "floranDescription": "Floran n'aime pas ce sssigne.",
      "glitchDescription": "Compatissant. La réaffectation de la pensée est courante chez les Glitchs.",
      "humanDescription": "Ce panneau est incroyablement flippant.",
      "hylotlDescription": "On dit que la méditation triomphe de telles pratiques. Les pensées ne peuvent pas être réaffectées quand elles n'existent pas.",
      "novakidDescription": "Ce panneau ne marche pas sur moi. Je ne me sens pas différent."
    }
  },
  "apextorturebed": {
    "name": "Table d'Interrogatoire",
    "desc": "Une table réservée aux traîtres.",
    "metadata": {
      "apexDescription": "Combien de mes frères ont été attachés à cette table...",
      "avianDescription": "De telles pratiques sont monstrueuses, cette table devrait être détruite.",
      "floranDescription": "Floran utilise de telss appareils pour préparer le dîner.",
      "glitchDescription": "Dégoûté. Les Glitchs utilisent de tels dispositifs pour extraire les secrets de leurs ennemis.",
      "humanDescription": "La torture... un acte que l'humanité a proscrit il y a de très, très nombreuses années.",
      "hylotlDescription": "La torture n'a pas sa place dans une société éclairée.",
      "novakidDescription": "Un appareil malfaisant."
    }
  },
  "apextv": {
    "name": "Télé Big Ape",
    "desc": "Il n'y a rien. Chaque chaîne affiche simplement une image de Big Ape.",
    "metadata": {
      "apexDescription": "Big Ape n'est jamais apparu en personne sur la télé Big Ape.",
      "avianDescription": "Il semble n'y avoir rien avec quoi interagir sur cet appareil.",
      "floranDescription": "Machine inutile.",
      "glitchDescription": "Observateur. L'appareil reçoit des milliers d'émissions différentes, mais elles semblent toutes identiques.",
      "humanDescription": "Est-ce que ses yeux viennent de bouger?",
      "hylotlDescription": "Les seules images de Big Ape semblent être artificielles.",
      "novakidDescription": "Une créature me fixe depuis l'écran."
    }
  },
  "apexwallpainting1": {
    "name": "Peinture Moderne",
    "desc": "Qu'est-ce que ça SIGNIFIE?",
    "metadata": {
      "apexDescription": "C'est passé de mode il y a bien longtemps.",
      "avianDescription": "Une décoration si intéressante.",
      "floranDescription": "Ces ffformes troublent Floran.",
      "glitchDescription": "Admiratif. Un art géométrique précis.",
      "humanDescription": "Mon dieu, cet art est tellement démodé.",
      "hylotlDescription": "On dit que l'art nourrit l'âme, mais certains aliments sont meilleurs que d'autres.",
      "novakidDescription": "Des formes aux couleurs de coucher de soleil sur une toile."
    }
  },
  "apexwallpainting2": {
    "name": "Peinture Moderne Verticale",
    "desc": "Qu'est-ce que ça SIGNIFIE?",
    "metadata": {
      "apexDescription": "C'est passé de mode il y a bien longtemps.",
      "avianDescription": "Une décoration si intéressante.",
      "floranDescription": "Ces ffformes troublent Floran.",
      "glitchDescription": "Admiratif. Un art géométrique précis.",
      "humanDescription": "Mon dieu, cet art est tellement démodé.",
      "hylotlDescription": "On dit que l'art nourrit l'âme, mais certains aliments sont meilleurs que d'autres.",
      "novakidDescription": "Des formes aux couleurs de coucher de soleil sur une toile."
    }
  },
  "apexwardrobe": {
    "name": "Garde-robe Standard",
    "desc": "Une garde-robe très basique produite en masse.",
    "metadata": {
      "apexDescription": "La résistance stockait autrefois ses déguisements dans ces garde-robes...",
      "avianDescription": "Aucun marquage, aucune décoration.",
      "floranDescription": "Garde-robe? Ces chosess ennuient Floran.",
      "glitchDescription": "Peu inspiré. Un tel mobilier ne stimule pas l'esprit.",
      "humanDescription": "C'est comme si quelqu'un s'était donné beaucoup de mal pour s'assurer que cette garde-robe soit terne.",
      "hylotlDescription": "Peut-être que quelque chose d'intéressant se trouve à l'intérieur. Les apparences peuvent être trompeuses.",
      "novakidDescription": "Cette garde-robe serait parfaite pour ranger mes sous-vêtements."
    }
  },
  "apexwoodenchair": {
    "name": "Chaise Standard",
    "desc": "Une chaise de salle à manger en bois standard.",
    "metadata": {
      "apexDescription": "Ces chaises simples sont produites en masse. J'ai une fois trouvé 'Aidez-nous' gravé dans le cadre d'une chaise.",
      "avianDescription": "Les pieds de cette chaise vacillent.",
      "floranDescription": "Floran fabrique de meilleurss chaisess, artisans passsé maîtres.",
      "glitchDescription": "Obsessionnel. Un pied de chaise est trois millimètres plus long que les autres.",
      "humanDescription": "Une chaise bancale et inconfortable.",
      "hylotlDescription": "Ce n'était manifestement pas un travail fait avec amour.",
      "novakidDescription": "Le genre de chaise faite jusste pour s'asseoir."
    }
  },
  "apexwoodenshelves": {
    "name": "Étagères Standard",
    "desc": "Les étagères sont vides.",
    "metadata": {
      "apexDescription": "Des étagères vides. Elles n'attendent que des bibelots et des souvenirs.",
      "avianDescription": "Une maison Avian est décorée d'objets qui aident à évoquer des souvenirs plaisants. Rien de tel ici.",
      "floranDescription": "Rien ici pour Floran, doit chercher ailleurss.",
      "glitchDescription": "Ennuyé. Il n'y a rien d'intéressant ici.",
      "humanDescription": "Vide... c'est triste.",
      "hylotlDescription": "Ces étagères n'ont absolument aucun caractère.",
      "novakidDescription": "Aussi stérile qu'un morceau de roche spatiale."
    }
  },
  "apexwoodpanel": {
    "name": "Panneau Mural Standard",
    "desc": "C'est juste un panneau mural.",
    "metadata": {
      "apexDescription": "Un panneau en bois. On en voit dans beaucoup de logements Apex.",
      "avianDescription": "Qu'est-ce que cela cache?",
      "floranDescription": "Décoration inutile.",
      "glitchDescription": "Peu impressionné. Panneau en bois sans intérêt.",
      "humanDescription": "Je parie qu'on pourrait cacher un micro derrière l'un de ceux-là.",
      "hylotlDescription": "Est-ce purement décoratif ou cela a-t-il une fonction?",
      "novakidDescription": "Ce bois est aussi fragile qu'une paire de bottes à deux balles."
    }
  },
  "arrowsign": {
    "name": "Panneau Flèche",
    "desc": "Je devrais probablement aller par là.",
    "metadata": {
      "apexDescription": "J'ai été conditionné à ne pas faire confiance aux flèches.",
      "avianDescription": "Une flèche. Je me demande où elle mène.",
      "floranDescription": "Flèche ne commande pas Floran, Floran est libre d'aller où Floran désseire.",
      "glitchDescription": "Analytique. La probabilité que ce panneau pointe dans la bonne direction est de 25 pour cent.",
      "humanDescription": "À quoi ça sert si on ne me dit pas ce qu'elle désigne?",
      "hylotlDescription": "Parfois, pour avancer, il faut faire un pas en arrière.",
      "novakidDescription": "Un panneau vers nulle part."
    }
  },
  "apexsecuritycamera": {
    "name": "Caméra de Sécurité High-tech",
    "desc": "La meilleure caméra de sécurité du coin.",
    "metadata": {
      "apexDescription": "Elle regarde toujours.",
      "avianDescription": "Je devrais me méfier des caméras de sécurité comme celle-ci.",
      "floranDescription": "Cette caméra bouge tout ssseule.",
      "glitchDescription": "Prudent. Cette caméra de sécurité est équipée d'un détecteur de mouvement.",
      "humanDescription": "Quelqu'un surveille mes moindres faits et gestes avec cette caméra. Tellement flippant.",
      "hylotlDescription": "Voir cette caméra me donne envie de me cacher sous l'océan pour fuir son regard.",
      "novakidDescription": "Qu'essst-ce que t'as à regarder, hein?"
    }
  },
  "apexturret": {
    "name": "Tourelle High-tech",
    "desc": "La meilleure tourelle de sécurité automatisée du coin.",
    "metadata": {
      "apexDescription": "Toujours prête à tirer.",
      "avianDescription": "Je dois me déplacer comme le vent pour ne pas être vu par cette tourelle.",
      "floranDescription": "Des lasssers si brillants. Veux pas être dans leur ligne de mire.",
      "glitchDescription": "Déterminé. Je ne dois pas devenir la cible.",
      "humanDescription": "Un fusil de sécurité automatisé. Une sale machine.",
      "hylotlDescription": "Un rappel des extrémités auxquelles certains sont prêts à aller.",
      "novakidDescription": "Un fusil automatique n'a pas d'âme pour se retenir."
    }
  },
  "airbooster": {
    "name": "Propulseur d'Air",
    "desc": "Le gaz libéré par ces conduits vous fait vous sentir léger comme une plume.",
    "metadata": {
      "apexDescription": "Le flux d'air de cet évent est un stimulus à faible gravité.",
      "avianDescription": "Cet évent simule la sensation du vol!",
      "floranDescription": "Évent fait sss'envoler Floran!",
      "glitchDescription": "Sceptique. Une bouche d'aération, ça semble assez sûr.",
      "humanDescription": "Donnez-moi un boost de gravité!",
      "hylotlDescription": "L'exposition au flux d'air de cet évent me permettra de conserver mon énergie.",
      "novakidDescription": "Parfois, on a juste besoin d'un petit coup de pouce dans la vie."
    }
  },
  "ancientbust": {
    "name": "Buste Antique",
    "desc": "Un buste antique représentant le Cultivateur. L'orbe qu'il tient produit de la lumière.",
    "metadata": {
      "apexDescription": "La lumière de cette statue antique semble toujours fonctionner parfaitement.",
      "avianDescription": "Il semble que cette statue dépeigne une puissante race ancienne.",
      "floranDescription": "Floran aime la lumière brrillante de l'astronaute.",
      "glitchDescription": "Fasciné. Cette statue antique possède toujours une lumière fonctionnelle.",
      "humanDescription": "Cette vieille statue produit encore de la lumière. Celui qui l'a fabriquée savait ce qu'il faisait.",
      "hylotlDescription": "La lumière de cette statue antique projette une ambiance sinistre.",
      "novakidDescription": "Ça alors. J'arrive pas à croire que cette vieille lumière marche encore."
    }
  },
  "ancientchest": {
    "name": "Coffre Antique",
    "desc": "Un coffre antique d'origine inconnue.",
    "metadata": {
      "apexDescription": "Un coffre extrêmement vieux. Il pourrait contenir n'importe quoi.",
      "avianDescription": "Ce coffre semble vraiment très ancien.",
      "floranDescription": "Floran est curieuxss... qu'est-ce qu'il y a dans cette boîte bizarre?",
      "glitchDescription": "Prudent. La structure de ce coffre est impénétrable pour mes capteurs.",
      "humanDescription": "C'est un coffre qui a l'air vraiment vieux.",
      "hylotlDescription": "Ce coffre a un design inconnu, je suis incapable d'en déterminer le fabricant.",
      "novakidDescription": "C'est un miracle que ce coffre tienne encore debout après tout ce temps."
    }
  },
  "ancientconsole": {
    "name": "Console Antique",
    "desc": "On dirait le panneau de contrôle de la porte. Il semble toujours fonctionner.",
    "metadata": {
      "apexDescription": "Une pièce de technologie extrêmement ancienne.",
      "avianDescription": "Cette console doit être aussi vieille que la porte elle-même. C'est dire!",
      "floranDescription": "Commandess antiques pour la porte antique.",
      "glitchDescription": "Impressionné. Le panneau de contrôle de la porte, il a l'air vraiment très vieux.",
      "humanDescription": "Le panneau de contrôle de la porte. Il doit être aussi vieux que la porte.",
      "hylotlDescription": "La console de la porte. Comme la porte elle-même, c'est un mystère.",
      "novakidDescription": "Voyons si j'peux pas faire marcher ce vieux machin."
    }
  },
  "ancientdoor": {
    "name": "Porte Antique",
    "desc": "Une porte à l'aspect antique.",
    "metadata": {
      "apexDescription": "Une porte faite d'une pierre ancienne.",
      "avianDescription": "Une porte robuste d'origine ancienne.",
      "floranDescription": "On dirait une porte antique.",
      "glitchDescription": "Méfiant. Il ne serait pas surprenant que cette porte antique refuse de s'ouvrir.",
      "humanDescription": "Je parie que ces runes disent 'ouvrir' et 'fermer'.",
      "hylotlDescription": "Cette porte est une relique d'un temps révolu.",
      "novakidDescription": "Cette vieille porte est une relique."
    }
  },
  "ancientgate": {
    "name": "Porte Antique",
    "desc": "Une mystérieuse porte antique.",
    "metadata": {
      "apexDescription": "Une porte mystérieuse vers quelque part.",
      "avianDescription": "Une porte d'origine mystérieuse.",
      "floranDescription": "Floran sse demande quelle créature bizarre a fait cette porrte.",
      "glitchDescription": "Confus. Je ne parviens pas à retracer les origines de cette porte.",
      "humanDescription": "Une porte étrange et profane enveloppée de mystère.",
      "hylotlDescription": "Une structure monumentale, elle s'élève au-dessus de moi. Oserais-je voir où elle mène?",
      "novakidDescription": "Une drôle de porte qui me ssuplie de la traverser."
    }
  },
  "ancienthiddenplatform": {
    "name": "Plateforme Antique Cachée",
    "desc": "Quelque chose ne tourne pas rond avec ces briques.",
    "metadata": {
      "apexDescription": "Certaines de ces briques sont mal placées.",
      "avianDescription": "Ces briques n'ont pas l'air réelles.",
      "floranDescription": "Briquess ssentent différent des autress briquess.",
      "glitchDescription": "Sceptique. Quelque chose est caché ici.",
      "humanDescription": "Ces briques ont un aspect inhabituel.",
      "hylotlDescription": "La façon dont ces briques sont façonnées est étrange.",
      "novakidDescription": "J'ai jamais vu des briques aussi peu fiables."
    }
  },
  "ancientlight": {
    "name": "Applique Murale Antique",
    "desc": "Une applique murale.",
    "metadata": {
      "apexDescription": "Qu'est-ce qui alimente cette lumière depuis tant d'années?",
      "avianDescription": "Je m'attendais à ce qu'une lampe murale de cette taille éclaire davantage.",
      "floranDescription": "Grande vieille lumière laide.",
      "glitchDescription": "Désintéressé. Une lumière grande et disgracieuse.",
      "humanDescription": "Cette lumière est probablement allumée depuis des millénaires.",
      "hylotlDescription": "Cette lumière n'a rien de remarquable.",
      "novakidDescription": "Cette lumière diffuse une lueur chaleureuse."
    }
  },
  "ancientlightplatform": {
    "name": "Plateforme de Lumière Antique",
    "desc": "Un faisceau de lumière solide créant une plateforme.",
    "metadata": {
      "apexDescription": "Juste une plateforme holographique ordinaire.",
      "avianDescription": "Cela ne me semble pas assez stable pour supporter mon poids.",
      "floranDescription": "Floran sse méfie de la lumière ssolide.",
      "glitchDescription": "Nerveux. On dirait que je vais passer à travers cette plateforme.",
      "humanDescription": "Cette plateforme est faite d'une sorte de technologie de champ de force.",
      "hylotlDescription": "Cette barrière d'énergie peut supporter un poids bien au-delà de ses capacités apparentes.",
      "novakidDescription": "De l'énergie solide, tout comme nous les Novakid."
    }
  },
  "ancientlightround": {
    "name": "Applique Murale Antique Ronde",
    "desc": "Une applique murale ronde.",
    "metadata": {
      "apexDescription": "Qu'est-ce qui alimente cette lumière depuis tant d'années?",
      "avianDescription": "Je m'attendais à ce qu'une lampe murale de cette taille éclaire davantage.",
      "floranDescription": "Grande vieille lumière laide.",
      "glitchDescription": "Désintéressé. Une lumière grande et disgracieuse.",
      "humanDescription": "Cette lumière est probablement allumée depuis des millénaires.",
      "hylotlDescription": "Cette lumière n'a rien de remarquable.",
      "novakidDescription": "Cette lumière diffuse une lueur chaleureuse."
    }
  },
  "ancientpillar": {
    "name": "Pilier Antique",
    "desc": "Un pilier antique trouvé près des portes. Il produit de la lumière.",
    "metadata": {
      "apexDescription": "Un pilier antique incandescent. Je suis impressionné.",
      "avianDescription": "Un monolithe brillant. L'univers est merveilleux.",
      "floranDescription": "Pierre qui brrille! Ça rappelle à Floran un soleil couchant.",
      "glitchDescription": "Perceptif. Cette lueur éthérée est produite par une substance que je ne reconnais pas.",
      "humanDescription": "C'est comme un vieux réverbère antique!",
      "hylotlDescription": "Ce pilier imposant doit avoir été le témoin de bien des pans de l'histoire.",
      "novakidDescription": "Cette pierre qui brille me rappelle une lune lointaine."
    }
  },
  "ancientplaque1": {
    "name": "Plaque Antique",
    "desc": "Un message incroyablement vieux.",
    "metadata": {
      "apexDescription": "Peut-être que cette ruine est une sorte de message?",
      "avianDescription": "Mes plumes frissonnent à l'idée de l'âge que cela doit avoir.",
      "floranDescription": "Floran peut pas lirre ça. Ennuyeux!",
      "glitchDescription": "Confus. Je ne parviens pas à analyser la signification de cette ruine.",
      "humanDescription": "Les vieilles runes effrayantes sont mes préférées.",
      "hylotlDescription": "Un vieux message. Les runes coulent et s'entrelacent comme des rivières.",
      "novakidDescription": "Y'a un truc familier dans ces gribouillis."
    }
  },
  "ancientpot1": {
    "name": "Pot Antique Ornemental",
    "desc": "Ce pot antique est dans un état remarquable compte tenu de son âge.",
    "metadata": {
      "apexDescription": "Tout ce qui se trouvait dans ce pot antique a été oublié depuis longtemps.",
      "avianDescription": "Je ne pense pas que ce pot soit de nature cérémonielle. Je me demande ce qu'il pourrait y avoir dedans.",
      "floranDescription": "Vieux potss doivent être cassséss.",
      "glitchDescription": "Émerveillé. Ce pot antique a réussi à survivre aux ravages du temps.",
      "humanDescription": "Ce pot a l'air antique! Peut-être qu'il reste quelque chose à l'intérieur.",
      "hylotlDescription": "Je me demande quels trésors anciens pourraient se trouver dans ce vieux pot.",
      "novakidDescription": "C'est presque dommage de bousiller un pot aussi vieux..."
    }
  },
