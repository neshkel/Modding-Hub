  "alpacacomponentrune": {
    "name": "Rune de Composant",
    "desc": "Une rune antique symbolisant le composant de base de la vie.",
    "metadata": {
      "apexDescription": "Cette rune est clairement ancienne, mais indique une certaine compréhension scientifique.",
      "avianDescription": "Aucune chance que cette rune soit d'origine Avian, trop scientifique.",
      "floranDescription": "Runess antiques... celle-ci signifie particules de vie.",
      "glitchDescription": "Respectueux. Une rune qui signifie l'élément le plus basique de la vie organique.",
      "humanDescription": "C'est un symbole bien avancé pour une rune si vieille. On dirait un atome.",
      "hylotlDescription": "Cette rune a-t-elle été créée par une race qui s'est répandue parmi les étoiles avant même les Hylotls?",
      "novakidDescription": "Une vieille rune, elle montre les briques de la vie."
    }
  },
  "alpacagrowthrune": {
    "name": "Rune de Croissance Alpaga",
    "desc": "Une rune antique qui est le symbole de la croissance personnelle.",
    "metadata": {
      "apexDescription": "C'est une rune antique censée signifier la croissance personnelle.",
      "avianDescription": "Une rune antique similaire à certaines de nos propres runes Avian. Celle-ci signifie la croissance personnelle.",
      "floranDescription": "Floran a du mal à comprrendre cette rune.",
      "glitchDescription": "Serein. Les Alpagas communiquent le concept de croissance personnelle avec ce symbole.",
      "humanDescription": "Cette rune communique l'idée de croissance personnelle en un seul symbole.",
      "hylotlDescription": "Le concept de croissance personnelle est magnifiquement capturé dans cette marque antique.",
      "novakidDescription": "Un symbole de croissance personnelle, hein? C'est plutôt poussé."
    }
  },
  "alpacahomerune": {
    "name": "Rune du Foyer",
    "desc": "Une rune antique qui est le symbole du chez-soi.",
    "metadata": {
      "apexDescription": "Une vieille rune commune qui fait référence au concept de foyer.",
      "avianDescription": "Une rune antique signifiant le foyer.",
      "floranDescription": "Rune signifie maissson.",
      "glitchDescription": "Sceptique. Une rune pour désigner le foyer, mais qu'est-ce que le foyer?",
      "humanDescription": "Est-ce que les gens utilisent cette rune pour parler de leur foyer, ou pour marquer leur maison aux yeux des autres?",
      "hylotlDescription": "On pourrait se demander si le concept de foyer peut vraiment être défini.",
      "novakidDescription": "Ce symbole signifie le foyer. Pour moi, le foyer est là où le cœur vagabonde."
    }
  },
  "alpacaknowledgerune": {
    "name": "Rune du Savoir",
    "desc": "Une rune antique qui est le symbole de la connaissance.",
    "metadata": {
      "apexDescription": "Une vieille rune assez complexe signifiant le savoir.",
      "avianDescription": "Une rune qui signifie le savoir - pas étonnant qu'elle ait l'air si complexe.",
      "floranDescription": "Une rune complexe pour ssymboliser le concept complexe du ssavoir.",
      "glitchDescription": "Intrigué. Une rune pour désigner le savoir.",
      "humanDescription": "Si cette rune signifie le savoir, que puis-je en apprendre?",
      "hylotlDescription": "Ce design petit mais complexe englobe le concept insondable de la connaissance elle-même.",
      "novakidDescription": "Une rune à l'air sophistiqué, ça a un rapport avec le savoir."
    }
  },
  "alpacaliferune": {
    "name": "Rune de Vie",
    "desc": "Une rune antique qui est le symbole de la vie.",
    "metadata": {
      "apexDescription": "C'est une vieille rune pour la vie elle-même.",
      "avianDescription": "Cette rune est censée représenter l'essence de la vie.",
      "floranDescription": "Un vieux ssymbole, ça veut dirre vie.",
      "glitchDescription": "Optimiste. Une vieille rune qui représente la vertu de la vie.",
      "humanDescription": "C'est une vieille rune qui signifie la vie, apparemment.",
      "hylotlDescription": "Un marquage antique pour représenter toute vie en un seul symbole.",
      "novakidDescription": "Une rune pour symboliser toute la vie, c'est ambitieux pour une seule petite rune."
    }
  },
  "alpacaruinrune": {
    "name": "Rune de Ruine",
    "desc": "Une rune antique qui est le symbole de la ruine.",
    "metadata": {
      "apexDescription": "C'est une rune antique qui signifie la ruine. Il est curieux qu'une spirale signifie une telle chose.",
      "avianDescription": "Une rune antique similaire à certaines des nôtres. Celle-ci signifie la ruine.",
      "floranDescription": "Runess antiques... ça veut dirre ruine.",
      "glitchDescription": "Attentif. Une vieille rune qui signifie la ruine et le déclin.",
      "humanDescription": "C'est une vieille rune qui signifie la ruine. Comme c'est sinistre.",
      "hylotlDescription": "Une vieille rune de pierre signifiant la ruine - nous rappelant à tous que la lente marée du temps consume toute chose.",
      "novakidDescription": "C'est une rune antique qui signifie la ruine."
    }
  },
