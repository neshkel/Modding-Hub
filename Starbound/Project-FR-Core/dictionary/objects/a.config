      "apexDescription": "Un casier de rangement hermétique.",
      "avianDescription": "Un casier mural en métal.",
      "floranDescription": "Casier de rangement pratique pour cacher des chosesss.",
      "glitchDescription": "Curieux. Les casiers comme celui-ci ont souvent de grandes capacités.",
      "humanDescription": "Un casier de rangement mural.",
      "hylotlDescription": "Un casier de rangement à l'apparence simple.",
      "novakidDescription": "On pourrait fourrer un sacré paquet de trucs dans un casier pareil."
    }
  },
  "astrotable": {
    "name": "Table Astro",
    "desc": "Une surface de travail solide fixée au sol.",
    "metadata": {
      "apexDescription": "Une table au look industriel.",
      "avianDescription": "Une bande est peinte sur cette table.",
      "floranDescription": "Jussste une table en métal.",
      "glitchDescription": "Indifférent. Cette table n'a rien de remarquable.",
      "humanDescription": "Cette table est fixée au sol, sinon je pense qu'elle basculerait.",
