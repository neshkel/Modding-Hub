  },
  "aviancaptainschair": {
    "name": "Siège de Capitaine Avian",
    "desc": "Le Capitaine s'assoit ici pour piloter le vaisseau.",
    "metadata": {
      "apexDescription": "Ahh... La douce liberté. Je peux utiliser le navigateur du vaisseau depuis ce siège.",
      "avianDescription": "Le siège du Capitaine. C'est moi! Je peux utiliser le navigateur du vaisseau depuis ce siège.",
      "floranDescription": "Meilleur ssiège du vaisssseau. Floran peut s'asseeoir ici pour utilissser le navigateur et piloter le vaisssseau!",
