      "glitchDescription": "Émerveillé. Ce pot antique a réussi à survivre aux ravages du temps.",
      "humanDescription": "Ce pot a l'air antique! Peut-être qu'il reste quelque chose à l'intérieur.",
      "hylotlDescription": "Je me demande quels trésors anciens pourraient se trouver dans ce vieux pot.",
      "novakidDescription": "C'est presque dommage de bousiller un pot aussi vieux..."
    }
  },
  "ancientpressureplate": {
    "name": "Plaque de Pression Antique",
    "desc": "Utilisez cette plaque de pression avec sagesse.",
    "metadata": {
      "apexDescription": "Je me demande à quelles merveilles mécaniques cette plaque de pression pourrait être reliée.",
      "avianDescription": "Les dalles à pression comme celle-ci sont courantes dans les tombes Avians.",
      "floranDescription": "Prrudent. Le plus petit pas pourrait déclencher cette plaque.",
      "glitchDescription": "Intéressé. Cette dalle pourrait être utilisée pour déclencher n'importe quoi.",
      "humanDescription": "Marcher sur cette vieille dalle pourrait déclencher un piège!",
      "hylotlDescription": "J'ai vu des dalles comme celle-ci utilisées dans des pièges anciens.",
      "novakidDescription": "Cette dalle a l'air d'être raccordée à quéqu'chose."
    }
  },
  "ancientprop": {
    "name": "Accessoire Antique",
    "desc": "Un accessoire temporaire.",
    "metadata": {
      "apexDescription": "Un accessoire temporaire.",
      "avianDescription": "Un accessoire temporaire.",
      "floranDescription": "Un accessssoire temporraire.",
      "glitchDescription": "Un accessoire temporaire.",
      "humanDescription": "Un accessoire temporaire.",
      "hylotlDescription": "Un accessoire temporaire."
    }
  },
  "ancientsmallconsole": {
    "name": "Console Antique",
    "desc": "On dirait un ancien panneau de contrôle. Il semble toujours fonctionner.",
    "metadata": {
      "apexDescription": "La console fonctionne, je me demande quels êtres ont fabriqué ceci.",
      "avianDescription": "Cette console est d'origine antique.",
      "floranDescription": "Floran appuie ssur les boutons. Fait arriver dess chosess!",
      "glitchDescription": "Impressionné. Les applications techniques de cette console sont aussi avancées qu'elles sont anciennes.",
      "humanDescription": "Une console conçue pour résister à l'épreuve du temps.",
      "hylotlDescription": "Cette console a l'air extrêmement vieille, mais elle est encore fonctionnelle.",
      "novakidDescription": "Cette console a l'air drôlement vieille..."
    }
  },
  "ancientstriplight1": {
    "name": "Bande Lumineuse Antique",
    "desc": "Une lumière mystérieuse.",
    "metadata": {
      "apexDescription": "Ces lumières ne semblent pas être alimentées par l'électricité.",
      "avianDescription": "Ces lumières diffusent une lueur éthérée.",
      "floranDescription": "Bizarre lumière bleue...",
      "glitchDescription": "Curieux. Je ne vois aucune source d'énergie pour ces lumières antiques.",
      "humanDescription": "Ces lumières auraient leur place soit dans des ruines antiques, soit dans une boîte de nuit.",
      "hylotlDescription": "Je me demande ce qui alimente ces lumières antiques?",
      "novakidDescription": "Qu'ess-ce qui fait briller cette lumière bleue?"
    }
  },
