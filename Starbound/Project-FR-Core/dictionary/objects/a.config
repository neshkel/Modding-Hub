{
  "alarm": {
    "name": "Alarme",
    "desc": "Une grosse lumière clignotante et une sirène hurlante, garanties pour attirer l'attention.",
    "metadata": {
      "apexDescription": "Elles sont utilisées comme moyen de dissuasion, mais aussi pour la sécurité.",
      "avianDescription": "Cette lumière clignotante alertera tout le monde en cas de méfaits.",
      "floranDescription": "Cela va alerter tousss les gardesss.",
      "glitchDescription": "Alarmé. Cela va en alerter beaucoup, je devrais être prudent.",
      "humanDescription": "Si c'était un film, je parie qu'elle se déclencherait juste au moment où je pars.",
      "hylotlDescription": "Une alarme. Utilisée pour signaler les vauriens aux gardes.",
      "novakidDescription": "Cette alarme va drôlement compliquer la fuite avec le butin."
    }
  },
  "and": {
    "name": "Interrupteur ET",
    "desc": "Un interrupteur /'ET'/. Nécessite que toutes les entrées soient sur /'on'/ pour fonctionner.",
    "metadata": {
      "floranDescription": "Un interrupteur /'ET'/. Nécessssite que toutes les entréess soient ssour /'on'/ pour fonctionner.",
      "glitchDescription": "Satisfait. Un interrupteur /'ET'/. Nécessite que toutes les entrées soient sur /'on'/ pour fonctionner."
    }
  },
  "ancientbouldertrap": {
    "name": "Piège à Rochers Ancien",
    "desc": "Un piège qui lâche de lourds rochers sur les intrus imprudents.",
    "metadata": {
      "apexDescription": "Si je calcule bien mes mouvements, je peux éviter les rochers qui tombent.",
      "avianDescription": "Mieux vaut bien calculer mon coup, je ne veux pas qu'un rocher me tombe dessus.",
      "floranDescription": "De lourdesss rochesss tombent de ce trou.",
      "glitchDescription": "Déçu. Qui fabriquerait un piège à rochers avec un timing aussi prévisible?",
      "humanDescription": "Des rochers sortent de ce petit trou.",
      "hylotlDescription": "Un piège à rochers est facile à éviter avec des mouvements bien synchronisés.",
      "novakidDescription": "Ça roule, les rochers!"
    }
  },
  "ancientcrystaltrap": {
    "name": "Piège à Cristal Ancien",
    "desc": "Un piège à cristal conçu pour décourager les envahisseurs.",
    "metadata": {
      "apexDescription": "Ce cristal forme un faisceau lumineux mortel.",
      "avianDescription": "Je n'aimerais pas être pris dans son rayon.",
      "floranDescription": "Le rayon du crissttal fait mal à Floran.",
      "glitchDescription": "Exaspéré. Un cristal qui projette des rayons lumineux mortels! J'aura tout vu.",
      "humanDescription": "Ce rayon a l'air de faire plutôt mal.",
      "hylotlDescription": "Si je mémorise le motif du rayon du cristal, je pourrai agir en conséquence.",
      "novakidDescription": "Un cristal dingue qui me tire de la lumière dessus!"
    }
  },
  "ancientflametrap": {
    "name": "Piège à Flammes Ancien",
    "desc": "Ce piège crache des flammes pour dissuader les envahisseurs.",
    "metadata": {
      "apexDescription": "Un piège à flammes, à éviter absolument.",
      "avianDescription": "Aïe! Les flammes et les plumes ne font pas bon ménage!",
      "floranDescription": "Le piège à feu essst le pire ennemi de Floran!",
      "glitchDescription": "Terrifié. C'est juste un petit piège à flammes, rien d'insurmontable.",
      "humanDescription": "Un bon vieux piège à flammes, fidèle et fiable.",
      "hylotlDescription": "Le guerrier agile ne craint pas la flamme.",
      "novakidDescription": "Simple mais mortel. Mon genre préféré."
    }
  },
  "ancienticetrap": {
    "name": "Piège à Glace Ancien",
    "desc": "Ce piège crache du givre pour dissuader les envahisseurs.",
    "metadata": {
      "apexDescription": "C'est un piège à glace mortel.",
      "avianDescription": "Un mécanisme de glace dangereux.",
      "floranDescription": "La glace peut être dangerousse.",
      "glitchDescription": "Prudent. C'est un piège à glace mortel.",
      "humanDescription": "Attention au souffle de glace mortel.",
      "hylotlDescription": "La glace, l'eau sous sa forme la plus meurtrière.",
      "novakidDescription": "Ce piège de givre pourrait geler les moustaches d'un raton."
    }
  },
  "arenaflametrap": {
    "name": "Piège à Flammes d'Arène",
    "desc": "Ce piège crache une flamme qui renforce les ennemis.",
    "metadata": {
      "floranDescription": "Cesss flamness rendent les ennemiss plus fortsss!",
      "glitchDescription": "Terrifié. Ces flammes vont augmenter la puissance d'attaque des ennemis.",
      "novakidDescription": "Mieux vaut rester loin de ces flammes, elles boostent les ennemis."
    }
  },
  "applebasket": {
    "name": "Panier de Pommes",
    "desc": "Un panier rempli de pommes.",
    "metadata": {
      "apexDescription": "De délicieuses pommes rouges pleines de nutriments.",
      "avianDescription": "De belles pommes rouges mûries par la bénédiction du soleil.",
      "floranDescription": "Trop de fruitsss, pas assez de viandesss.",
      "glitchDescription": "Approbateur. Ces pommes semblent symétriques et sans tache.",
      "humanDescription": "En y regardant de plus près, elles sont en cire. Encore raté.",
      "hylotlDescription": "Un panier de pommes de terre ferme. Pas aussi salées que les pommes de mer, mais agréables quand même.",
      "novakidDescription": "Rien de mieux qu'une pomme bien luisante."
    }
  },
  "arkdestinationteleporter": {
    "name": "Téléporteur de l'Arche Brisé",
    "desc": "Ce téléporteur ancien ne fonctionne plus.",
    "metadata": {
      "apexDescription": "Ce téléporteur ancien ne semble plus fonctionner.",
      "avianDescription": "Ce vieux téléporteur poussiéreux ne semble pas marcher.",
      "floranDescription": "Le téléporteur essst ssilencieux.",
      "glitchDescription": "Intrigué. Ce téléporteur brisé semble antique... Quel âge peut-il bien avoir?",
      "humanDescription": "Ce téléporteur m'emmènerait vers des terres inconnues, s'il fonctionnait.",
      "hylotlDescription": "Ce téléporteur semble être cassé depuis un bon moment.",
      "novakidDescription": "Ce vieux téléporteur n'a pas l'air d'être en état de marche."
    }
  },
  "arkteleporter": {
    "name": "Téléporteur de l'Arche",
    "desc": "Ce téléporteur devrait vous ramener à l'Arche.",
    "metadata": {
      "apexDescription": "On dirait que ceci est lié à l'Arche.",
      "avianDescription": "Ce téléporteur semble offrir une route rapide vers l'Arche.",
      "floranDescription": "Ceci pourrait emmener Floran direct aux ruinesss.",
      "glitchDescription": "Analytique. Je pense que ce téléporteur est connecté aux ruines de l'Arche.",
      "humanDescription": "À en juger par l'aspect de ce téléporteur, je parierais qu'il mène droit à l'Arche.",
      "hylotlDescription": "Je pense que ce téléporteur pourrait mener aux ruines de l'Arche.",
      "novakidDescription": "Un moyen pratique de retourner à l'Arche pour la prochaine aventure!"
    }
  },
  "astrocabinet": {
    "name": "Armoire Astro",
    "desc": "Une armoire métallique moderne avec des supports de fixation au sol.",
    "metadata": {
      "apexDescription": "Il doit y avoir une raison pour laquelle ces casiers ont cette forme.",
      "avianDescription": "Cette armoire est un peu trop sophistiquée à mon goût, mais je l'aime bien.",
      "floranDescription": "Les armoiress peuvent contenir toutes ssortess de chosess.",
      "glitchDescription": "Impressionné. Cette petite armoire a une capacité de stockage généreuse.",
      "humanDescription": "Ce casier me rappelle quelque chose. Je n'arrive pas à mettre le doigt dessus.",
      "hylotlDescription": "Je suis fan du design de cette armoire.",
      "novakidDescription": "Un casier, parfait pour planquer tout c'dont on a besoin."
    }
  },
  "astroceilingmonitor": {
    "name": "Moniteur de Plafond Astro",
    "desc": "Des supports sont intégrés à la base pour fixer ce moniteur au plafond.",
    "metadata": {
      "apexDescription": "Il y a quelque chose de familier dans cette configuration d'affichage.",
      "avianDescription": "Ces fixations maintiennent cet écran fermement en place.",
      "floranDescription": "Télévission de plafond qui clignote.",
      "glitchDescription": "Satisfait. Cette disposition d'affichage est une utilisation efficace de l'espace.",
      "humanDescription": "Franchement, c'est super bien placé pour s'adosser et regarder.",
      "hylotlDescription": "Cet écran permet d'utiliser l'espace habituellement inutilisé.",
      "novakidDescription": "Cet écran est juste pendu là."
    }
  },
  "astrochair": {
    "name": "Chaise Astro",
    "desc": "Une chaise au design moderne, couramment trouvée dans les vaisseaux spatiaux.",
    "metadata": {
      "apexDescription": "S'asseoir là-dedans m'aiderait peut-être à garder le dos droit.",
      "avianDescription": "Cette chaise a un design très familier, bien qu'aucun Avian ne construirait avec de tels matériaux.",
      "floranDescription": "Le ssiège en métal dur a l'air inconfortable.",
      "glitchDescription": "Intéressé. Ce siège est conçu pour supporter les forces de lancement pour les voyageurs spatiaux.",
      "humanDescription": "C'est le genre de chaise qu'on trouve dans un vaisseau spatial.",
      "hylotlDescription": "Cette chaise robuste est bâtie pour résister aux forces de décollage.",
      "novakidDescription": "Cette chaise est drôlement solide, je n'arrive même pas à la renverser d'un coup de pied."
    }
  },
  "astroconsole": {
    "name": "Console Astro",
    "desc": "Un grand écran conçu pour surveiller divers appareils.",
    "metadata": {
      "apexDescription": "J'aime ce grand écran, il a l'air important.",
      "avianDescription": "Cette console a l'air un peu massive à mon avis.",
      "floranDescription": "Un écran ssi brillant.",
      "glitchDescription": "Impressionné. Cet affichage d'informations est en bon état.",
      "humanDescription": "N'importe quoi pourrait être branché sur une console aussi grande.",
      "hylotlDescription": "La taille de l'écran de cette console rend la lecture des informations très facile.",
      "novakidDescription": "C'est une console rudement costaude."
    }
  },
  "astrocrate": {
    "name": "Caisse Astro",
    "desc": "Un grand conteneur spécialisé pour le transport spatial.",
    "metadata": {
      "apexDescription": "Une caisse d'expédition spatiale standard.",
      "avianDescription": "Ce conteneur est grand, ce qui signifie beaucoup de place pour ranger des choses.",
      "floranDescription": "Grande boîte en métal à rayuress.",
      "glitchDescription": "Intéressé. Les métaux utilisés pour cette caisse la rendent solide, mais assez légère.",
      "humanDescription": "Une caisse d'expédition surdimensionnée, on peut mettre beaucoup de choses dedans.",
      "hylotlDescription": "Un grand conteneur d'expédition, fait pour le transport de marchandises.",
      "novakidDescription": "J'pense qu'on pourrait ranger presque n'importe quoi dans cette grande caisse."
    }
  },
  "astrodoor": {
    "name": "Porte Astro",
    "desc": "Cette porte forme un joint hermétique lorsqu'elle est fermée.",
    "metadata": {
      "apexDescription": "Des portes comme celles-ci sont conçues pour sceller des sections de vaisseaux ou de stations.",
      "avianDescription": "Cette porte est conçue pour survivre à la rudesse de l'espace.",
      "floranDescription": "La porte de l'essspace peut glissser pour s'ouvrir et se fermer.",
      "glitchDescription": "Intéressé. Ce design de porte était autrefois populaire dans la construction de vaisseaux.",
      "humanDescription": "Cette porte moderne peut créer un joint hermétique pour maintenir l'atmosphère.",
      "hylotlDescription": "Ce type de porte moderne est élégant et réactif.",
      "novakidDescription": "Cette porte à l'air sophistiqué semble pouvoir résister à n'importe quoi."
    }
  },
  "astrolight": {
    "name": "Lampe Astro",
    "desc": "Une lanterne utilitaire fixée au plafond.",
    "metadata": {
      "apexDescription": "Cette lanterne n'est pas tape-à-l'œil, mais elle est fonctionnelle.",
      "avianDescription": "Cette lampe électrique projette une faible lumière jaune.",
      "floranDescription": "Le module d'essspace projette juste un peu de lumière.",
      "glitchDescription": "Curieux. Cette source de lumière est auto-suffisante d'une manière ou d'une autre.",
      "humanDescription": "Cette lampe fournit juste assez de lumière pour se déplacer.",
      "hylotlDescription": "Cette lampe semble hermétique, j'imagine qu'elle fonctionnerait bien sous l'eau.",
      "novakidDescription": "Cette lampe électrique brille plus fort qu'un feu de camp."
    }
  },
  "astromonitor": {
    "name": "Moniteur Astro",
    "desc": "Un moniteur d'affichage électronique compact.",
    "metadata": {
      "apexDescription": "Ce moniteur semble conçu pour afficher des données importantes.",
      "avianDescription": "Je ne suis pas sûr de comprendre ce que tous les boutons de ce moniteur contrôlent.",
      "floranDescription": "L'écran de l'essspace écrit des motsss étranges.",
      "glitchDescription": "Intéressé. Les informations sur cet écran pourraient être importantes.",
      "humanDescription": "Ce moniteur est d'un vieux design, mais il tient encore la route.",
      "hylotlDescription": "J'aime bien, un moniteur simple et fonctionnel.",
      "novakidDescription": "Cet écran peut sûrement afficher tout c'qu'on a besoin d'savoir."
    }
  },
  "astroserver": {
    "name": "Serveur Astro",
    "desc": "Une grande baie de serveurs informatiques, avec des supports pour montage au sol.",
    "metadata": {
      "apexDescription": "Cette baie de serveurs semble chargée d'équipements informatiques.",
      "avianDescription": "Une baie de serveurs au look élégant.",
      "floranDescription": "Armoire de ssserveur sophisstiquée pleine d'ordinateursss.",
      "glitchDescription": "Amusé. La plupart des technologies à l'intérieur de ce serveur pourraient désormais tenir dans un appareil portable.",
      "humanDescription": "Ce serveur a l'air d'être configuré pour quelque chose d'important.",
      "hylotlDescription": "Il semble que ce serveur soit refroidi par liquide, c'est intelligent.",
      "novakidDescription": "Gros ordi. À peu près la taille d'une cabane de jardin."
    }
  },"astrostoragelocker": {
    "name": "Casier de Rangement Astro",
