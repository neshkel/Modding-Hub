  "ancientswitchhidden": {
    "name": "Interrupteur Antique Caché",
    "desc": "Cette dalle semble différente des autres.",
    "metadata": {
      "apexDescription": "Cette dalle semble s'être détachée.",
      "avianDescription": "Cette dalle est mal ajustée.",
      "floranDescription": "Dalle qui bouge.",
      "glitchDescription": "Curieux. Une dalle légèrement mal placée.",
      "humanDescription": "Une dalle qui cliquette.",
      "hylotlDescription": "Une drôle de dalle.",
      "novakidDescription": "Y'a un truc qui cloche avec cette dalle."
    }
  },
  "ancienttorch": {
    "name": "Torche Antique",
    "desc": "Cette torche antique vacille doucement.",
    "metadata": {
      "apexDescription": "Une torche antique. Curieusement, elle est encore allumée.",
      "avianDescription": "Une torche antique. Qu'est-ce qui alimente cette vieille lumière depuis si longtemps?",
      "floranDescription": "Une torche brûlante trrès vieille. Dangereux.",
      "glitchDescription": "Observateur. Une vieille torche qui est restée allumée pendant une durée indéterminée, mais très longue.",
      "humanDescription": "Une torche antique. Je me demande depuis combien de temps elle brûle.",
      "hylotlDescription": "Une torche antique. Son âge est inconnu et sa source d'énergie est durable.",
      "novakidDescription": "Une vieille torche antique éclairant ses environs. Depuis combien de temps brûle-t-elle?"
    }
  },
  "ancientverticaldoor": {
    "name": "Trappe Antique",
    "desc": "Une porte de type trappe verticale antique.",
    "metadata": {
      "apexDescription": "Une porte verticale antique.",
      "avianDescription": "Une trappe antique.",
      "floranDescription": "On dirrait une porte dans le ssol.",
      "glitchDescription": "Observateur. Cette trappe est antique.",
      "humanDescription": "Une trappe pour quand se déplacer à l'horizontale ne suffit plus.",
      "hylotlDescription": "Une porte-trappe antique, une relique en soi.",
      "novakidDescription": "Une trappe dans le plancher. Elle a l'air drôlement vieille."
    }
  },
  "ancientmural1": {
    "name": "Fresque Antique",
    "desc": "Une immense fresque brisée.",
    "metadata": {
      "apexDescription": "Les glyphes brillants sur cette fresque émettent une lumière froide. Je me demande quel âge elle a?",
      "avianDescription": "J'ai l'étrange sentiment d'être la première personne à voir ceci depuis bien longtemps.",
      "floranDescription": "Floran n'a pas de temps pour les grands mots.",
      "glitchDescription": "Mécontent. Cette plaque fragmentée porte des inscriptions incroyablement anciennes.",
      "humanDescription": "Il y a quelque chose d'excitant dans les vieilles écritures lumineuses. Je me demande ce que ça dit?",
      "hylotlDescription": "Je me demande si cette plaque a été placée ici pour que je la trouve? Je frissonne à cette idée.",
      "novakidDescription": "Est-ce que j'ai déjà vu ça? Nan, je dois m'imaginer des trucs."
    }
  },
