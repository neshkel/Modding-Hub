  "protectoratestorage1": {
    "name": "Unité de Stockage de Capsules de Statut",
    "desc": "C'est un grand rack de capsules de statut.",
    "metadata": {
      "apexDescription": "Le Protectorat lance ces capsules dans le cosmos. Elles ont parfois tendance à mal fonctionner.",
      "avianDescription": "Ces capsules de statut peuvent parfois tomber en panne après des années d'inactivité.",
      "floranDescription": "Caps s sulesss brillantesss. Bonnesss ressssourcesss, mais sssouvent dangereusssesss.",
