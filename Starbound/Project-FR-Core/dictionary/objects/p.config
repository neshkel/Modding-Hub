      "apexDescription": "Une savoureuse gomme mauve.",
      "avianDescription": "Une grosse gomme mauve. Miam.",
      "floranDescription": "Floran mange gros bonbon!",
      "glitchDescription": "Ravi.",
      "humanDescription": "Bonbons! Ouaiiiis!",
      "hylotlDescription": "C'est tentant.",
      "novakidDescription": "Une gomme géante!"
    }
  },
  "poisonsign": {
    "name": "Panneau d'Avertissement en Bois",
    "desc": "Un panneau d'avertissement de mauvais augure.",
    "metadata": {
      "apexDescription": "Ce panneau m'avertit de dangers par ici. Je devrais être prudent.",
      "avianDescription": "Ce panneau est un avertissement. Peut-être y a-t-il un danger.",
      "floranDescription": "Floran ignore les dangers proches!",
      "glitchDescription": "Inquiet. Ce panneau avertit les autres. Je devrais faire attention.",
      "humanDescription": "Ce panneau prévient d'un danger. Je devrais peut-être me méfier.",
      "hylotlDescription": "Ce panneau rudimentaire prévient d'un danger imminent.",
      "novakidDescription": "Ce crâne et ces os sont un avertissement sûr qu'un truc dangereux rôde."
    }
  },
  "perfectlygenericitem": {
    "name": "Objet Parfaitement Générique",
    "desc": "C'est un objet parfaitement générique, peut-être un peu trop parfait.",
    "metadata": {
      "apexDescription": "Il y a quelque chose de dérangeant avec cet objet.",
      "avianDescription": "Jamais je n'avais vu un objet aussi parfaitement symétrique.",
      "floranDescription": "Cube parfait n'est pas naturel.",
      "glitchDescription": "Troublé. Un objet sans aucune imperfection physique.",
      "humanDescription": "Qu'est-ce qu'il y a de si spécial avec un cube parfaitement cubique?",
      "hylotlDescription": "Ce cube incarne la perfection géométrique.",
      "novakidDescription": "Y a pas grand-chose à dire. La perfection, c'est rasoir!"
    }
  },
  "pethouse": {
    "name": "Maison pour Animal",
    "desc": "Juste assez grande pour qu'un petit animal s'y installe confortablement.",
    "metadata": {
      "apexDescription": "Le foyer d'un animal de compagnie bien-aimé.",
      "avianDescription": "Une petite maison pour une créature. Mon lapin l'adorerait!",
      "floranDescription": "Serpent de Floran vit d'habitude dans les hautes herbes. Niche pas naturelle.",
      "glitchDescription": "Heureux. Ce chenil conviendrait à mon porcelet adoré.",
      "humanDescription": "Encore un cadeau que mon ingrat de félin va s'empresser d'ignorer.",
      "hylotlDescription": "Ce n'est pas conventionnel pour un Crasberry, mais ça fera l'affaire.",
      "novakidDescription": "Une niche! Un peu à l'étroit, mais qui s'en plaindra?"
    }
  },
