  "protectoratebeamaxe": {
    "name": "Manipulateur de Matière",
    "desc": "Ce Manipulateur de Matière m'était destiné... Et j'en aurai peut-être besoin pour sortir d'ici vivant.",
    "metadata": {
      "apexDescription": "Je dois prendre ce Manipulateur de Matière et trouver un moyen de m'échapper.",
      "avianDescription": "Je dois prendre ce Manipulateur de Matière et m'enfuir!",
      "floranDescription": "Floran ferait mieux de prendre le Manipulateur de Matière et de sss'enfuir en sssécurité!",
      "glitchDescription": "Stressé. Je devrais prendre ce Manipulateur de Matière et partir d'ici.",
      "humanDescription": "Je devrais prendre ce Manipulateur de Matière... J'en aurai peut-être besoin pour sortir d'ici vivant.",
      "hylotlDescription": "Ce Manipulateur de Matière sera peut-être ma seule aide pour sortir d'ici vivant.",
      "novakidDescription": "Pas l'temps de gamberger. J'dois prendre le Manipulateur de Matière et mettre les voiles.",
      "pickedUpParameters.apexDescription": "Je devrais y aller.",
      "pickedUpParameters.avianDescription": "Je dois partir.",
      "pickedUpParameters.floranDescription": "Floran doit sss'en aller.",
      "pickedUpParameters.glitchDescription": "Anxieux. Je dois partir.",
      "pickedUpParameters.humanDescription": "Je ferais mieux de bouger.",
      "pickedUpParameters.hylotlDescription": "Je ne devrais pas m'attarder ici.",
      "pickedUpParameters.novakidDescription": "J'ferais mieux d'me mettre en route."
    }
  },
