  "prismrockhumanoid": {
    "name": "Cristal Prisme",
    "desc": "Un prisme hautement réfractif. Il semble y avoir quelque chose à l'intérieur.",
    "metadata": {
      "apexDescription": "Il semble y avoir une silhouette humanoïde à l'intérieur de ce cristal.",
      "avianDescription": "Quelqu'un, ou quelque chose, est piégé dans ce prisme.",
      "floranDescription": "Qu'est-ce qu'il y a dedansss? C'est vivant?",
      "glitchDescription": "Horrifié. Il semble y avoir une personne à l'intérieur de ce prisme.",
      "humanDescription": "Il y a quelqu'un à l'intérieur. C'est une prison de cristal!",
      "hylotlDescription": "Une forme sombre et inquiétante réside dans ce cristal.",
      "novakidDescription": "Si je n'm'abuse, y a un gars là-dedans!"
    }
  },
  "prismrockpenguin": {
    "name": "Cristal Prisme",
    "desc": "Un prisme hautement réfractif. Il semble y avoir quelque chose à l'intérieur.",
    "metadata": {
      "apexDescription": "C'est un pingouin?",
      "avianDescription": "Il y a un pingouin enfermé dans ce cristal.",
      "floranDescription": "La roche a quelque chose dedansss! Floran veut casser la roche!",
      "glitchDescription": "Perplexe. Comment un pingouin peut-il bien se trouver dans ce prisme?",
      "humanDescription": "Un pingouin pétrifié.",
      "hylotlDescription": "Un pingouin dans un prisme. Par où commencer pour élucider ce mystère?",
      "novakidDescription": "Salut, p'tit gars."
    }
  },
  "prismrockrunes": {
    "name": "Cristal Prisme",
    "desc": "Un prisme hautement réfractif avec des runes gravées dessus.",
    "metadata": {
      "apexDescription": "Ce prisme semble porter des runes gravées.",
      "avianDescription": "Il y a des runes sur ce prisme.",
      "floranDescription": "Quelqu'un a gribouillé des runesss sur cette roche.",
      "glitchDescription": "Curieux. Ce prisme a des runes gravées à sa surface.",
      "humanDescription": "Je me demande pourquoi il y a des runes sur ce cristal.",
      "hylotlDescription": "Ce prisme porte de mystérieuses runes anciennes gravées.",
      "novakidDescription": "C'est quoi l'idée avec ces runes?"
    }
  },
  "prismtable": {
    "name": "Table Prisme",
    "desc": "Une table lisse taillée dans un verre réfractif.",
    "metadata": {
      "apexDescription": "J'aurais peur de renverser quelque chose sur cette table si propre.",
      "avianDescription": "Une pièce d'un grand savoir-faire, assurément.",
      "floranDescription": "Floran peut pas sse cacher derrière la table, elle déconcentre trop!",
      "glitchDescription": "Excité. Je pourrais poser de jolis ornements là-dessus!",
      "humanDescription": "C'est une table très classe pour dîner.",
      "hylotlDescription": "Cette table scintille avec tout un spectre de couleurs à l'intérieur.",
      "novakidDescription": "Je pourrais prendre mon p'tit déj' là-dessus, j'vous l'dis."
    }
  },
  "platinumsample": {
    "name": "Échantillon de Platine",
    "desc": "\"Un échantillon parfait de minerai de platine.\""
  },
  "plutoniumsample": {
    "name": "Échantillon de Plutonium",
    "desc": "\"Un échantillon parfait de minerai de plutonium.\""
  },
  "prisilitesample": {
    "name": "Échantillon de Prisilite",
    "desc": "\"Un échantillon parfait de minerai de prisilite.\""
  },
  "propeller": {
    "name": "Hélice",
    "desc": "Une hélice magnifiquement conçue.",
    "metadata": {
      "apexDescription": "Une hélice énorme.",
      "avianDescription": "Ce ne sont peut-être pas des ailes, mais des hélices comme celles-ci maintiennent les vaisseaux Avian en l'air.",
      "floranDescription": "Machine qui tourne ssert à faire voler les navires.",
      "glitchDescription": "Observateur. Ces hélices doivent tourner très vite pour maintenir un navire entier dans les airs.",
      "humanDescription": "L'hélice est très bruyante.",
      "hylotlDescription": "Bruyant et désagréable, mais remplit bien sa fonction.",
      "novakidDescription": "C'est une sacrée hélice. J'imagine que c'est pour faire avancer les dirigeables."
    }
  },
  "paintingapegothic": {
    "name": "Peinture Gothique Apex",
    "desc": "Un portrait d'un couple Apex.",
    "metadata": {
      "apexDescription": "Ce couple Apex semble... vide.",
      "avianDescription": "Ce sont les visages de gens qui vivent sans Kluex dans leur vie.",
      "floranDescription": "Comment le singe peut être sstérile alors qu'il a une grosse fourchette?",
      "glitchDescription": "Impressionné. Ce couple Apex porte des vêtements futuristes.",
      "humanDescription": "Je ne me rappelle pas que ce tableau classique mettait en scène des Apex.",
      "hylotlDescription": "Des émotions troublantes sont dépeintes ici.",
      "novakidDescription": "Un couple de fermiers Apex habillés comme des humains. Étrange."
    }
  },
  "paintingapescream": {
    "name": "Peinture de Singe Hurleur",
    "desc": "Une peinture hantante d'un Apex en train de hurler.",
    "metadata": {
      "apexDescription": "Est-ce encore un faux du Miniknog?",
      "avianDescription": "C'est ce qu'on ressent quand on ne connaît pas Kluex.",
      "floranDescription": "Floran voit cette figure chez tous sseux qu'on chasse!",
      "glitchDescription": "Nerveux. Cette peinture d'Apex est dérangeante.",
      "humanDescription": "Eh bien, ce n'est définitivement pas l'original.",
      "hylotlDescription": "Cette peinture d'Apex devrait être plus calme.",
      "novakidDescription": "C't'Apex est en train de piquer une crise."
    }
  },
  "paintingapespeare": {
    "name": "Portrait de Poète Apex",
    "desc": "Une peinture d'un grand poète Apex. Il... semble familier.",
    "metadata": {
      "apexDescription": "La poésie Apex a été brûlée et proscrite il y a bien des années.",
      "avianDescription": "Un Apex avec un cou à plumes?",
      "floranDescription": "Vieux singe, cossstume ridicule.",
      "glitchDescription": "Amusé. L'Apex semble vêtu selon la mode actuelle des Glitchs.",
      "humanDescription": "Cette image me rappelle quelque chose...",
      "hylotlDescription": "Un Apex des Arts, sans aucun doute.",
      "novakidDescription": "Un Apex tout pomponné avec une collerette."
    }
  },
  "paintingapexpearlearring": {
    "name": "Peinture Apex Subtile",
    "desc": "Le portrait d'un Apex portant une boucle d'oreille.",
    "metadata": {
      "apexDescription": "Un chef-d'œuvre, mais cet Apex semble porter des vêtements humains.",
      "avianDescription": "Cet Apex semble regarder par-dessus son épaule.",
      "floranDescription": "Singe regarde par-dessus l'épaule, ssourpris!",
      "glitchDescription": "Observateur. Le style de cette peinture ne semble pas correspondre à son âge.",
      "humanDescription": "Cette peinture me semble familière, mais elle me dérange d'une certaine manière.",
      "hylotlDescription": "Belle technique, mais je ne sais pas quoi penser du sujet.",
      "novakidDescription": "Jolie peinture, mais c'est une drôle de dame."
    }
  },
  "paintingapexpixellisa": {
    "name": "Peinture Apex Classique",
    "desc": "Un portrait très célèbre d'une dame mystérieuse.",
    "metadata": {
      "apexDescription": "Un portrait classique. Si beau.",
      "avianDescription": "Wow, elle a vraiment quelque chose, c'est sûr.",
      "floranDescription": "Floran veut vooler le tableau pour le revendre au marché noir.",
      "glitchDescription": "Observateur. Cette contrefaçon est magistrale.",
      "humanDescription": "Elle a l'air familière, et pourtant... non.",
      "hylotlDescription": "Pourquoi quelqu'un voudrait immortaliser la façade hideuse de cette créature?",
      "novakidDescription": "En v'là une drôle de dame."
    }
  },
  "paintingapexwithermine": {
    "name": "Peinture d'Animal Domestique",
    "desc": "Une peinture paisible d'un Apex avec un animal de compagnie.",
    "metadata": {
      "apexDescription": "Les Apex adorent vraiment leurs belettes. Elles ont tellement plus de caractère que les chats!",
      "avianDescription": "Est-ce que ce personnage vénère cet animal? Ou est-ce juste le sien?",
      "floranDescription": "Un goûter poilu! Floran veut l'arracher du tableau!",
      "glitchDescription": "Impressionné. Cet animal a dû rester immobile un long moment pour cette peinture.",
      "humanDescription": "C'est une hermine ou une belette?",
      "hylotlDescription": "Ce personnage ne fait qu'un avec la nature, ou du moins, avec cet animal.",
      "novakidDescription": "C'est un drôle d'animal à tenir pour un portrait."
    }
  },
  "paintingbirthofapevenus": {
    "name": "Belle Peinture Apex",
    "desc": "Une peinture d'une femme blonde debout dans un bénitier.",
    "metadata": {
      "apexDescription": "D'une certaine manière, je sens que ce n'est pas la version originale de ce tableau.",
      "avianDescription": "Pourquoi cet Apex est-il sur une coquille de palourde? Qu'est-ce que c'est?",
      "floranDescription": "Floran essst troublé par cette peinture...",
      "glitchDescription": "Horrifié. Je n'avais pas besoin de voir ça.",
      "humanDescription": "Eh bien, c'est terrifiant.",
      "hylotlDescription": "C'était presque beau, mais c'est un échec lamentable.",
      "novakidDescription": "Holà, j'aurais pu me passer de voir ça."
    }
  },
  "paintingbirthofvenus": {
    "name": "Belle Peinture",
    "desc": "Une peinture d'une femme blonde debout dans un bénitier.",
    "metadata": {
      "apexDescription": "Le Miniknog ne pourrait pas produire un art original comme celui-ci.",
      "avianDescription": "Je suis confus - Pourquoi cette femme se tient-elle sur une coquille?",
      "floranDescription": "L'humain a l'air effrayé. Sssans doute chassé par un Floran!",
      "glitchDescription": "Curieux. Est-ce que cette coquille flotte sur la mer?",
      "humanDescription": "Elle a l'air d'avoir un peu froid, non?",
      "hylotlDescription": "Ma partie préférée de ce tableau, c'est l'océan.",
      "novakidDescription": "Une peinture d'une grande dame arrivant sur un coquillage."
    }
  },
  "paintingcreationofapepixel": {
    "name": "Grande Peinture de Big Ape",
    "desc": "Une grande peinture de deux silhouettes Apex se pointant du doigt.",
    "metadata": {
      "apexDescription": "Big Ape, le sauveur des Apex? Ne me faites pas rire.",
      "avianDescription": "Ce serait mieux s'il y avait Kluex à la place.",
      "floranDescription": "Apex à chasser! L'un d'eux a un cerveau flottant pour ss'asseoir!",
      "glitchDescription": "Confus. Cela semble étrangement spirituel pour une peinture Apex.",
      "humanDescription": "Quelque chose cloche ici - je n'arrive pas à mettre le doigt dessus.",
      "hylotlDescription": "Les Apex ont leurs propres histoires sur l'origine du savoir.",
      "novakidDescription": "Un couple d'Apex en train de faire quelque chose. Je pige pas."
    }
  },
  "paintingcreationofpixel": {
    "name": "Grande Peinture",
    "desc": "Une grande peinture de deux silhouettes se pointant du doigt.",
    "metadata": {
      "apexDescription": "Un tel art serait interdit par le Miniknog.",
      "avianDescription": "Ce serait mieux s'il y avait Kluex à l'intérieur.",
      "floranDescription": "Regardez! Deux humainsss à chasser! Une prise rare!",
      "glitchDescription": "Curieux. Est-ce la quête du savoir sous forme peinte?",
      "humanDescription": "C'est une trouvaille rare. Il semble que ce soit un morceau d'une œuvre plus vaste.",
      "hylotlDescription": "Cette peinture dépeint-elle la connaissance? Les Hylotls l'admireraient sans doute.",
      "novakidDescription": "C'est une peinture de quelques humains qui flottent et pointent du doigt. Je saisis pas l'idée."
    }
  },
  "paintinggothic": {
    "name": "Peinture Gothique",
    "desc": "Le portrait d'un couple humain.",
    "metadata": {
      "apexDescription": "Ils semblent être... humains?",
      "avianDescription": "Une peinture curieuse.",
      "floranDescription": "Des humains sssi solennels.",
      "glitchDescription": "Déductif. Cela doit représenter l'humanité avant qu'elle ne soit connue du reste de l'univers.",
      "humanDescription": "Une très vieille peinture humaine.",
      "hylotlDescription": "Un chef-d'œuvre d'émotions capturées.",
      "novakidDescription": "J'aime bien ce tableau. Juste un couple de simples fermiers."
    }
  },
  "paintingmonalisa": {
    "name": "Peinture Classique",
    "desc": "Un portrait très célèbre d'une dame mystérieuse.",
    "metadata": {
      "apexDescription": "C'est peut-être ce à quoi le Miniknog aspire.",
      "avianDescription": "Une femme humaine.",
      "floranDescription": "L'humain a un joli ssourire, le sourire des Florans fait peur aux humains.",
      "glitchDescription": "Surpris. La peinture est d'une ancienneté sans mesure, mais semble bien conservée.",
      "humanDescription": "J'ai lu des trucs là-dessus... La Joconde, c'est ça? Elle n'a pas l'air malheureuse.",
      "hylotlDescription": "Un sourire magnifiquement capturé.",
      "novakidDescription": "Peu importe où je vais, la dame sur ce tableau me suit du regard."
    }
  },
  "paintingpearlearring": {
    "name": "Peinture Subtile",
    "desc": "Le portrait d'une femme avec une boucle d'oreille.",
    "metadata": {
      "apexDescription": "Beaucoup d'émotions subtiles sont capturées dans cette œuvre.",
      "avianDescription": "Cette femme se retourne pour regarder quelque chose, peut-être.",
      "floranDescription": "Humain sssurpris sur le point de subir une embuscade!",
      "glitchDescription": "Curieux. Vers quoi cet humain se tourne-t-il?",
      "humanDescription": "Une vieille peinture de mon espèce. Je suis content qu'elle existe encore.",
      "hylotlDescription": "Un chef-d'œuvre d'émotions capturées.",
      "novakidDescription": "Le portrait d'une jolie dame avec une écharpe chic."
    }
  },
  "paintingscream": {
    "name": "Peinture Criante",
    "desc": "Une peinture hantante d'un personnage qui hurle.",
    "metadata": {
      "apexDescription": "Le cri silencieux... Mon peuple peut s'y identifier.",
      "avianDescription": "C'est ce qu'on ressent quand on ne connaît pas Kluex.",
      "floranDescription": "Floran voit cette figure chez tous sseux qu'on chasse!",
      "glitchDescription": "Anxieux. Ce personnage est d'une terreur dérangeante.",
      "humanDescription": "Je me demande ce que ce personnage regarde en hurlant?",
      "hylotlDescription": "Cette peinture serait bien meilleure si elle était plus calme.",
      "novakidDescription": "Waouh, ce gars a l'air de perdre les pédales. Il a besoin de décompresser."
    }
  },
  "paintingshakespeare": {
    "name": "Portrait de Poète Célèbre",
    "desc": "Une peinture d'un célèbre poète terrien mort depuis longtemps.",
    "metadata": {
      "apexDescription": "Remarquablement similaire au grand poète Apex.",
      "avianDescription": "Un humain solennel. Il porte un plumage.",
      "floranDescription": "Floran n'enregistre pas l'individu, Floran essst un.",
      "glitchDescription": "Observateur. Les vêtements de cet humain seraient acceptés par les Glitchs.",
      "humanDescription": "Je me demande depuis combien de temps ce gars est mort...",
      "hylotlDescription": "De quels grands actes cet homme est-il responsable?",
      "novakidDescription": "Une peinture d'un gars chauve avec des collerettes au cou."
    }
  },
  "paintingstarrynight": {
    "name": "Peinture Abstraite",
    "desc": "Une magnifique peinture du ciel nocturne.",
    "metadata": {
      "apexDescription": "Les Apex sont-ils encore capables d'une telle beauté?",
      "avianDescription": "Est-ce l'éther? Le ciel éternel.",
      "floranDescription": "Floran languit de revoir le ciel de la jungle ssous les étoiles.",
      "glitchDescription": "Émerveillement. Une telle expression échappe aux Glitchs, nous sommes des créatures de raison.",
      "humanDescription": "Quelle œuvre magnifique. Les coups de pinceau donnent vie aux couleurs.",
      "hylotlDescription": "Quel talent artistique. Le créateur d'une telle œuvre serait vénéré par les Hylotls.",
      "novakidDescription": "Waouh, ces tourbillons de peinture me donnent le tournis."
    }
  },
  "persistenceofpixels": {
    "name": "Persistance des Pixels",
    "desc": "Un brin de surréalisme Glitch.",
    "metadata": {
      "apexDescription": "Une peinture étrange. On dirait qu'elle dépeint la mort du temps lui-même.",
      "avianDescription": "Elle semble représenter une sélection de lecteurs de temps Glitch en train de fondre.",
      "floranDescription": "Floran ne comprend pas sstrange peinture.",
      "glitchDescription": "Déductif. Je crois que les Glitchs sont conscients de leur situation de manière inconsciente. C'est peut-être ainsi que cette peinture est née.",
      "humanDescription": "Des horloges qui fondent. Pourquoi les Glitchs peindraient-ils ça?",
      "hylotlDescription": "Une œuvre d'art surréaliste. Si seulement on pouvait interroger l'artiste.",
      "novakidDescription": "Il a dû faire une sacrée chaleur pour faire fondre ces horloges."
    }
  },
  "plasmadisc": {
    "name": "Disque à Plasma",
    "desc": "Un champ de plasma chargé électriquement. Il réagit au son.",
    "metadata": {
      "apexDescription": "Encore de l'équipement Apex. Expérimentation ou torture, qui sait?",
      "avianDescription": "Est-ce de l'électricité? Les Avians utilisent la résonance des cristaux pour alimenter leur technologie.",
      "floranDescription": "Foudre en cage. Pas de menace pour Floranss.",
      "glitchDescription": "Anxieux. Cet appareil exploite plusieurs millions de volts.",
      "humanDescription": "Un de ces gadgets à plasma bizarres.",
      "hylotlDescription": "Un tel appareil a probablement un but sinistre.",
      "novakidDescription": "Je ne peux pas regarder ça trop longtemps."
    }
  },
  "powerbooster": {
    "name": "Boost de Puissance",
    "desc": "Le gaz libéré par ces conduits augmente votre puissance destructrice.",
    "metadata": {
      "apexDescription": "Cette machine semble booster la puissance du sujet exposé au gaz.",
      "avianDescription": "Le gaz a une odeur âcre, il me donne une énergie étrange.",
      "floranDescription": "Le gazss donne de la force à Floran!",
      "glitchDescription": "Suspicieux. Cet appareil semble avoir des propriétés augmentant la force.",
      "humanDescription": "Une bouffée de ce gaz suffit à me faire sentir puissant.",
      "hylotlDescription": "Un gaz malodorant qui renforce votre corps et votre esprit.",
      "novakidDescription": "Ce gaz semble augmenter ma force."
    }
  },
  "paraspriteaf": {
    "name": "Figurine de Parasprite",
    "desc": "L'étiquette indique: \"Une arme biologique sans cervelle créée par des scientifiques humains irresponsables.\""
  },
  "paratailaf": {
    "name": "Figurine de Paratail",
    "desc": "L'étiquette indique: \"Pendant les tempêtes, il s'accroche aux arbres pour ne pas s'envoler.\""
  },
  "peblitaf": {
    "name": "Figurine de Peblit",
    "desc": "L'étiquette indique: \"En raison de la taille de sa tête par rapport à son corps, il ne peut pas courir sur de longues distances.\""
  },
  "petricubaf": {
    "name": "Figurine de Petricub",
    "desc": "L'étiquette indique: \"Il vous fixe d'un air impatient avec ses petits yeux globuleux.\""
  },
  "pipkinaf": {
    "name": "Figurine de Pipkin",
    "desc": "L'étiquette indique: \"Bien qu'il semble amical, on le voit rarement interagir avec d'autres Pipkins.\""
  },
  "poptopaf": {
    "name": "Figurine de Poptop",
    "desc": "L'étiquette indique: \"Le Poptop fredonne magnifiquement pour troubler ses proies.\""
  },
  "pteropodaf": {
    "name": "Figurine de Ptéropode",
    "desc": "L'étiquette indique: \"Il prépare dans sa cosse une pâte toxique à base de fruits fermentés.\""
  },
  "pulpinaf": {
    "name": "Figurine de Pulpin",
    "desc": "L'étiquette indique: \"Il a une texture collante qui lui permet de grimper sur les surfaces avec facilité.\""
  },
  "pyromantleaf": {
    "name": "Figurine de Pyromantle",
    "desc": "L'étiquette indique: \"Son noyau brûlant produit un flux constant de lave. Il a un sacré punch.\""
  }
}