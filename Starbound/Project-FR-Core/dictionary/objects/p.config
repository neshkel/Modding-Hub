  "protectoratebrokenportrait5": {
    "name": "Portrait du Grand Protecteur",
    "desc": "Leda Portia, la Grande Protectrice.",
    "metadata": {
      "apexDescription": "Leda Portia. Je viens de la voir connaître une fin atroce.",
      "avianDescription": "Leda Portia, l'ancienne... Grande Protectrice. Je ne veux pas y penser.",
