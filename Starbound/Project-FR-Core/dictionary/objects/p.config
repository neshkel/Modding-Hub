  },
  "penguinposter1": {
    "name": "Affiche Réservée aux Pingouins",
    "desc": "Je ne me sens pas le bienvenu ici...",
    "metadata": {
      "apexDescription": "Je ne me sens pas le bienvenu ici...",
      "avianDescription": "Certains oiseaux se croient supérieurs aux autres! Je n'aime pas cette attitude.",
      "floranDescription": "Petits oiseaux dandinants ne peuvent pas sstop Floran!",
      "glitchDescription": "Nerveux. Je ne me sens pas le bienvenu ici.",
      "humanDescription": "Je ne me sens pas le bienvenu ici...",
      "hylotlDescription": "Je ne me sens pas le bienvenu ici...",
      "novakidDescription": "Essaie d'm'arrêter, p'tit gars."
    }
  },
  "proximitywallsensor": {
    "name": "Détecteur de Proximité Mural",
    "desc": "Faites attention où vous mettez les pieds!",
    "metadata": {
      "apexDescription": "Ceci se déclenchera si je m'approche trop.",
      "avianDescription": "Ne t'approche pas trop!",
      "floranDescription": "Le détecteur regarde Floran!",
      "glitchDescription": "Neutre. Un capteur de proximité.",
      "humanDescription": "Un capteur de proximité.",
      "hylotlDescription": "Un capteur.",
      "novakidDescription": "Faut avancer prudemment."
    }
  },
  "plainorbplush": {
    "name": "Peluche de Virorb",
    "desc": "Une adorable peluche de Virorb classique.",
    "metadata": {
      "apexDescription": "Est-ce qu'elle va drainer ma santé si je me la colle sur la tête?",
      "avianDescription": "Aussi dangereux soient-ils dans la nature, ils sont plutôt mignons en peluche.",
      "floranDescription": "Créaturess agaçantes.",
      "glitchDescription": "Détresse. Cette peluche va-t-elle drainer ma santé si je la mets sur ma tête?",
      "humanDescription": "Je n'avais jamais remarqué à quel point les Virorbs sont mignons!",
      "hylotlDescription": "Pour des créatures dangereuses, elles sont assez mignonnes.",
      "novakidDescription": "C'machin est plutôt mignon, j'imagine."
    }
  },
  "poptopplush": {
    "name": "Peluche de Poptop",
    "desc": "Une peluche de Poptop toute douce.",
    "metadata": {
      "apexDescription": "Les Poptops me flanquent la trouille, mais celui-là est presque mignon.",
      "avianDescription": "Pourquoi faire des peluches d'une créature aussi terrifiante?",
      "floranDescription": "Awww, Floran préfère la peluche de Poptop.",
      "glitchDescription": "Contrasté. Les Poptops sont des créatures mortelles, mais ils sont assez mignons.",
      "humanDescription": "Aww, ça ferait presque oublier à quel point les vrais Poptops font peur.",
      "hylotlDescription": "C'est une peluche tout à fait adorable d'une créature plutôt effrayante.",
      "novakidDescription": "Trop mignon pour être un vrai Poptop."
    }
  },
  "porthole": {
    "name": "Hublot",
    "desc": "C'est une fenêtre ronde.",
    "metadata": {
      "apexDescription": "Un hublot.",
      "avianDescription": "C'est un hublot.",
      "floranDescription": "Fenêtre ronde.",
      "glitchDescription": "Indifférent. Un hublot.",
      "humanDescription": "C'est un hublot.",
      "hylotlDescription": "Un hublot circulaire.",
      "novakidDescription": "Une fenêtre ronde."
    }
  },
  "pressuredoor": {
    "name": "Porte Pressurisée",
    "desc": "Une porte qui résiste bien à la pression.",
    "metadata": {
      "apexDescription": "Une porte pressurisée robuste.",
      "avianDescription": "Une porte métallique très lourde.",
      "floranDescription": "Grosse porte lourde marche mieux sssous l'eau.",
      "glitchDescription": "Soulagé. Cette porte est très lourde, elle devrait être étanche.",
      "humanDescription": "C'est une grosse porte robuste qui gère bien la haute pression.",
      "hylotlDescription": "Une porte pressurisée de bonne facture.",
      "novakidDescription": "Une porte pressurisée bien massive."
    }
  },
  "pumpsign": {
    "name": "Panneau de Pompe",
    "desc": "Un panneau qui indique l'état d'une pompe.",
    "metadata": {
      "apexDescription": "Ce panneau indique si la pompe est allumée ou éteinte.",
      "avianDescription": "Un appareil électronique simpliste.",
      "floranDescription": "Le ssigne dit à Floran si la pompe marche.",
      "glitchDescription": "Satisfait. Ce panneau à basse consommation a deux états.",
      "humanDescription": "Un panneau très utile.",
      "hylotlDescription": "Un panneau à lueurs douces.",
      "novakidDescription": "Pratique pour vérifier si la pompe fonctionne."
    }
  },
  "prisonarch": {
    "name": "Arche Gothique",
    "desc": "Une arche gothique ornée.",
    "metadata": {
      "apexDescription": "Les humains ont au moins une architecture agréable à regarder.",
      "avianDescription": "Je n'arrive pas à décider si c'est joli ou menaçant.",
      "floranDescription": "Architecture piquante.",
      "glitchDescription": "Ravi. L'architecture humaine et Glitch semblent partager certaines similitudes.",
      "humanDescription": "Ça irait super bien avec mes talents de décorateur d'intérieur flippant.",
      "hylotlDescription": "C'est simple, mais il y a quelque chose à admirer dans la fabrication.",
      "novakidDescription": "Joli ou terrifiant?"
    }
  },
  "prisonbarrelfire": {
    "name": "Baril en Feu",
    "desc": "Du feu dans un baril tout rouillé.",
    "metadata": {
      "apexDescription": "Un baril de pétrole en feu. Je ne pense pas que ce soit le chauffage officiel de la prison.",
      "avianDescription": "S'approcher trop près me brûlerait les plumes.",
      "floranDescription": "Floran gardera ssess doigts loin du baril brûlant...",
      "glitchDescription": "Inconfortable. On dirait presque un Glitch qui brûle.",
      "humanDescription": "Ah, le vieux baril en feu improvisé. Un classique.",
      "hylotlDescription": "Malgré l'apparence brute, allumer un feu dans un fût métallique est assez ingénieux.",
      "novakidDescription": "Une source de chaleur rudimentaire."
    }
  },
  "prisonbars": {
    "name": "Barreaux de Prison",
    "desc": "D'épais barreaux métalliques entourent chaque cellule. Les chances d'évasion semblent minces.",
    "metadata": {
      "apexDescription": "De solides barreaux en métal. D'une certaine manière, ils sont assez jolis.",
      "avianDescription": "Ces barreaux ont l'air plutôt costauds.",
      "floranDescription": "Barreaux ssolides.",
      "glitchDescription": "Impressionné. Un ensemble de barreaux remarquablement solides.",
      "humanDescription": "Des barreaux. Peu importe de quel côté on se trouve, ne sommes-nous pas toujours derrière eux?",
      "hylotlDescription": "Même dans une cage, l'esprit peut voyager librement.",
      "novakidDescription": "Faudrait de sacrés outils pour s'tirer d'ici."
    }
  },
  "prisonbed": {
    "name": "Lit en Métal Enchaîné",
    "desc": "Une dalle de métal froide et dure destinée à servir de lit.",
    "metadata": {
      "apexDescription": "Un lit en métal qui a l'air bien inconfortable.",
      "avianDescription": "Ce lit bénéficierait d'une couche de foin.",
      "floranDescription": "C'essst un lit?! Floran s'en ssent mal.",
      "glitchDescription": "Satisfait. Ce lit serait parfaitement confortable pour moi.",
      "humanDescription": "Parfois, la meilleure façon de punir quelqu'un est de le faire dormir là-dessus.",
      "hylotlDescription": "Un lit remarquablement inconfortable. Je ne voudrais pas finir ici.",
      "novakidDescription": "Certains diraient qu'un pieu pareil est la pire des punitions."
    }
  },
  "prisonbench": {
    "name": "Banc en Métal",
    "desc": "Un banc simple, à ceci près que les pieds sont cloués au sol.",
    "metadata": {
      "apexDescription": "Un banc. Il est beaucoup plus confortable qu'on ne le pense.",
      "avianDescription": "Un banc en métal assez confortable.",
      "floranDescription": "Floran ne s'opposerait pas à s'as s s eoir ici une minute.",
      "glitchDescription": "Observateur. Un banc relativement confortable.",
      "humanDescription": "Un banc. Il est cloué au sol. Décevant, j'en aurais bien eu besoin d'un.",
      "hylotlDescription": "Un banc sécurisé. Personne ne risque de le voler de sitôt.",
      "novakidDescription": "Un siège pour ceux qui ont perdu leur chemin."
    }
  },
  "prisoncabinet1": {
    "name": "Armoire à Fournitures Cassée",
    "desc": "On dirait qu'elle était remplie de fournitures médicales - ce n'est plus le cas.",
    "metadata": {
      "apexDescription": "Une armoire à fournitures défoncée. Quelqu'un l'a pillée.",
      "avianDescription": "Cette armoire contenait des médicaments, d'après ce qu'on voit.",
      "floranDescription": "Armoire cassée et vide.",
      "glitchDescription": "Observateur. La moindre trace d'iode peut être détectée.",
      "humanDescription": "Y a-t-il quelque chose de plus déprimant qu'une armoire à pharmacie saccagée? En fait, ouais, se faire déchiqueter par des monstres à tentacules.",
      "hylotlDescription": "Cette armoire aurait dû être sécurisée plus soigneusement.",
      "novakidDescription": "Voler des médocs, c'est vraiment bas."
    }
  },
  "prisoncamerastation": {
    "name": "Station de Caméras de Sécurité",
    "desc": "Un ensemble de moniteurs affichant les flux des caméras de sécurité. Attention aux activités paranormales.",
    "metadata": {
      "apexDescription": "Je suis sûr d'avoir vu quelqu'un disparaître au coin d'une rue sur l'un des écrans.",
      "avianDescription": "J'ai l'impression d'être un voyeur.",
      "floranDescription": "Tellement d'écrans. Ils ssont tous aussi peu intéressants.",
      "glitchDescription": "Inspecteur. Je suis certain que l'une de ces caméras tourne en boucle.",
      "humanDescription": "L'un de ces écrans affiche un flux de moi en train de regarder les écrans.",
      "hylotlDescription": "Quelle installation intrusive.",
      "novakidDescription": "Une station d'espionnage."
    }
  },
  "prisoncontrolpanel": {
    "name": "Panneau de Contrôle de Sécurité",
    "desc": "Un panneau de contrôle qui semble actionner les lumières, les portes et les alarmes.",
    "metadata": {
      "apexDescription": "C'est étrange d'être du côté de ceux qui manipulent le panneau de contrôle.",
      "avianDescription": "Cela semble être le moyen de gérer toutes sortes de fonctions de sécurité.",
      "floranDescription": "Que fait cette machine? Floran est tenté de le découvrir par la manière forte.",
      "glitchDescription": "Compréhensif. Cette machine contrôle une variété de fonctions de sécurité.",
      "humanDescription": "Je suis tenté de rassembler un tas de prisonniers puis de les libérer, juste pour pouvoir hurler « ÉVASION! »",
      "hylotlDescription": "Une approche détachée de la gestion de la sécurité.",
      "novakidDescription": "Un panneau de contrôle. Dommage qu'il n'puisse pas contrôler les nuisibles."
    }
  },
  "prisoncorner": {
    "name": "Poutre de Soutien Décorative",
    "desc": "Un coin gothique décoratif.",
    "metadata": {
      "apexDescription": "Les humains ont au moins une architecture agréable à regarder.",
      "avianDescription": "Je n'arrive pas à décider si c'est joli ou menaçant.",
      "floranDescription": "Architecture piquante.",
      "glitchDescription": "Ravi. L'architecture humaine et Glitch se ressemblent.",
      "humanDescription": "Parfait pour mon manoir hanté.",
      "hylotlDescription": "C'est simple mais bien réalisé.",
      "novakidDescription": "Joli ou terrifiant?"
    }
  },
  "prisondoor": {
    "name": "Porte à Barreaux",
    "desc": "Une porte faite d'épais barreaux métalliques.",
    "metadata": {
      "apexDescription": "De solides barreaux. Curieusement esthétiques.",
      "avianDescription": "Ces barreaux ont l'air très costauds.",
      "floranDescription": "Barreaux ssolides.",
      "glitchDescription": "Impressionné. Une porte remarquablement robuste.",
      "humanDescription": "Des barreaux. On finit toujours par se retrouver d'un côté ou de l'autre.",
      "hylotlDescription": "Même enfermé, l'esprit reste libre.",
      "novakidDescription": "Faut du bon matos pour forcer ça."
    }
  },
  "prisonexitsign": {
    "name": "Panneau de Sortie",
    "desc": "Si vous allez par là, vous allez sûrement sortir de... quelque chose.",
    "metadata": {
      "apexDescription": "Un panneau de sortie.",
      "avianDescription": "Un panneau indiquant la sortie.",
      "floranDescription": "C'est par là la ssortie!",
      "glitchDescription": "Observateur. Ce panneau indique le chemin vers la sortie.",
      "humanDescription": "Une vue bienvenue pour n'importe quel prisonnier. Sauf si on ne fait que passer devant.",
      "hylotlDescription": "Le chemin pour sortir d'ici.",
      "novakidDescription": "Par ici la sortie."
    }
  },
  "prisonfence1": {
    "name": "Grand Grillage",
    "desc": "C'est un grillage à mailles losangées.",
    "metadata": {
      "apexDescription": "Un grillage.",
      "avianDescription": "Une clôture. Une cruelle moquerie pour ceux qui ne peuvent pas voler.",
      "floranDescription": "Floran est ssûr que Floran pourrait ssauter ce grillage! Mais Floran n'essaiera pas.",
      "glitchDescription": "Neutre. Un grillage.",
      "humanDescription": "Un grillage solide.",
      "hylotlDescription": "Si ce grillage était sous l'océan, je pourrais nager par-dessus. Mais bon, pourquoi il y serait?",
      "novakidDescription": "Une clôture en métal."
    }
  },
  "prisonfence2": {
    "name": "Petit Grillage",
    "desc": "C'est un grillage à mailles losangées.",
    "metadata": {
      "apexDescription": "Un grillage.",
      "avianDescription": "Une clôture. Une moquerie pour ceux qui rampent au sol.",
      "floranDescription": "Floran pourrait franchir ça.",
      "glitchDescription": "Neutre. Un grillage.",
      "humanDescription": "Un grillage métallique.",
      "hylotlDescription": "Une barrière terrestre.",
      "novakidDescription": "Une clôture en métal."
    }
  },
  "prisonfile1": {
    "name": "Classeur Rouillé",
    "desc": "Il y avait des fournitures de bureau et des dossiers de détenus dans ce classeur.",
    "metadata": {
      "apexDescription": "Un dossier mentionne un homme emprisonné pour avoir jeté des peaux de banane. Glaçant.",
      "avianDescription": "Toute une ribambelle de racailles. Apparemment, quelqu'un a donné un coup de pied sauté à un Glitch.",
      "floranDescription": "Tellement de dossiers... Celui-là dit qu'un méchant humain a mis le feu à un Floran! Méprissable!",
      "glitchDescription": "Étonné. Quelqu'un a été emprisonné pour avoir assassiné un empereur. Il a pris une semaine de prison.",
      "humanDescription": "Il y a une personne ici qui me ressemble trait pour trait. Coïncidence. Je n'ai jamais dégradé de fresque.",
      "hylotlDescription": "Quelqu'un a été emprisonné pour avoir pêché sans permis. J'espère qu'ils ont jeté la clé.",
      "novakidDescription": "Des dossiers de détenus. On a tous nos secrets. J'vais pas fouiner."
    }
  },
  "prisonfile2": {
    "name": "Large Classeur Rouillé",
    "desc": "Il y avait des fournitures de bureau et des dossiers de détenus dans ce classeur.",
    "metadata": {
      "apexDescription": "Apparemment, la nudité publique est illégale pour les humains. Qui l'eût cru?",
      "avianDescription": "Une femme a été arrêtée pour des lunettes trop grandes. Apparemment, c'était un risque d'incendie.",
      "floranDescription": "Ce classeur est plein de crimess documentés. Les humains ssont dangereux!",
      "glitchDescription": "Abattu. Un grand nombre d'humains vont en prison pour s'être frappés au visage.",
      "humanDescription": "Oh tiens, cette femme est une contrebandière célèbre. C'est écrit qu'elle s'est évadée.",
      "hylotlDescription": "Le mot 'criminel' est écrit sur tout le visage de cet homme. Littéralement.",
      "novakidDescription": "Des dossiers de détenus. Chacun a sses sombres secrets. J'vais pas fouiller."
    }
  },
  "prisonfloodlight": {
    "name": "Petit Projecteur",
    "desc": "J'ai l'impression d'être sur scène!",
    "metadata": {
      "apexDescription": "Le Miniknog utilise ces projecteurs pour forcer les gens à parler. Entre autres...",
      "avianDescription": "Une lumière aveuglante et agaçante.",
      "floranDescription": "Floran a l'impression d'être le centre d'attention.",
      "glitchDescription": "Furtif. En analysant les cycles de ce projecteur, il serait facile de se faufiler.",
      "humanDescription": "J'ai toujours voulu être sous les projecteurs.",
      "hylotlDescription": "Un projecteur lumineux et perçant.",
      "novakidDescription": "Une lumière éclatante."
    }
  },
  "prisonfloodlightBroken": {
    "name": "Petit Projecteur Cassé",
    "desc": "Une lumière vacillante pour instaurer une ambiance sinistre.",
    "metadata": {
      "apexDescription": "Le Miniknog utilise ces projecteurs pour faire parler les gens. Celui-ci est bien endommagé.",
      "avianDescription": "Une lumière vacillante et agaçante.",
      "floranDescription": "La lumière qui clignote rend Floran nerveux.",
      "glitchDescription": "Agacé. Quelqu'un devrait réparer cette lampe.",
      "humanDescription": "Une lumière qui clignote! Encore quelques-unes comme ça et on ouvre une boîte de nuit!",
      "hylotlDescription": "Un projecteur endommagé. Je doute qu'il soit remplacé de sitôt.",
      "novakidDescription": "Une source de lumière vacillante. Agaçant."
    }
  },
  "prisonforcecell": {
    "name": "Cellule de Force",
    "desc": "Une sorte de dispositif d'isolement, peut-être?",
    "metadata": {
      "apexDescription": "Cette cellule semble plus sûre que les autres.",
      "avianDescription": "Être piégé dans un espace aussi restreint serait infernal.",
      "floranDescription": "Petite capsule pour garder les méchants... Mais ess-ce que ça les rend gentils après?",
      "glitchDescription": "Prudent. Le champ de force de cette cellule est conçu pour l'incapacitation.",
      "humanDescription": "Une cellule pour les plus dangereux. Tueurs, voleurs, piétons qui traversent au rouge...",
      "hylotlDescription": "Une forme barbare de cellule de détention.",
      "novakidDescription": "C'est vraiment une toute petite cellule."
    }
  },
  "prisongirderh": {
    "name": "Poutre Horizontale Rouillée",
    "desc": "De vieilles poutres rouillées - ça ne doit pas être très sûr.",
    "metadata": {
      "apexDescription": "Une poutre rouillée.",
      "avianDescription": "Une poutre à l'aspect peu sûr.",
      "floranDescription": "Gros métal!",
      "glitchDescription": "Prudent. La probabilité que cette poutre s'effondre est élevée.",
      "humanDescription": "Ça a l'air parfaitement sûr pour grimper dessus.",
      "hylotlDescription": "Une poutre métallique rouillée.",
      "novakidDescription": "Une poutre rouillée."
    }
  },
  "prisongirderv": {
    "name": "Poutre Verticale Rouillée",
    "desc": "De vieilles poutres rouillées - ça ne doit pas être très sûr.",
    "metadata": {
      "apexDescription": "Une poutre rouillée.",
      "avianDescription": "Une poutre à l'aspect peu sûr.",
      "floranDescription": "Gros métal!",
      "glitchDescription": "Prudent. La probabilité que cette poutre s'effondre est élevée.",
      "humanDescription": "Ça a l'air parfaitement sûr pour grimper dessus.",
      "hylotlDescription": "Une poutre métallique rouillée.",
      "novakidDescription": "Une poutre rouillée."
    }
  },
  "prisongraffiti1": {
    "name": "Graffiti 'Waz'",
    "desc": "Waz.",
    "metadata": {
      "apexDescription": "C'est écrit 'WAZ'. Poignant.",
      "avianDescription": "Que signifie ce mot? Mon traducteur ne trouve rien.",
      "floranDescription": "Floran écrit messsages sur le mur avec du sang.",
      "glitchDescription": "Académique. Il est possible que cela représente l'équation mathématique de l'évolution.",
      "humanDescription": "Héhé. Waz. Vous êtes pas croyables.",
      "hylotlDescription": "C'est un mot que ni moi ni mon traducteur ne connaissons."
    }
  },
  "prisongraffiti2": {
    "name": "Graffiti 'Pas d'Évasion'",
    "desc": "On dirait bien, cher artiste de graffiti anonyme.",
    "metadata": {
      "apexDescription": "Pas d'évasion, apparemment. Un avertissement que les Apex ne connaissent que trop bien.",
      "avianDescription": "Quelqu'un avait clairement une vision pessimiste des choses.",
      "floranDescription": "Jolie écriture, mais Floran n'est pas d'accord avec le messsage.",
      "glitchDescription": "Douteux. Malgré le graffiti, mes scans indiquent au moins quatre méthodes d'évasion.",
      "humanDescription": "Défi accepté.",
      "hylotlDescription": "Le graffiti suinte le désespoir autant qu'il suinte la peinture.",
      "novakidDescription": "Quelqu'un a écrit ça un mauvais jour."
    }
  },
  "prisongraffiti3": {
    "name": "Graffiti",
    "desc": "Un graffiti. Un avertissement sévère. Ignorez-le.",
    "metadata": {
      "apexDescription": "« Sortez tant que vous le pouvez toujours ». Comment savoir quand l'offre expire?",
      "avianDescription": "Je suis sûr que c'est juste une blague.",
      "floranDescription": "Floran s'interroge, essst-ce que la personne qui a écrit ça est sortie?",
      "glitchDescription": "Alarmé. Un avertissement sérieux.",
      "humanDescription": "Oh, quels farceurs.",
      "hylotlDescription": "Je devrais peut-être suivre ce conseil.",
      "novakidDescription": "Un avertissement de quelqu'un. Je vais le garder en tête."
    }
  },
  "prisongraffiti4": {
    "name": "Graffiti",
    "desc": "Un crâne grossièrement dessiné. Il a l'air joyeux.",
    "metadata": {
      "apexDescription": "On dirait un crâne humain.",
      "avianDescription": "Un crâne. Est-ce un avertissement?",
      "floranDescription": "Floran aimmme ce desssin. Grand artiste.",
      "glitchDescription": "Observateur. Un crâne humain grossièrement dessiné.",
      "humanDescription": "Une autre pièce frappante d'art de rue.",
      "hylotlDescription": "L'artiste était manifestement inapte.",
      "novakidDescription": "Un crâne. Soit c'est un avertissement... soit y a des pirates ici!"
    }
  },
  "prisongraffiti5": {
    "name": "Graffiti",
    "desc": "Un graffiti. L'auteur semble quelque peu agacé.",
    "metadata": {
      "apexDescription": "Je me demande à qui ce graffiti fait référence.",
      "avianDescription": "Pauvre auteur.",
      "floranDescription": "Floran est ssûr que la personne est revenue. Histoire joyeuse, sûrement.",
      "glitchDescription": "Compatissant. Peut-être que l'auteur aurait dû faire attention à ce qu'il souhaitait.",
      "humanDescription": "On dirait quelque chose sorti d'un film d'horreur.",
      "hylotlDescription": "On ne peut jamais compter sur personne dans ce monde.",
      "novakidDescription": "Dramatique."
    }
  },
  "prisongraffiti6": {
    "name": "Graffiti",
    "desc": "Un graffiti disant « faites demi-turn ». Chances que ce soit respecté: zéro.",
    "metadata": {
      "apexDescription": "Je ferai demi-tour quand j'atteindrai un cul-de-sac.",
      "avianDescription": "Ce graffiti est tellement autoritaire.",
      "floranDescription": "Ne dis pas à Floran quoi faire!",
      "glitchDescription": "Défiant. Non.",
      "humanDescription": "Comment ce graffiti sait de quel côté on arrive?",
      "hylotlDescription": "Exigeant.",
      "novakidDescription": "Pas de retour en arrière possible maintenant."
    }
  },
  "prisongraffiti7": {
    "name": "Graffiti",
    "desc": "Les mots « sortez d'ici » ont été écrits avec du sang.",
    "metadata": {
      "apexDescription": "Ce graffiti semble avoir été écrit avec du sang.",
      "avianDescription": "L'artiste avait clairement un goût pour le dramatique.",
      "floranDescription": "La peinture sssent bon.",
      "glitchDescription": "Inconfortable. Le sang utilisé ici provient d'un Hylotl.",
      "humanDescription": "Non, c'est toi qui sors!",
      "hylotlDescription": "Cet artiste de graffiti a besoin de faire une pause.",
      "novakidDescription": "Écrit avec du sang. Était-ce le leur?"
    }
  },
  "prisongrateh": {
    "name": "Grilles Métalliques Horizontales",
    "desc": "Des grilles métalliques rouillées destinées à la ventilation.",
    "metadata": {
      "apexDescription": "Une grille métallique rouillée.",
      "avianDescription": "Une grille en métal. Elle est rouillée.",
      "floranDescription": "Grille.",
      "glitchDescription": "Curieux. Peut-être qu'un Glitch agile pourrait s'y glisser.",
      "humanDescription": "J'ai toujours voulu ramper dans des conduits.",
      "hylotlDescription": "Une bouche d'aération. Elle n'a pas été entretenue.",
      "novakidDescription": "Un conduit. Pas sûr que ça marche. On étouffe ici."
    }
  },
  "prisongratev": {
    "name": "Grilles Métalliques Verticales",
    "desc": "Des grilles métalliques rouillées destinées à la ventilation.",
    "metadata": {
      "apexDescription": "Une grille métallique rouillée.",
      "avianDescription": "Une grille en métal. Elle est rouillée.",
      "floranDescription": "Grille.",
      "glitchDescription": "Curieux. Un Glitch agile pourrait passer par là.",
      "humanDescription": "J'ai toujours voulu ramper dans des conduits.",
      "hylotlDescription": "Une bouche d'aération. Elle n'a pas été entretenue.",
      "novakidDescription": "Un conduit. Pas sûr que ça marche. On étouffe ici."
    }
  },
  "prisonlocker1": {
    "name": "Petit Casier de Prison",
    "desc": "Un bon endroit pour cacher de la contrebande.",
    "metadata": {
      "apexDescription": "Un casier. Je me demande ce qu'il y a à l'intérieur.",
      "avianDescription": "Un casier. Peut-être rempli d'affaires de prisonniers.",
      "floranDescription": "Voler desss voleurs! Floran ne s'en sent même pas mal.",
      "glitchDescription": "Pensif. Est-ce un crime de voler des biens volés?",
      "humanDescription": "J'ai toujours voulu piller un casier de prison, et maintenant mes rêves deviennent réalité!",
      "hylotlDescription": "Les prisonniers sont partis depuis longtemps. Il est juste de prendre ce qu'il y a dedans.",
      "novakidDescription": "Un casier pour criminels."
    }
  },
  "prisonlocker2": {
    "name": "Grand Casier de Prison",
    "desc": "Un bon endroit pour cacher de la contrebande.",
    "metadata": {
      "apexDescription": "Un casier. Je me demande ce qu'il y a à l'intérieur.",
      "avianDescription": "Un casier. Peut-être rempli d'affaires de prisonniers.",
      "floranDescription": "Voler desss voleurs! Floran ne s'en sent même pas mal.",
      "glitchDescription": "Pensif. Est-ce un crime de voler des biens volés?",
      "humanDescription": "J'ai toujours voulu piller un casier de prison, et maintenant mes rêves deviennent réalité!",
      "hylotlDescription": "Les prisonniers sont partis depuis longtemps. Il est juste de prendre ce qu'il y a dedans.",
      "novakidDescription": "Un casier pour criminels."
    }
  },
  "prisonmattress": {
    "name": "Matelas Sale",
    "desc": "Ce matelas est dégoûtant! Je jure avoir vu quelque chose ramper à l'intérieur.",
    "metadata": {
      "apexDescription": "On approche des conditions de vie imposées par le Miniknog.",
      "avianDescription": "Un matelas répugnant.",
      "floranDescription": "Même Floran trouve l'odeur repoussive.",
      "glitchDescription": "Inquiet. Ce matelas a besoin d'être désinfecté. Je détecte des signes de vie.",
      "humanDescription": "J'ai déjà dormi sur pire.",
      "hylotlDescription": "Un matelas immonde et pourrissant. Je préfère rester à distance.",
      "novakidDescription": "C'est quoi cette odeur? Ça peut pas être... ce matelas?!"
    }
  },
  "prisonmirror1": {
    "name": "Grand Miroir Brisé",
    "desc": "On dirait que quelqu'un n'aime pas les lundis.",
    "metadata": {
      "apexDescription": "Un miroir brisé. Je dois faire attention à ne pas me couper.",
      "avianDescription": "Je ne vais pas lisser mes plumes ici de sitôt.",
      "floranDescription": "Les éclats de miroir coupants font de bons couteaux de lancer.",
      "glitchDescription": "Observateur. Il y a au moins quatre cent six éclats de verre ici.",
      "humanDescription": "On dirait que quelqu'un va avoir sept ans de malheur. Et pour une fois, ce n'est pas moi!",
      "hylotlDescription": "Un tel bris n'a pu être fait que sous le coup de la colère.",
      "novakidDescription": "J'peux voir mon reflet déformé dans les quelques morceaux restants."
    }
  },
  "prisonmirror2": {
    "name": "Petit Miroir Brisé",
    "desc": "On dirait que quelqu'un n'aime pas les lundis.",
    "metadata": {
      "apexDescription": "Un miroir brisé. Je dois faire attention à ne pas me couper.",
      "avianDescription": "Je ne lisserai pas mes plumes ici aujourd'hui.",
      "floranDescription": "Éclats de miroir pointus faire bons couteaux.",
      "glitchDescription": "Observateur. Quatre cent six éclats s'offrent à ma vue.",
      "humanDescription": "Sept ans de malheur pour quelqu'un d'autre! Enfin!",
      "hylotlDescription": "La marque d'une grande frustration.",
      "novakidDescription": "Mon reflet est tout de traviole là-dedans."
    }
  },
  "prisonpanel": {
    "name": "Panneau de Colonie Pénale USCM",
    "desc": "Le panneau affiche des informations sur l'interaction avec les prisonniers...",
    "metadata": {
      "apexDescription": "D'après ceci, il ne faut pas donner de coups de bâton aux prisonniers.",
      "avianDescription": "Apparemment, les demandes pour « une bonne tasse de thé » doivent être refusées.",
      "floranDescription": "« Ne pas faire de mal aux détenusss. » Trop de règles sstrictes.",
      "glitchDescription": "Sceptique. Il semble que les gardes doivent vérifier que les prisonniers sont bien humains. Cette erreur est-elle si courante?",
      "humanDescription": "Les prisonniers n'ont droit qu'à un maximum de trente jeux vidéo à la fois. Parlez d'une oppression!",
      "hylotlDescription": "Ceci parle d'une chose appelée « water-boarding ». Peut-être une sorte de loisir aquatique.",
      "novakidDescription": "Un guide pour causer avec les prisonniers. « Rappelez-vous: le détenu n'a jamais raison »."
    }
  },
  "prisonpaper1": {
    "name": "Avis",
    "desc": "Un avis écrit à l'encre.",
    "metadata": {
      "apexDescription": "Je n'arrive pas à déchiffrer cette écriture.",
      "avianDescription": "Je ne peux pas lire ça, c'est écrit comme un cochon.",
      "floranDescription": "Une ssorte d'avis... Floran trouve l'écriture difficile à lire.",
      "glitchDescription": "Déconcerté. Il est vraiment très difficile de lire cette écriture manuscrite.",
      "humanDescription": "Si vous voulez afficher un avis, rendez-le au moins lisible.",
      "hylotlDescription": "La personne qui a écrit cette note a une très belle écriture... Illisible, mais très belle.",
      "novakidDescription": "Une sorte d'avis... Mais j'suis damné si j'arrive à lire c'gribouillage."
    }
  },
  "prisonpaper2": {
    "name": "Mémo Déchiré de l'USCM",
    "desc": "Le papier est déchiré et les mots sont effacés.",
    "metadata": {
      "apexDescription": "Je suis sûr que ce qui était écrit ici était très important.",
      "avianDescription": "Je n'arrive pas tout à fait à distinguer les mots.",
      "floranDescription": "Floran ne peut pas lire ce messsage cassé. Dommage!",
      "glitchDescription": "Amusé. Il semble que c'était une note passive-agressive destinée à quelqu'un qui volait du lait.",
      "humanDescription": "C'était clairement un message crucial de l'USCM. C'est impossible à lire maintenant.",
      "hylotlDescription": "Ce papier semble avoir reçu des éclaboussures de liquide.",
      "novakidDescription": "Le message est perdu à jamais. Ça n'devait pas être bien important."
    }
  },
  "prisonpaper3": {
    "name": "Mémo d'Événement",
    "desc": "Groupe d'étude du Détenu #2162 pour les Criminels qui Savent pas Bien Lire",
    "metadata": {
      "apexDescription": "Il semble que les prisonniers étaient autorisés à s'instruire, chose que le Miniknog interdit spécifiquement.",
      "avianDescription": "Un dépliant pour un groupe d'étude de prisonniers. C'est bien de voir des détenus essayer de s'améliorer.",
      "floranDescription": "Floran ssait pas bien lire. Floran ne comprend pas ça.",
      "glitchDescription": "Optimiste. Un dépliant pour un groupe d'étude. L'idée que des prisonniers apprennent des compétences enfermés me remplit de positivité.",
      "humanDescription": "Un prospectus de groupe d'étude. Si j'avais su que la prison pouvait être éducative, je serais allé au trou plutôt qu'à l'école.",
      "hylotlDescription": "Une affiche pour un groupe d'étude. Encourager les prisonniers à apprendre est une chose que toutes les cultures devraient faire.",
      "novakidDescription": "Un prospectus pour un groupe d'étude de détenus."
    }
  },
  "prisonpipefence": {
    "name": "Clôture en Tuyaux",
    "desc": "Une clôture fabriquée à partir de gros tuyaux métalliques.",
    "metadata": {
      "apexDescription": "Une clôture faite de tuyaux. Ingénieux.",
      "avianDescription": "Une clôture. Une cruelle moquerie pour ceux qui restent au sol.",
      "floranDescription": "Floran est ssûr que Floran pourrait ssauter cette clôture! Mais Floran n'essaiera pas.",
      "glitchDescription": "Observateur. Une série de tuyaux façonnés en clôture.",
      "humanDescription": "Une clôture en tuyaux astucieuse.",
      "hylotlDescription": "Si cette clôture était sous l'océan, je pourrais simplement nager par-dessus. Mais bon, pourquoi le serait-elle?",
      "novakidDescription": "Une clôture en tuyaux."
    }
  },
  "prisonradiator": {
    "name": "Vieux Radiateur",
    "desc": "Le chauffage d'appoint émet un bourdonnement bas et désagréable.",
    "metadata": {
      "apexDescription": "Un petit chauffage d'appoint chaud et douillet.",
      "avianDescription": "Parfait pour se réchauffer les plumes.",
      "floranDescription": "Bonne chaleur, pas de feu. Sssûr pour Floran.",
      "glitchDescription": "Désintéressé. Un petit radiateur.",
      "humanDescription": "Un chauffage d'appoint. Le nom anglais « space heater » donne l'impression que c'est futuriste.",
      "hylotlDescription": "Une manière ingénieuse d'obtenir de la chaleur.",
      "novakidDescription": "Un radiateur. J'en ai jamais vraiment eu l'utilité."
    }
  },
  "prisonsecuritycamera": {
    "name": "Caméra de Sécurité",
    "desc": "Une caméra de sécurité. Un œil qui voit tout.",
    "metadata": {
      "apexDescription": "Une caméra de sécurité. Est-ce que Big Ape nous regarde?",
      "avianDescription": "Une caméra de sécurité.",
      "floranDescription": "Petite boîte qui fixe avec un œil. Elle fixe Floran!",
      "glitchDescription": "Inconfortable. J'ai l'impression d'être observé.",
      "humanDescription": "Je vais être une star!",
      "hylotlDescription": "Quelle invasion de la vie privée.",
      "novakidDescription": "Une caméra de sécurité. J'ai intérêt à bien m'tenir."
    }
  },
  "prisonshower": {
    "name": "Douche Rouillée",
    "desc": "Une douche. Parfaite pour se faire la malle proprement. Si seulement l'eau l'était aussi.",
    "metadata": {
      "apexDescription": "Je pourrais bien avoir besoin d'une douche là maintenant.",
      "avianDescription": "Si seulement j'avais le temps pour une douche chaude.",
      "floranDescription": "La douche crache de l'eau rouillée.",
      "glitchDescription": "Inconfortable. Les douches et les Glitchs ne font pas bon ménage.",
      "humanDescription": "Je prendrais bien une douche, mais mes vocalises pourraient alerter les ennemis.",
      "hylotlDescription": "Le contact de l'eau serait une bénédiction en ce moment.",
      "novakidDescription": "Ah, une douche."
    }
  },
  "prisonshowerdripping": {
    "name": "Douche de Prison qui Fuit",
    "desc": "Une douche. Parfaite pour s'éclipser proprement.",
    "metadata": {
      "apexDescription": "Je prendrais bien une douche.",
      "avianDescription": "Une douche chaude serait bienvenue.",
      "floranDescription": "La douche goutte de l'eau rouillée.",
      "glitchDescription": "Inconfortable. L'eau et les Glitchs, c'est pas ça.",
      "humanDescription": "Si je chante sous la douche, les ennemis vont m'entendre.",
      "hylotlDescription": "De l'eau... enfin!",
      "novakidDescription": "Ah, une douche."
    }
  },
  "prisonsign1": {
    "name": "Panneau de Bloc de Cellules",
    "desc": "Le panneau indique « Cell Block ».",
    "metadata": {
      "apexDescription": "Un panneau indiquant « Bloc de Cellules ».",
      "avianDescription": "Ceci pointe vers un bloc de cellules.",
      "floranDescription": "Un panneau ennuyeux.",
      "glitchDescription": "Neutre. « Bloc de Cellules ».",
      "humanDescription": "J'ai toujours voulu visiter un bloc de cellules! Ah non, je confonds avec le zoo.",
      "hylotlDescription": "Un panneau pour les gens incapables d'observer ce qui les entoure.",
      "novakidDescription": "Le panneau indique « Bloc de Cellules »."
    }
  },
  "prisonsign2": {
    "name": "Panneau du Réfectoire",
    "desc": "Le panneau indique « Mess Hall ».",
    "metadata": {
      "apexDescription": "Réfectoire. Peut-être y a-t-il de la nourriture par ici.",
      "avianDescription": "Un panneau pointant vers une sorte de salle à manger.",
      "floranDescription": "Salle de la pagaille? Floran essst confus.",
      "glitchDescription": "Neutre. Le panneau pour le réfectoire.",
      "humanDescription": "L'idée de visiter un réfectoire me remplit d'une angoisse existentielle. Je ne sais pas pourquoi.",
      "hylotlDescription": "Pourquoi les humains appelleraient-ils une pièce « pagaille » au lieu de simplement la ranger?",
      "novakidDescription": "Un réfectoire? J'imagine que les détenus ont aussi besoin de manger."
    }
  },
  "prisonstonesign": {
    "name": "Panneau de Colonie Pénale USCM",
    "desc": "L'USCM, hein? Je ne voudrais pas être l'un de leurs prisonniers.",
    "metadata": {
      "apexDescription": "Une démonstration audacieuse de l'autorité de l'USCM - même si cela ne signifie plus grand-chose.",
      "avianDescription": "Aucun risque d'oublier qui dirige cet endroit.",
      "floranDescription": "Un gros rocher pour un petit nom. Maintenant Floran veut rocher avec le nom de Floran!",
      "glitchDescription": "Inquiet. Ce rocher semble provenir d'un ancien cimetière. Il est peut-être maudit!",
      "humanDescription": "Quelque chose dans ce panneau me glace le sang. Il a l'air froid et usé par le temps.",
      "hylotlDescription": "L'USCM, s'efforçant encore une fois de faire remarquer sa présence.",
      "novakidDescription": "On dirait bien une grande pierre tombale. Pour certains, je suis sûr que c'en est une."
    }
  },
  "prisontable": {
    "name": "Table de Cafétéria",
    "desc": "Une table de cafétéria typique.",
    "metadata": {
      "apexDescription": "Une table.",
      "avianDescription": "Une table banale.",
      "floranDescription": "Une table ennuyeusse.",
      "glitchDescription": "Neutre. Une table ordinaire.",
      "humanDescription": "Une table normale.",
      "hylotlDescription": "Une table, sans aucune classe ni savoir-faire.",
      "novakidDescription": "Une table au look bien ordinaire."
    }
  },
  "prisntoilet": {
    "name": "Toilettes Sales",
    "desc": "On dirait que quelqu'un a passé une sale nuit.",
    "metadata": {
      "apexDescription": "Nous, les Apex, sommes habitués à des conditions horribles comme celle-ci.",
      "avianDescription": "Je pense que je vais aller ailleurs.",
      "floranDescription": "Siège qui pue! Beurk!",
      "glitchDescription": "Dégoûté. Je n'ai pas de mots.",
      "humanDescription": "Rien qu'un peu d'eau de Javel et de napalm ne puisse régler.",
      "hylotlDescription": "Jamais de ma vie je n'ai vu un tel mépris grotesque pour l'hygiène de base.",
      "novakidDescription": "Personne n'aime le ménage, mais là, ça dépasse l'entendement."
    }
  },
  "prisontorturebed1": {
    "name": "Lit de Torture Vertical",
    "desc": "Un lit de torture. Terrifiant! Heureusement qu'il y a l'oreiller.",
    "metadata": {
      "apexDescription": "Un lit de torture. J'ai déjà des flashbacks.",
      "avianDescription": "Un lit de torture menaçant. Je ne veux même pas penser à ce qui s'est passé ici.",
      "floranDescription": "Floran trouve que ça a l'air confortable! Est-ce vraiment pour punir?",
      "glitchDescription": "Curieux. Je me demande quelles méthodes de torture les humains emploient actuellement.",
      "humanDescription": "Hé, un manège de fête foraine! Qu'est-ce qu'il fait dans une prison? Ah, c'est un lit de torture.",
      "hylotlDescription": "La torture devrait être hors-la-loi. Barbare et cruel. C'est un univers sombre et malade.",
      "novakidDescription": "Le rembourrage a l'air souple, mais les angles racontent une tout autre histoire..."
    }
  },
  "prisontorturebed2": {
    "name": "Lit de Torture",
    "desc": "Un lit de torture. Terrifiant! Heureusement qu'il y a l'oreiller.",
    "metadata": {
      "apexDescription": "Un lit de torture. Déjà des ssouvenirs qui reviennent.",
      "avianDescription": "Un lit de torture menaçant.",
      "floranDescription": "Floran trouve ça confortable!",
      "glitchDescription": "Curieux. Quelles ssont les méthodes humaines?",
      "humanDescription": "Oh, une attraction! Attends... non, c'est pour la torture.",
      "hylotlDescription": "Barbare et cruel.",
      "novakidDescription": "Le rembourrage est doux, mais les sangles font peur."
    }
  },
  "prisonturbine": {
    "name": "Petite Turbine",
    "desc": "C'est une turbine. Vous savez, pour la science.",
    "metadata": {
      "apexDescription": "Une turbine. Pour, euh, turbiner des trucs.",
      "avianDescription": "Ça pourrait m'arracher les plumes d'un coup.",
      "floranDescription": "Floran est tenté de ssauter dans le tube. Peut-être que Floran le fera.",
      "glitchDescription": "Suspicieux. Les pales de cette turbine sont tachées de traces de sang.",
      "humanDescription": "Je crois qu'elles sont là pour que l'USCM puisse transformer n'importe quoi en forteresse volante.",
      "hylotlDescription": "Une turbine. De tels engins peuvent aussi être utilisés sous l'eau.",
      "novakidDescription": "J'sais pas trop à quoi servent ces engins."
    }
  },
  "present1": {
    "name": "Cadeau Sarcelle",
    "desc": "Un cadeau! Il est emballé dans du papier sarcelle avec un ruban doré!",
    "metadata": {
      "apexDescription": "Un cadeau! Est-ce pour moi?",
      "avianDescription": "Je me demande pour qui est ce cadeau.",
      "floranDescription": "Floran veut le cadeau! Poignarder tout!",
      "glitchDescription": "Pensif. Le contenu de ce cadeau m'échappe.",
      "humanDescription": "Des cadeaux! Des surprises! Des emballages! Ouais!",
      "hylotlDescription": "Un cadeau délicieusement emballé.",
      "novakidDescription": "Quelqu'un a mis le paquet pour l'emballage."
    }
  },
  "present2": {
    "name": "Cadeau Rouge",
    "desc": "Un cadeau! Il est emballé dans du papier rouge avec un ruban doré!",
    "metadata": {
      "apexDescription": "Un cadeau! C'est pour moi?",
      "avianDescription": "Pour qui est ce cadeau?",
      "floranDescription": "Floran veut cadeau! Tout poignarder!",
      "glitchDescription": "Pensif. Je me demande ce qu'il y a dedans.",
      "humanDescription": "Des cadeaux! Ouais!",
      "hylotlDescription": "Un présent fort bien emballé.",
      "novakidDescription": "Bel emballage."
    }
  },
  "present3": {
    "name": "Cadeau Bleu",
    "desc": "Un cadeau! Il est emballé dans du papier bleu avec un ruban doré!",
    "metadata": {
      "apexDescription": "Un présent! Est-il pour moi?",
      "avianDescription": "Je me demande qui va le recevoir.",
      "floranDescription": "Cadeau! Floran veut!",
      "glitchDescription": "Réfléchi. Que peut-il bien contenir?",
      "humanDescription": "Cadeaux! Super!",
      "hylotlDescription": "Un emballage raffiné.",
      "novakidDescription": "Beau boulot sur l'emballage."
    }
  },
  "present4": {
    "name": "Cadeau Vert",
    "desc": "Un cadeau! Il est emballé dans du papier vert avec un ruban doré!",
