      "glitchDescription": "Fier. Les dents des Glitchs ne font qu'une bouchée des pois perles.",
      "humanDescription": "Comme un pois, avec un mal de dents en prime.",
      "hylotlDescription": "Délicieux pois croquants. Assez précieux sous l'eau.",
      "novakidDescription": "Les pois perles sont parfaits pour mon pistolet! Piou piou!"
    }
  },
  "pineappleseed": {
    "name": "Graine d'Ananas",
    "desc": "Ananas: assurez-vous de l'ouvrir d'abord.",
    "metadata": {
      "apexDescription": "Les ananas sont sucrés et juteux. Une gâterie rafraîchissante.",
      "avianDescription": "Les feuilles ressemblent à des plumes, mais elles sont loin d'être aussi douces.",
      "floranDescription": "Les ananass ressemblent à des têtes de Florans.",
      "glitchDescription": "Suffisant. Les Glitchs sont connus pour utiliser les ananas comme cibles d'entraînement.",
      "humanDescription": "Des ananas. Parfaits pour les desserts, ou sur la pizza!",
      "hylotlDescription": "Écoeurant de sucre. On ne trouverait jamais d'ananas sous la mer.",
      "novakidDescription": "Qui l'eût cru qu'un truc si piquant soit si doux à l'intérieur?"
    }
  },
  "potatoseed": {
    "name": "Graine de Pomme de Terre",
    "desc": "Des patates! Bouillies, en purée, ou dans un ragoût.",
    "metadata": {
      "apexDescription": "Les pommes de terre sont tout à fait banales.",
      "avianDescription": "La purée de pommes de terre est un plat réconfortant.",
      "floranDescription": "Patatess dures et croquantes, fraîches sorties de la terre.",
      "glitchDescription": "Admiration. Les humains créent de nombreux plats à partir d'une chose aussi simple.",
      "humanDescription": "Ahhh, les patates. Y a-t-il quelque chose qu'on ne puisse pas faire avec?",
      "hylotlDescription": "Un légume racine commun et ennuyeux.",
      "novakidDescription": "Parfait pour rôtir sur un feu d'camp par une nuit froide."
    }
  },
  "pussplumseed": {
    "name": "Graine de Pussplum",
    "desc": "La juteuse pussplum tire son nom de son centre crémeux.",
    "metadata": {
      "apexDescription": "Les pussplums ont meilleur goût qu'elles n'en ont l'air.",
      "avianDescription": "De petites délicatesses juteuses et faciles à digérer. Peuvent être servies roulées dans des graines.",
      "floranDescription": "Coulant, sanglant, délicieuxss.",
      "glitchDescription": "Alarmé. Pratiquement tout peut devenir une délicatesse, tant que ça a bon goût pour quelqu'un.",
      "humanDescription": "Apparemment, c'est excellent... Pour une raison obscure, j'hésite à vérifier.",
      "hylotlDescription": "Crémeuses mais acidulées, les pussplums ne sont pas au goût des Hylotls.",
      "novakidDescription": "J'ai entendu dire que c'était bon, mais après en avoir vu une, j'suis pas si sûr."
    }
  },
  "poisonfluffaloegg": {
    "name": "Œuf de Fluffalo de Poison",
    "desc": "Donne naissance à un jeune fluffalo de poison vulnérable - une bonne source d'échantillons de venin une fois adulte.",
    "metadata": {
      "apexDescription": "Un 'œuf de fluffalo de poison'. Ni l'œuf, ni le fluffalo à l'intérieur ne vous empoisonneront.",
      "avianDescription": "C'est un œuf de fluffalo de poison. Ils sont bien plus amicaux qu'ils n'en ont l'air.",
      "floranDescription": "Gros œuf de fluffalo de poison avec petit fluffalo à l'intérieurss.",
      "glitchDescription": "Enchanté. J'espère que le petit fluffalo de poison va bientôt éclore.",
      "humanDescription": "Un œuf empoisonné! Oh attendez... Un œuf de fluffalo de poison. C'est beaucoup mieux.",
      "hylotlDescription": "Cet œuf extraordinairement brillant donnera naissance à un fluffalo de poison.",
      "novakidDescription": "C'est un œuf de fluffalo de poison. Pas toxique pour un sou, juste une grosse bestiole à l'intérieur."
    }
  },
  "pethealingstation": {
    "name": "^orange;Station de Soin pour Animaux^white;",
    "desc": "La station de soin est utilisée pour soigner les créatures capturées.",
    "metadata": {
      "subtitle": "Pour les animaux tristes",
      "apexDescription": "Des machines comme celles-ci sont utilisées pour soigner les créatures capturées.",
      "avianDescription": "C'est utile, je peux soigner n'importe quelle créature capturée avec ça.",
      "floranDescription": "Floran peut garder ses créaturess en forme avec ça.",
      "glitchDescription": "Impressionné. Cet appareil peut soigner n'importe quelle créature capturée.",
      "humanDescription": "Je peux utiliser ça pour soigner les créatures que j'ai capturées. Sympa!",
      "hylotlDescription": "De tels objets sont utiles pour garantir l'excellente santé des créatures.",
      "novakidDescription": "J'peux utiliser ce gadget pour soigner mes créatures capturées."
    }
  },
  "pixelcompressor": {
    "name": "^orange;Compresseur de Pixels^white;",
    "desc": "Compresse les pixels pour le stockage.",
    "metadata": {
      "apexDescription": "Je peux stocker des pixels ici.",
      "avianDescription": "Un endroit sûr pour stocker mes pixels.",
      "floranDescription": "Floran met les briillants en lieu sûr!",
      "glitchDescription": "Neutre. Une banque de pixels.",
      "humanDescription": "Je me demande si cette banque de pixels a une fonction de découvert...",
      "hylotlDescription": "Économiser des pixels pour l'avenir est un bon investissement.",
      "novakidDescription": "Une machine pour stocker vos carrés dorés. J'espère que c'est sécurisé..."
    }
  },
  "pagodaaquarium": {
    "name": "Aquarium Pagode",
    "desc": "Un aquarium majestueux, surmonté d'une petite maquette de pagode Hylotl.",
    "metadata": {
      "apexDescription": "Cet aquarium possède une île miniature sur le dessus.",
      "avianDescription": "Quelle charmante île miniature! Cela transforme cet aquarium en diorama.",
      "floranDescription": "Floran ne voit aucun poissson dans le réservoir.",
      "glitchDescription": "Impressionné. Cet aquarium en verre a une maquette d'île sur le dessus, reliée à la base par un tunnel en métal.",
      "humanDescription": "C'est un aquarium très impressionnant. Je me demande si l'île est basée sur un lieu réel?",
      "hylotlDescription": "L'île miniature magnifiquement construite sur cet aquarium a dû demander beaucoup de temps.",
      "novakidDescription": "Y a pas de poisson dans cet aquarium. Par contre, la p'tite île sur le dessus a fière allure."
    }
  },
  "phoenixfly": {
    "name": "Mouche-Phénix",
    "desc": "Cet insecte frotte ses pattes ensemble pour produire de minuscules étincelles."
  },
  "polarmoth": {
    "name": "Mite Polaire",
    "desc": "Les pattes de ce petit insecte sont couvertes de poils transparents."
  },
  "petalfountain": {
    "name": "Fontaine Florale",
    "desc": "Une magnifique fontaine en pierre avec une pièce maîtresse florale.",
    "metadata": {
      "apexDescription": "Une jolie fontaine. Le son est apaisant.",
      "avianDescription": "Un grand bain pour oiseaux.",
      "floranDescription": "L'eau apporte la vie à Floranss.",
      "glitchDescription": "Relaxé. L'eau me calme.",
      "humanDescription": "Une fontaine! Je devrais peut-être y jeter un pixel.",
      "hylotlDescription": "Parfois, l'océan me manque.",
      "novakidDescription": "Une vision sereine. Ça me rend d'humeur vagabonde."
    }
  },
  "platinumrock": {
    "name": "Roche de Platine",
    "desc": "Une roche fissurée pleine de platine.",
    "metadata": {
      "apexDescription": "Il semble y avoir du platine à l'intérieur de cette roche fragile.",
      "avianDescription": "Si je brise cette roche, je devrais pouvoir récolter le minerai de platine qu'elle contient.",
      "floranDescription": "Roche qui brille. Faut l'écras sser!",
      "glitchDescription": "Observateur. Cette roche contient du platine et est couverte de fissures.",
      "humanDescription": "Une roche pleine de platine! Je peux peut-être la briser.",
      "hylotlDescription": "Un coup sec sur cette roche libérerait le platine à l'intérieur.",
      "novakidDescription": "Une roche riche en platine. Je devrais la casser."
    }
  },
  "platinumrocksmall": {
    "name": "Petite Roche de Platine",
    "desc": "Une roche fissurée pleine de platine.",
    "metadata": {
      "apexDescription": "Il semble y avoir du platine à l'intérieur de cette roche fragile.",
      "avianDescription": "Si je brise cette roche, je devrais pouvoir récolter le minerai de platine qu'elle contient.",
      "floranDescription": "Roche qui brille. Faut l'écras sser!",
      "glitchDescription": "Observateur. Cette roche contient du platine et est couverte de fissures.",
      "humanDescription": "Une roche pleine de platine! Je peux peut-être la briser.",
      "hylotlDescription": "Un coup sec sur cette roche libérerait le platine à l'intérieur.",
      "novakidDescription": "Une roche riche en platine. Je devrais la casser."
    }
  },
  "prismbed": {
    "name": "Lit Prisme",
    "desc": "Un lit minimaliste fait d'un verre réfractif.",
    "metadata": {
      "apexDescription": "Je suis impressionné par la lisseté de ce matériau raffiné.",
      "avianDescription": "L'arc-en-ciel de lumières à l'intérieur est merveilleux.",
      "floranDescription": "Floran est confus. La lumière essst piégée dedans?",
      "glitchDescription": "Transfixié. Mon regard est captivé par les lumières dansantes de ce lit.",
      "humanDescription": "C'est sûr que c'est joli, mais est-ce confortable?",
      "hylotlDescription": "Ce verre est si clair qu'on dirait une étendue d'eau immobile.",
      "novakidDescription": "Comme de regarder un ciel dégagé après la pluie."
    }
  },
  "prismchair": {
    "name": "Chaise Prisme",
    "desc": "Une chaise aux lignes nettes faite de verre réfractif.",
    "metadata": {
      "apexDescription": "Bien que peu confortable, cette chaise est d'une fabrication impressionnante.",
      "avianDescription": "Comment un meuble aussi simple peut-il être aussi envoûtant?",
      "floranDescription": "Floran s'interroge... Est-ce qu'une chaisse tranchante ferait une bonne arme?",
      "glitchDescription": "Impressionné. Les angles de cette chaise sont mathématiquement parfaits.",
      "humanDescription": "Un bloc de verre bizarre, ça ne fait pas la plus confortable des chaises...",
      "hylotlDescription": "Cette chaise parvient à capturer constamment la lumière qui brille en elle.",
      "novakidDescription": "C'est-y pas joli..."
    }
  },
  "prismdoor": {
    "name": "Porte Prisme",
    "desc": "Une porte lisse faite de verre réfractif.",
    "metadata": {
      "apexDescription": "Une porte en verre lisse qui semble briller de tout un spectre de couleurs.",
      "avianDescription": "Une porte en verre finement réalisée.",
      "floranDescription": "Floran peut voir à travers la porte... Pas pratique pour les embussscade!",
      "glitchDescription": "Impressionné. Un verre aussi lisse est rare à l'état naturel.",
      "humanDescription": "Cette porte capture vraiment la lumière. C'est ravissant.",
      "hylotlDescription": "C'est une porte que je peux vraiment apprécier.",
      "novakidDescription": "Cette porte brille comme un étang calme après l'orage."
    }
  },
  "prismlamp1": {
    "name": "Lampe Prisme Magenta",
    "desc": "Une lampe faite d'un cristal luminescent finement sculpté.",
    "metadata": {
      "apexDescription": "Cette lampe cristalline émet une étrange lueur rose.",
      "avianDescription": "Cette lampe de cristal diffuse une lumière céleste.",
      "floranDescription": "Floran est nerveux devant la roche qui brillesss...",
      "glitchDescription": "Curieux. Qu'est-ce qui fait briller ce fragment de verre?",
      "humanDescription": "Je me demande pourquoi le simple fait de toucher cette lampe la fait briller?",
      "hylotlDescription": "Il y a quelque chose de curieux dans cette lampe prismatique luminescente.",
      "novakidDescription": "Ça me rendrait nerveux de toucher des trucs brillants comme ça."
    }
  },
  "prismlamp2": {
    "name": "Lampe Prisme Émeraude",
    "desc": "Une lampe faite d'un cristal luminescent finement sculpté.",
    "metadata": {
      "apexDescription": "La lueur verte de cette lampe me rappelle des déchets radioactifs...",
      "avianDescription": "La lueur de cette lampe est troublante.",
      "floranDescription": "Floran essst nerveux devant la roche qui brille...",
      "glitchDescription": "Inquiet. Est-ce censé briller comme ça?",
      "humanDescription": "Cette lampe a l'air radioactive. J'espère qu'elle ne l'est pas.",
      "hylotlDescription": "Ce cristal luminescent fait office de lampe. Comme c'est curieux.",
      "novakidDescription": "On dirait une sorte de cactus brillant."
    }
  },
  "prismlamp3": {
    "name": "Lampe Prisme Cyan",
    "desc": "Une lampe faite d'un cristal luminescent finement sculpté.",
    "metadata": {
      "apexDescription": "La lueur bleue dégagée par cette lampe est apaisante.",
      "avianDescription": "Cette douce lueur bleue me rappelle un éclatant ciel d'été.",
      "floranDescription": "Floran s'interroge... Est-ce qu'on peut jeter la lampe sur les gensss?",
      "glitchDescription": "Calme. Cette lampe en cristal bleu apaise mes craintes.",
      "humanDescription": "Il y a quelque chose de relaxant dans cette lampe en cristal bleu.",
      "hylotlDescription": "Cette lampe bleue brille comme un océan vivant. Je pourrais la regarder pendant des heures.",
      "novakidDescription": "La lumière de ce truc est comme un ciel bleu en plein midi."
    }
  },
  "prismrock1": {
    "name": "Cristal Prisme",
    "desc": "Un prisme hautement réfractif.",
    "metadata": {
      "apexDescription": "Un petit amas de pierres précieuses prismatiques.",
      "avianDescription": "Quelques petites roches prismatiques. Très jolies!",
      "floranDescription": "Rochesss colorées.",
      "glitchDescription": "Impressionné. Ces prismes se forment naturellement.",
      "humanDescription": "Je suis toujours partant pour des cailloux arc-en-ciel.",
      "hylotlDescription": "Une pierre précieuse qui réfracte la lumière, les couleurs me rappellent un récif de corail tropical.",
      "novakidDescription": "Ces pierres sont jolies, d'accord... mais ça vaut combien?"
    }
  },
