    "metadata": {
      "apexDescription": "Ça va se déclencher si je m'approche trop.",
      "avianDescription": "Ne t'approche pas trop!",
      "floranDescription": "Floran sssait qu'il faut faire attention avec çccca!",
      "glitchDescription": "Prudent. Un capteur de proximité.",
      "humanDescription": "Un capteur de proximité.",
      "hylotlDescription": "Un capteur.",
      "novakidDescription": "Faut avancer prudemment."
    }
  },
  "pastelbed": {
    "name": "Lit Pastel",
    "desc": "Un charmant lit aux couleurs pastel.",
    "metadata": {
      "apexDescription": "Quelle douceur écœurante.",
      "avianDescription": "Ce sont des couleurs très vives pour un lit!",
      "floranDescription": "Le lit a desss fleursss. Çccca va pour Floran.",
      "glitchDescription": "Intrigué. Ce lit fourmille de détails, comme le cœur sur la tête de lit et les draps à motifs floraux.",
      "humanDescription": "Quel lit adorable!",
      "hylotlDescription": "Ce lit est fait avec une très belle sélection de couleurs.",
      "novakidDescription": "Ce lit a l'air un peu trop chic pour moi..."
    }
  },
  "pastelbunnyplush": {
    "name": "Peluche Lapin Pastel",
    "desc": "Une peluche de lapin rose parfumée.",
    "metadata": {
      "apexDescription": "Cette peluche horriblement mignonne sent aussi la rose.",
      "avianDescription": "Cette peluche mignonne est en fait aussi parfumée à la rose.",
      "floranDescription": "Petite chossse sssent la rossse. Floran approuve.",
      "glitchDescription": "Épris. Cette peluche est absolument adorable.",
      "humanDescription": "Ce lapin rose est tellement mignon que ça me donne envie de lui mettre un coup de poing.",
      "hylotlDescription": "Cette peluche sent vraiment la rose. C'est une touche délicate.",
      "novakidDescription": "C'est-y pas la chose la plus mignonne que t'aies vue?"
    }
  },
  "pastelcabinet": {
    "name": "Armoire Pastel",
    "desc": "Une petite armoire peinte dans des tons pastel éclatants.",
    "metadata": {
      "apexDescription": "Une petite armoire plutôt charmante.",
      "avianDescription": "Cette armoire a une poignée en forme d'étoile. Jolie touche!",
      "floranDescription": "Floran aime lesss couleursss fleuries de l'armoire.",
      "glitchDescription": "Impressionné. La poignée est sculptée pour ressembler à une petite étoile - un beau détail.",
      "humanDescription": "Oh, cette armoire a des petits cœurs sur le côté!",
      "hylotlDescription": "Cette armoire est tout à fait charmante.",
      "novakidDescription": "Les couleurs sont un peu trop criardes à mon goût."
    }
  },
  "pastelchair": {
    "name": "Chaise Pastel",
    "desc": "Une chaise de couleur pastel avec un dossier en forme de cœur.",
    "metadata": {
      "apexDescription": "Le dossier de cette chaise est en forme de cœur. C'est créatif.",
      "avianDescription": "Quelle charmante petite chaise!",
      "floranDescription": "La chaisssse a de bellesss couleursss.",
      "glitchDescription": "Surpris. Le dossier de cette chaise est un cœur... avec un cœur plus petit au-dessus!",
      "humanDescription": "Cette chaise a vraiment beaucoup de cœurs sur elle!",
      "hylotlDescription": "Cette chaise arbore des couleurs très tropicales. J'aime beaucoup.",
      "novakidDescription": "J'suis pas sûr que cette chaise soit mon genre, mais j'apprécie l'attention portée aux détails."
    }
  },
  "pastellight": {
    "name": "Lampe Pastel",
    "desc": "Une lampe fluorescente rose fixée au mur.",
    "metadata": {
      "apexDescription": "Je n'ai pas vu beaucoup de lampes qui brillent en rose comme celle-ci!",
      "avianDescription": "La douce lueur rose de cette lampe est apaisante.",
      "floranDescription": "Floran aime la couleur de la lumière. Bonne couleur.",
      "glitchDescription": "Observateur. Je n'ai pas vu beaucoup de lampes qui brillent en rose comme celle-ci.",
      "humanDescription": "La lueur rose subtile de cette lampe est très apaisante. Je pourrais la regarder pendant des heures.",
      "hylotlDescription": "Je pourrais croire qu'un Hylotl a fabriqué cette lampe - c'est tellement calme!",
      "novakidDescription": "Cette lampe dégage une lueur chaleureuse, n'est-ce pas?"
    }
  },
  "pastelstool": {
    "name": "Tabouret Pastel",
    "desc": "Un petit tabouret de couleur pastel.",
    "metadata": {
      "apexDescription": "Un petit tabouret orné de cœurs décoratifs.",
      "avianDescription": "Un petit tabouret pittoresque. Il y a des cœurs dessus!",
      "floranDescription": "Floran sss e demande sssi le tabouret essst fait avec de vraisss cœursss.",
      "glitchDescription": "Curieux. Un petit tabouret décoré de cœurs.",
      "humanDescription": "C'est un petit tabouret plutôt attrayant.",
      "hylotlDescription": "Un petit tabouret plutôt plaisant.",
      "novakidDescription": "Un joli p'tit tabouret pour se reposer un coup."
    }
  },
  "pasteltable": {
    "name": "Table Pastel",
    "desc": "Une table aux couleurs vives avec une nappe fleurie.",
    "metadata": {
      "apexDescription": "Cette table possède une nappe très agréable.",
      "avianDescription": "J'aime la nappe fleurie sur cette table!",
      "floranDescription": "Floran aime la table fleurie.",
      "glitchDescription": "Observateur. Cette table a été peinte avec une variété de couleurs pastel.",
      "humanDescription": "Les fleurs sur cette nappe sont cousues main. Quel dévouement!",
      "hylotlDescription": "Quelle table à la décoration complexe.",
      "novakidDescription": "C'est une bien jolie table."
    }
  },
  "pastelwallclock": {
    "name": "Horloge Murale Pastel",
    "desc": "Une horloge murale carrée et colorée.",
    "metadata": {
      "apexDescription": "Une horloge murale de couleur lilas.",
      "avianDescription": "Une horloge murale au look plutôt unique.",
      "floranDescription": "Floran n'a passs le temps de vérifier l'heure.",
      "glitchDescription": "Curieux. C'est une horloge de forme très étrange.",
      "humanDescription": "J'aime que mes horloges soient carrées et de couleurs vives!",
      "hylotlDescription": "Une horloge de forme plutôt amusante.",
      "novakidDescription": "Le temps file à toute allure."
    }
  },
  "pastelwardrobe": {
    "name": "Garde-robe Pastel",
    "desc": "Une merveilleuse garde-robe de couleur pastel.",
    "metadata": {
      "apexDescription": "Une garde-robe finement décorée.",
      "avianDescription": "Cette garde-robe est décorée de cœurs peints et d'une grande étoile au sommet.",
      "floranDescription": "Floran veut sssse cacher dansss ce truc.",
      "glitchDescription": "Impressionné. Cette garde-robe semble être un travail de passion.",
      "humanDescription": "C'est une garde-robe à l'aspect très magique. Pensez à tout ce qui pourrait se trouver à l'intérieur!",
      "hylotlDescription": "Un travail d'artisanat soigné a été nécessaire pour fabriquer cette garde-robe.",
      "novakidDescription": "J'aime bien la petite décoration en étoile au sommet de c'te garde-robe."
    }
  },
  "plutomodel": {
    "name": "Maquette de Pluton",
    "desc": "Une maquette détaillée de Pluton, la planète naine du système Sol.",
    "metadata": {
      "apexDescription": "Je ne comprends pas l'obsession des humains pour cette planète naine mineure et insignifiante.",
      "avianDescription": "Pluton a été nommée d'après un dieu des enfers dans l'ancienne mythologie terrestre. Cela me rappelle certains mythes Avians similaires.",
      "floranDescription": "Petite planète naine avec une orbite chaotique aux confinsss du sssyssstème Sssol.",
      "glitchDescription": "Perplexe. Pourquoi les humains tiennent-ils tant à Pluton? Ce n'est même pas une planète.",
      "humanDescription": "Pauvre Pluton... Tu as vraiment perdu de ton prestige.",
      "hylotlDescription": "J'ai étudié le statut culturel controversé de cette planète naine lors du cours Culture Terrestre 101 à l'Académie.",
      "novakidDescription": "Pluton était considérée comme la neuvième planète du système Sol avant que son statut ne soit révoqué. Maintenant, c'est juste une petite canaille."
    }
  },
