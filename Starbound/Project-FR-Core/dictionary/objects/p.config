  },
  "plantdesklamp": {
    "name": "Lampe de Bureau Organique",
    "desc": "Une lampe de bureau fabriquée à partir d'une cosse de plante luminescente.",
    "metadata": {
      "apexDescription": "Cette lampe de bureau est en fait une plante électroluminescente.",
      "avianDescription": "Cette lampe n'est qu'un support pour positionner cette plante brillante.",
