  },
  "plantorb": {
    "name": "Orbe Lumineux",
    "desc": "Un orbe lumineux. On dirait qu'il y a de la place pour ranger des choses à l'intérieur.",
    "metadata": {
      "apexDescription": "Cette plante émet une lueur verte maladive.",
      "avianDescription": "Une plante lumineuse, l'orbe est creux à l'intérieur.",
