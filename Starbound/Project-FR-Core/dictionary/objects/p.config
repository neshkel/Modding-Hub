  "protectorateinfobooth": {
    "name": "Stand d'Information",
    "desc": "Une bonne source d'informations.",
    "metadata": {
      "apexDescription": "Si jamais je suis perdu, je peux toujours demander de l'aide à la dame du stand d'info.",
      "avianDescription": "Mami, la dame du stand d'info, est super serviable.",
      "floranDescription": "Même sssi c'essst une Hylotl visssqueussse, la dame de l'info essst gentille et utile.",
      "glitchDescription": "Appréciatif. Mami au bureau d'information est adorable et serviable.",
      "humanDescription": "La dame du stand d'info a toujours un conseil utile.",
      "hylotlDescription": "Mami au bureau d'info m'a aidé sans relâche quand j'étais un nouvel étudiant confus.",
      "novakidDescription": "Dès qu'j'ai besoin d'un p'tit coup de main amical, j'viens ici."
    }
  },
  "protectoratelavalamp": {
    "name": "Lampe à Lave du Protectorat",
    "desc": "C'est envoûtant. Je ne peux pas détourner le regard.",
    "metadata": {
      "apexDescription": "Une lampe hypnotisante.",
      "avianDescription": "Cette lampe exige qu'on la regarde fixement.",
      "floranDescription": "Est-ce que cette lampe essst vivante? Çccca bouge à l'intérieur!",
      "glitchDescription": "Calme. Ce liquide bouge d'une manière fascinante.",
      "humanDescription": "Ça me rappelle un mauvais rêve que j'ai fait un jour.",
      "hylotlDescription": "La façon dont le liquide reflue et coule me rend nostalgique.",
      "novakidDescription": "C'te lampe a l'air aussi bizarre que moi. Étrange."
    }
  },
  "protectoratelight": {
    "name": "Néon Brisé",
    "desc": "Ce néon a connu des jours meilleurs.",
    "metadata": {
      "apexDescription": "Cette lumière n'émet qu'un faible scintillement. Peut-être peut-elle être réparée.",
      "avianDescription": "Cette lumière est presque totalement hors service.",
      "floranDescription": "Lumière qui gréssssille et clignote.",
      "glitchDescription": "Mécontent. Ce néon est presque non fonctionnel.",
      "humanDescription": "Une lampe brisée qui vacille faiblement.",
      "hylotlDescription": "Cette lumière semble ne pas fonctionner correctement.",
      "novakidDescription": "C'te lumière foutue n'éclaire pas plus qu'une bougie."
    }
  },
  "protectoratelightrays": {
    "name": "Rayons de lumière du Protectorat",
    "desc": "De magnifiques et chauds rayons de lumière.",
    "metadata": {
      "apexDescription": "Si merveilleusement chaud sur la fourrure.",
      "avianDescription": "Si seulement je pouvais voler face au soleil.",
      "floranDescription": "Tant de chaleur, Floran sssent une vague d'énergie.",
      "glitchDescription": "Détendu. Le soleil réchauffe mes circuits.",
      "humanDescription": "Ah, le soleil, il n'y a rien de tel.",
      "hylotlDescription": "Si je reste trop longtemps au soleil, je risque de me dessécher.",
      "novakidDescription": "C'te chaleur me rappelle la maison."
    }
  },
  "protectoratelobbybin": {
    "name": "Poubelle du Protectorat",
    "desc": "Une poubelle.",
    "metadata": {
      "apexDescription": "Une poubelle à déchets.",
      "avianDescription": "Une poubelle.",
      "floranDescription": "Poubelle dégoûtante!",
      "glitchDescription": "Neutre. Juste une poubelle standard.",
      "humanDescription": "Une poubelle. Passionnant! Ou pas.",
      "hylotlDescription": "Des détritus sont éparpillés autour de cette poubelle.",
      "novakidDescription": "C'est une poubelle."
    }
  },
  "protectoratelobbychair": {
    "name": "Chaise de Hall du Protectorat",
    "desc": "Une jolie chaise pour les étudiants branchés du Protectorat.",
    "metadata": {
      "apexDescription": "Une chaise au design sympa.",
      "avianDescription": "Cette chaise est en forme d'œuf!",
      "floranDescription": "Floran sss'est endormi ici une fois.",
      "glitchDescription": "Neutre. C'est une chaise en forme d'œuf.",
      "humanDescription": "N'importe qui a l'air cool assis dans cette chaise.",
      "hylotlDescription": "Une chaise en forme d'œuf. On se sent en sécurité quand on s'assoit dedans.",
      "novakidDescription": "C'est une chouette chaise. Elle est confortable en plus."
    }
  },
  "protectoratelobbylockers": {
    "name": "Casiers Verrouillés du Protectorat",
    "desc": "Une rangée de casiers verrouillés du Protectorat.",
    "metadata": {
      "apexDescription": "Une rangée de casiers. Ils sont verrouillés.",
      "avianDescription": "Des casiers d'étudiants. Ils sont verrouillés.",
      "floranDescription": "Cassssiers pour mettre sssesss affaires. Ceux-là sssont fermés.",
      "glitchDescription": "Désintéressé. Des casiers verrouillés.",
      "humanDescription": "Ces casiers sont fermés à clé.",
      "hylotlDescription": "Ce sont les casiers des étudiants. Le mien est ailleurs.",
      "novakidDescription": "C'est pas mon casier. Le mien est kek' part par là."
    }
  },
  "protectoratelobbylockers2": {
    "name": "Mon Casier",
    "desc": "Une rangée de casiers du Protectorat, incluant le vôtre.",
    "metadata": {
      "apexDescription": "L'un de ces casiers est le mien.",
      "avianDescription": "Des casiers d'étudiants, dont le mien.",
      "floranDescription": "Floran possssède ce cassssier.",
      "glitchDescription": "Familier. C'est mon casier depuis plusieurs années.",
      "humanDescription": "Mon casier, là où je garde mes manuels et mes posters de groupes.",
      "hylotlDescription": "Ce humble casier d'étudiant a été bon envers moi.",
      "novakidDescription": "Ouaip, c'est mon casier. Y'a pas grand-chose dedans, cela dit."
    }
  },
  "protectoratelobbyplant": {
    "name": "Plante de Hall du Protectorat",
    "desc": "Une jolie plante de hall.",
    "metadata": {
      "apexDescription": "Une plante d'intérieur robuste. Elles sont courantes.",
      "avianDescription": "Une plante ravissante. Il y en a quelques-unes en pot dans l'académie.",
      "floranDescription": "Ami feuillu. Floran aime ta compagnie.",
      "glitchDescription": "Observateur. Ficus benjamina. Une plante d'intérieur commune à l'académie.",
      "humanDescription": "Une jolie plante. Elle a l'air... d'une plante.",
      "hylotlDescription": "Avoir la nature près de nous est un bon rappel de nos origines.",
      "novakidDescription": "Une plante en pot. J'peux pas dire que ce soit bien palpitant."
    }
  },
  "protectoratelobbyracebanners": {
    "name": "Bannières des Races du Protectorat",
    "desc": "Bannières des races de l'Académie du Protectorat.",
    "metadata": {
      "apexDescription": "Ces bannières représentent les différentes races.",
      "avianDescription": "Des bannières colorées représentant six races. La bannière Avian est sur la droite.",
      "floranDescription": "La bannière Floran a la meilleure couleur. Vert comme jeune feuille.",
      "glitchDescription": "Fier. Les six bannières raciales! La bannière Glitch est de ma nuance de gris préférée.",
      "humanDescription": "Six bannières. Chacune représente une race différente.",
      "hylotlDescription": "Chaque bannière représente une race. Personnellement, je préfère la simplicité de celle des Hylotls.",
      "novakidDescription": "Six bannières raciales pendues au-dessus de la fenêtre."
    }
  },
  "protectoratelobbytable": {
    "name": "Table de Hall du Protectorat",
    "desc": "Une table de l'académie du Protectorat.",
    "metadata": {
      "apexDescription": "Une table simple. Je l'aime bien.",
      "avianDescription": "Cette table est très blanche. Elle me rappelle les nuages d'été.",
      "floranDescription": "Table blanche et propre. Floran peut voir ssson reflet dedans.",
      "glitchDescription": "Peu impressionné. Une table blanche au design sobre. Peut-être une conception Apex.",
      "humanDescription": "C'est une table super cool! Je me sens classe à côté d'elle.",
      "hylotlDescription": "Une table moderne avec une surface brillante.",
      "novakidDescription": "J'suis pas un passionné de tables, mais j'trouve que celle-ci a fière allure."
    }
  },
  "protectoratelobbytv": {
    "name": "Télévision de Hall",
    "desc": "Une télévision diffusant un reportage d'actualité.",
    "metadata": {
      "apexDescription": "Une télé diffusant des informations instructives et impartiales.",
      "avianDescription": "Une télé accrochée au mur. Le son est coupé.",
      "floranDescription": "La télé montre desss gens en pleine diss sscussion. Dommage que le ssson ssoit coupé.",
      "glitchDescription": "Intéressé. Oh waouh! Les Turbo Bootz existent maintenant en vert et magenta.",
      "humanDescription": "C'est un programme d'actualités, mais le volume est baissé.",
      "hylotlDescription": "Un programme d'information couvrant les derniers développements sur la planète.",
      "novakidDescription": "Un écran télé. C'est toujours la même chaîne d'infos."
    }
  },
  "protectoratelobbyvending": {
    "name": "Distributeur du Protectorat",
    "desc": "Un distributeur automatique du hall du Protectorat.",
    "metadata": {
      "apexDescription": "Ce distributeur vend des boissons et des en-cas.",
      "avianDescription": "On peut acheter des boissons énergisantes dans cette machine.",
      "floranDescription": "Lesss boissssonsss énergisssantesss aident Floran à révissser pour lesss examensss!",
      "glitchDescription": "Déçu. Ces boissons énergisantes ne font pas grand-chose pour un Glitch.",
      "humanDescription": "Oh lala. J'ai bu beaucoup trop de ces boissons énergisantes.",
      "hylotlDescription": "Un distributeur pour acheter des boissons sucrées et des snacks.",
      "novakidDescription": "Ces boissons peuvent vous tenir éveillé toute la nuit. C'est de la folie, j'vous dis.",
      "interactData.paneLayoutOverride.windowtitle.title": " Distributeur",
      "interactData.paneLayoutOverride.windowtitle.subtitle": " En-cas Savoureux"
    }
  },
  "protectoratemanipulator": {
    "name": "Manipulateur de Matière du Protectorat",
    "desc": "Une réplique d'un Manipulateur de Matière.",
    "metadata": {
      "apexDescription": "Cette réplique d'un Manipulateur de Matière est assez fidèle.",
      "avianDescription": "Le Manipulateur de Matière. Un outil puissant.",
      "floranDescription": "Manipulateur de Matière. Floran a hâte d'en avoir un!",
      "glitchDescription": "Appréciatif. Le Manipulateur de Matière est un outil puissant. Ceci n'est qu'une réplique.",
      "humanDescription": "Bientôt j'aurai mon propre Manipulateur de Matière! Je suis impatient.",
      "hylotlDescription": "Le Manipulateur de Matière est l'outil emblématique des Protecteurs.",
      "novakidDescription": "À la cérémonie d'aujourd'hui, j'vais avoir mon propre Manipulateur. C'est un grand jour."
    }
  },
  "protectorateportrait1": {
    "name": "Portrait du Grand Protecteur",
    "desc": "Un portrait d'un ancien Grand Protecteur.",
    "metadata": {
      "apexDescription": "Un portrait du premier Grand Protecteur. Il a un regard sévère.",
      "avianDescription": "Un portrait du premier Grand Protecteur. Il a l'air très fier du livre qu'il tient.",
      "floranDescription": "Vieux monsieur de chair. Mort maintenant!",
      "glitchDescription": "Impressionné. Cet humain fut le premier Grand Protecteur. Quel accomplissement.",
      "humanDescription": "Le premier Grand Protecteur! Il ressemble exactement à ce qu'on imagine.",
      "hylotlDescription": "Un portrait du premier Grand Protecteur. Tant de sagesse dans ses yeux.",
      "novakidDescription": "Une peinture du tout premier Grand Protecteur. Un gars à l'air strict."
    }
  },
  "protectorateportrait2": {
    "name": "Portrait du Grand Protecteur",
    "desc": "Un portrait d'un ancien Grand Protecteur.",
    "metadata": {
      "apexDescription": "Cette Grande Protectrice dégage une gentillesse tranquille.",
      "avianDescription": "Cette Grande Protectrice a l'air amicale. Je serais devenu son ami si elle n'était pas morte depuis longtemps.",
      "floranDescription": "La persssonne de chair ne peut passs échapper à Floran.",
      "glitchDescription": "Calme. Cette femme semble avoir été accueillante envers les autres.",
      "humanDescription": "J'aime le visage de cette ancienne Grande Protectrice. Elle a l'air d'avoir été sympathique.",
      "hylotlDescription": "Cette ancienne Grande Protectrice semble calme et accueillante.",
      "novakidDescription": "C'te vieille dame a l'air d'avoir été une âme charitable."
    }
  },
  "protectorateportrait3": {
    "name": "Portrait du Grand Protecteur",
    "desc": "Un portrait d'un ancien Grand Protecteur.",
    "metadata": {
      "apexDescription": "Ce Grand Protecteur fut le premier non-humain à occuper ce poste.",
      "avianDescription": "Ce Hylotl est devenu Grand Protecteur bien qu'il ne soit pas humain. C'est merveilleux!",
      "floranDescription": "Persssonne-poissson sss'essst fait piéger dans la peinture. Floran ne peut passs la ssso r tir.",
      "glitchDescription": "Impressionné. Ça a dû être difficile d'être un Grand Protecteur Hylotl à l'époque.",
      "humanDescription": "Le premier Grand Protecteur non-humain. Je suis sûr qu'il devait être très sage.",
      "hylotlDescription": "Quelle inspiration! Le seul Hylotl à être devenu Grand Protecteur jusqu'ici.",
      "novakidDescription": "C'est le premier portrait qui n'est pas un humain. C'est pas rien."
    }
  },
  "protectorateportrait4": {
    "name": "Portrait du Grand Protecteur",
    "desc": "Un portrait d'un ancien Grand Protecteur.",
    "metadata": {
      "apexDescription": "Cet ancien Grand Protecteur pourrait être bien plus vieux qu'il n'en a l'air.",
      "avianDescription": "Ce vieux Grand Protecteur a une étincelle de jeunesse dans ses vieux yeux.",
      "floranDescription": "Encore desss gens de chair ridésss.",
      "glitchDescription": "Calme. Ce Grand Protecteur avait une lueur amicale dans son regard buriné.",
      "humanDescription": "Ce Grand Protecteur a l'air vieux, mais possède l'étincelle amicale d'un homme plus jeune.",
      "hylotlDescription": "Ce Grand Protecteur a beau paraître vieux, son esprit jeune est visible dans ses yeux.",
      "novakidDescription": "Ce vieux bonhomme a encore l'étincelle de la jeunesse en lui."
    }
  },
  "protectorateportrait5": {
    "name": "Portrait du Grand Protecteur",
    "desc": "Un portrait d'un ancien Grand Protecteur.",
    "metadata": {
      "apexDescription": "Cette ancienne Grande Protectrice a l'air à la fois vieille et avenante.",
      "avianDescription": "Une ancienne Grande Protectrice, qui semble vieille et inoffensive.",
      "floranDescription": "Floran pourrait battre la vieille Grande Protectrice au combat...",
      "glitchDescription": "Accueillant. Cette Grande Protectrice semblait très agréable à côtoyer.",
      "humanDescription": "Cette Grande Protectrice a l'air d'avoir toujours eu une réserve de lait et de biscuits à disposition.",
      "hylotlDescription": "Cette Grande Protectrice du temps jadis semblait d'une immense bonté.",
      "novakidDescription": "C'te vieille Grande Protectrice n'aurait pas fait de mal à une mouche."
    }
  },
  "protectorateposter1": {
    "name": "Affiche",
    "desc": "Une affiche d'un Manipulateur de Matière.",
    "metadata": {
      "apexDescription": "Une affiche plutôt dramatique d'un Manipulateur de Matière.",
      "avianDescription": "Le Manipulateur de Matière est le bien le plus précieux d'un diplômé du Protectorat.",
      "floranDescription": "Une afffiche de l'outil le plusss important desss Protecteursss!",
      "glitchDescription": "Inspiré. Cette affiche me donne envie de partir à l'aventure à travers l'univers.",
      "humanDescription": "Cette affiche présente le Manipulateur de Matière, le multi-outil tant prisé du Protectorat.",
      "hylotlDescription": "Le Manipulateur de Matière, un outil aux multiples capacités. Quelle inspiration.",
      "novakidDescription": "Les gens comme moi auraient bien besoin d'un outil comme ce Manipulateur."
    }
  },
  "protectorateposter2": {
    "name": "Affiche",
    "desc": "Une affiche rétro.",
