      "glitchDescription": "Ravi. Une savoureuse gomme mauve.",
      "humanDescription": "Des bonbons! Oui!",
      "hylotlDescription": "Ça a l'air appétissant.",
      "novakidDescription": "Un bonbon qui a l'air sacrément bon!"
