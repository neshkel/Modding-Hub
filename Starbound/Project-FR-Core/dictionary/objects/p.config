  "peacekeepertable": {
    "name": "Table de Pacificateur",
    "desc": "Une table très lourde et robuste en métal.",
    "metadata": {
      "apexDescription": "Cette table renforcée pourrait servir d'abri efficace lors d'une fusillade.",
      "avianDescription": "Quelqu'un a tenté d'égayer cette table avec une bande jaune. Pas très convaincant.",
      "floranDescription": "Floran pourrait posser trophées de chasse sur la table. Utile.",
      "glitchDescription": "Curieux. Je me demande si cette table pourrait résister au coup d'une hache?",
      "humanDescription": "J'ai vu beaucoup de tables dans ma vie, et celle-ci en est certainement une.",
      "hylotlDescription": "C'est une table assez inesthétique.",
      "novakidDescription": "C'te table a l'air rudement lourde à déplacer!"
    }
  },
  "peacekeepervendingmachine": {
    "name": "Distributeur de Pacificateur",
    "desc": "Un distributeur automatique qui semble cuire et distribuer uniquement des donuts.",
    "metadata": {
      "apexDescription": "Ces pâtisseries sont si mauvaises pour la santé. Je ne devrais pas en abuser.",
      "avianDescription": "Des donuts? Comme c'est charmant!",
      "floranDescription": "Floran n'aime pas friandissses qui ne sont pas faites de viande.",
      "glitchDescription": "Excité. De tels trésors se cachent à l'intérieur!",
      "humanDescription": "Des donuts! La nourriture préférée de l'humanité.",
      "hylotlDescription": "Ces gâteries ne valent pas la peine de polluer mon corps. Enfin... peut-être juste un.",
      "novakidDescription": "V'voyez, j'suis même pas sûr qu'ce soit mauvais pour quelqu'un comme moi.",
      "interactData.paneLayoutOverride.windowtitle.title": " Vendeur de Donuts",
      "interactData.paneLayoutOverride.windowtitle.subtitle": " Faites le plein de pâtisseries!"
    }
  },
  "penguinbarbottom": {
    "name": "Bar de Pingouin",
    "desc": "Un bar digne d'un pingouin.",
    "metadata": {
      "apexDescription": "Ce bar a sans doute connu des jours meilleurs.",
      "avianDescription": "Ce bar a dû être joli autrefois.",
      "floranDescription": "Ce bar est fait de bois de basse qualité.",
      "glitchDescription": "Peu impressionné. Ce bar est rayé et crasseux.",
      "humanDescription": "Ce bar est aussi bon marché qu'on le dit. Ça lui donne du caractère!",
      "hylotlDescription": "Ce bar est dans un tel état que je suis surpris qu'il tienne debout.",
      "novakidDescription": "C'bar n'est pas délabré, il est juste bien utilisé!"
    }
  },
  "penguinbartop": {
    "name": "Comptoir de Bar de Pingouin",
    "desc": "Un comptoir de bar digne d'un pingouin.",
    "metadata": {
      "apexDescription": "Le bar n'est pas très bien approvisionné. Je ne suis pas convaincu qu'ils servent vraiment ici...",
      "avianDescription": "Pour un bar avec autant de bouteilles, je ne vois jamais le barman en vendre une seule...",
      "floranDescription": "Le bar ne vend de boissson à personne!",
      "glitchDescription": "Suspicieux. Le barman tient une bouteille, mais il ne vend rien à personne...",
      "humanDescription": "Ce bar est à peine stocké. Ils n'ont pas l'intention de vendre des boissons.",
      "hylotlDescription": "Quel stock de basse qualité. C'est un soulagement que rien ne soit à vendre.",
      "novakidDescription": "C'bouge n'essaie même pas d'faire semblant d'vendre des verres."
    }
  },
  "penguinbartop2": {
    "name": "Comptoir de Bar de Pingouin",
    "desc": "Un comptoir de bar digne d'un Pingouin.",
    "metadata": {
      "apexDescription": "Le bar n'est pas très bien approvisionné. Est-ce vraiment un bar?",
      "avianDescription": "Je ne vois pas le barman vendre quoi que ce soit...",
      "floranDescription": "Bar ne vend rien!",
      "glitchDescription": "Suspicieux. On dirait une couverture pour autre chose.",
      "humanDescription": "C'est assez évident qu'ils ne vendent pas de boissons ici.",
      "hylotlDescription": "Un établissement de bien piètre qualité.",
      "novakidDescription": "C'bouge n'essaie même pas d'faire semblant d'vendre des verres.",
      "interactData.paneLayoutOverride.windowtitle.title": "Bar du Beakeasy",
      "interactData.paneLayoutOverride.windowtitle.subtitle": "Engagez des mercenaires Pingouins!"
    }
  },
  "penguinbarlamp": {
    "name": "Lampe de Bar de Pingouin",
    "desc": "Un plafonnier métallique.",
    "metadata": {
      "apexDescription": "Un plafonnier métallique.",
      "avianDescription": "Un plafonnier.",
      "floranDescription": "Lampe ssuspendue.",
      "glitchDescription": "Blasé. Un luminaire.",
      "humanDescription": "Un appareil qu'on s'attache sur la tête... Ah non, c'est juste une lampe.",
      "hylotlDescription": "Un plafonnier sans intérêt.",
      "novakidDescription": "Une lampe de plafond toute simple."
    }
  },
  "penguinbarsign": {
    "name": "Enseigne de Bar de Pingouin",
    "desc": "C'est fascinant. Je ne peux pas détacher mon regard.",
    "metadata": {
      "apexDescription": "Une enseigne de bar qui attire l'œil.",
      "avianDescription": "Cette enseigne exige d'être contemplée.",
      "floranDescription": "Oiseaux trappus ont un bar.",
      "glitchDescription": "Curieux. Est-ce cassé, ou est-ce fait exprès?",
      "humanDescription": "Ooh, un bar! Avec des pingouins!",
      "hylotlDescription": "Cette enseigne n'est pas discrète, mais elle a du charme.",
      "novakidDescription": "Ces oisiaux chahuteurs ont fini par s'trouver un bar."
    }
  },
  "penguinbay": {
    "name": "Penguin Bay",
    "desc": "Cet endroit vend des licences de vaisseau contrefaites.",
    "metadata": {
      "apexDescription": "Des oiseaux suspects et leurs marchandises du marché noir.",
      "avianDescription": "Les pingouins me rendent nerveux.",
      "floranDescription": "Pingouin tout mous et croustillant avec trucs à vendre!",
      "glitchDescription": "Amusé. Ces minuscules pingouins sont des contrebandiers.",
      "humanDescription": "J'ai l'impression d'être dans un film de gangsters.",
      "hylotlDescription": "Des oiseaux criminels et grossiers.",
      "novakidDescription": "Des piafs turbulents qui vendent du matos louche. Tout c'que j'aime.",
      "interactData.paneLayoutOverride.windowtitle.title": "The Penguin Bay",
      "interactData.paneLayoutOverride.windowtitle.subtitle": "Licences de vaisseau 100 % légitimes"
    }
  },
  "penguinbayclosed": {
    "name": "Penguin Bay Fermé",
    "desc": "Ce serait un endroit sympa pour une boutique.",
    "metadata": {
      "apexDescription": "C'est un très gros cadenas sur cette porte... Et une ancre encore plus grosse.",
      "avianDescription": "Cette caisse est sécurisée par un cadenas surdimensionné. Qu'y a-t-il dedans?",
      "floranDescription": "Floran veut ssavoir ce qu'il y a dedans.",
      "glitchDescription": "Curieux. Comment ont-ils obtenu une ancre aussi grande?",
      "humanDescription": "L'ancre sur cette caisse est énorme. D'où peut-elle bien venir?",
      "hylotlDescription": "Est-ce que cette ancre géante provient d'un navire géant?",
      "novakidDescription": "C'est une boîte bien louche. J'me demande c'qu'il y a dedans?"
    }
  },
  "penguinweaponshop": {
    "name": "Armurerie Honorable de Biggy",
    "desc": "Propose des améliorations pour les armes rares.",
    "metadata": {
      "apexDescription": "Une sorte de comptoir du marché noir pour les armes.",
      "avianDescription": "Tellement d'épées. La plupart sont plus grandes que le marchand!",
      "floranDescription": "Floran voit plein d'armess. Floran excité.",
      "glitchDescription": "Impressionné. Comment ce bout de commerçant soulève-t-il sa marchandise?",
      "humanDescription": "Ça ressemble à un établissement parfaitement respectable!",
      "hylotlDescription": "Le marchand a des goûts excentriques en matière de chapeaux.",
      "novakidDescription": "Pas mal d'outils qui cognent dur ici. Ça pourrait servir.",
      "interactData.paneLayoutOverride.windowtitle.title": "Armurerie Honorable de Biggy",
      "interactData.paneLayoutOverride.windowtitle.subtitle": " ^#b9b5b2;Améliorations d'armes chaque jour!"
