  },
  "protectorateclock": {
    "name": "Horloge du Protectorat",
    "desc": "Je suis très, très en retard!",
    "metadata": {
      "apexDescription": "Je devrais vraiment me dépêcher d'aller à la salle de réunion.",
      "avianDescription": "J'ai vraiment dormi comme une souche. Je ferais mieux de me dépêcher!",
      "floranDescription": "Le temps sss'écoule. Floran devrait accélérer.",
      "glitchDescription": "Stressé. Je devrais vraiment me bouger.",
      "humanDescription": "Waouh, c'est l'heure qu'il est? Je devrais me dépêcher.",
      "hylotlDescription": "Je n'arrive pas à croire qu'il soit déjà cette heure-là!",
      "novakidDescription": "La cérémonie n'attendra personne. J'ferais mieux d'me grouiller."
    }
  },
  "protectoratedoor": {
    "name": "Porte de l'Académie du Protectorat",
    "desc": "La porte de l'Académie du Protectorat.",
    "metadata": {
      "apexDescription": "Un sas.",
      "avianDescription": "Un sas.",
      "floranDescription": "Une porte.",
      "glitchDescription": "Neutre. Un sas.",
      "humanDescription": "Un sas.",
      "hylotlDescription": "Un sas.",
      "novakidDescription": "Un sas."
    }
  },
  "protectoratedormbed": {
    "name": "Lit Superposé du Protectorat",
    "desc": "Le lit superposé standard pour les étudiants du Protectorat.",
    "metadata": {
      "apexDescription": "Ces lits sont de conception simple. Ils sont pourtant incroyablement confortables.",
      "avianDescription": "Doux comme le duvet d'un oisillon. Si je n'étais pas pressé, je m'offrirais bien une sieste.",
      "floranDescription": "Floran a sssommeil, mais doit sssse dépêcher pour ne passs rater la cérémonie!",
      "glitchDescription": "Fatigué. Je ne serais pas contre retourner dormir, mais je suppose que je devrais me dépêcher pour la cérémonie.",
      "humanDescription": "J'ai passé de nombreuses nuits à écouter les ronflements de mon voisin.",
      "hylotlDescription": "Le lit superposé standard du Protectorat.",
      "novakidDescription": "Un bon vieux lit du Protectorat. J'aimerais bien pouvoir retourner dans l'mien."
    }
  },
  "protectoratedormmirror": {
    "name": "Miroir de Salle de Bain du Protectorat",
    "desc": "Un miroir de salle de bain de l'académie du Protectorat.",
    "metadata": {
      "apexDescription": "Un lavabo et un miroir.",
      "avianDescription": "C'est un lavabo.",
      "floranDescription": "Eau propre pour sss'éclabousssser ou ssse laver.",
      "glitchDescription": "Jaloux. D'autres étudiants se brossent les dents ici. Parfois, je polis ma mâchoire.",
      "humanDescription": "Je n'ai pas le temps de me brosser les dents!",
      "hylotlDescription": "Parfois, je viens ici et j'ouvre le robinet. Le bruit de l'eau qui coule est apaisant.",
      "novakidDescription": "Un lavabo et un miroir."
    }
  },
  "protectoratedormtoilet": {
    "name": "Toilettes du Dortoir du Protectorat",
    "desc": "Les toilettes standard des dortoirs du Protectorat.",
    "metadata": {
      "apexDescription": "Ces toilettes ont une chasse d'eau automatique.",
      "avianDescription": "Des toilettes! J'ai eu d'excellentes idées en restant assis là-dessus.",
      "floranDescription": "Floran n'aime passs partager lesss toilettesss avec d'autresss étudiantsss.",
      "glitchDescription": "Satisfait. Ces toilettes sont très propres!",
      "humanDescription": "Tu connais la blague du petit coin? Laisse tomber, elle est trop sale.",
      "hylotlDescription": "Je n'ai pas besoin d'utiliser ça. Je devrais me dépêcher pour la cérémonie!",
      "novakidDescription": "Ouaip. C'est bien des toilettes."
    }
  },
  "protectoratedormtoiletroll": {
    "name": "Dérouleur de Papier Toilette du Protectorat",
    "desc": "Un dérouleur de papier toilette. Espérons qu'il n'en manque pas!",
    "metadata": {
      "apexDescription": "Un dérouleur de papier toilette. Il a été rechargé récemment.",
      "avianDescription": "Du papier toilette de qualité supérieure! C'est tellement doux.",
      "floranDescription": "Le papier toilette essst presssque fini!",
      "glitchDescription": "Compatissant. Ce rouleau de papier a un travail ingrat.",
      "humanDescription": "L'horreur de réaliser que le rouleau est vide! Heureusement, ce n'est pas le cas ici.",
      "hylotlDescription": "Un porte-rouleau de papier toilette.",
      "novakidDescription": "Un dérouleur avec encore pas mal de papier dessus."
    }
  },
  "protectorateextinguisher": {
    "name": "Extincteur du Protectorat",
    "desc": "Un extincteur pour quand le pire arrive.",
    "metadata": {
      "apexDescription": "La sécurité avant tout.",
      "avianDescription": "Un extincteur.",
      "floranDescription": "Tueur de feu! Floran détestssse le feu.",
      "glitchDescription": "Détendu. Je suis ravi qu'il y ait des mesures de sécurité par ici.",
      "humanDescription": "Un extincteur. Je doute qu'il ait jamais servi.",
      "hylotlDescription": "C'est un extincteur.",
      "novakidDescription": "Pour éteindre les feux."
    }
  },
  "protectoratefallenrope": {
    "name": "Cordon de Sécurité au Sol",
    "desc": "Un ruban de balisage tombé.",
    "metadata": {
      "apexDescription": "Un ruban. Il est tombé.",
      "avianDescription": "Ce ruban rouge est tombé par terre.",
      "floranDescription": "La barrière de ruban rouge essst cassssée...",
      "glitchDescription": "Triste. Des objets brisés éparpillés sur le sol...",
      "humanDescription": "Ce ruban est tombé.",
      "hylotlDescription": "C'est triste. Ce ruban a dû tomber pendant les turbulences.",
      "novakidDescription": "C'te corde ne tient plus debout."
    }
  },
  "protectoratefbannertorn1": {
    "name": "Bannière Murale Déchirée du Protectorat",
    "desc": "Une bannière murale déchirée de l'académie du Protectorat.",
    "metadata": {
      "apexDescription": "Cette bannière est déchirée...",
      "avianDescription": "Une bannière déchirée! Dévastateur!",
      "floranDescription": "Bannière cassssée... Floran essst trisssste de voir çccca.",
      "glitchDescription": "Dévasté. Une bannière du Protectorat déchirée...",
      "humanDescription": "La bannière du Protectorat ne tient plus très bien.",
      "hylotlDescription": "Cette bannière est en lambeaux. Ça me brise le cœur.",
      "novakidDescription": "Même ces fières bannières ne tiennent plus l'coup."
    }
  },
  "protectoratefbannertorn2": {
    "name": "Bannière Murale Déchirée du Protectorat",
    "desc": "Une bannière murale déchirée de l'académie du Protectorat.",
    "metadata": {
      "apexDescription": "Cette bannière est déchirée...",
      "avianDescription": "Une bannière déchirée! Dévastateur!",
      "floranDescription": "Bannière cassssée... Floran n'aime passs çccca.",
      "glitchDescription": "Dévasté. Une bannière du Protectorat déchirée...",
      "humanDescription": "La bannière du Protectorat n'est pas en très bon état.",
      "hylotlDescription": "La bannière se déchire! Tout comme mon cœur.",
      "novakidDescription": "Même les fières bannières sont en train de lâcher."
    }
  },
  "protectoratefigures": {
    "name": "Jouet Poptop du Protectorat",
    "desc": "Une figurine de Poptop provenant du Protectorat.",
    "metadata": {
      "apexDescription": "Quelques jouets.",
      "avianDescription": "Des jouets mignons.",
      "floranDescription": "Desss jouetsss qui regardent Floran!",
      "glitchDescription": "Joyeux. De belles pièces de collection!",
      "humanDescription": "De jolies figurines de collection!",
      "hylotlDescription": "Ces figurines sont très mignonnes.",
      "novakidDescription": "Des p'tits jouets."
    }
  },
  "protectorateflower": {
    "name": "Fleur du Protectorat",
    "desc": "Quelle jolie fleur!",
    "metadata": {
      "apexDescription": "Une ravissante fleur rose. Je devrais la ramasser et la garder en souvenir de cette journée.",
      "avianDescription": "Quelle fleur vibrante et pleine d'espoir. Je devrais l'emporter avec moi!",
      "floranDescription": "Hé petit ami... Peut-être que Floran pourrait garder fleur dans sssesss pochetesss!",
      "glitchDescription": "Sentimental. Je devrais cueillir ceci et le garder en souvenir de ma remise de diplôme.",
      "humanDescription": "Salut toi... Je devrais peut-être t'emmener comme souvenir de ma promotion?",
      "hylotlDescription": "Quelle fleur magnifique pour une si belle journée. Devrais-je la prendre?",
      "novakidDescription": "J'suis pas du genre sentimental... mais j'ai bien envie d'embarquer c'te fleur en souvenir d'aujourd'hui."
    }
  },
  "protectorategamesconsole": {
    "name": "Console de Jeux du Protectorat",
    "desc": "Pour quand vous voulez procrastiner.",
    "metadata": {
      "apexDescription": "Parfois, je l'allume pour faire quelques parties avec mes colocataires.",
      "avianDescription": "Ah, ma vieille console. Je me suis concentré sur mes études, alors elle est un peu poussiéreuse...",
      "floranDescription": "Lesss jeux de tir sssont lesss préférésss de Floran!",
      "glitchDescription": "Enthousiaste. Ma console de jeux! J'essaie de ne pas me laisser distraire pendant la période des examens.",
      "humanDescription": "Oh la la... J'aimerais tellement pouvoir jouer un peu là maintenant.",
      "hylotlDescription": "Je ne peux pas me laisser distraire par des jeux en ce moment.",
      "novakidDescription": "Travailler dur, s'amuser dur. C'est comme ça qu'on fait par ici."
    }
  },
  "protectorategardenbench": {
    "name": "Banc de Jardin du Protectorat",
    "desc": "Un banc trouvé dans le jardin du Protectorat. Il comporte une plaque.",
    "metadata": {
      "apexDescription": "Un banc en bois massif. La plaque indique « En l'honneur d'Esther Bright ».",
      "avianDescription": "Il y a une plaque sur ce banc. On peut y lire « En l'honneur d'Esther Bright ».",
      "floranDescription": "Floran sss'asssoit sssouvent sssur ce banc. La plaque dit « En l'honneur d'Esther Bright ».",
      "glitchDescription": "Intrigué. Je n'avais jamais lu la plaque de ce banc auparavant... « En l'honneur d'Esther Bright ».",
      "humanDescription": "Un joli banc en bois. La plaque indique « En l'honneur d'Esther Bright ».",
      "hylotlDescription": "La plaque sur ce banc indique « En l'honneur d'Esther Bright ».",
      "novakidDescription": "Voyons voir c'que dit c'te plaque... « En l'honneur d'Esther Bright »."
    }
  },
  "protectorategardentree": {
    "name": "Arbustes du Jardin du Protectorat",
    "desc": "Des arbustes du jardin du Protectorat.",
    "metadata": {
      "apexDescription": "Le grand arbre. Son tronc est large et solide. Je me demande ce qui se passera quand il sera trop grand pour cette plateforme.",
      "avianDescription": "Ce grand arbre est précieux pour le Protectorat. J'ai entendu dire qu'il est aussi vieux que l'académie.",
      "floranDescription": "Le grand arbre essst vieux et sssage. Floran voudrait devenir aussssi vieux et sssage que l'arbre.",
      "glitchDescription": "Impressionné. Cet arbre est aussi vieux que l'académie.",
      "humanDescription": "L'arbre du Protectorat. On l'appelle simplement « l'Arbre ».",
      "hylotlDescription": "La floraison est plus éclatante et plus belle cette année que je ne l'ai jamais vue.",
      "novakidDescription": "On raconte que l'vieux grand arbre est aussi ancien que l'académie elle-même."
    }
  },
  "protectorateguidelines": {
    "name": "Vieux Livre du Protectorat",
    "desc": "Un vieux livre rempli de directives pour les Protecteurs.",
    "metadata": {
      "apexDescription": "Ce livre contient les directives originales, un peu datées, pour devenir un Protecteur.",
      "avianDescription": "Un livre écrit il y a longtemps contenant les principes de base pour être un Protecteur.",
      "floranDescription": "Livre poussss ssiéreux avec de vieillesss règlesss.",
      "glitchDescription": "Impressionné. Ce livre est bien conservé.",
      "humanDescription": "Un vieux livre poussiéreux. Il contient des directives obsolètes.",
      "hylotlDescription": "Ce livre contient les toutes premières directives écrites pour devenir Protecteur.",
      "novakidDescription": "Un bouquin qui a l'air vraiment antique."
    }
  },
  "protectorateguitar": {
    "name": "Guitare Rouge du Protectorat",
    "desc": "Une guitare d'étudiant.",
    "metadata": {
      "apexDescription": "Une jolie guitare rouge. Je ne sais pas en jouer.",
      "avianDescription": "Mon coloc joue plutôt bien de la guitare. Peut-être qu'il pourrait m'apprendre.",
      "floranDescription": "Çccca fait desss bruitsss fortsss. Floran aime!",
      "glitchDescription": "Envieux. L'un de mes colocataires sait très bien jouer de la guitare.",
      "humanDescription": "Bien sûr que je sais en jouer. Mais pas maintenant.",
      "hylotlDescription": "La musique. Un langage si expressif.",
      "novakidDescription": "J'préfère l'acoustique, mais j'peux gratter kek' mélodies simples sur ce truc."
    }
  },
  "protectoratehallcurtain": {
    "name": "Rideau de Scène du Protectorat",
    "desc": "Un rideau de scène de l'académie du Protectorat.",
    "metadata": {
      "apexDescription": "Un rideau magnifique. Luxueux.",
      "avianDescription": "Oh waouh, ce rideau ressemble à des nuages cotonneux.",
      "floranDescription": "Rideau doux. Floran aime caresssser.",
      "glitchDescription": "Impressionné. Ce matériau est pour le moins exclusif.",
      "humanDescription": "Ces rideaux sont si doux! Je pourrais m'endormir ici même, adossé contre eux.",
      "hylotlDescription": "Un rideau luxuriant fait de la soie la plus fine.",
      "novakidDescription": "Ces rideaux ont l'air bien chics. J'me demande en quoi c'est fait."
    }
  },
  "protectoratehallcurtain2": {
    "name": "Rideau de Scène du Protectorat",
    "desc": "Un rideau de scène de l'académie du Protectorat.",
    "metadata": {
      "apexDescription": "Un rideau magnifique. Luxueux.",
      "avianDescription": "Oh waouh, ce rideau ressemble à des nuages cotonneux.",
      "floranDescription": "Rideaux doux. Floran aime caresssser.",
