  "protectoratehalllight": {
    "name": "Projecteur de Hall",
    "desc": "Une lumière destinée à attirer l'attention sur une zone.",
    "metadata": {
      "apexDescription": "C'est un petit projecteur.",
      "avianDescription": "C'est un petit projecteur.",
      "floranDescription": "Projecteur.",
      "glitchDescription": "Neutre. Un projecteur.",
      "humanDescription": "Un projecteur parfaitement ordinaire.",
      "hylotlDescription": "Un projecteur ordinaire."
    }
  },
  "protectoratehologlobe": {
    "name": "Hologlobe du Protectorat",
    "desc": "C'est envoûtant. Je ne peux pas détourner le regard.",
    "metadata": {
      "apexDescription": "Cette lampe est un gaspillage d'énergie.",
      "avianDescription": "Une lampe en forme d'orbe qui bouge de manière hypnotique.",
      "floranDescription": "Lampe qui rebondit essst chouette!",
      "glitchDescription": "Appréciatif. J'apprécie ce bibelot, malgré son manque d'utilité.",
      "humanDescription": "Une lampe-balle funky! C'est comme ça que je l'appelle.",
      "hylotlDescription": "Une lampe sphérique apaisante.",
      "novakidDescription": "C'te lampe s'arrête jamais."
    }
  },
  "protectoratehulagirl": {
    "name": "Danseuse Hula du Protectorat",
    "desc": "Une danseuse hula. Aloha!",
    "metadata": {
      "apexDescription": "L'humaine qui se balance semble jouer du ukulélé.",
      "avianDescription": "Cette danseuse porte une jupe en herbe.",
      "floranDescription": "Jouetsss humainsss de mauvaisss goût...",
      "glitchDescription": "Envoûté. Le balancement a un effet presque hypnotique.",
      "humanDescription": "Aloha!",
      "hylotlDescription": "Ça me rappelle le sable blanc et la mer bleue.",
      "novakidDescription": "Regardez-la, en train de gratouiller son p'tit ukulélé."
    }
  },
  "protectorateincap1": {
    "name": "Corps d'un Protecteur",
    "desc": "Un Protecteur...",
    "metadata": {
      "apexDescription": "Je ne veux pas regarder...",
      "avianDescription": "Seigneur Dieu...",
      "floranDescription": "Tant de trisss tesse...",
      "glitchDescription": "Dévasté. Je n'ai pas de mots...",
      "humanDescription": "Je suis tellement désolé...",
      "hylotlDescription": "Je ne peux pas regarder...",
      "novakidDescription": "Non! Ça peut pas arriver."
