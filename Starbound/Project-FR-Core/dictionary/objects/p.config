  "peacekeeperchair": {
    "name": "Chaise de Pacificateur",
    "desc": "Une lourde chaise en métal avec un rembourrage ergonomique.",
    "metadata": {
      "apexDescription": "Cette chaise a l'air de pouvoir faire une barricade efficace en cas de besoin.",
      "avianDescription": "Ce n'est pas la chaise la plus confortable que j'aie jamais vue.",
      "floranDescription": "Floran ne pen s s se pas pouvoir s s soulever cette lourde chais s se.",
      "glitchDescription": "Impressionné. Cette chaise semble pouvoir résister à plusieurs coups violents.",
      "humanDescription": "Cette chaise en métal a l'air inconfortable, mais le dossier semble améliorer la posture!",
      "hylotlDescription": "Cette chaise est entièrement conçue dans un but fonctionnel. C'est assez répugnant.",
      "novakidDescription": "J'pourrais piquer un p'tit roupillon là-dedans, si besoin est."
    }
  },
  "peacekeepercomputer": {
    "name": "Ordinateur de Pacificateur",
    "desc": "Un vieil ordinateur en métal. Équipement standard pour les équipes de recherche des Pacificateurs.",
    "metadata": {
      "apexDescription": "Le boîtier de cet ordinateur semble très résistant. Il serait difficile de le briser.",
      "avianDescription": "Cet ordinateur terne serait bien plus attrayant avec une nouvelle couche de peinture.",
      "floranDescription": "Floran n'a pas le temp s s s pour la boîte à mot s s s.",
      "glitchDescription": "Amusé. Cet énorme ordinateur semble très robuste, mais aussi très démodé.",
      "humanDescription": "Cet immense ordinateur a l'air un peu dépassé. Il serait peut-être temps de passer à la vitesse supérieure?",
      "hylotlDescription": "Ce gros ordinateur semble être utilisé depuis des décennies. Quel triste spectacle.",
      "novakidDescription": "J'apprécie les lumières néon sur c'vieux machin."
    }
  },
  "peacekeeperdesk": {
    "name": "Bureau de Pacificateur",
    "desc": "Un bureau rond, typiquement trouvé dans les stations des Pacificateurs.",
    "metadata": {
      "apexDescription": "Ce bureau est d'une taille tout à fait appropriée.",
      "avianDescription": "Quelqu'un a maintenu ce bureau en bon état!",
      "floranDescription": "Floran peut s s se tenir s s sur la table pour gagner un avantage tactique.",
      "glitchDescription": "C'est certainement un bureau rond... Je ne vois pas trop quoi dire d'autre.",
      "hylotlDescription": "Cette grande table est remarquablement bien polie.",
      "novakidDescription": "C'te table ronde me semble parfaite pour une p'tite partie de cartes."
    }
  },
  "peacekeeperdoor": {
    "name": "Porte de Pacificateur",
    "desc": "Une porte automatique, typiquement utilisée dans les Stations des Pacificateurs.",
    "metadata": {
      "apexDescription": "Cette porte automatique est stylisée avec un emblème de Pacificateur.",
      "avianDescription": "Cette porte est ornée d'un fier emblème.",
      "floranDescription": "Floran voit porte. Floran veut pas s s s er la porte.",
      "glitchDescription": "Impressionné. J'apprécie que cette porte choisisse de s'ouvrir elle-même, plutôt que d'attendre qu'on l'ouvre.",
      "humanDescription": "Vous savez, l'emblème des Pacificateurs ressemble vachement à un visage souriant...",
      "hylotlDescription": "J'ai vu des portes bien plus élégantes que celle-ci.",
      "novakidDescription": "Cette porte s'ouvre toute seule! Sacrément pratique..."
    }
  },
  "peacekeeperemblem": {
    "name": "Emblème de Pacificateur",
    "desc": "Une plaque murale dorée, gravée de l'emblème des Pacificateurs.",
    "metadata": {
      "apexDescription": "Cet emblème est très bien poli.",
      "avianDescription": "Cet emblème poli brille comme le soleil!",
      "floranDescription": "Trop brillant pour Floran. Floran n'a pas confian s s se.",
      "glitchDescription": "Impressionné. Quelqu'un a gardé cet emblème très bien poli.",
      "humanDescription": "Quel emblème géant. Ça fait très officiel.",
      "hylotlDescription": "Quel bouclier élégamment fabriqué.",
      "novakidDescription": "C't emblème est rudement bien astiqué."
    }
  },
  "peacekeeperemblem2": {
    "name": "Emblème de Pacificateur Rouillé",
    "desc": "Une plaque murale rouillée, gravée de l'emblème des Pacificateurs.",
    "metadata": {
      "apexDescription": "Cet emblème a besoin d'un peu d'entretien.",
      "avianDescription": "Cet emblème a manifestement connu des jours meilleurs.",
      "floranDescription": "Le truc au mur est... rouillé.",
      "glitchDescription": "Peu impressionné. Les surfaces métalliques peuvent être maintenues en bon état avec une routine d'entretien correcte.",
      "humanDescription": "Cet emblème a connu des jours meilleurs.",
      "hylotlDescription": "Cet emblème est dans un état de délabrement manifeste.",
      "novakidDescription": "C'bouclier aurait bien besoin d'un coup d'chiffon."
    }
  },
  "peacekeeperfurnishings": {
    "name": "Ameublement de Pacificateur",
    "desc": "De beaux meubles, avec une touche Pacificateur.",
    "metadata": {
      "apexDescription": "Cette grenouille semble vendre des meubles de Pacificateur.",
      "avianDescription": "Je suppose que je pourrais m'acheter quelques meubles de Pacificateur!",
      "floranDescription": "Floran s s se demande pourquoi grenouille ne parle pas s s s.",
      "glitchDescription": "Impressionné. Ce gentil amphibien a poli son casque jusqu'à ce qu'il brille!",
      "humanDescription": "J'imagine que \"Frögg Furnishing\" doit être une chaîne de magasins?",
      "hylotlDescription": "Cet individu curieux semble vendre des meubles.",
      "novakidDescription": "On dirait bien qu'c'est l'occasion idéale pour refaire la déco!",
      "interactData.paneLayoutOverride.windowtitle.title": " Meubles de Pacificateur",
      "interactData.paneLayoutOverride.windowtitle.subtitle": " Décorez comme un Pacificateur!"
    }
  },
  "peacekeeperlamppost": {
    "name": "Lampadaire de Pacificateur",
    "desc": "Un lampadaire brillant, très commun dans les Stations des Pacificateurs.",
    "metadata": {
      "apexDescription": "Un lampadaire bien conçu, probablement en durasteel renforcé.",
      "avianDescription": "Une lampe plutôt élégante!",
      "floranDescription": "Floran a vu beaucoup de lumière s s s hautess s . Celle-ci en est une aus s si.",
      "glitchDescription": "Impressionné. Malgré les apparences, l'extérieur métallique de ce lampadaire est extrêmement durable.",
      "humanDescription": "L'urbanisation galopante n'est pas complète sans un ou deux lampadaires!",
      "hylotlDescription": "Un lampadaire assez laid.",
      "novakidDescription": "C'lampadaire est rudement grand, pas vrai?"
    }
  },
  "peacekeepermug": {
    "name": "Mug de Pacificateur",
    "desc": "Un mug de café frais. Il semble perpétuellement brûlant.",
    "metadata": {
      "apexDescription": "L'apport en caféine est utile pour rester vigilant lors d'une mission.",
      "avianDescription": "Ce mug continue de fumer. Va-t-il finir par refroidir un jour?",
      "floranDescription": "Café chaud, arme improvis s sée efficace contre les gens de chair.",
      "glitchDescription": "Curieux. Une inscription sur ce mug indique: \"Détective n°1 de l'univers\".",
      "humanDescription": "Il y a une inscription sur ce mug: \"Détective n°1 de l'univers\".",
      "hylotlDescription": "Ça a l'air bien trop chaud pour être bu. Je ferais mieux de le laisser.",
      "novakidDescription": "Rien de tel qu'une tasse de café bien frais pour s'mettre en jambe le matin."
    }
  },
  "peacekeepernotes": {
    "name": "Notes de Pacificateur",
    "desc": "Une collection pêle-mêle de pistes et de preuves, utilisée pour traquer les criminels.",
    "metadata": {
      "apexDescription": "On dirait que quelqu'un est sur le point d'élucider un mystère.",
      "avianDescription": "On dirait que quelqu'un essaie passionnément de résoudre un mystère. Comme c'est excitant!",
      "floranDescription": "Floran pas as s s ez interess s s é pour lire desss notesss.",
      "glitchDescription": "Excité. Ces notes semblent indiquer que quelqu'un est proche d'une percée sur une affaire!",
      "humanDescription": "On ne peut pas résoudre de crimes sans journaux, de la ficelle et des notes épinglées n'importe comment sur un mur!",
      "hylotlDescription": "Une approche plutôt rudimentaire pour résoudre des mystères, mais je suppose qu'elle doit être efficace.",
      "novakidDescription": "Yee-haw, on dirait bien qu'quelqu'un est sur l'point d'boucler une grosse affaire!"
    }
  },
  "peacekeeperpainting": {
    "name": "Peinture de Pacificateur",
    "desc": "Une peinture sympa d'un coucher de soleil brumeux sur une plage intemporelle.",
    "metadata": {
      "apexDescription": "C'est une œuvre d'art plaisante.",
      "avianDescription": "En tant qu'Avian, j'aime toujours les représentations artistiques du soleil.",
      "floranDescription": "Floran voit desss arbresss. Floran approuve.",
      "glitchDescription": "Calme. Cette scène peinte évoque un sentiment d'intemporalité.",
      "humanDescription": "Couchers de soleil roses et palmiers... Le rêve.",
      "hylotlDescription": "Un dégradé de couleurs plutôt agréable.",
      "novakidDescription": "Une scène assez intemporelle, pas vrai?"
    }
  },
  "peacekeeperposter1": {
    "name": "Grande Affiche de Pacificateur",
    "desc": "Une affiche avec quelques photographies décolorées de criminels.",
    "metadata": {
      "apexDescription": "Cette affiche est un appel à témoin concernant une organisation criminelle locale.",
      "avianDescription": "Cette affiche montre les photos de certains criminels vus récemment.",
      "floranDescription": "Floran pas s s s interess s s é par le papier peint.",
      "glitchDescription": "Intrigué. Cette affiche montre des brigands locaux qui ont jusqu'ici échappé à la justice.",
      "humanDescription": "Une affiche de recherche classique. Apparemment, il y a des criminels locaux en cavale qui préparent un mauvais coup!",
      "hylotlDescription": "Hmm... il semble que les Pacificateurs traquent actuellement un criminel local qui a échappé à la justice.",
