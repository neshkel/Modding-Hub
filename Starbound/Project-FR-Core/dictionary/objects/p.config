      "glitchDescription": "Neutre. Un pilier.",
      "humanDescription": "Ce pilier est vraiment intéressant. Si, si.",
      "hylotlDescription": "Un pilier de qualité médiocre.",
      "novakidDescription": "Un pilier, se tenant bien droit."
    }
  },
