    }
  },
  "plantlog": {
    "name": "Bûche pour s'asseoir",
    "desc": "Une bûche, polie pour s'y asseoir.",
    "metadata": {
      "apexDescription": "Cette bûche semble avoir la hauteur idéale pour s'asseoir.",
