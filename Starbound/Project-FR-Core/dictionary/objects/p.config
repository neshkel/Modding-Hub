  "plantchair": {
    "name": "Chaise Envahie",
    "desc": "Une chaise en bois envahie par des lianes.",
    "metadata": {
      "apexDescription": "Est-ce que ces lianes poussent sur cette chaise ou est-ce qu'elles la maintiennent entière?",
