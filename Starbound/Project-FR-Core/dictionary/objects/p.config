  },
  "podchest": {
    "name": "Coffre Capsule",
    "desc": "Un coffre de rangement utile.",
    "metadata": {
      "apexDescription": "Un coffre capsule. Qu'y a-t-il à l'intérieur?",
      "avianDescription": "Ces coffres sont solides pour protéger leur contenu.",
      "floranDescription": "Ouvrons ce coffre! Peut-être de la nourriture dedans.",
      "glitchDescription": "Impatient. Pas de temps à perdre, ouvrons-le!",
      "humanDescription": "Un coffre capsule est toujours une vue bienvenue.",
      "hylotlDescription": "Les cadeaux sont plus excitants quand ils sont encore emballés.",
      "novakidDescription": "Un coffre capsule. J'me demande ce qu'il y a dedans..."
    }
  },
  "poop": {
    "name": "Crotte",
    "desc": "Un tas de crotte répugnant. L'odeur est immonde!",
    "metadata": {
      "apexDescription": "Des excréments. Qu'est-ce que ça fait là?",
      "avianDescription": "Je préférerais ne pas trop m'approcher.",
      "floranDescription": "Sent mauvaisss.",
      "glitchDescription": "Résolu. Les entités biologiques sont dégoûtantes.",
      "humanDescription": "Dites-moi que c'est un faux, s'il vous plaît.",
      "hylotlDescription": "Tout cela fait partie d'un processus naturel.",
      "novakidDescription": "J'ai rien de correct à dire sur le sujet."
    }
  },
  "portcullis": {
    "name": "Herse en Durasteel",
    "desc": "Une herse faite de durasteel massif.",
    "metadata": {
      "apexDescription": "On dirait que cette porte en durasteel s'ouvre vers le haut.",
      "avianDescription": "Cette porte a été forgée dans du durasteel massif.",
      "floranDescription": "Lourdes barres de métal font la porte.",
      "glitchDescription": "Suffisant. Les Glitchs créent leurs herses à une échelle bien plus grande.",
      "humanDescription": "Je détesterais rester coincé dessous quand elle se ferme.",
      "hylotlDescription": "Durasteel massif. La fonction prime sur la forme.",
      "novakidDescription": "Le genre de porte sous laquelle on peut glisser si on est vif!"
    }
  },
  "plantbed1": {
    "name": "Paillasse de Plantes",
    "desc": "Un sac de couchage de prison Floran. Il s'étale sur le sol.",
    "metadata": {
      "apexDescription": "Un sac de couchage de prison. Mieux que de dormir dans la poussière.",
      "avianDescription": "Un sac de couchage de prison fait de plantes.",
      "floranDescription": "Les prisonniers Florans ont des paillasses basiques.",
      "glitchDescription": "Dégoûté. Ce sac de couchage est fait de plantes et infesté d'insectes.",
      "humanDescription": "Ce sac de couchage n'a pas l'air d'offrir beaucoup de soutien.",
      "hylotlDescription": "Il semble que ces plantes soient tissées pour former une couche.",
      "novakidDescription": "On dirait un tapis de sommeil fait de plantes."
    }
  },
  "plantbed2": {
    "name": "Couchette Murale Végétale",
    "desc": "Une couchette de prison Floran à monter au mur.",
    "metadata": {
      "apexDescription": "Ce lit rudimentaire peut être suspendu à un mur.",
      "avianDescription": "Un lit de prison suspendu par des lianes.",
      "floranDescription": "Ce lit de prison tient avec de ssolides lianes.",
      "glitchDescription": "Impressionné. La conception de ce lit lui permet d'être suspendu au mur.",
      "humanDescription": "Ce lit a l'air très inconfortable, mais au moins il ne touche pas le sol.",
      "hylotlDescription": "Ce lit Floran semble tout droit sorti d'une cellule de prison.",
      "novakidDescription": "Une couchette murale de prison faite de plantes."
    }
  },
  "plantbed3": {
    "name": "Lit à Roulettes",
    "desc": "Une paillasse rudimentaire sur un cadre en bois à roulettes.",
    "metadata": {
      "apexDescription": "Un lit de prison en bois avec des roulettes.",
      "avianDescription": "Ce lit de prison a des roulettes pour le déplacer.",
      "floranDescription": "Les prisonniers Florans n'ont pas de lits luxueux.",
      "glitchDescription": "Suspicieux. Je ne suis pas sûr que ce cadre puisse supporter mon poids.",
      "humanDescription": "Un cadre de lit en bois garni de plantes. Ça n'a pas l'air douillet.",
      "hylotlDescription": "Ce lit a l'air très inconfortable et n'a même pas de couvertures.",
      "novakidDescription": "J'imagine que ce lit ferait l'affaire en cas de besoin."
    }
  },
  "plantbed4": {
    "name": "Paillasse Végétale avec Couverture",
    "desc": "Un sac de couchage de prisonnier Floran recouvert d'une couverture.",
    "metadata": {
      "apexDescription": "Un tapis de lit de prison. Au moins, il y a une couverture.",
      "avianDescription": "Un tapis de sol fait de plantes.",
      "floranDescription": "Les prisonniers Florans ont des tapis de sol basiques.",
      "glitchDescription": "Surpris. Ce simple tapis peut servir de lit?",
      "humanDescription": "Au moins, ce tapis de lit possède une couverture chaude.",
      "hylotlDescription": "Un tapis de lit à l'aspect ferme, fait de plantes.",
      "novakidDescription": "On dirait un tapis de sommeil posé par terre."
    }
  },
  "plantbiolight": {
    "name": "Biolumière Organique",
    "desc": "Cette lumière organique vacille doucement.",
    "metadata": {
      "apexDescription": "Une petite plante luminescente.",
      "avianDescription": "Une plante à la lueur délicieusement douce.",
