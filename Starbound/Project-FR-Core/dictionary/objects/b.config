  "brokenapexfuelhatch": {
    "name": "Trappe à carburant SLM cassée",
    "desc": "Une trappe à carburant SLM cassée. Ça ne va pas du tout!",
    "metadata": {
      "apexDescription": "Convertit le carburant en liberté.",
      "avianDescription": "Chargeons-le et partons vers les étoiles!",
      "floranDescription": "C'essst parti!",
      "glitchDescription": "Excitation. Une fois rempli, nous pourrons visiter une autre planète.",
      "humanDescription": "Une trappe à carburant. Je peux la remplir et explorer.",
      "hylotlDescription": "Le carburant est le sang de l'exploration.",
      "novakidDescription": "Le carburant SLM va là-dedans! Quand ce s'ra réparé..."
    }
  },
