    "name": "Buisson Décoratif 1",
    "desc": "Un buisson provenant d'une planète océanique."
  },
  "bushprop2": {
    "name": "Buisson Décoratif 2",
    "desc": "Un buisson provenant d'une planète océanique."
  },
  "bushprop3": {
    "name": "Buisson Décoratif 3",
    "desc": "Un buisson provenant d'une planète océanique."
  },
  "bigapescreen": {
    "name": "Écran de Big Ape",
    "desc": "Cet écran diffuse divers messages de propagande de Big Ape.",
    "metadata": {
      "floranDescription": "Floran pen sss e que sss oidisant 'grand' sssinge pas sssi grand.",
      "glitchDescription": "Alarmé. Ces séquences vidéo contiennent de nombreux messages subliminaux."
    }
  },
  "badgooplush": {
    "name": "Peluche de Glu Maléfique",
    "desc": "Peluche Bad Goo. Une poupée de glu câline.",
    "metadata": {
      "apexDescription": "Une adorable poupée de glu.",
      "avianDescription": "Un mignon petit jouet de glu.",
      "floranDescription": "Peluss s s che de glu!",
      "glitchDescription": "Appréciatif. Une petite glu toute douce.",
      "humanDescription": "Cool, j'en veux une!",
      "hylotlDescription": "Oh! Il me faut absolument cette peluche pour ma collection!",
      "novakidDescription": "J'ssuis pas sssûr de l'utilité de c'truc."
    }
  },
  "barstool": {
    "name": "Tabouret de bar",
    "desc": "Un tabouret de bar bancal.",
    "metadata": {
      "apexDescription": "C'est juste un tabouret de bar.",
      "avianDescription": "Un tabouret de bar. Je m'assiérais bien un instant.",
      "floranDescription": "Un tabouret de bar rond! Floran peut tournesss de sssus! Amusssant, ça donne le vertige.",
      "glitchDescription": "Indifférence. Le métal de ce tabouret a besoin d'un polissage.",
      "humanDescription": "Tout comme les tabourets de bar classiques de chez moi.",
      "hylotlDescription": "Un siège assez typique que l'on trouve dans les bars urbains.",
      "novakidDescription": "Un tabouret de bar. J'connais bien ça. Un peu trop même."
    }
  },
  "bearplush": {
    "name": "Peluche d'ours",
    "desc": "Une peluche d'ours câline. Awwwww.",
    "metadata": {
      "apexDescription": "Un ours en peluche adorable.",
      "avianDescription": "Comme c'est mignon, un ours en peluche.",
      "floranDescription": "Le jouet tout doux sssurveille Floran.",
      "glitchDescription": "Enthousiasme. Cet ours charmant est presque trop pour moi!",
      "humanDescription": "J'ai juste envie de câliner cet ours pour toujours.",
      "hylotlDescription": "Cri de joie! Une magnifique peluche d'ours. Il me la faut!",
      "novakidDescription": "Ce p'tit gars est plutôt mignon, j'imagine."
    }
  },
  "beautifulattempt": {
    "name": "Machine Beautiful Attempt!",
    "desc": "Une borne d'arcade avec un jeu narratif interactif.",
    "metadata": {
      "apexDescription": "Une borne d'arcade aux couleurs vives, quel genre de jeu est-ce?",
      "avianDescription": "Le jeu sur cette borne d'arcade lumineuse semble pouvoir être relaxant.",
      "floranDescription": "Cette borne d'arcade essst colorée comme une fleur.",
      "glitchDescription": "Confusion. Les jeux de ce type ont un objectif peu clair.",
      "humanDescription": "Cette borne lumineuse contient un jeu Hylotl très populaire.",
      "hylotlDescription": "C'est un classique, chaque Hylotl en connaît toutes les fins.",
      "novakidDescription": "Cette borne d'arcade est rudement jolie."
    }
  },
  "barbedwire": {
    "name": "Fil barbelé",
    "desc": "Aïe! Je ne devrais pas m'approcher de ça.",
    "metadata": {
      "apexDescription": "Du fil barbelé. Le Miniknog l'utilise souvent pour garder les gens à l'extérieur... ou à l'intérieur.",
      "avianDescription": "Du fil tranchant. Je dois faire attention à ce qu'il n'accroche pas mes plumes.",
      "floranDescription": "Ficssselle tranchante et piquante.",
      "glitchDescription": "Prudence. Ce fil tranchant pourrait rayer même la plus robuste des carapaces Glitch.",
      "humanDescription": "Du fil barbelé. Le fléau des vêtements humains.",
      "hylotlDescription": "Des pointes acérées façonnées avec du fil. Une forme de sécurité barbare et primitive.",
      "novakidDescription": "Du fil barbelé."
    }
  },
  "basicbath": {
    "name": "Baignoire basique",
    "desc": "",
    "metadata": {
      "apexDescription": "Une jolie petite baignoire. Elle semble assez petite pour un Apex.",
      "avianDescription": "Une baignoire avec une douche. Comme de l'eau sur le dos d'un Avian.",
      "floranDescription": "Grand sssceau de baignade.",
      "glitchDescription": "Suffisance. Les Glitch n'ont pas besoin de prendre de bains.",
      "humanDescription": "Un bon bain chaud. Exactement ce que le médecin a prescrit. Il ne manque plus que des bulles et des bougies.",
      "hylotlDescription": "Une auge dans laquelle les humains se lavent. Nous, les Hylotl, nous contentons d'aller nager.",
      "novakidDescription": "J'apprécie un bon bain chaud de temps à autre."
    }
  },
  "basicbathdripping": {
    "name": "Baignoire basique fuyante",
    "desc": "",
    "metadata": {
      "apexDescription": "Une jolie petite baignoire. Elle semble assez petite pour un Apex.",
      "avianDescription": "Une baignoire avec une douche. Comme de l'eau sur le dos d'un Avian.",
      "floranDescription": "Grand sssceau de baignade.",
      "glitchDescription": "Suffisance. Les Glitch n'ont pas besoin de prendre de bains.",
      "humanDescription": "Un bon bain chaud. Exactement ce que le médecin a prescrit. Il ne manque plus que des bulles et des bougies.",
      "hylotlDescription": "Une auge dans laquelle les humains se lavent. Nous, les Hylotl, nous contentons d'aller nager.",
      "novakidDescription": "J'apprécie un bon bain chaud de temps à autre."
    }
  },
  "basictoilet": {
    "name": "Toilettes basiques",
    "desc": "Des toilettes d'apparence normale! Merci les étoiles!",
    "metadata": {
      "apexDescription": "De petites toilettes. Elles n'ont pas l'air tout à fait hygiéniques.",
      "avianDescription": "Un endroit pour les déjections.",
      "floranDescription": "Endroit brillant pour les sssales besssoinsss.",
      "glitchDescription": "Désintérêt. Des toilettes.",
      "humanDescription": "Des toilettes. Toujours une vue bienvenue.",
      "hylotlDescription": "Des toilettes rudimentaires.",
      "novakidDescription": "Juste des toilettes simples. Pas glamour, mais rudement nécessaire."
    }
  },
  "basictv": {
    "name": "Vieille télévision",
    "desc": "Une télévision! Je ne pense pas qu'elle ait fonctionné depuis longtemps.",
    "metadata": {
      "apexDescription": "Un téléviseur. Je m'attends toujours à voir le visage de Big Ape.",
      "avianDescription": "Un moniteur, pour regarder de vieux programmes.",
      "floranDescription": "Imagesss animéesss bruyantesss.",
      "glitchDescription": "Appréciation. La télévision est véritablement l'exportation la plus précieuse de l'humanité.",
      "humanDescription": "Rien de mieux que de se détendre sur le canapé en regardant les dessins animés du samedi matin.",
      "hylotlDescription": "Bien que la technologie soit impressionnante, de nombreuses émissions de télévision sont dépourvues de tout mérite artistique.",
      "novakidDescription": "Une bonne vieille télévision. J'aime bien r'garder un sombre mystère s'dérouler."
    }
  },
  "bunkerbigpanel": {
    "name": "Grand moniteur",
    "desc": "La quantité de données sur cet écran est accablante.",
    "metadata": {
      "apexDescription": "Un ensemble de moniteurs. Je m'attends toujours à voir le visage de Big Ape.",
      "avianDescription": "Un moniteur, pour... des relevés de données, peut-être.",
      "floranDescription": "Trop d'informationsss pour Floran en ce moment.",
      "glitchDescription": "Curiosité. Les relevés on ce moniteur indiquent qu'ils concernent l'étoile la plus proche.",
      "humanDescription": "Cet écran central semble analyser l'étoile locale. Indice: elle est très chaude.",
      "hylotlDescription": "D'après ces moniteurs, l'étoile locale ne risque pas encore de s'effondrer.",
      "novakidDescription": "Des relevés de données. Pour quoi faire?"
    }
  },
  "bunkerbookcase": {
    "name": "Bibliothèque métallique",
    "desc": "Il y a un livre ici intitulé « Comment voyager dans le passé pour les Nuls ».",
    "metadata": {
      "apexDescription": "Une bibliothèque, remplie de livres intéressants. Le Miniknog brûlerait tout cela.",
      "avianDescription": "Beaucoup de livres scientifiques. Il ne semble pas y avoir beaucoup de textes religieux.",
      "floranDescription": "Beaucoup de livresss avec desss motsss, peu de livresss avec desss imagesss.",
      "glitchDescription": "Intérêt. Certains de ces livres ont des centaines d'années. Ils pourraient tomber en lambeaux au moindre contact.",
      "humanDescription": "Il y a un tas de livres familiers écrits par des humains. Je me demande combien de personnes les lisent?",
      "hylotlDescription": "Des tomes riches de l'histoire humaine. Ils ne sont pas aussi bien écrits que les ouvrages Hylotl, bien entendu.",
      "novakidDescription": "Une bibliothèque. Y'a beaucoup de bouquins de développement personnel par ici..."
    }
  },
  "bunkercabinet1": {
    "name": "Armoire métallique",
    "desc": "On dirait qu'elle est pleine de matières dangereuses.",
    "metadata": {
      "apexDescription": "Une armoire métallique. Une odeur étrange s'en dégage.",
      "avianDescription": "Le contenu semble dangereux. Toxique ou explosif, peut-être.",
      "floranDescription": "Boîte en métal dangeruessse? Ça peut pas être plusss dangereux que Floran!",
      "glitchDescription": "Amusement. Malgré le panneau d'avertissement, cette caisse contient en réalité une collection de chaussettes dépareillées.",
      "humanDescription": "Une odeur immonde s'échappe de sous le couvercle. Ça me rappelle mon adolescence.",
      "hylotlDescription": "Un conteneur de matières dangereuses. Apparemment, les humains s'en débarrassaient souvent dans leurs océans.",
      "novakidDescription": "Un conteneur avec des rayures d'alerte. J'vais pas ouvrir ça."
    }
  },
  "bunkerceilinglight1": {
    "name": "Plafonnier métallique",
    "desc": "Un plafonnier métallique.",
    "metadata": {
      "apexDescription": "Un plafonnier métallique.",
      "avianDescription": "Un plafonnier.",
      "floranDescription": "Lampe sssuspendue.",
      "glitchDescription": "Ennui. Un luminaire.",
      "humanDescription": "Un appareil que l'on fixe sur sa tête, et... attendez, non, c'est juste une lampe.",
      "hylotlDescription": "Un plafonnier sans intérêt.",
      "novakidDescription": "Un plafonnier à l'air tout simple."
    }
  },
  "bunkerceilinglight2": {
    "name": "Plafonnier métallique",
    "desc": "Un plafonnier métallique.",
    "metadata": {
      "apexDescription": "Un plafonnier métallique.",
      "avianDescription": "Un plafonnier.",
      "floranDescription": "Lampe sssuspendue.",
      "glitchDescription": "Ennui. Un luminaire.",
      "humanDescription": "Un appareil que l'on fixe sur sa tête, et... attendez, non, c'est juste une lampe.",
      "hylotlDescription": "Un plafonnier sans intérêt.",
      "novakidDescription": "Un plafonnier à l'air tout simple."
    }
  },
  "bunkercomputer": {
    "name": "Petit ordinateur",
    "desc": "Semble principalement utilisé pour la saisie de données. Rien de très intéressant.",
    "metadata": {
      "apexDescription": "Un ordinateur. Le clavier est trop petit pour des doigts d'Apex.",
      "avianDescription": "Qu'est-ce que cela commande, je me demande?",
      "floranDescription": "Un ordinateur pour taper de sssus et le regarder.",
      "glitchDescription": "Mélancolie. Je ressens une certaine parenté avec cet ordinateur humain.",
      "humanDescription": "Un ordinateur. Il exécute un programme qui demande de saisir un code à intervalles réguliers.",
      "hylotlDescription": "Un ordinateur humain. Technologiquement, c'est assez impressionnant.",
      "novakidDescription": "C'est un ordinateur. J'suis pas sûr qu'ça soit utile."
    }
  },
  "bunkerconsole1": {
    "name": "Console de commande",
    "desc": "Elle est pleine de leviers vraiment tentants, mais je devrais probablement la laisser tranquille.",
    "metadata": {
      "apexDescription": "Une console de commande. Je ne sais pas ce qu'elle fait.",
      "avianDescription": "Cela semble dangereux de jouer avec.",
      "floranDescription": "Machine avec plein de boutonsss et de levier sss! Tentant, mais Floran ferait mieux de pas toucher à ça...",
      "glitchDescription": "Observation. Plus une console a de leviers, plus il est dangereux de s'en amuser.",
      "humanDescription": "Je pense que ça ouvre les portes de la soute. Ou que ça fait sauter un truc. Ça fait quelque chose, en tout cas.",
      "hylotlDescription": "Ne... pas... actionner... les leviers...",
      "novakidDescription": "Qui sait c'que ces boutons et ces leviers fabriquent. J'vais pas l'apprendre à mes dépens, c'est sûr."
    }
  },
  "bunkerconsole2": {
    "name": "Grande console",
    "desc": "Deux claviers et un moniteur?",
    "metadata": {
      "apexDescription": "Une console de commande. Je ne sais pas ce qu'elle fait.",
      "avianDescription": "Cela semble dangereux de jouer avec.",
      "floranDescription": "Ordinateur a un nombre inutile de boutonsss. Floran essst perplexe.",
      "glitchDescription": "Observation. Plus une console a de claviers, plus... non. Je sèche.",
      "humanDescription": "Ah, le tristement célèbre design à « double clavier ». Ça n'a jamais vraiment percé.",
      "hylotlDescription": "Pourquoi aurait-on jamais besoin de deux claviers?",
      "novakidDescription": "Cet ordinateur a plus d'un clavier. Ça semble excessif si vous voulez mon avis."
    }
  },
    "bunkerconsole3": {
    "name": "Petite console",
    "desc": "On dirait un écran rempli de notes de service pour le personnel.",
    "metadata": {
      "apexDescription": "Il y a un message à l'écran. « Chère Marjory. N'oublie pas de sortir le chat. Affectueusement, David » Intéressant.",
      "avianDescription": "Il y a un message sur l'écran. « Les résultats des tests de toxicité d'hier n'étaient pas concluants. Veuillez en prévoir d'autres. Docteur Kleiner » D'accord.",
      "floranDescription": "Hmm... Un messssage misss en évidence sssur l'écran. « Acheter desss œufs aprèsss le travail ».",
      "glitchDescription": "Indiscrétion. Il y a un message sur l'écran. « Laisse-moi t'expliquer pourquoi tu as tort... » Le reste du message n'est qu'une diatribe inintelligible.",
      "humanDescription": "À en juger par ce compte mail, quelqu'un a été victime de la fameuse erreur du « répondre à tous ». Pauvre type.",
      "hylotlDescription": "D'après ces messages, les humains se contentent de frapper leur visage contre le clavier lorsqu'ils se disputent par ordinateur.",
      "novakidDescription": "Un poste informatique personnel. J'suis pas du genre à fourrer mon nez partout."
    }
  },
  "bunkerconsole4": {
    "name": "Console large",
    "desc": "C'est un écran rempli de données de mission super top secrètes... Ennuyeux.",
    "metadata": {
      "apexDescription": "Apparemment, cette planète allait exploser. Je pense que c'était une fausse alerte.",
      "avianDescription": "Une équipe a été envoyée pour récupérer un artefact maudit. Ils ne sont jamais revenus. Peut-être se sont-ils simplement égarés?",
      "floranDescription": "Chasssse... fêtesss.... Les Floransss font aussssi desss fêtesss pendant la chasssse.",
      "glitchDescription": "Inquiétude. Il semble que l'utilisateur précédent de cette console ait perdu la raison. On y trouve un certain nombre de messages alarmants.",
      "humanDescription": "Ooh, des données secrètes. Il s'avère que le gouvernement nous espionnait! Qui l'aurait cru?",
      "hylotlDescription": "Il est détaillé ici un plan alarmant pour drainer les océans de ce monde. Heureusement, il a été rejeté.",
      "novakidDescription": "Y'a des infos ici sur une pétition pour interdire le moonwalk. Suivi d'une recette de soupe à l'oignon."
    }
  },
  "bunkercorner": {
    "name": "Poutre de soutien métallique",
    "desc": "Une poutre de soutien peinte avec des bandes d'avertissement. Attention à votre tête!",
    "metadata": {
      "apexDescription": "Une poutre de soutien.",
      "avianDescription": "Un support métallique.",
      "floranDescription": "Sssupport.",
      "glitchDescription": "Ennui. Une poutre de soutien.",
      "humanDescription": "Une poutre en métal.",
      "hylotlDescription": "Poutre de soutien métallique.",
      "novakidDescription": "Une poutre de soutien."
    }
  },
  "bunkercrate": {
    "name": "Caisse métallique",
    "desc": "Une caisse en métal.",
    "metadata": {
      "apexDescription": "Une caisse métallique.",
      "avianDescription": "Une caisse faite de métal.",
      "floranDescription": "Boîte en métal.",
      "glitchDescription": "Neutre. Une boîte métallique.",
      "humanDescription": "Une grande caisse métallique.",
      "hylotlDescription": "Une caisse métallique à l'aspect pesant.",
      "novakidDescription": "C'est une simple caisse en métal."
    }
  },
  "bunkerdesk": {
    "name": "Bureau métallique",
    "desc": "Un bureau avec un moniteur intégré. On dirait que quelqu'un faisait du codage.",
    "metadata": {
      "apexDescription": "Ce bureau possède un moniteur intégré.",
      "avianDescription": "Un bureau simple avec un moniteur fixé dessus.",
      "floranDescription": "Bureau avec écran fixssé dessssusss.",
      "glitchDescription": "Cynisme. L'électronique intégrée est souvent inférieure à ses homologues séparés. Sauf dans le cas des Glitch, bien sûr.",
      "humanDescription": "Ce moniteur est intégré au bureau.",
      "hylotlDescription": "Un moniteur intégré. Une fusion intelligente de technologie et de confort.",
      "novakidDescription": "Un écran collé à un bureau."
    }
  },
  "bunkerdisplay1": {
    "name": "Écran de plans",
    "desc": "L'écran montre une pièce centrale ronde bifurquant vers plusieurs couloirs.",
    "metadata": {
      "apexDescription": "On dirait une sorte de carte numérique.",
      "avianDescription": "Peut-être la disposition de cette zone?",
      "floranDescription": "Desss lignesss gribouilléesss qui ne veulent rien dire pour lesss Floransss.",
      "glitchDescription": "Observation. Cela semble dépeindre la disposition de la zone dans laquelle nous nous trouvons.",
      "humanDescription": "Un affichage de carte basique.",
      "hylotlDescription": "Les couloirs et les pièces sont disposés sur cette carte.",
      "novakidDescription": "J'suis sûr qu'c'est une carte."
    }
  },
  "bunkerdisplay2": {
    "name": "Écran statistique",
    "desc": "Un écran avec un diagramme circulaire représentant les statistiques budgétaires.",
    "metadata": {
      "apexDescription": "Un diagramme circulaire. Ça n'a pas l'air très appétissant.",
      "avianDescription": "Ce graphique ressemble un peu à une tarte aux baies avec une part manquante.",
      "floranDescription": "Donnéesss étrangesss et peu intéressssantesss.",
      "glitchDescription": "Sarcastique. Un diagramme circulaire fascinant détaillant les dépenses en fournitures de bureau.",
      "humanDescription": "Ooh, une infographie. Malheureusement pas l'une de ces drôles qu'on trouve sur internet.",
      "hylotlDescription": "Il est logique que les humains surveillent de près leurs dépenses.",
      "novakidDescription": "J'sais pas trop c'que ce gros cercle est censé illustrer. Mais il lui manque un morceau."
    }
  },
  "bunkerdisplay3": {
    "name": "Écran de carte",
    "desc": "C'est une carte montrant une salle centrale ronde se divisant en plusieurs couloirs.",
    "metadata": {
      "apexDescription": "On dirait une sorte de carte numérique.",
      "avianDescription": "Peut-être la disposition de cette zone?",
      "floranDescription": "Desss lignesss gribouilléesss qui ne veulent rien dire pour lesss Floransss.",
      "glitchDescription": "Observation. Cela semble dépeindre la disposition de la zone dans laquelle nous nous trouvons.",
      "humanDescription": "Un affichage de carte basique.",
      "hylotlDescription": "Les couloirs et les pièces sont disposés sur cette carte.",
      "novakidDescription": "J'suis sûr qu'c'est une carte."
    }
  },
  "bunkerdisplay4": {
    "name": "Écran anomalie",
    "desc": "Ce n'est pas une lune...",
    "metadata": {
      "apexDescription": "Un orbe holographique. Il semble être significatif.",
      "avianDescription": "L'orbe représenté ici semble être céleste, mais certains signes indiquent qu'il est de fabrication humaine.",
      "floranDescription": "Balle holographique ennuyeussse.",
      "glitchDescription": "Terreur. Les scans suggèrent que c'est... non... ce n'est pas possible...",
      "humanDescription": "Wow, est-ce que c'est la lune?",
      "hylotlDescription": "L'orbe brille d'une lumière froide. Il me donne des frissons.",
      "novakidDescription": "On dirait la lune, m'observant par une froide nuit d'hiver."
    }
  },
  "bunkereyescanner": {
    "name": "Scanner oculaire",
    "desc": "Un appareil pour scanner les globes oculaires et les faire correspondre aux données du personnel.",
    "metadata": {
      "apexDescription": "Un scanner oculaire. Il ne semble pas reconnaître les yeux des Apex.",
      "avianDescription": "Un dispositif pour scanner les yeux humains. Mais dans quel but?",
      "floranDescription": "La machine veut ssscaner lesss yeux. Floran refussse!",
      "glitchDescription": "Réflexion. Avec le bon calibrage, ce scanner pourrait être trompé par un œil de Glitch.",
      "humanDescription": "Un scanner oculaire. Quelqu'un a mis de l'encre autour de l'œilleton. Oh, sacrés farceurs.",
      "hylotlDescription": "Un scanner oculaire. De tels dispositifs sont peu commodes pour les Hylotls. Nos têtes n'ont pas la bonne forme.",
      "novakidDescription": "Un scanner oculaire? J'suis pas sûr de c'que j'dois en faire."
    }
  },
  "bunkerhandscanner": {
    "name": "Scanner d'empreintes",
    "desc": "Il scanne les empreintes digitales et les fait correspondre aux données du personnel.",
    "metadata": {
      "apexDescription": "Un scanner d'empreintes digitales. Plus petit qu'une main d'Apex.",
      "avianDescription": "Les Avians n'ont pas d'empreintes digitales. De tels dispositifs de sécurité sont inutiles pour nous.",
      "floranDescription": "Appareil pour ssscaner lesss mainsss. Ne réagit passs à la main de Floran...",
      "glitchDescription": "Ressentiment. Les dispositifs de sécurité biométriques sont un luxe que seules certaines espèces peuvent s'offrir.",
      "humanDescription": "Un scanner d'empreintes digitales. Malheureusement, je ne suis pas enregistré. J'ai toujours voulu en activer un.",
      "hylotlDescription": "Les mains des Hylotls peuvent faire dérailler ces appareils.",
      "novakidDescription": "Un genre d'appareil de ssscan pour les mains. J'doute qu'il capte les miennes."
    }
  },
  "bunkerheater1": {
    "name": "Radiateur d'appoint",
    "desc": "Un radiateur d'appoint!",
    "metadata": {
      "apexDescription": "Un petit radiateur portable, chaud et confortable.",
      "avianDescription": "Parfait pour se réchauffer les plumes.",
      "floranDescription": "Bonne chaleur, passs de feu. Sssûr pour Floran.",
      "glitchDescription": "Désintérêt. Un petit radiateur.",
      "humanDescription": "Un radiateur d'appoint. Le nom en anglais, « space heater », lui donne un côté futuriste et cool.",
