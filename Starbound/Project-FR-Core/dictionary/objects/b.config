  "bathroomhanddryer": {
    "name": "Sèche-mains de salle de bain",
    "desc": "Un sèche-mains pratique. Ne pas toucher.",
    "metadata": {
      "apexDescription": "Un sèche-mains. Je me demande si cela fonctionne sur les poils denses des Apex.",
      "avianDescription": "C'est certain que cela va ébouriffer quelques plumes.",
      "floranDescription": "Floran sssèche ses mainsss.",
      "glitchDescription": "Ravi. Un sèche-mains - utile pour prévenir la rouille.",
      "humanDescription": "C'est un peu basique.",
      "hylotlDescription": "Les Hylotls n'éprouvent nul besoin de se sécher les mains.",
      "novakidDescription": "Un bidule pour s'sécher les mains mouillées."
    }
  },
  "bathroomsink": {
    "name": "Lavabo de salle de bain",
    "desc": "Un lavabo. Lavez-vous les mains!",
    "metadata": {
      "apexDescription": "Un lavabo basique.",
      "avianDescription": "Un évier.",
      "floranDescription": "Lavabo qui fait des sssplosssh.",
      "glitchDescription": "Neutre. Un lavabo.",
      "humanDescription": "Un lavabo. Je devrais peut-être me laver les mains...",
      "hylotlDescription": "Bien trop exigu pour y nager.",
      "novakidDescription": "Un bête lavabo tout simple."
    }
  },
  "bathroomstall": {
    "name": "Cabine de toilette",
    "desc": "Une cabine de toilette. Ne restez pas coincé!",
    "metadata": {
      "apexDescription": "Une cabine de toilette rudimentaire.",
      "avianDescription": "Une cabine de toilette.",
      "floranDescription": "Floran aime sss'cacher dans les cabinesss et regarder les gens passsser par la fente!",
      "glitchDescription": "Neutre. Une cabine de toilette.",
      "humanDescription": "Parfait pour se cacher et jouer à des jeux sur mobile.",
      "hylotlDescription": "Une cabine de toilette des plus rustiques.",
      "novakidDescription": "Quand faut y aller, faut y aller."
    }
  },
  "bathroomtrash": {
    "name": "Poubelle",
    "desc": "Des ordures. Juste des ordures. Ou pas? Réponse: si.",
    "metadata": {
      "apexDescription": "C'est le jour des poubelles!",
      "avianDescription": "Des détritus.",
      "floranDescription": "Joliesss orduresss.",
      "glitchDescription": "Peu impressionné. Des déchets.",
      "humanDescription": "Il est temps de sortir les poubelles!",
      "hylotlDescription": "D'infâmes immondices.",
      "novakidDescription": "C'est rien d'autre que des ordures."
    }
  },
  "bathroomtrashquest": {
    "name": "Poubelle de salle de bain",
