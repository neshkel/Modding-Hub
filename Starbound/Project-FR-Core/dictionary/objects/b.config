  "bathroomurinal": {
    "name": "Urinoir de salle de bain",
    "desc": "Un urinoir. Utile pour certains.",
    "metadata": {
      "apexDescription": "Est-ce que... je dois m'asseoir là-dessus ou...?",
      "avianDescription": "Je ne suis pas certain de savoir ce que c'est.",
      "floranDescription": "Floran pas ssûr pour le sssiège qui pue.",
      "glitchDescription": "Impassible. Un urinoir.",
      "humanDescription": "Un urinoir.",
      "hylotlDescription": "Un urinoir ordinaire.",
      "novakidDescription": "Un urinoir à l'air bien sssale."
    }
  },
