  "brainsynapse1": {
    "name": "Synapse",
    "desc": "Une terminaison nerveuse de tentacule"
  },
  "bonebed": {
    "name": "Lit Cercueil en Os",
    "desc": "Un lit cercueil. Le summum du confort pour les morts-vivants.",
    "metadata": {
      "apexDescription": "Ce lit a l'air petit et claustrophobique. Il a un couvercle!",
      "avianDescription": "Dormir dans ce lit serait très désagréable.",
      "floranDescription": "Floran connais pas sssercueils.",
      "glitchDescription": "Terrorisé. Ce lit est sstylisé comme un cercueil.",
      "humanDescription": "Peut-être que des vampires de l'espace utilisent ce lit. Est-ce qu'ils existent? J'espère!",
      "hylotlDescription": "Quelque chose dans ce lit me met mal à l'aise.",
      "novakidDescription": "Une de ces boîtes de dodo sophisstiquées."
    }
  },
  "bonechair": {
    "name": "Chaise en Os",
    "desc": "Un trône d'os. Pour tous vos besoins royaux en ossature.",
    "metadata": {
      "apexDescription": "J'imagine un genre de tyran assis ici. Peut-être que Big Ape apprécierait.",
      "avianDescription": "Je m'attendrais à trouver ça dans un temple Avian. Un temple très ssinistre.",
      "floranDescription": "Floran aime sssiège en os. Floran s'asseyoir, penser aux os ssoureux.",
      "glitchDescription": "Réflexion. L'os ici provient d'une créature morte depuis longtemps. Peut-être éteinte.",
      "humanDescription": "Une chaise effrayante. Étonnamment confortable. Je pourrais m'asseoir ici et donner des ordres ssinistres.",
      "hylotlDescription": "Une chaise rudimentaire façonnée à partir des morts. Horrifique.",
      "novakidDescription": "Un trône d'os, digne d'un roi des os."
    }
  },
  "bonechest": {
    "name": "Coffre en Os",
    "desc": "Un coffre fait d'os. Espérons qu'il ne soit pas rempli de moelle.",
    "metadata": {
      "apexDescription": "Ce coffre semble être entièrement fait d'os.",
      "avianDescription": "Un coffre façonné dans l'os.",
      "floranDescription": "Floran impressionné par coffrrre. Ça a l'air ssympa à cassser.",
      "glitchDescription": "Désapprobateur. Ce coffre est sculpté dans l'os.",
      "humanDescription": "Je pourrais utiliser ça pour ranger mes bijoux à pentagrammes et mes bougies noires!",
      "hylotlDescription": "Quoi que ce soit qui soit mort pour faire ce coffre, il méritait une meilleure fin.",
      "novakidDescription": "Un coffre en os. Peut-être fait à partir d'une cage thoracique."
    }
  },
  "bonedoor": {
    "name": "Porte en Os",
    "desc": "Une porte faite d'os. Où mène-t-elle? En enfer? Ou aux toilettes?",
    "metadata": {
      "apexDescription": "Une porte menaçante en os. J'ai peur de la franchir.",
      "avianDescription": "Sûrement, derrière une telle porte doit se trouver quelque chose de respectable.",
      "floranDescription": "Floran ssent un lien avec porte. Ouvrir à coups de pieds.",
      "glitchDescription": "Comique. On peut dire que la mort de cette créature a... ouvert des portes.",
      "humanDescription": "C'est froid au toucher. Un frisson me parcourt l'échine. Au loin, un chien aboie. Ah non, c'était juste un Apex qui chantait.",
      "hylotlDescription": "Une vile porte de mort. Quelle horreur. Charnières remarquablement fluides, cependant.",
      "novakidDescription": "La porte de la mort."
    }
  },
  "bonetable": {
    "name": "Table en Os",
    "desc": "Une table en os effrayante. Ressemble plus à un autel sacrificiel. Bien pour les pique-niques.",
    "metadata": {
      "apexDescription": "Cette table en os n'a pas beaucoup de place pour les jambes.",
      "avianDescription": "Cela me rappelle les autels sacrificiels que je préférerais oublier.",
      "floranDescription": "Floran a hâte de couper viande ssour table. Table sssemble prête.",
      "glitchDescription": "Curieux. La surface de cette table est couverte de marques de couteaux. Certaines semblent brutales.",
      "humanDescription": "Cool! Une table flippante. Pile ce que j'ai toujours voulu.",
      "hylotlDescription": "Une table née de la mort. Nul doute que beaucoup de chair a été consommée ici.",
      "novakidDescription": "Ça ressemble plus à un autel en os ssinistre pour moi."
    }
  },
  "bioshroom1": {
    "name": "Champignons Lumineux",
    "desc": "Une touffe de petits champignons brillants.",
    "metadata": {
      "apexDescription": "Jolis petits champignons lumineux.",
      "avianDescription": "Ces champignons brillants sont adorables!",
      "floranDescription": "Ceux-là aident Floran à voir dans le noirss.",
      "glitchDescription": "Satisfait. Ces champignons fournissent une lumière naturelle bienvenue.",
      "humanDescription": "Ces champignons brillent d'un vert radioactif. Je ne devrais probablement pas essayer de les manger.",
      "hylotlDescription": "La lueur de ces petits champignons est une vue bienvenue sous terre.",
      "novakidDescription": "Salut, les petits gars brillants."
    }
  },
  "bioshroom2": {
    "name": "Champignons Lumineux",
    "desc": "Une touffe de petits champignons brillants.",
    "metadata": {
      "apexDescription": "Jolis petits champignons lumineux.",
      "avianDescription": "Ces champignons brillants sont adorables!",
      "floranDescription": "Ceux-là aident Floran à voir dans le noirss.",
      "glitchDescription": "Satisfait. Ces champignons fournissent une lumière naturelle bienvenue.",
      "humanDescription": "Ces champignons brillent d'un vert radioactif. Je ne devrais probablement pas essayer de les manger.",
      "hylotlDescription": "La lueur de ces petits champignons est une vue bienvenue sous terre.",
      "novakidDescription": "Salut, les petits gars brillants."
