{
  "bigredbutton": {
    "name": "Gros bouton rouge",
    "desc": "L'envie... d'appuyer... augmente!",
    "metadata": {
      "apexDescription": "S'appuyer là-dessus pourrait activer quelque chose.",
      "avianDescription": "Un gros bouton rouge.",
      "floranDescription": "Doit appuier sssur le bouton!",
      "glitchDescription": "Résistance. Ressent une envie irrésistible d'appuyer sur le bouton.",
      "humanDescription": "Comment pourrais-je ne pas appuyer là-dessus?",
      "hylotlDescription": "Je peux comprendre le désir d'appuyer sur un bouton quand il nous est révélé. Mais vous devez pratiquer la maîtrise de soi, dompter vos pulsions.",
      "novakidDescription": "Eh ben, j'dois juste appuyer sur c'bouton!"
    }
  },
  "bulb": {
    "name": "Ampoule",
    "desc": "Un voyant lumineux. Indique si quelque chose est allumé ou éteint.",
    "metadata": {
      "floranDescription": "Un voyant lumineuxss. Indique sssi quelque cho sse essst allumé ou éteint.",
      "glitchDescription": "Neutre. Un voyant lumineux. Indique si quelque chose est allumé ou éteint."
    }
  },
  "bouldertrap": {
    "name": "Piège à rochers du temple",
    "desc": "Un piège qui lâche de lourds rochers sur les intrus imprudents.",
    "metadata": {
      "apexDescription": "Si je calcule bien mes mouvements, je peux éviter les rochers qui tombent.",
      "avianDescription": "Mieux vaut bien calculer mes déplacements, je n'ai pas envie qu'un rocher me tombe dessus.",
      "floranDescription": "De lourds caillouxss tombent de ce trou.",
      "glitchDescription": "Déception. Qui fabriquerait un piège pour lâcher des rochers avec un timing aussi opportun?",
      "humanDescription": "Des rochers sortent de ce petit trou.",
      "hylotlDescription": "Un piège à rochers est facile à éviter avec des mouvements bien synchronisés.",
      "novakidDescription": "Des rochers qui roulent!"
    }
  },
  "baguettebox": {
    "name": "Boîte de pain",
    "desc": "Une boîte de pain frais et croustillant.",
    "metadata": {
      "apexDescription": "Ces miches sont clairement artisanales, rien à voir avec le 'pain' de chez nous.",
      "avianDescription": "De fines miches de grains moulus.",
      "floranDescription": "Les grainsss manquent de sssaveur.",
      "glitchDescription": "Sentimental. Ces miches rustiques me rappellent une vie plus simple.",
      "humanDescription": "Je crois que sur l'ancienne Terre, on appelait ça des 'baguettes'.",
      "hylotlDescription": "Le pain fraîchement cuit est beaucoup moins agréable sous l'eau.",
      "novakidDescription": "Rien n'bat du pain fraîchement cuit."
    }
  },
  "blackteleporter": {
    "name": "Téléporteur de direction",
    "desc": "Un téléporteur personnel, se connecte aux lieux enregistrés. \n^red;Détruit s'il est brisé.",
    "metadata": {
      "apexDescription": "Un téléporteur personnel. Un équipement fonctionnel mais amusant.",
      "avianDescription": "J'adore le sifflement de mes plumes quand je me téléporte!",
      "floranDescription": "Téléporteur perssonnel essst élégant!",
      "glitchDescription": "Attiré. Un téléporteur personnel, avec un design personnalisé.",
      "humanDescription": "Un téléporteur personnel! Ça c'est voyager avec style.",
      "hylotlDescription": "Un téléporteur personnel, il arbore un design personnalisé.",
      "novakidDescription": "Pour un téléporteur, il a l'air drôlement chic!"
    }
  },
  "brassteleporter": {
    "name": "Téléporteur en laiton",
    "desc": "Un téléporteur personnel, se connecte aux lieux enregistrés. \n^red;Détruit s'il est brisé.",
