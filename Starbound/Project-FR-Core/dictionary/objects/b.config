  "bunkerpanel1": {
    "name": "Panneau de données environnementales",
    "desc": "Ce panneau semble surveiller des données environnementales obscures.",
    "metadata": {
      "apexDescription": "Ceci semble être un panneau affichant les changements sub-protoniques locaux.",
      "avianDescription": "Des données sont transmises à cet écran, qui affiche de nombreuses mesures.",
      "floranDescription": "Floran n'a passs le temps pour lesss tout petitsss motsss.",
      "glitchDescription": "Confusion. Ce panneau affiche des changements environnementaux extraordinairement infimes. Dans quel but?",
      "humanDescription": "Quelqu'un effectuait beaucoup d'analyses de données obscures à l'aide de cet écran.",
      "hylotlDescription": "Données sur l'environnement environnant. Les changements mesurés sont d'un niveau minuscule.",
      "novakidDescription": "J'suis sûr qu'ces données sont intéressantes pour quelqu'un. Mais c'est pas moi."
    }
  },
  "bunkerpanel2": {
    "name": "Panneau de données médicales",
    "desc": "C'est un écran affichant un ancien scanner médical.",
    "metadata": {
      "apexDescription": "Cet écran semble afficher un diagnostic médical.",
      "avianDescription": "Un scan de ce qui semble être des données médicales.",
      "floranDescription": "L'écran montre une persssonne de chair. Floran ssse demande sssi la persssonne essst piégée à l'intérieur.",
      "glitchDescription": "Intrigue. Cela semble être un scanner médical du corps entier. Je me demande ce qu'ils avaient?",
      "humanDescription": "Un scanner médical numérique! C'est tout bleu, parce que le bleu est la couleur par défaut de la technologie scientifique.",
      "hylotlDescription": "Un scanner médical – à en juger par les images, ce n'était pas celui d'un Hylotl.",
      "novakidDescription": "J'me demande à quoi servaient ces infos?"
    }
  },
  "bunkerpanel3": {
    "name": "Panneau de recrutement LED",
    "desc": "Une affiche de recrutement électronique tape-à-l'œil.",
    "metadata": {
      "apexDescription": "Une station de recrutement? Il semble que le recrutement militaire soit optionnel ici. Pour les Apex, ce luxe n'existe pas.",
      "avianDescription": "Une publicité pour le recrutement militaire. Les Enracinés choisissent souvent de devenir des guerriers.",
      "floranDescription": "Panneau de recrutement. Floran ne recrute passs pour le sssstyle de vie de guerrier. Floran essst né comme ça.",
      "glitchDescription": "Réflexion. Un panneau de recrutement. Les Glitch qui ne sont pas conscients d'eux-mêmes choisissent souvent de devenir des guerriers.",
      "humanDescription": "Ah, un panneau de recrutement militaire. Leurs méthodes de recrutement deviennent de plus en plus clinquantes.",
      "hylotlDescription": "Un panneau de recrutement militaire. Comme c'est odieux.",
      "novakidDescription": "Cette pub est aveuglante."
    }
  },
  "bunkerposter1": {
    "name": "Affiche de motivation",
    "desc": "Ce n'est pas très encourageant.",
    "metadata": {
      "apexDescription": "Si c'était une affiche du Miniknog, le texte manquant serait « vous ne serez pas éliminé ».",
      "avianDescription": "Les Avians prient Kluex pour le calme. Nous n'avons pas besoin de sottes affiches de motivation.",
      "floranDescription": "L'affiche essst endommagée. Floran ssse sssent moinsss calme aprèsss avoir vu cette affiche.",
      "glitchDescription": "Frustration. Essayer de deviner le texte manquant va m'irriter pendant des jours.",
      "humanDescription": "Je ne suis pas surpris que quelqu'un ait dégradé ça.",
      "hylotlDescription": "Nous, les Hylotls, n'avons pas besoin d'affiches pour nous aider à atteindre le Zen.",
      "novakidDescription": "Restez calme et quoi? J'imagine que j'le saurai jamais."
    }
  },
  "bunkerposter2": {
    "name": "Affiche apaisante",
    "desc": "Il n'y a aucune raison d'être contrarié.",
    "metadata": {
      "apexDescription": "Big Ape? Ici? Pourquoi les humains auraient-ils une telle affiche? Est-ce une blague?",
      "avianDescription": "Cela semble mettre en scène ce personnage de Big Ape. Les humains ont-ils un lien avec les Apex?",
      "floranDescription": "Floran passs sssûr de pourquoi il y a un Apex sssur cette affiche. Ou peut-être un humain poilu?",
      "glitchDescription": "Suspicion. Pourquoi les humains ont-ils une affiche de Big Ape, je me demande?",
      "humanDescription": "Ce personnage de dessin animé me semble familier. Attendez... est-ce que c'est Big Ape?",
      "hylotlDescription": "Une affiche humaine, un méchant Apex. Curieux.",
      "novakidDescription": "Un Apex. Il me dit d'pas être contrarié."
    }
  },
  "bunkerserver": {
