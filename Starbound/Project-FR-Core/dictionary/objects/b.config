  },
  "bioshroom3": {
    "name": "Champignons Lumineux",
    "desc": "Une touffe de petits champignons brillants.",
    "metadata": {
      "apexDescription": "Jolis petits champignons lumineux.",
      "avianDescription": "Ces champignons brillants sont adorables!",
      "floranDescription": "Ceux-là aident Floran à voir dans le noirss.",
      "glitchDescription": "Satisfait. Ces champignons fournissent une lumière naturelle bienvenue.",
      "humanDescription": "Ces champignons brillent d'un vert radioactif. Je ne devrais probablement pas essayer de les manger.",
      "hylotlDescription": "La lueur de ces petits champignons est une vue bienvenue sous terre.",
      "novakidDescription": "Salut, les petits gars brillants."
    }
  },
  "bioshroom4": {
    "name": "Champignons Lumineux",
    "desc": "Une touffe de petits champignons brillants.",
    "metadata": {
      "apexDescription": "Jolis petits champignons lumineux.",
      "avianDescription": "Ces champignons brillants sont adorables!",
