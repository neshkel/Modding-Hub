    "name": "Banc",
    "desc": "Un banc basique.",
    "metadata": {
      "apexDescription": "Un banc ordinaire.",
      "avianDescription": "Un banc.",
      "floranDescription": "Sssiège.",
      "glitchDescription": "Neutre. Un banc.",
      "humanDescription": "Un banc.",
      "hylotlDescription": "Un banc en toute simplicité.",
      "novakidDescription": "Un p'tit coin pour reposer ses jambes fatiguées."
    }
