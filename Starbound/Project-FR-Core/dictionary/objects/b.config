  "bountyboard": {
    "name": "Panneau de Primes",
    "desc": "Un tableau d'affichage où sont publiées les primes pour les criminels notoires!"
  },
  "bonespike": {
    "name": "Pointe en Os",
    "desc": "Vaudrait mieux ne pas tomber là-dessus...",
    "metadata": {
      "apexDescription": "Une pointe acérée, faite d'os.",
      "avianDescription": "Cet os semble tranchant comme un rasoir.",
      "floranDescription": "Tranchant et sssalement pointu.",
      "glitchDescription": "Prudent. Un os pointu pourrait pénétrer la carapace d'un Glitch.",
      "humanDescription": "Je ferais mieux de ne pas toucher à ça.",
      "hylotlDescription": "J'éviterai ces pointes avec élégance.",
      "novakidDescription": "Mieux vaut éviter c'genre de truc."
    }
  },
  "bossdoor": {
    "name": "Champ de Force",
    "desc": "Un champ de force qui ne peut être franchi que dans un seul sens.",
    "metadata": {
      "apexDescription": "Cette porte à l'aspect antique ne peut être franchie que dans une direction.",
      "avianDescription": "Cette porte va m'obliger à aller de l'avant - je ne pourrai plus revenir sur mes pas.",
      "floranDescription": "Vieille porte laissse pas Floran revenir en arrière.",
      "glitchDescription": "Inquiet. Cette porte ne peut être franchie que dans un seul sens. Il n'y a pas de retour possible.",
      "humanDescription": "Cette porte génère un champ de force à sens unique. Quiconque entre ne ressortira pas par là...",
      "hylotlDescription": "Cette porte crée un champ de force accessible d'un seul côté. Il est impossible de rebrousser chemin.",
      "novakidDescription": "Y'aura pas de marche arrière possible une fois franchie c'te vieille porte."
    }
  },
  "bossweb": {
    "name": "Toile d'Ixodoom",
    "desc": "La toile de l'Ixodoom.",
    "metadata": {
      "apexDescription": "Beurk... Quelle créature répugnante.",
      "avianDescription": "C'est la toile de l'Ixodoom. Je ferais mieux de l'éviter si je tiens à la vie!",
      "floranDescription": "Toile dégoûtantesss.",
      "glitchDescription": "Terrifié. Juste une énorme toile collante. Rien dont il faille avoir peur.",
      "humanDescription": "La toile de l'Ixodoom. Crado!",
      "hylotlDescription": "Une toile infecte produite par l'Ixodoom.",
      "novakidDescription": "Un genre de glu dégoûtante."
    }
  },
  "brokentank": {
    "name": "Char d'assaut brisé",
    "desc": "Un char d'assaut en morceaux.",
    "metadata": {
      "apexDescription": "Un char d'assaut militaire brisé.",
      "avianDescription": "Un étrange véhicule, il semble être hors d'usage.",
      "floranDescription": "Une sssorte de boîte en métal.",
      "glitchDescription": "Alarmé. Un char d'assaut détruit.",
      "humanDescription": "Un tank, il est cassé.",
      "hylotlDescription": "Un véhicule militaire quelconque. Je ne pense pas qu'il soit opérationnel.",
      "novakidDescription": "Une sssorte de véhicule. Ça n'ira nulle part de sssitôt!"
    }
  },
