  "bardoor2": {
    "name": "Herse",
    "desc": "Cette lourde herse en fer s'ouvre vers le haut.",
    "metadata": {
      "apexDescription": "On dirait que cette porte en fer s'ouvre vers le haut.",
      "avianDescription": "Des portes comme celle-ci sont souvent utilisées pour décourager ceux qui voudraient les profaner.",
      "floranDescription": "Porte essst lourde, piques de métal tranchantess font la porte.",
      "glitchDescription": "Suffisant. Les Glitchs créent leurs herses à une échelle bien plus grande.",
      "humanDescription": "Je détesterais rester coincé dessous pendant qu'elle se ferme.",
      "hylotlDescription": "Fer massif. La fonction prime sur la forme.",
      "novakidDescription": "C'est que c'est du costaud, ces barreaux en fer."
    }
  },
  "bardoor2sideways": {
    "name": "Herse Horizontale",
    "desc": "Cette lourde herse en fer s'ouvre vers l'intérieur.",
    "metadata": {
      "apexDescription": "On dirait que cette porte en fer s'ouvre vers l'intérieur.",
      "avianDescription": "De lourdes portes en fer comme celles-ci sont idéales pour sécuriser n'importe quel endroit.",
      "floranDescription": "Grille de métal essst lourde, barress de métal ssont ssolides.",
      "glitchDescription": "Inquiet. Ces barres de métal tranchantes semblent dangereuses.",
      "humanDescription": "Cette lourde porte métallique est alignée sur le côté.",
      "hylotlDescription": "Fer massif. Ce n'est peut-être pas joli, mais ça éloigne les invités indésirables.",
      "novakidDescription": "C'est une sacrée porte bien robuste."
    }
  },
  "bardoor3": {
    "name": "Grande Herse",
    "desc": "Cette herse massive en fer se ferme avec un bruit sourd.",
    "metadata": {
      "apexDescription": "J'en ai marre des barreaux et des chaînes.",
      "avianDescription": "Une grille solide, tout à fait capable de repousser les envahisseurs.",
      "floranDescription": "Sssolide porte en métal.",
      "glitchDescription": "Mélancolique. Cette herse me rappelle l'endroit où j'ai été assemblé.",
      "humanDescription": "Une herse, on dirait un retour dans le temps! Très authentique.",
      "hylotlDescription": "Cette porte est très peu accueillante.",
      "novakidDescription": "V'là une porte qui m'a l'air drôlement résistante."
    }
  },
  "bigjar1": {
    "name": "Grande Jarre Oiseau",
    "desc": "Une jarre somptueuse en forme d'oiseau. Je pourrais peut-être la briser...",
    "metadata": {
      "apexDescription": "Une grande jarre en forme d'oiseau. Je me demande s'il y a quelque chose à l'intérieur...",
      "avianDescription": "Ces jarres ont été construites pour transporter les biens des Avians dans l'au-delà.",
      "floranDescription": "Sssupide jarre oiseau sse cassse facilement.",
      "glitchDescription": "Curieux. Y a-t-il un trésor à l'intérieur de cette jarre?",
      "humanDescription": "Une grande jarre d'oiseau cassable.",
      "hylotlDescription": "Puis-je vraiment éviter de briser cela?",
      "novakidDescription": "Cette grande jarre d'oiseau est parfaite pour s'entraîner au tir."
    }
  },
  "birdaltar2": {
    "name": "Autel de Prière Avian",
    "desc": "L'autel est couvert de sculptures d'un dieu ailé.",
    "metadata": {
      "apexDescription": "Un autel. Il est couvert de sculptures complexes d'un Avian avec des ailes.",
      "avianDescription": "Cet autel est couvert de sculptures de Kluex. Les Stargazers l'utilisent pour communier avec Kluex et le prier d'accepter les morts dans l'éther. Des offrandes sont souvent faites ici.",
      "floranDescription": "Homme-oiseau de ppierre sculpté ssour table de ppierre.",
      "glitchDescription": "Confus. Cet autel semble avoir un but religieux qui m'échappe.",
      "humanDescription": "Un autel couvert de sculptures Avian. C'est peut-être leur dieu?",
      "hylotlDescription": "Une telle piété n'est pas la voie à suivre.",
      "novakidDescription": "On dirait un vieil autel. Y'a des gravures partout."
    }
  },
  "birdbed": {
    "name": "Nid de Gardien",
    "desc": "Un lit de pierre solide surmonté d'un nid de foin.",
    "metadata": {
      "apexDescription": "Un lit de pierre rempli de foin. Ça a l'air incroyablement inconfortable.",
      "avianDescription": "Un nid de gardien. Les gardiens protègent le sol sacré des Avians. Ce sont des guerriers sauvages mus par la piété.",
      "floranDescription": "Hommess-oiseaux ont nid de foin. Floran utilise literie sssimilaire.",
      "glitchDescription": "Inquiet. L'ergonomie de ce lit est mal conçue.",
      "humanDescription": "Un lit de pierre. Le foin n'offre que peu de confort. La pierre est froide au toucher.",
      "hylotlDescription": "Il faut être dur comme le roc pour dormir parmi les pierres. Un lit de guerrier.",
      "novakidDescription": "C'est pas c'foin qui va rendre ce lit plus confortable."
    }
  },
  "birddoor": {
    "name": "Porte en Cristal Doré",
    "desc": "Une lourde porte dorée incrustée de cristaux.",
    "metadata": {
      "apexDescription": "Les cristaux de cette porte bourdonnent comme s'ils généraient de l'énergie. Cette technologie est inconnue.",
      "avianDescription": "Ces portes bourdonnent par résonance cristalline.",
      "floranDescription": "Brillante porte rend Floran heureux.",
      "glitchDescription": "Inquisitif. La porte contient une source d'énergie qui dépasse ma compréhension.",
      "humanDescription": "Les cristaux de cette porte sont chauds. Elle bourdonne doucement sous mes doigts.",
      "hylotlDescription": "Une porte en pierre magnifiquement sculptée, ornée de cristaux.",
      "novakidDescription": "Si c'est pas la porte la plus brillante que j'aie jamais vue."
    }
  },
  "birdgodemblem": {
    "name": "Emblème Avian",
    "desc": "Je jure que l'œil me suit dans la pièce...",
    "metadata": {
      "apexDescription": "C'est sculpté d'un seul bloc de pierre. Ça a dû prendre des années de travail.",
      "avianDescription": "Cet emblème marque une chambre d'audience. On dit que ceux qui se tiennent devant lui sont en audience avec Kluex.",
      "floranDescription": "Géant oiseau avec oeil à la pplace des f fesses. Essst-ce qu'il pond des pleurss?",
      "glitchDescription": "Impressionné. Il n'y a ici rien d'autre que de la pierre traitée.",
      "humanDescription": "L'œil est flippant. C'est comme si le dieu Avian nous regardait.",
      "hylotlDescription": "Cette sculpture en pierre semble prête à tomber en ruines. Elle devrait être préservée.",
      "novakidDescription": "J'voudrais pas croiser cet oiseau-là."
    }
  },
  "birdgong1": {
    "name": "Grand Gong",
    "desc": "Un grand gong en métal. C'est si tentant de lui coller une baffe!",
    "metadata": {
      "apexDescription": "Frapper ce gong produit un son profond.",
      "avianDescription": "Ces gongs sont utilisés dans les temples pour appeler les Avians à la prière.",
      "floranDescription": "Floran aime pas le bruit des hommme-oiseaux.",
      "glitchDescription": "Amusé. La tonalité de ce gong résonne bruyamment.",
      "humanDescription": "C'est si dur de résister à l'envie de frapper ce gong.",
      "hylotlDescription": "J'imagine qu'un gong sous l'océan sonnerait bien différemment.",
      "novakidDescription": "Je parie qu'frapper là-d'ssus fait un sacré boucan."
    }
  },
  "birdgong2": {
    "name": "Gong Avian Somptueux",
    "desc": "Un grand gong sophistiqué. Il est couvert de gravures.",
    "metadata": {
      "apexDescription": "Quel son cela doit produire.",
      "avianDescription": "Les prêtres faisaient sonner ce gong au début et à la fin de la prière.",
      "floranDescription": "Plaque à bruit Avian bruyante comme gong Floran.",
      "glitchDescription": "Fasciné. Il semble vibrer à la même fréquence que les cristaux Avians.",
      "humanDescription": "J'ai toujours voulu en frapper un comme ça.",
      "hylotlDescription": "De tels sons n'ont jamais retenti sous l'océan.",
      "novakidDescription": "Frapper ce truc doit faire pas mal de bruit."
    }
  },
  "birdgroundlantern": {
    "name": "Support de Torche",
    "desc": "Des ombres profondes s'étirent loin de cette torche vacillante.",
    "metadata": {
      "apexDescription": "La torche fournit une lumière douce.",
      "avianDescription": "Les temples Avians ne sont éclairés que par de la lumière naturelle.",
      "floranDescription": "Flammesss rendent Floran nerveux.",
      "glitchDescription": "Soulagé. La lumière de cette torche éclaire faiblement la zone.",
      "humanDescription": "Une torche qui a l'air vieille.",
      "hylotlDescription": "Les Hylotls n'allument pas de torches. Sous l'océan, l'air est trop précieux pour être gaspillé.",
      "novakidDescription": "Cette torche a une flamme correcte, mais pas assez pour cuisiner."
    }
  },
  "birdjar1": {
    "name": "Jarre de Temple Élégante",
    "desc": "Cette jarre a connu des jours meilleurs. Elle a l'air facile à briser...",
    "metadata": {
      "apexDescription": "Les gravures sont usées ici. Le pot semble prêt à voler en éclats.",
      "avianDescription": "Cette jarre aurait été décorée d'images de Kluex. Elle peut contenir des objets offerts en offrande.",
      "floranDescription": "Jarre toute usssée, prête à être cassssée.",
      "glitchDescription": "Observateur. Le matériau est fragile et facile à briser.",
      "humanDescription": "Ce truc a l'air de pouvoir tomber en morceaux au moindre toucher. Je me demande s'il y a quelque chose dedans.",
      "hylotlDescription": "Les marquages sur cette jarre ne sont plus discernables. Elle pourrait toutefois contenir quelque chose d'utile.",
      "novakidDescription": "Cette jarre fragile est parfaite pour s'entraîner au tir."
    }
  },
  "birdjar2": {
    "name": "Jarre de Temple Laide",
    "desc": "Quelle jarre affreuse.",
    "metadata": {
      "apexDescription": "Une jarre peu attrayante. Peu de soin a été apporté à sa fabrication.",
      "avianDescription": "Cette jarre aurait été produite par des initiés. Elle est assez laide.",
      "floranDescription": "Vilaine jarre. Floran va casssser!",
      "glitchDescription": "Intrigué. Briser cette jarre pourrait révéler ce qu'elle contient.",
      "humanDescription": "Cassons celle-là. Elle n'est vraiment pas belle.",
      "hylotlDescription": "Il n'y a aucune valeur ici. Brisons-la.",
      "novakidDescription": "Je pourrais utiliser cette jarre pour m'entraîner au tir."
    }
  },
  "birdtable": {
    "name": "Table de Temple",
    "desc": "Une table en pierre dans le style typique Avian.",
    "metadata": {
      "apexDescription": "Une table en pierre. Décorée de motifs et de gravures.",
      "avianDescription": "Les gardiens du temple mangeaient sur cette table. Les gravures remercient Kluex pour sa générosité.",
      "floranDescription": "Table couverte de gravuress d'hommme-oiseaux. Tachess de nourriture sur le dessus.",
      "glitchDescription": "Observateur. Cette table est tachée par de nombreux aliments différents.",
      "humanDescription": "Une table en pierre, probablement une table à manger à en juger par son usure.",
      "hylotlDescription": "Les gravures sur cette table sont magnifiques, mais malheureusement, elle n'a pas été bien entretenue.",
      "novakidDescription": "Une table en pierre. J'imagine qu'c'est pas facile à déplacer."
    }
  },
  "birdthrone": {
    "name": "Trône Avian",
    "desc": "Un trône magistralement conçu, digne de Kluex lui-même.",
    "metadata": {
      "apexDescription": "Un trône couvert de gravures. C'est tout un spectacle.",
      "avianDescription": "Un trône de Stargazer. Chaque Stargazer se voit assigner un temple à protéger.",
      "floranDescription": "Trône d'hommme-oiseau fera un bon trophée pour Floran.",
      "glitchDescription": "D'accord. Les seigneurs Glitchs siègent également sur des trônes.",
      "humanDescription": "Un trône de pierre. Ça rime avec couronne.",
      "hylotlDescription": "Ce trône a l'air inconfortable. Il semble également à peine utilisé, peut-être juste une démonstration de puissance.",
      "novakidDescription": "Cette chaise est faite de pierre, ça m'a l'air drôlement inconfortable."
    }
  },
  "benjaminstatue": {
    "name": "Statue de Benjamin Deust",
    "desc": "Une statue dédiée à Benjamin \"Meuterion\" Deust.",
    "metadata": {
      "apexDescription": "La plaque indique \"Une statue dédiée à Benjamin \"Meuterion\" Deust.\"",
      "floranDescription": "Floran penssse que cet homme a fait quelque choose d'important s'il est une ssstatue.",
      "glitchDescription": "Observateur. La plaque affirme que ceci est dédié au grand Benjamin \"Meuterion\" Deust.",
      "humanDescription": "La plaque indique \"Une statue dédiée à Benjamin \"Meuterion\" Deust.\"",
      "hylotlDescription": "On dit que les statues des grands hommes sont faites avec les pierres qu'on leur a jetées de leur vivant.",
      "novakidDescription": "La plaque indique \"Une statue dédiée à Benjamin \"Meuterion\" Deust.\""
    }
  },
  "blueflask": {
    "name": "Flasque Bleue",
    "desc": "Une flasque remplie de liquide bleu.",
    "metadata": {
      "apexDescription": "Dieu seul sait quelles souffrances ce mélange a causées.",
      "avianDescription": "Une potion bleue? Ça ne peut pas être bon.",
      "floranDescription": "Sssent terriblement mauvais.",
      "glitchDescription": "Inspiré. Bleu!",
      "humanDescription": "Ça sent comme... Quelque chose qui ne devrait pas passer les lèvres.",
      "hylotlDescription": "Ce mélange a l'air toxique.",
      "novakidDescription": "Rien de bleu n'est jamais naturel."
    }
  },
  "batongaf": {
    "name": "Figurine de Batong",
    "desc": "L'étiquette indique: \"En goûtant les particules dans l'air, il peut sentir ce qui se trouve devant lui.\""
  },
  "bigapeaf": {
    "name": "Figurine de Big Ape",
    "desc": "L'étiquette indique: \"La figure de proue du régime Miniknog. Nécessite des projecteurs holographiques pour rester stable.\""
  },
  "bobfaeaf": {
    "name": "Figurine de Bobfae",
    "desc": "L'étiquette indique: \"Pas le voltigeur le plus efficace, c'est un mystère de savoir comment les bobfae ont survécu en tant qu'espèce.\""
  },
  "bobotaf": {
    "name": "Figurine de Bobot",
    "desc": "L'étiquette indique: \"Personne ne sait d'où il vient ni qui l'a fabriqué.\""
  },
  "bonedragonaf": {
    "name": "Figurine de Dragon d'Os",
    "desc": "L'étiquette indique: \"Un dragon robotique cracheur de feu imposant, conçu pour ressembler à un squelette réanimé.\""
  },
  "bulbopaf": {
    "name": "Figurine de Bulbop",
    "desc": "L'étiquette indique: \"Il ressemble à un poireau large et trapu. Mais il saigne quand on le coupe.\""
  }
}