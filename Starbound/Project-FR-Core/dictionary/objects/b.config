      "glitchDescription": "Intrigue. Pourquoi cette lumière me donne-t-elle une telle sensation de froid?",
      "humanDescription": "Des lumières bleues, parfaites pour donner une atmosphère fraîche à une pièce.",
      "hylotlDescription": "Cette lumière bleue me rappelle les rayons du soleil filtrés par les océans de saphir.",
      "novakidDescription": "Cette lumière est comme une étoile qui brûle à froid, bien qu'un peu plusss petite."
    }
  },
  "box1": {
    "name": "Caisse en bois",
    "desc": "Une petite caisse en bois.",
    "metadata": {
      "apexDescription": "Une simple boîte en bois.",
      "avianDescription": "Une boîte faite de bois.",
      "floranDescription": "Une boîte de chair d'arbre dépouillé.",
      "glitchDescription": "Satisfaction. Cette caisse en bois est simple mais efficace.",
      "humanDescription": "Une caisse faite de petites planches de bois.",
      "hylotlDescription": "Une caisse en bois. C'est fonctionnel, mais peu gracieux.",
      "novakidDescription": "Une caisse toute simple faite de bois."
    }
  },
  "box2": {
    "name": "Caisse en bois sécurisée",
    "desc": "Une caisse en bois sécurisée.",
    "metadata": {
      "apexDescription": "Une boîte en bois qui a été renforcée.",
      "avianDescription": "Une boîte faite de bois et de métal.",
      "floranDescription": "Le métal maintient cette boîte en bois.",
      "glitchDescription": "Intérêt. Ces supports métalliques ont rendu cette boîte nettement plus robuste.",
      "humanDescription": "Une caisse en bois maintenue par du métal.",
      "hylotlDescription": "Une simple caisse de bois et de métal.",
      "novakidDescription": "C'te boîte ressemble à un p'tit tonneau carré."
    }
  },
  "burningcoals": {
    "name": "Charbons ardents",
    "desc": "Ne vous brûlez pas les pieds!",
    "metadata": {
      "apexDescription": "Des charbons chauds. Ils sont brûlants au toucher.",
      "avianDescription": "Des charbons ardents. Ils ont l'air brûlants.",
      "floranDescription": "Floran détes s s te lesss pierresss de feu!",
      "glitchDescription": "Prudence. Ces charbons incandescents semblent dangereusement chauds.",
      "humanDescription": "Je ne pense pas que ce soit le genre de charbons ardents sur lesquels on peut marcher.",
      "hylotlDescription": "La chaleur est désagréable.",
      "novakidDescription": "Des charbons ardents. Assez chauds pour brûler mes bottes."
    }
  },
  "butterflybush": {
    "name": "Buisson à papillons",
    "desc": "De petits insectes battant des ailes semblent bouger à l'intérieur de ce buisson.",
    "metadata": {
      "apexDescription": "Un buisson rempli d'insectes.",
      "avianDescription": "J'ai trouvé un insecte dans ce buisson.",
      "floranDescription": "Minusssculesss insectesss dans le buis s s on trop petitsss pour être poignardésss.",
      "glitchDescription": "Intérêt. La biologie de ce buisson doit attirer ces insectes d'une manière ou d'une autre.",
      "humanDescription": "Certains de ces insectes sont jolis, je devrais en attraper dans un bocal.",
      "hylotlDescription": "De charmants petits insectes.",
      "novakidDescription": "Ce p'tit virevoltant est tout couvert de bestioles."
    }
  },
  "basicmetalchair": {
    "name": "Chaise en métal basique",
    "desc": "Une chaise en métal robuste.",
    "metadata": {
      "apexDescription": "Une chaise en métal sans grand intérêt.",
      "avianDescription": "Une simple chaise en métal.",
      "floranDescription": "Chaise en métal.",
      "glitchDescription": "Désintérêt. Une chaise métallique.",
      "humanDescription": "Une chaise en métal. Pas grand-chose à ajouter.",
      "hylotlDescription": "Une chaise manquant singulièrement d'inspiration.",
      "novakidDescription": "Une bête chaise en métal."
    }
  },
  "bowlingpin": {
    "name": "Quille de bowling",
    "desc": "Renversez-la!",
    "metadata": {
      "apexDescription": "C'est une quille de bowling en équilibre.",
      "avianDescription": "Une pièce utilisée pour un jeu de compétition.",
      "floranDescription": "Floran veut la renvers s s er.",
      "glitchDescription": "Curiosité. Elle est alignée pour être renversée à nouveau.",
      "humanDescription": "Une quille de bowling. J'ai envie de la faire tomber.",
      "hylotlDescription": "Elle a été renversée maintes fois, mais se relève toujours.",
      "novakidDescription": "Cette quille de bowling ne demande qu'à être renversssée."
    }
  },
  "bamboodoor": {
    "name": "Porte en Bambou",
    "desc": "Cette porte est robuste et issue de sources durables.",
    "metadata": {
      "apexDescription": "Du bambou tressé en porte. C'est plus résistant qu'il n'y paraît.",
      "avianDescription": "La plante utilisée pour fabriquer cette porte semble aussi solide que la pierre.",
      "floranDescription": "Le bambou Floran essst aussisss sssolide que le métal.",
      "glitchDescription": "Surpris. Cette porte est faite de matériaux organiques, mais elle est aussi solide que l'acier.",
      "humanDescription": "Cette porte a de petits interstices là où les tiges de bambou se rejoignent. Je vois tout à travers!",
      "hylotlDescription": "Les Florans semblent capables de plier la nature à leur volonté. Ce n'est pas un mince exploit.",
      "novakidDescription": "L'bon vieux bambou, l'acier de la nature."
    }
  },
  "bananaseed": {
    "name": "Graine de Banane",
    "desc": "Des bananes génétiquement améliorées. Des arbres plus petits avec des fruits plus gros.",
    "metadata": {
      "apexDescription": "Il existe un stéréotype selon lequel les Apex adorent les bananes, grâce au Miniknog. Elles sont délicieuses, cela dit.",
      "avianDescription": "Ces bananes ont un goût inhabituel que je n'arrive pas à définir.",
      "floranDescription": "Sssent comme l'homme-sssinge.",
      "glitchDescription": "Cynique. Les Apex adorent ça, mais les Glitchs n'y voient rien de spécial.",
      "humanDescription": "C'est comme une banane, mais encore plus... banané.",
      "hylotlDescription": "Une banane génétiquement modifiée, je peux sentir le goût artificiel.",
      "novakidDescription": "Les bananes génétiquement améliorées sont les meilleures bananes."
    }
  },
  "beakseedseed": {
    "name": "Graine de Graine-bec",
    "desc": "Fait pousser des graines-becs croquantes. La narine est la meilleure partie.",
    "metadata": {
      "apexDescription": "La graine-bec est anormalement croquante, et pas tout à fait agréable.",
      "avianDescription": "Il existe un vieux conte populaire sur des Avians mangeant des graines-becs lors d'un banquet... J'aime bien celui-là.",
      "floranDescription": "Graine-bec croquante, pas sssoft comme les autresss bouchesss.",
      "glitchDescription": "Philosophique. Est-ce que la graine-bec ressemble à un bec, ou est-ce que les becs ressemblent à des graines-becs?",
      "humanDescription": "La récolte ressemble à un visage d'Avian. C'est un peu déconcertant.",
      "hylotlDescription": "Les graines-becs sont étonnamment savoureuses. On ne peut que supposer que les becs sont loin d'être aussi appétissants.",
      "novakidDescription": "J'voudrais pas manger un vrai bec par erreur."
    }
  },
  "boltbulbseed": {
    "name": "Graine de Boulon-bulbe",
    "desc": "Fait pousser du boulon-bulbe! Étonnamment mou.",
    "metadata": {
      "apexDescription": "Mou comme une banane, mais avec un horrible goût métallique.",
      "avianDescription": "Les Terre-à-terre ont fini par apprécier ce légume métallique étrange.",
      "floranDescription": "Métal mou, pas comme la chair des Glitchsss.",
      "glitchDescription": "Sentimental. Ce légume a le goût de la maison.",
      "humanDescription": "Dégoûtant, manger ça, c'est comme manger des morceaux de camion.",
      "hylotlDescription": "Le boulon-bulbe est l'un des rares légumes véritablement savoureux, pour les vrais connaisseurs.",
      "novakidDescription": "Un légume métallique? J'veux bien goûter n'importe quoi une fois."
    }
  },
  "bonebooseed": {
    "name": "Graine d'Os-bou",
    "desc": "L'os-bou, une bonne source de calcium.",
    "metadata": {
      "apexDescription": "Une plante particulièrement inhabituelle. Tige croquante, fruit charnu.",
      "avianDescription": "Les os-bous ne sont pas au goût des Avians.",
      "floranDescription": "Nourrituresss croquantesss, sssouplesss et charnuesss.",
      "glitchDescription": "Désintéressé. Cette plante ressemble apparemment à l'anatomie interne organique. Les Glitchs n'ont pas de tels organes.",
      "humanDescription": "Cette plante n'est peut-être pas adaptée aux végétariens.",
      "hylotlDescription": "De nombreux repas végétariens Hylotls sont préparés avec la plante os-bou.",
      "novakidDescription": "Un fruit qu'a l'goût de la viande. Déroutant!"
    }
  },
  "bigapedoll": {
    "name": "Poupée de Big Ape",
    "desc": "Une poupée de Big Ape quelque peu suspecte.",
    "metadata": {
      "apexDescription": "Une poupée de Big Ape bien faite... Attendez, les yeux sont des caméras?",
      "avianDescription": "C'est une assez jolie poupée, mais je pense que les yeux sont en fait des caméras...",
      "floranDescription": "Floran sssuspecte la poupée.",
      "glitchDescription": "Inquiet. Je pense que cette poupée est en fait une sorte de dispositif d'espionnage.",
      "humanDescription": "Les yeux de cette poupée n'arrêtent pas de clignoter... Je suis presque sûr que c'est un dispositif d'espionnage.",
      "hylotlDescription": "Quelque chose dans cette poupée me met mal à l'aise... Je pense qu'elle a peut-être des caméras à la place des yeux.",
      "novakidDescription": "Quéqu'chose dans c'te poupée m'met pas vraiment à l'aise."
    }
  },
  "bigapetargetmap": {
    "name": "Carte de Cible de Big Ape",
    "desc": "Une carte désorganisée pour localiser Big Ape. Quiconque l'a dessinée était très en colère.",
    "metadata": {
      "apexDescription": "Cette carte est couverte de notes griffonnées et d'indications sur la localisation probable de Big Ape.",
      "avianDescription": "Cela semble contenir beaucoup de notes et d'informations sur l'endroit où se trouve Big Ape.",
      "floranDescription": "Floran pas sssûr de l'utilité de la carte.",
      "glitchDescription": "Intrigué. Cette carte semble contenir des informations sur la localisation de Big Ape, le chef de facto de la population Apex.",
      "humanDescription": "Cette carte semble contenir beaucoup de notes griffonnées sur l'emplacement de Big Ape. L'auteur a clairement une dent contre le dictateur.",
      "hylotlDescription": "Cette carte comporte de nombreuses notes griffonnées et des renseignements sur l'emplacement de Big Ape. Quelqu'un veut manifestement le retrouver.",
      "novakidDescription": "C'te affiche a quéqu's infos sur la planque de Big Ape - écrite par des gens en colère, à n'en pas douter."
    }
  },
  "blueback": {
    "name": "Dos-bleu",
    "desc": "Cet insecte bleu a de petites dents acérées."
  },
  "brightstripe": {
    "name": "Rayure-brillante",
    "desc": "Vibrant et magnifique, il arbore un petit sourire amical."
  },
  "butterbee": {
    "name": "Abeille-beurre",
    "desc": "Un insecte d'un jaune éclatant, ses ailes sentent le beurre."
  },
  "bosstentacle": {
    "name": "Tentacule de Boss",
    "desc": "Tentacule de la Ruine."
  },
  "bossrightspawner": {
    "name": "Générateur de Boss Droit",
    "desc": "Générateur de la Ruine."
  },
  "boilervalve": {
    "name": "Valve de Chaudière",
    "desc": "Une valve en laiton, rouillée par des années d'utilisation.",
    "metadata": {
      "apexDescription": "Une roue de valve en laiton grinçante.",
      "avianDescription": "Je me demande si tourner cela servira à quelque chose?",
      "floranDescription": "Floran veut lancer la roue sssur ssses ennemisss.",
      "glitchDescription": "Observateur. Cette valve a reçu de nombreuses couches de peinture.",
      "humanDescription": "On ne peut pas avoir de vapeur sans valve!",
      "hylotlDescription": "Cette vieille roue est le plus souvent utilisée pour réguler le débit d'un fluide.",
      "novakidDescription": "Tourner c'te valve demande un peu d'huile de coude."
    }
  },
  "brasslamppost1": {
    "name": "Lampadaire en Laiton",
    "desc": "Un lampadaire grinçant, fait de tuyaux en laiton.",
    "metadata": {
      "apexDescription": "Ce lampadaire semble être fait de ferraille.",
      "avianDescription": "Ce lampadaire éclairera, espérons-le, le chemin.",
      "floranDescription": "Grandesss et brillantesss lampe.",
      "glitchDescription": "Observateur. Un grand lampadaire fait de métal.",
      "humanDescription": "Un joli lampadaire fait de tuyaux.",
      "hylotlDescription": "Ce lampadaire semble pouvoir résister même à des conditions subaquatiques.",
      "novakidDescription": "La lumière de c'lampadaire vacille pas comme une flamme nue."
    }
  },
  "beaconsnow": {
    "name": "Balise de Détresse",
    "desc": "Une balise de détresse. Qui sait qui pourrait l'entendre?",
    "metadata": {
      "apexDescription": "Une balise de détresse. J'espère que la personne qui l'a laissée va bien.",
      "avianDescription": "Une balise de détresse. Quelqu'un doit avoir des ennuis.",
      "floranDescription": "Floran aide aussisssi bien qu'il chassse. Parfoiss.",
      "glitchDescription": "Observateur. Cette balise de détresse émet sur plusieurs fréquences.",
      "humanDescription": "Cette balise envoie un appel de détresse.",
      "hylotlDescription": "Quelqu'un a besoin d'aide. Protéger les faibles est une quête louable.",
      "novakidDescription": "On dirait une balise de détresse. J'me demande qui l'a activée."
    }
  },
  "blueprintblob": {
    "name": "Blob de Plans",
    "desc": "Un plan enfermé dans une infâme bulle de vase.",
    "metadata": {
      "apexDescription": "Un plan enfermé dans une vase immonde.",
      "avianDescription": "Une sorte de plan est enfermé à l'intérieur.",
      "floranDescription": "Essst-ce un plan à l'intérieursss?",
      "glitchDescription": "Curieux. Cela semble contenir un plan.",
      "humanDescription": "Il y a une sorte de plan à l'intérieur de ce truc!",
      "hylotlDescription": "Je vois que les Florans ont trouvé un contenant digne de leurs créations.",
      "novakidDescription": "C'truc a pas l'air bien pratique, c'est sûr."
    }
  },
  "bombsheltershelf1": {
    "name": "Étagère d'Abri",
    "desc": "Tout ce dont vous avez besoin pour survivre. Ou presque.",
    "metadata": {
      "apexDescription": "Il y a des objets utiles sur cette étagère.",
      "avianDescription": "Il y a des objets de soin sur cette étagère.",
      "floranDescription": "Étagère contient desss objetsss.",
      "glitchDescription": "Soulagé. Cette étagère contient de nombreux objets utiles.",
      "humanDescription": "Ce serait utile s'il y avait une sorte de catastrophe.",
      "hylotlDescription": "Cela a été construit pour l'utilité, pas pour la beauté.",
      "novakidDescription": "Ça s'rait bien utile en cas de pépin!"
    }
  },
  "brokenanchor": {
    "name": "Ancre Brisée",
    "desc": "Une ancre brisée",
    "metadata": {
      "apexDescription": "Une ancre brisée.",
      "avianDescription": "Cette ancre semble être brisée.",
      "floranDescription": "C'essst casssé.",
      "glitchDescription": "Craintif. Cette ancre est couverte de rouille, l'ennemi des Glitchs.",
      "humanDescription": "D'où vient cette ancre?",
      "hylotlDescription": "On a déjà vu des ancres s'abattre depuis la surface et heurter des cités Hylotls.",
      "novakidDescription": "J'arrive pas trop à dire si c'est juste vieux ou si c'est du travail bâclé."
    }
  },
  "beanstalk": {
    "name": "Haricot Magique",
    "desc": "Une tige de haricot, elle grimpe jusqu'au ciel.",
    "metadata": {
      "apexDescription": "Un véritable haricot magique!",
      "avianDescription": "Un haricot magique de légende.",
      "floranDescription": "Haricot pousssse haut, Floran atteint le cielsss.",
      "glitchDescription": "Méfiant. Qu'est-ce qui pourrait bien se trouver au sommet d'un haricot magique?",
      "humanDescription": "Ce haricot magique me rappelle un conte de fées.",
      "hylotlDescription": "Il doit y avoir une vue magnifique depuis le sommet.",
      "novakidDescription": "Une tige de haricot, ça grimpe droit vers le ciel."
    }
  },
