      "novakidDescription": "Salut, les petits gars brillants."
    }
  },
  "bioshroomtable": {
    "name": "Table Phosphorescente",
    "desc": "Une table champignon géante et lumineuse. Parfaite pour s'asseoir dans le noir.",
    "metadata": {
      "apexDescription": "Si on avait trop faim, on pourrait manger la table elle-même.",
      "avianDescription": "Cette table est un peu trop brillante pour mes goûts.",
      "floranDescription": "Floran secouer table en coupant viande.",
      "glitchDescription": "Ébloui. Cette table géante ressemble à s'y méprendre à un champignon.",
      "humanDescription": "Manger ici donnerait l'impression de faire un pique-nique magique.",
      "hylotlDescription": "Conçue pour ressembler aux champignons souterrains, cette table imite leur éclat.",
      "novakidDescription": "Un gros faux champignon qui peut servir de table."
    }
  },
  "biovine1": {
    "name": "Liane Lumineuse",
    "desc": "C'est une liane qui brille!",
    "metadata": {
      "apexDescription": "Des tentacules lumineuses.",
      "avianDescription": "Il y a quelque chose de beau dans ces lianes.",
      "floranDescription": "Lianesss vertesss brillantesss.",
      "glitchDescription": "Satisfait. J'aimerais que ces lianes poussent dans chaque grotte.",
      "humanDescription": "D'inquiétantes lianes lumineuses.",
      "hylotlDescription": "Ces lianes sont comme les algues mouvantes des profondeurs, leur faible éclat est apaisant.",
      "novakidDescription": "On peut faire toutes ssortes de trucs utiles avec ces lianes."
    }
  },
  "biovine2": {
    "name": "Liane Lumineuse",
    "desc": "C'est une liane qui brille!",
    "metadata": {
      "apexDescription": "Des tentacules lumineuses.",
