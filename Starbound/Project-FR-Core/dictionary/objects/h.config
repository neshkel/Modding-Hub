  },
  "huntinglight3": {
    "name": "Liane à Cosse Lumineuse",
    "desc": "Une grande cosse lumineuse suspendue à une liane.",
    "metadata": {
      "apexDescription": "Une bien jolie lumière.",
      "avianDescription": "Une plante qui s'éclaire. Remarquable.",
      "floranDescription": "Lumière de plante ne brûle pass Floran.",
      "glitchDescription": "Impressionné. Les Florans sont capables d'exploiter la nature très efficacement.",
      "humanDescription": "Cette lumière a l'air d'avoir poussé, pas d'avoir été fabriquée.",
      "hylotlDescription": "Même les vils Florans apprécient la beauté, semble-t-il.",
      "novakidDescription": "Cette plante peut carrément éclairer."
    }
  },
  "huntingpike1": {
    "name": "Os sur Pique",
    "desc": "Quelques os sur une pique. Quel morbide.",
    "metadata": {
      "apexDescription": "Il semble s'agir de parties d'un squelette disposées sur une pique.",
      "avianDescription": "Les Florans exposent souvent des os comme trophées. Quelle pratique rudimentaire.",
      "floranDescription": "Squelette fait une bonne décoration.",
      "glitchDescription": "Horrifié. Ces Florans exposent les os des morts d'une manière si violente.",
      "humanDescription": "Qui que fût ce gars, il n'aurait pas dû finir comme ça.",
      "hylotlDescription": "Ces os sont-ils assemblés en guise d'avertissement?",
      "novakidDescription": "Regarder ce truc me donne les jetons."
    }
  },
  "huntingpike2": {
    "name": "Crâne sur Pique",
    "desc": "Un crâne sur une pique. Un favori des Florans.",
    "metadata": {
      "apexDescription": "Un crâne humain disposé sur une pique.",
      "avianDescription": "Contrairement aux Florans, la culture Aviane honore les morts.",
      "floranDescription": "Floran exposse ssess trophéess de chassse ssur dess piques.",
      "glitchDescription": "Observateur. Le crâne sur cette pique semble être humain.",
      "humanDescription": "Ce crâne a l'air usé par le temps, il est sur cette pique depuis un moment.",
      "hylotlDescription": "Un crâne posé sur une pique de chasse Floran.",
      "novakidDescription": "Un crâne posé sur une pique, c'est juste pas correct."
    }
  },
  "huntingpike3": {
    "name": "Pique d'Os de Pingouin",
    "desc": "Des os de pingouin sur une pique disposés de façon décorative.",
    "metadata": {
      "apexDescription": "Ce pingouin a dû connaître une fin atroce.",
      "avianDescription": "Aucun oiseau ne devrait finir ainsi, pas même un pingouin.",
      "floranDescription": "Floran met dess oss de petits ois sseaux ssur une pique.",
      "glitchDescription": "Dégoûté. Cette décoration est grotesque.",
      "humanDescription": "Ces os sur une pique semblent provenir d'un pingouin.",
      "hylotlDescription": "Des os exposés à la mode typique des Florans.",
      "novakidDescription": "De flippants os de pingouin perchés sur une pique."
    }
  },
  "huntingplatform1": {
    "name": "Plateforme Surélevée",
    "desc": "Une plateforme surélevée. Ne restez pas coincé dessous.",
    "metadata": {
      "apexDescription": "Une grande plateforme surélevée en bois.",
      "avianDescription": "Cette plateforme en bois a l'air très robuste.",
      "floranDescription": "Cette plateforme a été conssstruite par dess chassseurss Florans.",
      "glitchDescription": "Intéressé. À quoi peut bien servir une plateforme comme celle-ci?",
      "humanDescription": "Une plateforme en bois surélevée juste au-dessus du sol.",
      "hylotlDescription": "Quel que soit le Floran qui a construit cette plateforme, ce n'était pas un artisan très qualifié.",
      "novakidDescription": "Juste une vieille plateforme faite en bois."
    }
  },
  "huntingplatform2": {
    "name": "Plateforme à Rampe",
    "desc": "Une plateforme surélevée. Ne restez pas coincé dessous.",
    "metadata": {
      "apexDescription": "Cette plateforme en bois semble solidement construite.",
      "avianDescription": "Une large plateforme, je me demande quel en est le but.",
      "floranDescription": "Une grande plateforme Floran utilissée pour sse tenir debout.",
      "glitchDescription": "Impressionné. Bien que les matériaux soient basiques, cette plateforme est très bien faite.",
      "humanDescription": "Cette plateforme est surélevée comme une sorte de scène.",
      "hylotlDescription": "Une plateforme surélevée en bois.",
      "novakidDescription": "On dirait presque une scène pour moi."
    }
  },
  "huntingplatformleaves": {
    "name": "Fagot de Feuilles",
    "desc": "Un paquet de feuilles inhabituellement grandes.",
    "metadata": {
      "apexDescription": "Un groupement de grandes feuilles.",
      "avianDescription": "Quelques feuilles. Ont-elles été disposées ainsi intentionnellement?",
      "floranDescription": "Floran adore les grandess feuilless.",
      "glitchDescription": "Intéressé. Ces feuilles semblent inhabituellement grandes.",
      "humanDescription": "Un tas de feuilles énormes.",
      "hylotlDescription": "Je n'ai jamais vu de feuilles comme celles-ci sous l'eau.",
      "novakidDescription": "Un joli paquet de feuilles."
    }
  },
  "huntingplatformrocks": {
    "name": "Rochers Gravés d'une Flèche",
    "desc": "Des rochers très utiles. Ou bien la flèche pourrait-elle être un piège?",
    "metadata": {
      "apexDescription": "Un rocher avec une flèche dessus.",
      "avianDescription": "Un rocher avec une flèche gravée.",
      "floranDescription": "Par ici pour poignarder.",
      "glitchDescription": "Curieux. Pourquoi une flèche a-t-elle été gravée dans ce rocher?",
      "humanDescription": "Suivons la flèche sur ce rocher.",
      "hylotlDescription": "Un rocher grossièrement taillé.",
      "novakidDescription": "Quelqu'un s'est amusé à graver une flèche sur ce rocher là."
    }
  },
  "huntingpressureplate": {
    "name": "Plaque de Pression de Chasse",
    "desc": "Un dispositif idéal pour préparer des pièges et autres joyeusetés.",
    "metadata": {
      "apexDescription": "Une sorte de plaque de pression.",
      "avianDescription": "Que se passe-t-il si je monte dessus?",
      "floranDescription": "Bouton dans le ssol. Utile pour les piè gess.",
      "glitchDescription": "Curieux. Cette plaque est-elle reliée à quelque chose?",
      "humanDescription": "Un tapis de pression géant.",
      "hylotlDescription": "Qu'est-ce que cela active?",
      "novakidDescription": "Je parie qu'il s'passera un truc si j'marche là-dessus."
    }
  },
  "huntingpunjisticks1": {
    "name": "Grands Pieux Aiguisés",
    "desc": "Des bâtons pointus et tranchants. Ne tombez pas dessus.",
    "metadata": {
      "apexDescription": "Des pointes mortelles.",
      "avianDescription": "Des pointes dangereuses.",
      "floranDescription": "Piège à piquesss. Tranchant.",
      "glitchDescription": "Nerveux. Ces pointes aiguisées pourraient empaler même un Glitch.",
      "humanDescription": "Je devrais me balancer au-dessus de ces pointes.",
      "hylotlDescription": "Quelles pointes brutales.",
      "novakidDescription": "Les bouts de ces bâtons sont rudement pointus."
    }
  },
  "huntingpunjisticks2": {
    "name": "Petits Pieux Aiguisés",
    "desc": "Des bâtons pointus et tranchants. Ne tombez pas dessus.",
    "metadata": {
      "apexDescription": "Des pointes mortelles.",
      "avianDescription": "Des pointes dangereuses.",
      "floranDescription": "Piège à piquesss. Tranchant.",
      "glitchDescription": "Nerveux. Ces pointes aiguisées pourraient empaler même un Glitch.",
      "humanDescription": "Je devrais me balancer au-dessus de ces pointes.",
      "hylotlDescription": "Quelles pointes brutales.",
      "novakidDescription": "Les bouts de ces bâtons sont rudement pointus."
    }
  },
  "huntingrail1": {
    "name": "Garde-corps en Os Tordu",
    "desc": "Une rambarde maintenue par des os.",
    "metadata": {
      "apexDescription": "La configuration des os rend cette rambarde assez robuste.",
      "avianDescription": "Quelle morbidité. Aucun Avian n'utiliserait des os de cette manière.",
      "floranDescription": "Oss ssolides pour rambarde de ssécurité.",
      "glitchDescription": "Impressionné. Il n'est pas facile de renforcer une rambarde en utilisant des os.",
      "humanDescription": "Cette rambarde est faite d'os géants. Plutôt solide.",
      "hylotlDescription": "C'est désagréable de voir des os utilisés de cette façon.",
      "novakidDescription": "Des os tous attachés ensemble, servant de rambarde."
    }
  },
  "huntingrail2": {
    "name": "Garde-corps en Piques Tordues",
    "desc": "Une rambarde faite de piques attachées ensemble.",
    "metadata": {
      "apexDescription": "Cette rambarde doit être décorative, elle n'est pas très solide.",
      "avianDescription": "Une rambarde à l'aspect très primitif.",
      "floranDescription": "La ssécurité d'abord.",
      "glitchDescription": "Inquiet. Cette rambarde a l'air tranchante.",
      "humanDescription": "Je ferais mieux de ne pas m'appuyer sur cette rambarde, ces piques sont pointues.",
      "hylotlDescription": "Cette rambarde semble à peine fonctionnelle.",
      "novakidDescription": "Cette rambarde n'a pas l'air faite pour s'y accouder."
    }
  },
  "huntingstatue": {
    "name": "Statue Floran",
    "desc": "Une statue de Floran tenant une lance d'un air menaçant.",
    "metadata": {
      "apexDescription": "Un Floran affichant ses prouesses au lancer de lance.",
      "avianDescription": "Un Floran faisant ce qu'il fait de mieux: se préparer à tuer quelque chose.",
      "floranDescription": "Cette ssstatue dépeint la gloire de la chassse.",
      "glitchDescription": "Analyse. La lance a récemment été utilisée pour empaler une créature.",
      "humanDescription": "C'est un Floran qui a l'air coriace. Je me demande s'il s'agit de quelqu'un en particulier.",
      "hylotlDescription": "Même une statue de Floran me met mal à l'aise.",
      "novakidDescription": "Ce Floran a l'air d'être un partenaire plutôt solide."
    }
  },
  "huntingtrophy1": {
    "name": "Crâne Monté Rond",
    "desc": "Une tête montée sur une plaque ronde. Ses yeux vous suivent...",
    "metadata": {
      "apexDescription": "Une tête montée. Terrifiant.",
      "avianDescription": "Une tête, probablement issue d'une vieille proie.",
      "floranDescription": "Floran aime exposser les proiess de la chassse.",
      "glitchDescription": "Dégoûté. Cette tête est exposée comme décoration.",
      "humanDescription": "Regarder ce truc me donne la chair de poule.",
      "hylotlDescription": "Un vil défilé de meurtres.",
      "novakidDescription": "Je détesterais vraiment finir comme ce bougre."
    }
  },
  "huntingtrophy2": {
    "name": "Crâne Monté sur Écusson",
    "desc": "Une plaque finement sculptée présentant un crâne.",
    "metadata": {
      "apexDescription": "Une tête montée sur une plaque sculptée.",
      "avianDescription": "Les Florans exposent leurs victimes d'une manière honteuse.",
      "floranDescription": "Floran exposse fièrement sess proiess de chassse.",
      "glitchDescription": "Appréhensif. Ce crâne est utilisé pour décorer.",
      "humanDescription": "Cette plaque en bois porte un crâne fermement attaché.",
      "hylotlDescription": "Cette plaque est joliment sculptée, c'est dommage qu'un crâne y soit monté.",
      "novakidDescription": "Un crâne monté comme un trophée."
    }
  },
  "huntingtrophy3": {
    "name": "Crâne Monté sur Croix",
    "desc": "Un crâne monté en trophée sur des planches de bois croisées.",
    "metadata": {
      "apexDescription": "Une plaque murale grossière avec un crâne.",
      "avianDescription": "Cette tête est fixée au mur à l'aide de petites planches.",
      "floranDescription": "Floran accroche ssouvent dess trophéess de chassse au mur.",
      "glitchDescription": "Perturbé. Accrocher un crâne de cette façon est un peu inhabituel.",
      "humanDescription": "Ce pauvre gars n'aurait jamais imaginé finir comme ça.",
      "hylotlDescription": "Pourquoi quelqu'un aimerait-il exposer ce crâne?",
      "novakidDescription": "Ce trophée de crâne ne me revient pas."
    }
  },
  "huntingweaponrack1": {
    "name": "Ratelier d'Armes de Chasse",
    "desc": "Un râtelier d'armes Floran. Sans surprise, beaucoup d'armes ont disparu.",
    "metadata": {
      "apexDescription": "Un râtelier contenant des lances Florans.",
      "avianDescription": "Un support conçu pour ranger des armes.",
      "floranDescription": "Support pour les lancesss.",
      "glitchDescription": "Prudent. Ces lances acérées semblent prêtes à être saisies à tout moment.",
      "humanDescription": "Ces armes n'ont pas l'air de valoir le coup d'être prises.",
      "hylotlDescription": "Une démonstration éhontée d'intention violente.",
      "novakidDescription": "Un support en bois contenant quelques lances."
    }
  },
  "huntingweaponrack2": {
    "name": "Ratelier d'Armes Vide",
    "desc": "Un râtelier d'armes Floran. Toutes les armes manquent à l'appel.",
    "metadata": {
      "apexDescription": "Un râtelier d'armes, il est complètement vide.",
      "avianDescription": "Il semble que ce support serve à ranger des armes.",
      "floranDescription": "Support d'armes de chassse vide.",
      "glitchDescription": "Hypothétique. D'après les dimensions, ce support semble conçu pour des lances.",
      "humanDescription": "Un râtelier à lances, sans aucune lance.",
      "hylotlDescription": "Un support pour ranger les armes rudimentaires des Florans.",
      "novakidDescription": "Ce support est fait pour des lances, je me demande s'il tiendrait un fusil?"
    }
  },
  "henegg": {
    "name": "Œuf de Poule",
    "desc": "Éclot en un minuscule poussin qui devient une poule. La poule adulte pond de délicieux œufs.",
    "metadata": {
      "apexDescription": "C'est un œuf de poule. Il y a un poussin à l'intérieur.",
      "avianDescription": "Un œuf de poule avec un minuscule poussin dedans... Je me sens soudainement très protecteur.",
      "floranDescription": "Petit œuf de poule tachetée.",
      "glitchDescription": "Excité. Cet œuf de poule semble prêt à éclore!",
      "humanDescription": "Il y a un petit poussin duveteux à l'intérieur de cet œuf.",
      "hylotlDescription": "Un œuf de poule – l'un des designs les plus simples mais les plus exquis de la nature.",
      "novakidDescription": "Cet œuf de poule est sur le point d'éclore."
    }
  },
  "hylotllibraryposter1": {
    "name": "Affiche de Bibliothèque Vintage",
    "desc": "Une vieille affiche d'une ancienne bibliothèque Hylotl.",
    "metadata": {
      "apexDescription": "Cette ancienne affiche peinte à la main vante ce qui semble être une bibliothèque Hylotl.",
      "avianDescription": "Une affiche magnifiquement peinte à la main montrant une bibliothèque sur fond de coucher de soleil.",
      "floranDescription": "Coucher de sssoleil. Moment idéal pour que Floran chassse.",
      "glitchDescription": "Curieux. Cette affiche est vieille et peinte à la main - je me demande à quoi elle sert?",
      "humanDescription": "Cette vieille affiche peinte à la main décrit une vaste bibliothèque Hylotl. Ça devait être important pour que quelqu'un prenne le temps de la faire.",
      "hylotlDescription": "Le sens artistique de cette affiche de bibliothèque peinte à la main est indéniablement l'œuvre d'un Hylotl.",
      "novakidDescription": "Ce coucher de soleil me donne des frissons de chaleur. C'est une bien belle image."
    }
  },
  "hylotlmusicbox": {
    "name": "Boîte à Musique Décorée",
    "desc": "Une boîte à musique artisanale complexe. La mélodie qu'elle joue est apaisante.",
    "metadata": {
      "apexDescription": "Une boîte à musique artisanale, elle a été bien entretenue.",
      "avianDescription": "Cette boîte à musique semble avoir été spéciale pour quelqu'un.",
      "floranDescription": "Jolie boîte en bois brillant qui fait de la mussique.",
      "glitchDescription": "Ravi. Cette boîte a été conçue pour jouer une chanson simple.",
      "humanDescription": "Il y a quelque chose de très tranquille dans cette petite boîte à musique.",
      "hylotlDescription": "Simple et beau - cela incarne tout ce que les Hylotls apprécient.",
      "novakidDescription": "Cette p'tite boîte en bois joue un air rudement joli."
    }
  },
  "heathugger": {
    "name": "Câlineur de Chaleur",
    "desc": "Attiré par la chaleur, ce petit gars a besoin de rester au chaud."
  },
  "hivehog": {
    "name": "Goret de Ruche",
    "desc": "Cet insecte n'arrête jamais de manger."
  },
  "hivebed": {
    "name": "Lit de Ruche",
    "desc": "Un lit de soie reposant sur une étrange base rappelant une ruche.",
    "metadata": {
      "apexDescription": "Ce lit utilise une structure organique en nid d'abeille pour tenir debout.",
      "avianDescription": "Je ne suis pas sûr que je pourrais dormir tranquille sur un lit comme celui-ci.",
      "floranDescription": "Floran se demande pourquoi le lit res ssemble à un nid de proie?",
      "glitchDescription": "Inquiet. Je ne pense pas que je pourrais me reposer confortablement sur un lit aussi effrayant.",
      "humanDescription": "J'espère que rien ne me grimpera sur la jambe pendant que je dors là-dedans...",
      "hylotlDescription": "Je ne pense pas que je pourrais dormir aussi calmement que nécessaire dans un lit pareil.",
      "novakidDescription": "Même une âme épuisée comme la mienne ne pourrait pas dormir tranquille dans un truc pareil..."
    }
  },
  "hivebush1": {
    "name": "Œufs de Ruche",
    "desc": "Une sorte d'œufs.",
    "metadata": {
      "apexDescription": "Ce doit être des œufs d'une espèce originaire de cet endroit.",
      "avianDescription": "On dirait des œufs. Ce ne sont pas les miens, en tout cas.",
      "floranDescription": "Mmmm, dess œufffss.",
      "glitchDescription": "Curieux. Cela semble être des œufs d'une espèce native de ce biome.",
      "humanDescription": "C'est des œufs, ça? Ils n'ont pas l'air d'œufs que j'aurais envie de manger.",
      "hylotlDescription": "Ce sont des œufs effroyablement gros...",
      "novakidDescription": "Eh ben ça alors - regardez la taille de ces œufs!"
    }
  },
