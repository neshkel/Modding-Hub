  "hylotlcashregister": {
    "name": "Caisse Enregistreuse de Magasin",
    "desc": "Gling-gling!",
    "metadata": {
      "apexDescription": "Un appareil utilisé pour calculer les transactions.",
      "avianDescription": "Un appareil utilisé pour la vente de choses.",
      "floranDescription": "Gling-gliiiing!",
      "glitchDescription": "Curieux. Je me demande si cet établissement se porte bien, financièrement?",
      "humanDescription": "On dirait une caisse enregistreuse.",
      "hylotlDescription": "C'est une caisse enregistreuse.",
      "novakidDescription": "Une machine pour stocker la monnaie."
    }
  },
  "hylotlchair": {
    "name": "Chaise Bleue",
    "desc": "Une chaise bleu sarcelle.",
    "metadata": {
      "apexDescription": "C'est une chaise.",
      "avianDescription": "Une chaise bleue.",
      "floranDescription": "Chaise.",
      "glitchDescription": "Pas intéressé. Je n'ai pas besoin de m'asseoir...",
      "humanDescription": "C'est une chaise.",
      "hylotlDescription": "Une simple chaise bleu sarcelle.",
      "novakidDescription": "C'est une chaise."
    }
  },
  "hylotlcityposter": {
    "name": "Affiche de Cité Hylotl",
    "desc": "Une affiche encadrée d'une ville.",
    "metadata": {
      "apexDescription": "C'est une très belle photo d'une ville.",
      "avianDescription": "Une photo d'une ville inconnue.",
      "floranDescription": "C'essst une image.",
      "glitchDescription": "Curieux. Quelle ville est représentée sur cette photographie?",
      "humanDescription": "C'est une photo vraiment ravissante. Ça me rappelle un peu chez moi.",
      "hylotlDescription": "Une magnifique photographie d'une ville moderne. J'en pleurerais.",
      "novakidDescription": "Un grand paysage urbain inconnu."
    }
  },
  "hylotlclassicbookcase": {
    "name": "Bibliothèque Traditionnelle",
    "desc": "Un chef-d'œuvre d'artisanat. Magnifique.",
    "metadata": {
      "apexDescription": "Un certain nombre de livres Hylotl. Je les lirai, heu, plus tard.",
      "avianDescription": "Il y a beaucoup de livres sur l'histoire Hylotl ici.",
      "floranDescription": "Les hommes-poisssson aiment lire. Poisssons sstupides et ennuyeux.",
      "glitchDescription": "Critique. Chaque livre raconte à quel point les Hylotl sont merveilleux. Quel ennui.",
      "humanDescription": "Je me suis endormi rien qu'en lisant les titres.",
      "hylotlDescription": "Une étagère riche en histoire Hylotl. Les autres espèces affluent vers nos grandes bibliothèques.",
      "novakidDescription": "Des étagères remplies de bouquins sur les Hylotl. Je vois plein de trucs que j'préférerais faire plutôt que de lire ça."
    }
  },
  "hylotlclassiccabinet1": {
    "name": "Armoire Carrée Traditionnelle",
    "desc": "Une armoire en bois. Ses portes sont couvertes de décorations gravées.",
    "metadata": {
      "apexDescription": "Quelqu'un a-t-il dégradé cette armoire, ou est-ce censé ressembler à ça?",
      "avianDescription": "Ces décorations sont jolies! Enfin, en plissant les yeux.",
      "floranDescription": "Floran sse demande qui a décoré cette vilaine armoire.",
      "glitchDescription": "Critique. Cette armoire a-t-elle été décorée par un enfant? On dirait bien.",
      "humanDescription": "On dirait qu'un artiste amateur a essayé de décorer ça. C'est pittoresque.",
      "hylotlDescription": "La profondeur et la signification de ces sculptures sont à couper le souffle.",
      "novakidDescription": "Une drôle d'armoire. Qui pourrait trouver ça beau?"
    }
  },
  "hylotlclassicchair": {
    "name": "Chaise Élégante Traditionnelle",
    "desc": "Une chaise en bois de haute qualité, destinée aux personnalités importantes.",
    "metadata": {
      "apexDescription": "Une chaise convenable. Pas mal!",
      "avianDescription": "Cette chaise est plutôt jolie, je ne comprends pas pourquoi elle est réservée aux invités importants.",
      "floranDescription": "Pourquoi la chaissse est ssi chic?",
      "glitchDescription": "Impressionné. Cette chaise a été sculptée avec soin.",
      "humanDescription": "Correcte pour s'asseoir un petit moment.",
      "hylotlDescription": "Des chaises aussi étonnantes sont réservées aux individus les plus royaux.",
      "novakidDescription": "C'est pas une mauvaise chaise, je l'admets."
    }
  },
  "hylotlclassicdesk": {
    "name": "Bureau Classique",
    "desc": "Un bureau de style classique.",
    "metadata": {
      "apexDescription": "Un bureau avec beaucoup de rangements. Sympa!",
      "avianDescription": "On dirait le genre de bureau qui cache de nombreux secrets dans ses tiroirs.",
      "floranDescription": "Grand bureau en boiss.",
      "glitchDescription": "Neutre. C'est un vieux bureau.",
      "humanDescription": "Un vieux bureau qui sent le renfermé.",
      "hylotlDescription": "C'est un bel exemple de bureau.",
      "novakidDescription": "Un bureau. J'aime pas passer trop de temps devant ces trucs-là."
    }
  },
  "hylotlclassicgong": {
    "name": "Gong Traditionnel",
    "desc": "Hé, ce gong a un gros éclat... oh. Oh, je vois. C'est un nénuphar.",
    "metadata": {
      "apexDescription": "Je suppose que ce gong est sympa si on aime ce genre de choses.",
      "avianDescription": "La forme du gong fait qu'il ne résonne pas tout à fait correctement.",
      "floranDescription": "Floran frappe le gong, maiss le bruit n'est pass ssatisfaisant.",
      "glitchDescription": "Pensif. Bien que la forme altère le son, elle est agréable à l'œil.",
      "humanDescription": "Un gong en forme de nénuphar. Je pourrais imaginer ça dans une boutique de souvenirs.",
      "hylotlDescription": "Un travail si splendide qu'il est presque dommage de frapper dessus.",
      "novakidDescription": "Un instrument pour faire du boucan. Dans quel but, j'en sais trop rien..."
    }
  },
  "hylotlclassicpainting1": {
    "name": "Peinture de Guerrier Hylotl",
    "desc": "Une ancienne peinture calligraphique représentant un guerrier Hylotl d'autrefois.",
    "metadata": {
      "apexDescription": "On dirait une vieille estampe. Je me demande comment ils la gardent en si bon état?",
      "avianDescription": "C'est curieux de voir à quel point les styles de combat diffèrent selon les cultures.",
      "floranDescription": "Guerrier charnu sse battrait mieux avec des armess Florans.",
      "glitchDescription": "Impressionné. La posture de ce guerrier montre qu'il est prêt pour la bataille.",
      "humanDescription": "Ce gars est prêt à frapper! C'est du sérieux.",
      "hylotlDescription": "Un guerrier Hylotl des premiers temps, entraîné pour défendre son peuple. Inspirant.",
      "novakidDescription": "Ce gaillard a l'air prêt pour l'action, pas vrai?"
    }
  },
  "hylotlclassictable": {
    "name": "Table Traditionnelle",
    "desc": "Une table de style traditionnel.",
    "metadata": {
      "apexDescription": "Une bonne table pour mener des recherches.",
      "avianDescription": "Cette table a l'air de n'avoir presque jamais servi.",
      "floranDescription": "Table ssans oss aide Floran à sse concentrer.",
      "glitchDescription": "Peu emballé. On ne peut pas imaginer une telle table dans une forteresse.",
      "humanDescription": "Mon grand-père possédait une table comme celle-ci.",
      "hylotlDescription": "Un juste équilibre entre l'ornemental et le pratique.",
      "novakidDescription": "Un drôle de bureau."
    }
  },
  "hylotlclassictable2": {
    "name": "Petite Table Traditionnelle",
    "desc": "Une table en bois au design délicat.",
    "metadata": {
      "apexDescription": "Une petite table. Elle n'a pas l'air très solide.",
      "avianDescription": "Les pieds fragiles de cette table semblent pouvoir céder à tout moment.",
      "floranDescription": "Vieille table trop fragile pour que Floran coupe de la viande desssus.",
      "glitchDescription": "Critique. Un seul coup de pied et cette table s'effondrerait.",
      "humanDescription": "Cette table vacille assez facilement.",
      "hylotlDescription": "Avec une table comme celle-ci, chaque repas est une expérience joyeuse.",
      "novakidDescription": "Une table toute simple. Elle m'a pas l'air bien solide."
    }
  },
  "hylotlclassicwardrobe1": {
    "name": "Armoire Traditionnelle",
    "desc": "Le nénuphar pivote pour verrouiller ses portes.",
    "metadata": {
      "apexDescription": "Cette armoire est presque vraiment jolie!",
      "avianDescription": "Le nénuphar gâche ce qui serait autrement une armoire tout à fait correcte.",
      "floranDescription": "Floran sse cache dans l'armoire. Ssort d'un coup. Ssurprisse pour les amis. Amussant!",
      "glitchDescription": "Diplomate. Le motif de nénuphar est un choix de design intéressant.",
      "humanDescription": "Le verrou de cette armoire est capricieux et difficile à tourner.",
      "hylotlDescription": "Une armoire exceptionnelle avec un mécanisme de verrouillage inspiré.",
      "novakidDescription": "Le nénuphar semble servir de verrou. Malin."
    }
  },
  "hylotlconsole": {
    "name": "Console Hi-Tech",
    "desc": "Une console à écran tactile avec toutes sortes de boutons amusants.",
    "metadata": {
      "apexDescription": "Je me demande ce qui se passe si j'appuie sur... ce bouton?",
      "avianDescription": "C'est très tentant d'appuyer sur les boutons...",
      "floranDescription": "Floran veut appuyer ssur tous les jolis boutonss.",
      "glitchDescription": "Curieux. Je suis très tenté d'appuyer sur tous ces boutons.",
      "humanDescription": "Peut-être qu'appuyer sur un bouton ou deux mènera à quelque chose d'intéressant.",
      "hylotlDescription": "Je devrais éviter d'appuyer sur les boutons... Qui sait ce qui pourrait arriver?",
      "novakidDescription": "Une console avec plusieurs boutons tentants. Est-ce que je devrais...?"
    }
  },
  "hylotlcounter": {
    "name": "Comptoir Hylotl",
    "desc": "Un comptoir qui ressemble étrangement à un Hylotl.",
    "metadata": {
      "apexDescription": "Les Hylotl aiment vraiment créer des objets à leur image.",
      "avianDescription": "Ce comptoir est serti de gemmes qui ressemblent à des yeux Hylotl.",
      "floranDescription": "C'est bien les hommess-poisssons de faire des meubles qui leur ressemblent.",
      "glitchDescription": "Amusé. Ce meuble Hylotl ressemble beaucoup à l'un d'entre eux.",
      "humanDescription": "Les Hylotl semblent apprécier fabriquer des meubles à leur propre image.",
      "hylotlDescription": "Nous, les Hylotl, sommes intensément fiers de notre esthétique, et nous aimons donc créer de l'art qui nous ressemble.",
      "novakidDescription": "Est-ce qu'un visage Hylotl me dévisage depuis ce meuble? Troublant."
    }
  },
  "hylotldrinks": {
    "name": "Distributeur Bleu",
    "desc": "Un distributeur automatique rempli de boissons populaires.",
    "metadata": {
      "apexDescription": "C'est rempli de toutes sortes de sodas.",
      "avianDescription": "Les boissons là-dedans ont l'air un peu trop sucrées à mon goût...",
      "floranDescription": "Floran n'aime pass les boisssons trop sssucrées.",
      "glitchDescription": "Intrigué. Ça ne me dérangerait pas de goûter certaines de ces boissons étrangères.",
      "humanDescription": "La machine vend des sodas. Je me demande quel goût a le Reef-Cola?",
      "hylotlDescription": "Personnellement, j'ai un faible pour le Reef-Cola.",
      "novakidDescription": "J'ai jamais été un grand fan des boissons gazeuses.",
      "interactData.paneLayoutOverride.windowtitle.title": " Distributeur automatique",
      "interactData.paneLayoutOverride.windowtitle.subtitle": " Snacks savoureux"
    }
  },
  "hylotlemblem": {
    "name": "Emblème Hylotl",
    "desc": "Un emblème courant chez les Hylotl. Trois cristaux représentant leurs trois yeux...",
    "metadata": {
      "apexDescription": "Le symbole du peuple Hylotl.",
      "avianDescription": "Les Avians préfèrent la symbolique des ailes à celle des yeux.",
      "floranDescription": "Trois yeux Hylotl qui fixent Floran... Floran n'aime pass!",
      "glitchDescription": "Critique. Ce symbole Hylotl est perturbant à cause de leur trop grand nombre d'yeux.",
      "humanDescription": "Le symbole Hylotl représentant leur peuple.",
      "hylotlDescription": "Un symbole de mon peuple.",
      "novakidDescription": "Un emblème. Les trois gemmes représentent les yeux Hylotl, j'imagine."
    }
  },
  "hylotlfashionhologram": {
    "name": "Hologramme de Mode Hylotl",
    "desc": "Un hologramme affichant les dernières tendances de la mode Hylotl.",
    "metadata": {
      "apexDescription": "Les Hylotl ont des goûts vestimentaires intéressants.",
      "avianDescription": "Ces styles ne sont pas ceux dont j'ai l'habitude...",
      "floranDescription": "Mode d'hommess-poissson. Floran n'aime pass.",
      "glitchDescription": "Intrigué. Je me demande si ces vêtements m'iraient.",
      "humanDescription": "Malgré toute leur prétention, je dois admettre que les Hylotl ont du style.",
      "hylotlDescription": "Ces looks sont très tendance.",
      "novakidDescription": "Peut-être que je devrais tenter la mode Hylotl?"
    }
  },
  "hylotlfloorornament": {
    "name": "Ornement de Sol",
    "desc": "C'est une sorte d'ornement de sol. Des œufs de grenouille tourbillonnent à l'intérieur.",
    "metadata": {
      "apexDescription": "Il y a des œufs de grenouille là-dedans. C'est un peu dégoûtant.",
      "avianDescription": "Des œufs de grenouille flottent à l'intérieur de ce truc. Qui voudrait exposer ça?",
      "floranDescription": "Floran voit des bébés grenouilless nager dans l'orbe. Floran peut les manger?",
      "glitchDescription": "Curieux. Il semble que ce soit une sphère contenant des œufs de grenouille vivants.",
      "humanDescription": "Waouh, il y a des têtards qui nagent dans cette boule. La tentation de la fracasser est immense.",
      "hylotlDescription": "Je peux voir les précieux œufs de grenouille nager à l'intérieur. Une célébration de la vie Hylotl.",
      "novakidDescription": "C'est des œufs de grenouille qui nagent dans l'orbe?"
    }
  },
  "hylotlkatanarack": {
    "name": "Râtelier de Sabres Traditionnel",
    "desc": "Un râtelier de sabres traditionnels.",
    "metadata": {
      "apexDescription": "Une impressionnante collection d'armes traditionnelles.",
      "avianDescription": "Tout un râtelier rempli d'épées tranchantes.",
      "floranDescription": "Épées brillantess et tranchantess.",
      "glitchDescription": "Fasciné. De nombreuses années de savoir-faire ont été nécessaires pour forger ces lames.",
      "humanDescription": "Tout un râtelier d'épées... J'ai envie d'en brandir une.",
      "hylotlDescription": "Une arme classique ; un apprenti s'entraîne des années avant même d'en forger une.",
      "novakidDescription": "Un râtelier de sabres, c'est sûr que c'est... classique."
    }
  },
  "hylotllamp": {
    "name": "Bio-Lampe",
    "desc": "Une petite lampe qui diffuse une faible lumière rouge.",
    "metadata": {
      "apexDescription": "Je me demande de quoi cette lampe est faite?",
      "avianDescription": "Le concept semble proche des lampes à cristaux des Avians.",
      "floranDescription": "Lampe brillante et lussstrousse.",
      "glitchDescription": "Intrigué. Je me demande comment de telles lampes sont fabriquées?",
      "humanDescription": "Ça ressemble un peu à un œil Hylotl. Je me demande en quoi c'est fait?",
      "hylotlDescription": "La gemme luminescente est taillée pour ressembler à un œil Hylotl. Elle diffuse une lumière très atmosphérique.",
      "novakidDescription": "Une lampe. Elle est correcte."
    }
  },
  "hylotllantern1": {
    "name": "Lanterne en Papier Traditionnelle",
    "desc": "Un plafonnier en papier.",
    "metadata": {
      "apexDescription": "Une lanterne en papier ne semble pas être la meilleure idée pour la sécurité incendie.",
      "avianDescription": "Je me demande à quelle fréquence ces trucs prennent feu.",
      "floranDescription": "Lanterne en papier danger-eusse pour Floran. Feu!",
      "glitchDescription": "Critique. Une lanterne en papier. Ça respecte vachement les normes de sécurité, tiens.",
      "humanDescription": "Oh mon dieu, pas les abeilles! Attendez, c'est une lanterne en papier. Bon, c'est ennuyeux.",
      "hylotlDescription": "Une lanterne en papier fabriquée à la main. Finalement, l'humidité finit par les emporter, comme elle nous emportera tous.",
      "novakidDescription": "Tout le monde sait que c'est pas une bonne idée de combiner du papier avec une ampoule brûlante."
    }
  },
  "hylotllilyclock": {
    "name": "Horloge Nénuphar",
    "desc": "Une horloge en forme de nénuphar.",
    "metadata": {
      "apexDescription": "Une horloge en forme de nénuphar. Comme c'est adorable.",
      "avianDescription": "On dirait un genre de gadget de fête foraine.",
      "floranDescription": "Tic tac tic tac, les hommess-poisssons ont une horloge sstupide.",
      "glitchDescription": "Amusé. Quelle forme fantaisiste pour une horloge.",
      "humanDescription": "C'est plutôt mignon, pour un gadget.",
      "hylotlDescription": "Pas seulement un exemple remarquable de praticité, mais un commentaire sur la nature éphémère du temps lui-même.",
      "novakidDescription": "Une horloge nénuphar. J'en avais une en forme de cactus avant."
    }
  },
  "hylotllilydeco1": {
    "name": "Petit Nénuphar",
    "desc": "Une petite décoration en forme de nénuphar.",
    "metadata": {
      "apexDescription": "Un nénuphar décoratif. Sympa.",
      "avianDescription": "Je n'avais pas vu autant de nénuphars depuis la fois où je me suis écrasé dans un marais.",
      "floranDescription": "Sstupide plante en plassstique. Floran est dégoûté!",
      "glitchDescription": "Amusé. Quelqu'un est fan de nénuphars.",
      "humanDescription": "Le cadeau parfait pour quelqu'un qui adore les nénuphars. Malheureusement, ce quelqu'un n'est pas moi.",
      "hylotlDescription": "La beauté de la nature, capturée en une seule pièce.",
      "novakidDescription": "Y'en a un qui aime vraiment ses nénuphars, hein."
    }
  },
  "hylotllilydeco2": {
    "name": "Minuscules Nénuphars",
    "desc": "Un petit ensemble de nénuphars muraux.",
    "metadata": {
      "apexDescription": "Un nénuphar décoratif. Sympa.",
      "avianDescription": "Je n'avais pas vu autant de nénuphars depuis la fois où je me suis écrasé dans un marais.",
      "floranDescription": "Sstupide plante en plassstique. Floran est dégoûté!",
      "glitchDescription": "Amusé. Quelqu'un est fan de nénuphars.",
      "humanDescription": "Le cadeau parfait pour quelqu'un qui adore les nénuphars. Malheureusement, ce quelqu'un n'est pas moi.",
      "hylotlDescription": "La beauté de la nature, capturée en une seule pièce.",
      "novakidDescription": "Y'en a un qui aime vraiment ses nénuphars, hein."
    }
  },
  "hylotllilydeco3": {
    "name": "Grand Nénuphar",
    "desc": "Une grande décoration murale en forme de nénuphar.",
    "metadata": {
      "apexDescription": "Un nénuphar décoratif. Sympa.",
      "avianDescription": "Je n'avais pas vu autant de nénuphars depuis la fois où je me suis écrasé dans un marais.",
      "floranDescription": "Sstupide plante en plassstique. Floran est dégoûté!",
      "glitchDescription": "Amusé. Quelqu'un est fan de nénuphars.",
      "humanDescription": "Le cadeau parfait pour quelqu'un qui adore les nénuphars. Malheureusement, ce quelqu'un n'est pas moi.",
      "hylotlDescription": "La beauté de la nature, capturée en une seule pièce.",
      "novakidDescription": "Y'en a un qui aime vraiment ses nénuphars, hein."
    }
  },
  "hylotllilypad": {
    "name": "Nénuphar en Métal",
    "desc": "On dirait un nénuphar décoratif.",
    "metadata": {
      "apexDescription": "Un nénuphar décoratif. Sympa.",
      "avianDescription": "Je n'avais pas vu autant de nénuphars depuis la fois où je me suis écrasé dans un marais.",
      "floranDescription": "Sstupide plante en plassstique. Floran est dégoûté!",
      "glitchDescription": "Amusé. Quelqu'un est fan de nénuphars.",
      "humanDescription": "Le cadeau parfait pour quelqu'un qui adore les nénuphars. Malheureusement, ce quelqu'un n'est pas moi.",
      "hylotlDescription": "La beauté de la nature rencontre la rudesse de l'étalement urbain.",
      "novakidDescription": "Y'en a un qui aime vraiment ses nénuphars, hein."
    }
  },
  "hylotlliquidsensor": {
    "name": "Capteur de Liquide",
    "desc": "N'utilisez pas votre doigt! Ce capteur fiable indique la présence de liquides.",
    "metadata": {
      "apexDescription": "Un objet utile, il peut servir à la détection de liquides.",
      "avianDescription": "J'ai entendu parler de ça, ils détectent les liquides d'une manière ou d'une autre.",
      "floranDescription": "Capteur détecte les liquide-sss. Peut déclencher des filss.",
      "glitchDescription": "Impressionné. Cet appareil peut détecter les liquides pour des circuits de câblage.",
      "humanDescription": "J'en ai entendu parler, c'est fait pour détecter les liquides dans des montages électriques complexes.",
      "hylotlDescription": "L'un de mes appareils préférés, il détecte automatiquement la présence de liquides.",
      "novakidDescription": "C'est un de ces détecteurs de liquide sophistiqués."
    }
  },
  "hylotlmailbox": {
    "name": "Boîte aux Lettres Urbaine",
    "desc": "Une boîte aux lettres bleue.",
    "metadata": {
      "apexDescription": "C'est une boîte aux lettres.",
      "avianDescription": "Une boîte pour envoyer des lettres.",
      "floranDescription": "Floran n'envoie pass de lettress.",
      "glitchDescription": "Indifférent. Un point de dépôt pour le courrier.",
      "humanDescription": "C'est une boîte aux lettres.",
      "hylotlDescription": "Ce n'est qu'une boîte aux lettres.",
      "novakidDescription": "Une boîte pour envoyer du courrier? Ça ressemble pas à un téléporteur pour moi..."
    }
  },
  "hylotlmovieposter1": {
    "name": "Affiche de Film d'Action",
    "desc": "Une affiche encadrée du film \"Apocalypse Cybernétique\".",
    "metadata": {
      "apexDescription": "On dirait un autre film de robots géants irréalistes.",
      "avianDescription": "Il semble que ce soit un film sur des mécas géants montés sur pattes.",
      "floranDescription": "Floran n'a pass bessoin de gros robotss en métal bruyantss. Floran a sseulement bessoin de couteau qui pique.",
      "glitchDescription": "Intéressé. Les robots dans ce film ont l'air vraiment puissants.",
      "humanDescription": "C'est un film de robots géants! C'est génial, ça.",
      "hylotlDescription": "Encore un film d'action décérébré sur des robots géants.",
      "novakidDescription": "Un film avec un géant de fer."
    }
  },
  "hylotlmovieposter2": {
    "name": "Affiche de Film de Guerrier",
    "desc": "Une affiche encadrée du film \"Le Croisé à la Lame de Feu\".",
    "metadata": {
      "apexDescription": "On dirait un de ces films de 'quête de vengeance sanglante'.",
      "avianDescription": "On dirait le genre d'histoire avec une fin triste...",
      "floranDescription": "C'essst un film que Floran pourrait aimer.",
      "glitchDescription": "Curieux. Je me demande contre quoi le croisé se bat avec sa lame de feu?",
      "humanDescription": "Ça rappelle beaucoup un vieux film de samouraï que j'ai vu autrefois...",
      "hylotlDescription": "Malgré son titre cliché, \"Le Croisé à la Lame de Feu\" est un film véritablement magnifique.",
      "novakidDescription": "On dirait un film sur un guerrier solitaire... Je serais partant pour regarder ça."
    }
  },
  "hylotlmovieposter3": {
    "name": "Affiche de Film Romantique",
    "desc": "Une affiche encadrée du film romantique controversé \"10 Choses que je Déteste chez les Florans\".",
    "metadata": {
      "apexDescription": "\"10 Choses que je Déteste chez les Florans\". Ça a l'air bien mielleux. Et... un peu raciste?",
      "avianDescription": "\"10 Choses que je Déteste chez les Florans\". Je peux déjà citer quelques trucs que je n'aime pas chez eux.",
      "floranDescription": "Film appelé \"10 Chosess que je Détesste chez les Florans\"... Floran devrait brûler ssça!",
      "glitchDescription": "Intrigué. \"10 Choses que je Déteste chez les Florans\". Dix choses? Je n'en vois que trois.",
      "humanDescription": "Ce film a l'air... ennuyeux.",
      "hylotlDescription": "Un film romantique très controversé sur une relation interdite entre un Floran et un Hylotl.",
      "novakidDescription": "Une affiche pour une comédie romantique. \"10 Choses que je Déteste chez les Florans\"."
    }
  },
  "hylotlpainting1": {
    "name": "Peinture de Vague Traditionnelle",
    "desc": "C'est une peinture d'une énorme vague.",
    "metadata": {
      "apexDescription": "Cette peinture est plutôt jolie.",
      "avianDescription": "Pas mal! Les coups de pinceau sont un peu brouillons, par contre.",
      "floranDescription": "Floran s'en fiche de la sstupide peinture de vague.",
      "glitchDescription": "Envieux. L'artiste a su capturer la vague parfaitement.",
      "humanDescription": "Je suis presque sûr qu'on avait exactement la même peinture sur Terre.",
      "hylotlDescription": "Chaque coup de pinceau dégouline d'émotion, la beauté des vagues capturée pour l'éternité.",
      "novakidDescription": "Cette peinture d'une vague géante est vraiment impressionnante."
    }
  },
  "hylotlpainting2": {
    "name": "Peinture de Montagne Traditionnelle",
    "desc": "C'est une copie d'une ancienne peinture célèbre.",
    "metadata": {
      "apexDescription": "Cette peinture est plutôt jolie.",
      "avianDescription": "Pas mal! Les coups de pinceau sont un peu brouillons, par contre.",
      "floranDescription": "Floran s'en fiche de la sstupide peinture de montagne.",
      "glitchDescription": "Envieux. Cette peinture est peut-être une copie, mais elle est bien exécutée.",
      "humanDescription": "Je suis presque sûr qu'on avait exactement la même peinture sur Terre.",
      "hylotlDescription": "Une époustouflante cavalcade de couleurs et d'émotions.",
      "novakidDescription": "C'est une sorte de peinture classique."
    }
  },
  "hylotlpainting3": {
    "name": "Peinture de Pont Traditionnelle",
    "desc": "C'est une peinture d'un pont au-dessus d'une eau calme.",
    "metadata": {
      "apexDescription": "Ce pont n'a pas l'air structurellement solide, mais il est joli.",
      "avianDescription": "Quelle jolie scène! J'aimerais visiter cet endroit, s'il était réel.",
      "floranDescription": "Floran veut sse cacher sous le pont pour faire peur aux genss.",
      "glitchDescription": "Impressionné. Le pont sur cette peinture semble assez sûr à traverser.",
      "humanDescription": "Quelle belle peinture. Si ce pont était réel, je le traverserais encore et encore.",
      "hylotlDescription": "Les traits discrets de cette peinture accentuent la tranquillité de la scène.",
      "novakidDescription": "Je me demande si un chariot pourrait traverser un petit pont aussi beau que celui-là."
    }
  },
  "hylotlplant1": {
    "name": "Fausse Plante en Plastique",
    "desc": "Une réplique de plante, manifestement en plastique.",
    "metadata": {
      "apexDescription": "Pourquoi quelqu'un voudrait-il une fausse plante?",
      "avianDescription": "Une fausse plante. Sympa.",
      "floranDescription": "Floran détesste plante en plassstique!",
      "glitchDescription": "Peu emballé. Une plante en plastique. C'est cheap.",
      "humanDescription": "Ça me rappelle les salles d'attente.",
      "hylotlDescription": "Une dégoûtante plante en plastique factice.",
      "novakidDescription": "Ces feuilles ont l'air bien dures... Attendez, c'est du plastique!"
    }
  },
  "hylotlpost": {
    "name": "Poteau en Bois Traditionnel",
    "desc": "Un poteau décoratif en bois intégrant une lanterne.",
    "metadata": {
      "apexDescription": "Un poteau quelconque.",
      "avianDescription": "Plutôt pas mal pour s'aiguiser le bec dessus.",
      "floranDescription": "Poteau de lampe.",
      "glitchDescription": "Critique. Même pour un simple poteau, c'est peu inspirant.",
      "humanDescription": "Ce poteau a l'air assez bancal.",
      "hylotlDescription": "Ceci offre une source de lumière extérieure agréable.",
      "novakidDescription": "Un poteau avec une lanterne. Brille, mon pote."
    }
  },
  "hylotlprizecounter": {
    "name": "Comptoir à Prix d'Arcade",
    "desc": "Une vitrine pleine de peluches et de jouets.",
    "metadata": {
      "apexDescription": "Oohh, je me demande si je peux gagner la peluche licorne?",
      "avianDescription": "Ça ne me déplairait pas de gagner une peluche Poptop, moi.",
      "floranDescription": "Hmmm, Floran veut peluche Tortue.",
      "glitchDescription": "Motivé. J'aimerais bien en gagner quelques-unes...",
      "humanDescription": "J'ai un faible pour cette peluche Numi... je me demande combien elle coûte?",
      "hylotlDescription": "Oooh! Je les veux toutes!",
      "novakidDescription": "Je suis pas très branché peluches, mais celles-là sont plutôt mignonnes."
    }
  },
  "hylotlredalert": {
    "name": "Alerte Bleue",
    "desc": "Une alarme bleue brillante.",
    "metadata": {
      "apexDescription": "Cette lumière clignotera et une alarme retentira en cas d'urgence.",
      "avianDescription": "Une lumière clignotante et une sirène qui signalent une urgence.",
      "floranDescription": "La sirène bleue qui clignote fait du bruit.",
      "glitchDescription": "Nerveux. Une sirène qui annonce une urgence.",
      "humanDescription": "Est-ce qu'une alerte bleue est différente d'une alerte rouge?",
      "hylotlDescription": "Une lumière qui signale une urgence.",
      "novakidDescription": "Une lumière d'avertissement quand le danger est proche."
    }
  },
  "hylotlshojidoor": {
    "name": "Porte Shoji Traditionnelle",
    "desc": "Une porte coulissante de type shoji.",
    "metadata": {
      "apexDescription": "Une porte simple. Remplit son office.",
      "avianDescription": "Une porte correcte qui laisse entrer beaucoup de lumière.",
      "floranDescription": "Une foiss, Floran est tombé à travers sssur une porte comme ssça.",
      "glitchDescription": "Critique. Cette porte est tout simplement parfaite si vous avez horreur de l'intimité.",
      "humanDescription": "Une porte fragile. Pas très efficace pour empêcher quoi que ce soit d'entrer.",
      "hylotlDescription": "Les contours et la fabrication de cette porte permettent un mouvement d'ouverture parfaitement fluide.",
      "novakidDescription": "Cette porte n'a pas l'air sûre. Je pourrais faire un trou dedans avec mon doigt."
    }
  },
  "hylotlshojiscreen": {
    "name": "Paravent Shoji Traditionnel",
    "desc": "Un paravent pour que les personnes pudiques puissent se cacher pendant qu'elles se changent.",
    "metadata": {
      "apexDescription": "Un paravent. Les Apex n'ont pas droit à de telles choses.",
      "avianDescription": "Ce paravent a l'air de pouvoir s'écrouler à la moindre brise.",
      "floranDescription": "Floran pourrait faire deux trouss dans le paravent pour regarder à travers!",
      "glitchDescription": "Critique. On peut pratiquement voir à travers ce paravent. Inutile.",
      "humanDescription": "On ne peut pas vraiment se cacher derrière ce paravent. Les gens verraient votre silhouette.",
      "hylotlDescription": "Pudeur, intégrité, beauté. Ce paravent a tout pour lui.",
      "novakidDescription": "Un mince paravent en papier. Je peux presque voir à travers."
    }
  },
  "hylotlshopsign": {
    "name": "Enseigne Hylotl Amicale",
    "desc": "Un panneau de bienvenue joyeux destiné aux magasins tenus par des Hylotls.",
    "metadata": {
      "apexDescription": "Ce visage Hylotl joyeux m'invite dans un magasin. Comment résister?",
      "avianDescription": "Ce visage a l'air plutôt amical.",
      "floranDescription": "Sstupide visage d'homme-poissson.",
      "glitchDescription": "Intrigué. Je devrais peut-être voir ce que ce magasin a à offrir.",
      "humanDescription": "Ce joyeux visage Hylotl me tente d'entrer dans ce magasin.",
      "hylotlDescription": "L'enseigne est censée indiquer un bon service client.",
      "novakidDescription": "Une enseigne de magasin. Je devrais peut-être voir ce qu'ils vendent."
    }
  },
  "hylotlshorttable": {
    "name": "Table Basse Traditionnelle",
    "desc": "Une table réglée à hauteur de genoux pour s'y agenouiller.",
    "metadata": {
      "apexDescription": "Une petite table. Elle n'a pas l'air très solide.",
      "avianDescription": "Cette table est placée très bas, c'est inhabituel.",
      "floranDescription": "Table trop fragile pour que Floran coupe de la viande desssus.",
      "glitchDescription": "Méfiant. Je n'ai pas l'habitude d'une table aussi basse.",
      "humanDescription": "Cette table est si basse que je n'aurais même pas besoin de chaise. C'est peut-être l'idée.",
      "hylotlDescription": "Avec une table comme celle-ci, chaque repas est une expérience joyeuse.",
      "novakidDescription": "La table la plus basse que j'aie jamais vue."
    }
  },
  "hylotlsign1b": {
    "name": "Enseigne Coquillage Bleu",
    "desc": "Un néon bleu décoré d'un coquillage.",
    "metadata": {
      "apexDescription": "On dirait que les Hylotls s'intéressent enfin à autre chose qu'aux nénuphars.",
      "avianDescription": "L'enseigne grésille légèrement.",
      "floranDescription": "Ensseigne bruyante énerve Floran.",
      "glitchDescription": "Confus. Pourquoi les flèches pointent-elles vers le coquillage?",
      "humanDescription": "Qu'est-ce que ce panneau me dit? Achetez des coquillages? Collectionnez les coquillages?",
      "hylotlDescription": "Je me souviens que beaucoup d'Hylotls collectionnaient les coquillages. C'était une véritable mode.",
      "novakidDescription": "Y'a un coquillage sur cette enseigne là-bas."
    }
  },
  "hylotlsign1g": {
    "name": "Enseigne Nénuphar Vert",
    "desc": "Un néon vert faisant la promotion de meubles issus d'un mouvement de design inspiré par les nénuphars.",
    "metadata": {
      "apexDescription": "Cette enseigne semble faire de la pub pour... un nénuphar.",
      "avianDescription": "Vers quel nénuphar cette enseigne pointe-t-elle au juste?",
      "floranDescription": "Ensseigne bruyante énerve Floran.",
      "glitchDescription": "Critique. Une enseigne représentant un nénuphar! Les Hylotls semblent excessivement friands de lys.",
      "humanDescription": "Je me demande ce que cette enseigne indique. Peut-être le magasin de nénuphars?",
      "hylotlDescription": "Rien que de voir cette enseigne, ça me réchauffe le cœur. Tant de souvenirs.",
      "novakidDescription": "Un nénuphar, si je n'm'abuse."
    }
  },
  "hylotlsign1o": {
    "name": "Enseigne Apex Orange",
    "desc": "Un néon orange affichant ce qui semble être Big Ape.",
    "metadata": {
      "apexDescription": "Le visage de Big Ape s'étend jusque dans les profondeurs marines. Effrayant.",
      "avianDescription": "Le visage ressemble un peu à un Apex. Étrange.",
      "floranDescription": "Ensseigne bruyante énerve Floran.",
      "glitchDescription": "Confus. Est-ce censé être Big Ape?",
      "humanDescription": "Ceci affiche un... Apex? Qu'est-ce que ça fait là?",
      "hylotlDescription": "\"Gorille Géant est attiré par le poisson\"? On dirait que ça a été mal traduit.",
      "novakidDescription": "C'est un Apex, ça?"
    }
  },
  "hylotlsign2b": {
    "name": "Néon Bleu",
    "desc": "Une enseigne qui semble dire \"BULLE\"...",
    "metadata": {
      "apexDescription": "Une enseigne qui dit \"bulle\". C'est gentil, je suppose!",
      "avianDescription": "J'hésite même à suivre la direction de cette enseigne.",
      "floranDescription": "Ensseigne bruyante énerve Floran.",
      "glitchDescription": "Critique. Une enseigne qui dit simplement \"bulle\". Quelle utilité.",
      "humanDescription": "J'ai l'impression que ces enseignes sont plutôt décoratives. Je ne vois pas ce que ça pourrait annoncer.",
      "hylotlDescription": "Des bulles. De magnifiques orbes de vie flottant vers les cieux immenses.",
      "novakidDescription": "Quelqu'un aime vraiment les bulles."
    }
  },
  "hylotlsign2g": {
    "name": "Néon Vert",
    "desc": "Une enseigne qui semble dire \"COASSE\"...",
    "metadata": {
      "apexDescription": "Une enseigne qui dit \"coasse\". C'est gentil, je suppose!",
      "avianDescription": "J'hésite même à suivre la direction de cette enseigne.",
      "floranDescription": "Ensseigne bruyante énerve Floran.",
      "glitchDescription": "Critique. Une enseigne qui dit simplement \"coasse\". Quelle utilité.",
      "humanDescription": "Je suis sûr que cette enseigne mène à un endroit génial. Si seulement je n'étais pas si occupé à faire... d'autres trucs...",
      "hylotlDescription": "Baignant dans l'éclat néon de cette enseigne, je me rappelle d'amis anciens et nouveaux. J'en ai la gorge nouée.",
      "novakidDescription": "C'est quoi c'truc écrit là?"
    }
  },
  "hylotlsign2o": {
    "name": "Néon Orange",
    "desc": "On dirait le mot 'croâ', mais apparemment cela signifie quelque chose de complètement différent.",
    "metadata": {
      "apexDescription": "Une enseigne qui dit 'croâ'. C'est gentil, je suppose!",
      "avianDescription": "J'hésite même à suivre la direction de cette enseigne.",
      "floranDescription": "Ensseigne bruyante énerve Floran.",
      "glitchDescription": "Critique. Une enseigne qui dit simplement 'croâ'. Quelle utilité.",
      "humanDescription": "Je suis sûr que ça mène à un endroit génial. Si seulement je n'étais pas si occupé à faire... d'autres trucs...",
      "hylotlDescription": "Baignant dans l'éclat néon de cette enseigne, je me rappelle d'amours perdus et retrouvés. J'en ai la gorge nouée.",
      "novakidDescription": "J'crois pas que j'pige vraiment."
    }
  },
  "hylotlsign3b": {
    "name": "Néon de Magasin Bleu",
    "desc": "De petites créatures marines nagent à l'intérieur de cette enseigne.",
    "metadata": {
      "apexDescription": "Cette enseigne pourrait-elle indiquer un aquarium?",
      "avianDescription": "Peut-être que ça mène quelque part d'intéressant. Ça changerait.",
      "floranDescription": "Ensseigne bruyante énerve Floran.",
      "glitchDescription": "Critique. De petits poissons nagent à l'intérieur de l'enseigne. Je pensais que les Hylotls étaient censés prendre soin de leurs semblables.",
      "humanDescription": "Si cet aquarium a un requin bipède, je suis TELLEMENT PARTANT.",
      "hylotlDescription": "Une enseigne indiquant les toilettes publiques. Naturellement, les Hylotls les gardent impeccables.",
      "novakidDescription": "Ça doit indiquer un truc intéressant."
    }
  },
  "hylotlsign3g": {
    "name": "Néon Pod Vert",
    "desc": "Une enseigne affichant des reefpods, une délicieuse friandise.",
    "metadata": {
      "apexDescription": "Je pense que c'est l'enseigne pour un genre de restaurant. Je m'y arrêterai peut-être si j'ai une faim de loup.",
      "avianDescription": "Des reefpods. Quel régal. Ravi d'avoir emporté mon propre déjeuner.",
      "floranDescription": "Floran préférerait manger un homme-poissson plutôt que de la nourriture d'hommess-poisssons.",
      "glitchDescription": "Curieux. Certains considèrent les reefpods comme un mets délicat.",
      "humanDescription": "Je serais plus enthousiaste à l'idée de dîner ici s'ils servaient de la viande.",
      "hylotlDescription": "La cuisine Hylotl a la réputation d'être l'une des meilleures de la galaxie auprès des autres espèces.",
      "novakidDescription": "J'suis pas sûr d'aimer vraiment les reefpods."
    }
  },
  "hylotlsign3o": {
    "name": "Enseigne de Collecte Orange",
    "desc": "Une enseigne demandant aux Hylotls de collecter les pontes à la surface.",
    "metadata": {
      "apexDescription": "Mon traducteur dit que cette enseigne demande aux Hylotls de kidnapper des bébés. Ça ne peut pas être ça, n'est-ce pas?",
      "avianDescription": "D'après mon traducteur, les Hylotls volent des enfants. J'ai du mal à y croire.",
      "floranDescription": "Ensseigne bruyante énerve Floran.",
      "glitchDescription": "Critique. Peut-être que les Hylotls devraient réfléchir à la façon dont leur langue est traduite. On dirait qu'ils volent des bébés.",
      "humanDescription": "Waouh, j'ai toujours soupçonné les Hylotls de préparer quelque chose. Non, ça ne peut pas être vrai.",
      "hylotlDescription": "Une demande pour que les Hylotls collectent les pontes à la surface, un acte charitable et bienveillant.",
      "novakidDescription": "J'ai pas l'temps de tout traduire!"
    }
  },
  "hylotlradio": {
    "name": "Radio Traditionnelle",
    "desc": "Une vieille radio, elle joue encore de la musique.",
    "metadata": {
      "apexDescription": "Je suis étonné que cette radio fonctionne encore.",
      "avianDescription": "L'air qui sort de cette vieille radio semble assez triste.",
      "floranDescription": "Vieille boîte à moussique flippante.",
      "glitchDescription": "Joyeux. Cette vieille radio joue une musique apaisante.",
      "humanDescription": "Ce poste crée une atmosphère d'autrefois.",
      "hylotlDescription": "Une radio antique, un vestige pittoresque du passé.",
      "novakidDescription": "Le poste joue un joli petit air."
    }
  },
  "hylotlstoragelocker": {
    "name": "Casier de Rangement Hylotl",
