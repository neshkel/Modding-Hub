  "humanshipdoorBroken": {
    "name": "Porte de Vaisseau Humain",
    "desc": "Une porte adaptée à un vaisseau spatial.",
    "metadata": {
      "apexDescription": "Ces portes sont utilisées sur tous nos vaisseaux. Celle-ci fait des siennes.",
      "avianDescription": "Une porte. Elle ne s'ouvre pas.",
      "floranDescription": "Porte veut pas ss'ouvrir!",
      "glitchDescription": "Déçu. Une porte. Elle semble être désactivée pour le moment.",
      "humanDescription": "Chouette porte. Dommage qu'elle ne s'ouvre pas maintenant.",
      "hylotlDescription": "Une porte de vaisseau basique. Elle ne s'ouvre pas pour l'instant.",
      "novakidDescription": "La porte est cassée, elle va pas s'ouvrir de sitôt."
    }
  },
  "humanshiplocker": {
    "name": "Casier de Vaisseau",
    "desc": "Un casier. Pourquoi ne pas y stocker quelques trucs?",
    "metadata": {
      "apexDescription": "Je me demande s'il y a des secrets à l'intérieur de ce casier?",
      "avianDescription": "Pourrait-il y avoir quelque chose de valeur dans ce casier?",
      "floranDescription": "Floran fouille le cassier pour des objetss de valeur.",
      "glitchDescription": "Excité. Je me demande s'il y a des objets intéressants à l'intérieur?",
      "humanDescription": "Un casier de vaisseau.",
      "hylotlDescription": "Peut-être qu'il y a quelque chose d'utile dans ce casier.",
      "novakidDescription": "Un casier, pour mettre des choses dedans."
    }
  },
  "humanshiplockerTier0": {
    "name": "Casier de Vaisseau",
    "desc": "Un casier. Pourquoi ne pas y stocker quelques trucs?",
    "metadata": {
      "apexDescription": "Le système de stockage du vaisseau. Il n'est pas fonctionnel pour le moment.",
      "avianDescription": "Un appareil pour garder des objets en sécurité. Il est cassé pour l'instant.",
      "floranDescription": "Sstockage. Ça marche pass.",
      "glitchDescription": "Affligé. Le système de stockage de ce vaisseau ne fonctionne pas.",
      "humanDescription": "Un casier de stockage. Il ne semble pas fonctionner.",
      "hylotlDescription": "Une solution de stockage élégante. Elle n'est pas alimentée actuellement.",
      "novakidDescription": "Un casier. Pas très utile tant que c'est pas réparé."
    }
  },
  "humantechstation": {
    "name": "S.A.I.L",
    "desc": "Ship-based Artificial Intelligence Lattice, ou S.A.I.L en abrégé.",
    "metadata": {
      "apexDescription": "Je peux parler à SAIL via cette console.",
      "avianDescription": "Je peux utiliser cette station pour parler à SAIL.",
      "floranDescription": "Floran utilise ce panneau magique pour parler à SAIL!",
      "glitchDescription": "Heureux. Cette station me permet de parler à SAIL.",
      "humanDescription": "Cette station me permet de communiquer avec SAIL.",
      "hylotlDescription": "Cette console me permet de communiquer avec SAIL.",
      "novakidDescription": "Cette station là me permet de causer avec SAIL."
    }
  },
  "humantechstationTier0": {
    "name": "S.A.I.L",
    "desc": "Ship-based Artificial Intelligence Lattice, ou S.A.I.L en abrégé.",
    "metadata": {
      "apexDescription": "Quand ça marche, je peux parler à SAIL via cette console.",
      "avianDescription": "Redémarrer cette station devrait me permettre de parler à SAIL.",
      "floranDescription": "Floran répare ce panneau pour réveiller le vaisssseau!",
      "glitchDescription": "Affligé. Je dois d'abord redémarrer cette station pour communiquer avec SAIL.",
      "humanDescription": "Si je peux redémarrer cette station, SAIL devrait revenir en ligne!",
      "hylotlDescription": "Cette console me permettra de communiquer avec SAIL. Je dois d'abord la redémarrer.",
      "novakidDescription": "C'est l'heure de redémarrer cette station pour parler à SAIL."
    }
  },
  "humanteleporter": {
    "name": "Téléporteur",
    "desc": "Fidèle téléporteur, que ferions-nous sans toi?",
    "metadata": {
      "apexDescription": "Le téléporteur du vaisseau. Se téléporter donne l'impression d'être sur des montagnes russes à la vitesse de la lumière.",
      "avianDescription": "Le téléporteur! La téléportation donne l'impression de voler.",
      "floranDescription": "Téléporteur du vaisssseau. Floran sse ssent tout chose pendant la téléportation.",
      "glitchDescription": "Arrogant. Un téléporteur. Je suis capable d'entrer en mode veille pendant le processus de téléportation.",
      "humanDescription": "Le téléporteur! La téléportation est une telle décharge d'adrénaline.",
      "hylotlDescription": "Un téléporteur. Se téléporter ressemble à plonger dans l'océan depuis le sommet d'une montagne.",
      "novakidDescription": "Le téléporteur du vaisseau. Allons faire un tour!"
    }
  },
  "humanteleporterTier0": {
    "name": "Téléporteur",
    "desc": "Fidèle téléporteur, que ferions-nous sans toi?",
    "metadata": {
      "apexDescription": "Le téléporteur du vaisseau. Je dois l'allumer.",
      "avianDescription": "Le téléporteur! Si seulement celui-là était sous tension.",
      "floranDescription": "Téléporteur du vaisssseau. Celui-là est mort.",
      "glitchDescription": "Déçu. Un téléporteur sans courant. Je dois l'alimenter.",
      "humanDescription": "Le téléporteur! Dommage qu'il ne soit pas alimenté.",
      "hylotlDescription": "Ce téléporteur est éteint.",
      "novakidDescription": "Téléporteur du vaisseau. Faut que j'remette le jus!"
    }
  },
