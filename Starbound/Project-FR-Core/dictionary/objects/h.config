  },
  "huntingbench": {
    "name": "Banc Rudimentaire",
    "desc": "Un banc fabriqué grossièrement. Il a beaucoup servi durant les chasses des Florans.",
    "metadata": {
      "apexDescription": "Combien de proies ont été découpées par un Floran assis ici?",
      "avianDescription": "Un banc de chasse Floran qui a l'air robuste.",
      "floranDescription": "Banc de chassse pour que Floran se reposse.",
      "glitchDescription": "Surpris. La construction est simple, mais ce banc est usé par des années d'utilisation.",
      "humanDescription": "Un banc de chasse Floran à l'apparence simple.",
      "hylotlDescription": "Un banc probablement utilisé par les Florans pour se reposer entre deux chasses.",
      "novakidDescription": "Ce banc a l'air d'être un bon endroit pour se poser un instant."
    }
  },
  "huntingbigstatue": {
    "name": "Grande Statue Floran",
    "desc": "Une statue de Floran. On dirait un grand chasseur.",
    "metadata": {
      "apexDescription": "Un imposant seigneur Floran, sans aucun doute.",
      "avianDescription": "Je suppose que cela représente un maître de chasse Floran.",
      "floranDescription": "Cette sstatue représente la chassse, pas un Floran précisss.",
      "glitchDescription": "Curieux. Le Floran représenté ici était-il un chasseur important?",
      "humanDescription": "Je parie que les livres d'histoire ont beaucoup à dire sur ce Floran.",
      "hylotlDescription": "Un Floran hideux et moqueur. Immortalisé dans la pierre.",
      "novakidDescription": "Une sacrée grande statue de Floran."
    }
  },
  "huntingdisplay1": {
    "name": "Lance sur Plaque",
    "desc": "Une lance Floran montée sur une plaque décorative.",
    "metadata": {
      "apexDescription": "Une lance décorative montée sur plaque.",
      "avianDescription": "Une arme robuste exposée.",
      "floranDescription": "Floran est fier de sess armess de chassse.",
      "glitchDescription": "Amusé. Les Glitchs exposent souvent des armes sur les murs, mais cette lance est d'origine Floran.",
      "humanDescription": "Une lance. Elle doit être importante pour être exposée ainsi.",
      "hylotlDescription": "Une fois de plus, les Florans affichent fièrement leur barbarie.",
      "novakidDescription": "Eh bien, cette lance ne servira pas à grand-chose accrochée comme ça."
    }
  },
  "huntingdisplay2": {
    "name": "Plaque Vide",
    "desc": "Une plaque vide. Qu'est-ce qui va ici?",
    "metadata": {
      "apexDescription": "Peut-être que cette plaque attend une tête.",
      "avianDescription": "Une plaque en attente d'un trophée.",
      "floranDescription": "Plaque de chassse pour exposser les armess Floran.",
      "glitchDescription": "Confus. La forme de cette plaque est inhabituelle, qu'est-il censé y être exposé?",
      "humanDescription": "On dirait une plaque de chasse vide, peut-être faite pour exposer un fusil ou une lance.",
      "hylotlDescription": "Je frémis à l'idée de ce qui apparaîtra ici un jour.",
      "novakidDescription": "Cette plaque semble parfaite pour y accrocher un fusil."
    }
  },
  "huntingdoor1": {
    "name": "Porte en Bambou",
    "desc": "Cette porte est à peine capable de protéger des intempéries.",
    "metadata": {
      "apexDescription": "Du bambou tissé en guise de porte. C'est plus dur qu'il n'y paraît.",
      "avianDescription": "La plante utilisée pour fabriquer cette porte semble aussi solide que de la pierre.",
      "floranDescription": "Le bambou Floran pous sse fort. Cette porte essst ssolide.",
      "glitchDescription": "Surpris. Cette porte est construite en matière organique, mais elle est aussi solide que le fer.",
      "humanDescription": "Cette porte présente de petits interstices là où les tiges de bambou se rejoignent.",
      "hylotlDescription": "Les Florans semblent capables de plier la nature à leur volonté. Ce n'est pas un mince exploit.",
      "novakidDescription": "Cette porte est faite de barres de bambou."
    }
  },
  "huntinggroundtorch": {
    "name": "Support de Torche Robuste",
    "desc": "Une torche sur pied. Illumine la bête géante sur le point de vous dévorer.",
    "metadata": {
      "apexDescription": "La conception de ce support de torche garantit qu'il ne brûlera rien autour de lui.",
      "avianDescription": "Ce support semble s'élever vers le haut. J'aime bien.",
      "floranDescription": "La torche Floran garde le feu enfermé.",
      "glitchDescription": "Surpris. Ce support de torche témoigne d'un haut niveau d'artisanat.",
      "humanDescription": "Un support de torche Floran bien construit.",
      "hylotlDescription": "Je suis sûr que ce support de torche est élégant selon les standards Florans.",
      "novakidDescription": "Un bien beau support de torche."
    }
  },
  "huntinglight1": {
    "name": "Grandes Lianes Lumineuses",
    "desc": "Une lampe faite de lianes. Ou une liane faite de lampes?",
    "metadata": {
      "apexDescription": "De bien jolies lumières.",
      "avianDescription": "Une plante qui s'éclaire. Remarquable.",
      "floranDescription": "Lumièress de plantess ne brûlent pass Floran.",
      "glitchDescription": "Impressionné. Les Florans sont capables d'exploiter la nature très efficacement.",
      "humanDescription": "Cette lampe a l'air d'avoir poussé, pas d'avoir été fabriquée.",
      "hylotlDescription": "Même les vils Florans apprécient la beauté, semble-t-il.",
      "novakidDescription": "Cette plante peut carrément éclairer."
    }
  },
  "huntinglight2": {
    "name": "Petites Lianes Lumineuses",
    "desc": "Une lampe faite de lianes. Ou une liane faite de lampes?",
