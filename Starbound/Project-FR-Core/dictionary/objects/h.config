      "glitchDescription": "Curieux. Cela semble être un sac d'œufs d'une espèce native de ce biome.",
      "humanDescription": "C'est un sac d'œufs? Je ne pense pas vouloir manger ce qu'il y a dedans.",
      "hylotlDescription": "Quel sac d'œufs à l'aspect étrange!",
      "novakidDescription": "C'est un sac d'œufs? C'est tout... tortillé."
    }
  },
  "hivebush5": {
    "name": "Sac d'Œufs de Ruche",
    "desc": "Un sac d'œufs à la forme étrange.",
    "metadata": {
      "apexDescription": "Ce doit être un sac d'œufs d'une espèce originaire de cet endroit.",
      "avianDescription": "On dirait une sorte de sac d'œufs.",
      "floranDescription": "Dess œufffss?",
      "glitchDescription": "Curieux. Cela semble être un sac d'œufs d'une espèce native de ce biome.",
      "humanDescription": "C'est un sac d'œufs? Je ne pense pas vouloir manger ce qu'il y a dedans.",
      "hylotlDescription": "Quel sac d'œufs à l'aspect étrange!",
      "novakidDescription": "C'est un sac d'œufs? C'est tout... tortillé."
    }
  },
  "hivechair": {
    "name": "Chaise de Ruche",
    "desc": "Une étrange chaise faite de curieuses cosses hexagonales.",
    "metadata": {
      "apexDescription": "Cette chaise à l'aspect organique est un peu collante. J'hésite à m'asseoir dessus.",
      "avianDescription": "Cette chaise me donne presque l'impression de frétiller...",
      "floranDescription": "Chaise ssent bizarre... Floran n'a pass trop envie de ss'asseoir là-desssus...",
      "glitchDescription": "Inquiet. Est-ce vraiment une chaise, ou une ruche pour une créature?",
      "humanDescription": "Cette chaise est faite à partir d'une sorte de ruche d'insectes. Pourquoi quelqu'un fabriquerait ça?!",
      "hylotlDescription": "Je suppose que cette chaise est censée avoir l'air organique, mais au lieu de cela, elle est simplement révoltante.",
      "novakidDescription": "Je sais pas trop quoi penser de l'allure de c'te chaise..."
    }
  },
  "hivechest": {
    "name": "Coffre de Ruche",
    "desc": "Un coffre à l'aspect vraiment répugnant.",
    "metadata": {
      "apexDescription": "Un coffre plutôt ignoble.",
      "avianDescription": "Ce coffre me donne des frissons dans le dos.",
      "floranDescription": "Floran veut manger le coffre.",
      "glitchDescription": "Dégoût. Un coffre charnu et palpitant.",
      "humanDescription": "Un coffre assez dégoûtant fait de chair.",
      "hylotlDescription": "Quel coffre abhorrent.",
      "novakidDescription": "Il n'est pas très engageant, mais je veux quand même ce qu'il y a dedans."
    }
  },
  "hivedoor": {
    "name": "Porte de Ruche",
    "desc": "Une porte collante faite de cosses hexagonales organiques.",
    "metadata": {
      "apexDescription": "En observant de près, cette porte semble laisser échapper de légers fluides biologiques.",
      "avianDescription": "Cette porte laisse quelque chose de collant sur mes plumes quand je la touche...",
      "floranDescription": "Floran veut défoncer c'te bizarre porte collante.",
      "glitchDescription": "Alarmé. Cette porte semble suinter d'un fluide biologique quelconque...",
      "humanDescription": "Je ne suis pas sûr qu'une porte qui dégouline de bave partout soit le choix le plus hygiénique pour décorer.",
      "hylotlDescription": "Je peux imaginer un millier d'autres matériaux plus judicieux pour construire une porte.",
      "novakidDescription": "J'ai la chair de poule rien qu'en regardant cette porte."
    }
  },
  "hivelamp": {
    "name": "Lampe de Ruche",
    "desc": "Une lampe étrange faite d'une structure rappelant une ruche.",
    "metadata": {
      "apexDescription": "Je me demande si la source de lumière de cette lampe est biologique ou électronique.",
      "avianDescription": "Cette lampe pourrait-elle être éclairée par des insectes luisants?",
      "floranDescription": "Le truc de la ruche brille comme du feu. Floran est confus.",
      "glitchDescription": "Perplexe. Qu'est-ce qui fait briller cette lampe?",
      "humanDescription": "Je ne vois aucun fil... Alors, qu'est-ce qui fait briller cette lampe?",
      "hylotlDescription": "La lueur naturelle apaisante de cette lumière jure avec son design grotesque.",
      "novakidDescription": "Je n'ai aucune idée de comment c'te vieille lampe s'allume..."
    }
  },
  "hivelight1": {
    "name": "Lumière de Ruche",
    "desc": "Une lumière charnue et palpitante.",
    "metadata": {
      "apexDescription": "Cette lumière répugnante dégage une lueur maladive.",
      "avianDescription": "Quelle lumière dégoûtante.",
      "floranDescription": "Floran trouve que la lumière a l'air appétissante.",
      "glitchDescription": "Répulsion. Une lumière charnue et vile.",
      "humanDescription": "Quelle lumière dégoûtante.",
      "hylotlDescription": "C'est contre-nature dans son aspect naturel.",
      "novakidDescription": "Qui est responsable de la décoration de cet endroit?"
    }
  },
  "hivelight2": {
    "name": "Petite Lumière de Ruche",
    "desc": "Une lumière sinistre provenant de la ruche.",
    "metadata": {
      "apexDescription": "Cette lumière me met mal à l'aise.",
      "avianDescription": "Il y a quelque chose de maladif dans cette lumière.",
      "floranDescription": "Les yeux de Floran font mal si Floran regarde la lumière.",
      "glitchDescription": "Analytique. Cette lumière semble être alimentée par une sorte de fluide organique.",
      "humanDescription": "J'ai les poils de la nuque qui se hérissent.",
      "hylotlDescription": "Quelle lumière d'une simplicité adorable!",
      "novakidDescription": "Qu'est-ce qui alimente cette lumière? J'aime pas ça."
    }
  },
  "hivetable": {
    "name": "Table de Ruche",
    "desc": "Une table collante qui ressemble plus à une ruche qu'à un meuble.",
    "metadata": {
      "apexDescription": "Ceci semble avoir été construit à partir d'une sorte de matériau organique.",
      "avianDescription": "Cette table a-t-elle été faite par des gens, ou par une sorte de créature?",
      "floranDescription": "La table essst collante... Floran est confus.",
      "glitchDescription": "Observateur. La table semble ressembler à une ruche d'insectes.",
      "humanDescription": "Je pense que manger sur cette table ne serait pas très sain.",
      "hylotlDescription": "Cette table est faite pour ressembler à une ruche organique, pour une raison quelconque.",
      "novakidDescription": "Je serais rudement réticent à servir un ragoût sur cette table."
    }
  },
  "hologram1": {
    "name": "Hologramme Ancien",
    "desc": "Une ancienne représentation holographique d'une scène mythologique.",
    "metadata": {
      "apexDescription": "Cet hologramme semble dépeindre une figure ancienne avec des planètes.",
      "avianDescription": "Cette représentation d'une divinité me rappelle Kluex.",
      "floranDescription": "L'homme de l'image qui brille aide les planètess.",
      "glitchDescription": "Observateur. Cette scène semble montrer un être protégeant des planètes.",
      "humanDescription": "Les fresques anciennes adorent être vagues et mystérieuses...",
      "hylotlDescription": "L'hologramme est une représentation magnifique et mystérieuse d'un être.",
      "novakidDescription": "C'te vieille image montre une mystérieuse silhouette étrange."
    }
  },
  "hologram2": {
    "name": "Hologramme Ancien",
    "desc": "Une ancienne représentation holographique d'une scène mythologique.",
    "metadata": {
      "apexDescription": "Ceci dépeint un destructeur de planètes borgne. Troublant.",
      "avianDescription": "Cette image d'un être détruisant des mondes rivalise avec la puissance des dieux.",
      "floranDescription": "Cette image d'un monsstre tueur essst impressionnante!",
      "glitchDescription": "Perturbé. Cette fresque d'un être détruisant des planètes est déconcertante.",
      "humanDescription": "Eh bien, ça a l'air de mauvais augure!",
      "hylotlDescription": "Cet hologramme montre un être à plusieurs membres détruisant des planètes.",
      "novakidDescription": "Ce truc qui ressemble à un calamar n'est pas beau à voir..."
    }
  },
  "hologram3": {
    "name": "Hologramme Ancien",
    "desc": "Une ancienne représentation holographique d'une scène mythologique.",
    "metadata": {
      "apexDescription": "Cette scène semble montrer une figure poussant un monstre dans un vortex.",
      "avianDescription": "Ceci montre une sorte de bataille cataclysmique entre deux forces puissantes.",
      "floranDescription": "Vieille image d'un combat! Manque de poignardage.",
      "glitchDescription": "Curieux. Est-ce que l'être à droite est poussé dans un vortex?",
      "humanDescription": "L'intrigue est captivante. Le suspense me tue.",
      "hylotlDescription": "Je me demande s'il s'agit d'un récit historique ou d'une histoire mythique?",
      "novakidDescription": "Celle-ci montre quelqu'un en train de se colleter avec le vilain monstre-œil."
    }
  },
  "hologram4": {
    "name": "Hologramme Ancien",
    "desc": "Une ancienne représentation holographique d'une scène mythologique.",
    "metadata": {
      "apexDescription": "Six races, chacune tenant un objet d'une importance suggérée.",
      "avianDescription": "Ceci montre six races, chacune tenant une sorte d'objet important.",
      "floranDescription": "Floran meilleure race! Poignarde tout le resste!",
      "glitchDescription": "Observateur. Une représentation des six races sentientes de l'univers.",
      "humanDescription": "Hé regardez, celui en haut est un humain! Allez nous!",
      "hylotlDescription": "Je me demande quelle est l'importance de ces six races?",
      "novakidDescription": "Six races qui tiennent quelque chose. Pourquoi les miens ne sont pas là?"
    }
  },
  "hologramgalaxy": {
    "name": "Hologramme Ancien",
    "desc": "Une ancienne représentation holographique d'une galaxie.",
    "metadata": {
      "apexDescription": "Cet hologramme semble dépeindre une sorte de galaxie.",
      "avianDescription": "Des planètes en orbite autour d'un soleil. De quel système solaire pourrait-il s'agir?",
      "floranDescription": "Image de planètess! Des planètess à piller!",
      "glitchDescription": "Inspiré. Cet hologramme me donne envie de voyager parmi les étoiles.",
      "humanDescription": "L'espace, c'est joli!",
      "hylotlDescription": "Je me demande comment cet hologramme des étoiles a été fabriqué?",
      "novakidDescription": "Les étoiles - mon peuple ne les connaît que trop bien..."
    }
  },
  "hemogoblinaf": {
    "name": "Figurine d'Hémogobelin",
    "desc": "L'étiquette indique: \"Il est en fait couvert de peau rouge, mais c'est quand même assez dégoûtant.\""
  },
  "hypnareaf": {
    "name": "Figurine d'Hypnare",
    "desc": "L'étiquette indique: \"Il adore s'ébattre dans les forêts et les prairies.\""
  }
}