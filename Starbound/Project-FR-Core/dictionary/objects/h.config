      "avianDescription": "Oh, certains de ces aliments ont l'air plutôt intéressants.",
      "floranDescription": "Hein... Où essst la viande?",
      "glitchDescription": "Intrigué. Certains de ces aliments ont l'air de pouvoir être savoureux.",
      "humanDescription": "Certains plats Hylotls ont l'air plutôt bons!",
      "hylotlDescription": "Miam, ils vendent certains de mes aliments préférés.",
      "novakidDescription": "Y'a tout un tas de courses bizarres ici."
    }
  },
  "hylotlstyleposter": {
    "name": "Affiche de Comédie",
    "desc": "Une affiche pour un film Hylotl impopulaire, \"La Griffe de l'Effroi\".",
    "metadata": {
      "apexDescription": "Est-ce une publicité pour un magasin de vêtements?",
      "avianDescription": "J'ai déjà vu cet emblème quelque part...",
      "floranDescription": "Affissche pour film Hylotl sstupide.",
      "glitchDescription": "Amusé. C'était un film terrible.",
      "humanDescription": "C'est une pub pour un navet Hylotl. Ça a été un bide.",
      "hylotlDescription": "Oubliable et pas drôle, je ne suis pas fan de ce film.",
      "novakidDescription": "Un film sur un bandit à griffe, j'ai oublié le nom."
    }
  },
  "hylotlsupportbeam": {
    "name": "Support Pressurisé",
    "desc": "Une poutre de soutien structurelle capable de résister à la pression des grands fonds.",
    "metadata": {
      "apexDescription": "C'est une poutre de soutien pour la construction sous-marine.",
      "avianDescription": "Une poutre de soutien pour la construction sous-marine.",
      "floranDescription": "Maintient les bâtiments ssous-marins debout.",
      "glitchDescription": "Ennuyé. Une poutre de soutien conçue pour résister à de hauts niveaux de pression.",
      "humanDescription": "Une poutre de soutien couramment utilisée dans la construction en haute mer.",
      "hylotlDescription": "Des poutres de soutien structurelles comme celles-ci sont une partie intégrante de la magnifique architecture Hylotl.",
      "novakidDescription": "Une poutre pour un bâtiment sous-marin."
    }
  },
  "hylotlswitch": {
    "name": "Levier Standard",
    "desc": "C'est un levier très tentant.",
    "metadata": {
      "apexDescription": "Devrais-je actionner ce levier?",
      "avianDescription": "J'aimerais bien tirer ce levier.",
      "floranDescription": "Floran veut tirer le levier.",
      "glitchDescription": "Tenté. J'aimerais voir ce qui se passe si je tire ce levier.",
      "humanDescription": "Hmm, j'ai l'impression que je devrais tirer ce levier.",
      "hylotlDescription": "Aussi tentant soit-il de tirer ce levier, je dois résister.",
      "novakidDescription": "Je me demande ce que ce levier fabrique..."
    }
  },
  "hylotlsymbolb": {
    "name": "Symbole Néon Bleu",
    "desc": "Un nénuphar en métal avec un emblème bleu brillant.",
    "metadata": {
      "apexDescription": "Un nénuphar avec un symbole dessus.",
      "avianDescription": "On dirait qu'un Hylotl a marché dans de la peinture avant de piétiner le nénuphar.",
      "floranDescription": "Floran ne comprend pass le concept de cette pièce.",
      "glitchDescription": "Critique. Un nénuphar décoré reste un nénuphar.",
      "humanDescription": "Ça a l'air plus excitant que ça ne l'est probablement.",
      "hylotlDescription": "Quelle magnifique fusion des motifs culturels Hylotls.",
      "novakidDescription": "C'est quoi ce symbole brillant?"
    }
  },
  "hylotlsymbolg": {
    "name": "Symbole Néon Vert",
    "desc": "Un nénuphar en métal avec un emblème vert brillant.",
    "metadata": {
      "apexDescription": "Un nénuphar avec un symbole dessus.",
      "avianDescription": "On dirait qu'un Hylotl a marché dans de la peinture avant de piétiner le nénuphar.",
      "floranDescription": "Floran ne comprend pass le concept de cette pièce.",
      "glitchDescription": "Critique. Un nénuphar décoré reste un nénuphar.",
      "humanDescription": "Ça a l'air plus excitant que ça ne l'est probablement.",
      "hylotlDescription": "Quelle magnifique fusion des motifs culturels Hylotls.",
      "novakidDescription": "C'est quoi ce symbole brillant?"
    }
  },
  "hylotltable": {
    "name": "Table Hylotl",
    "desc": "Une table ornée d'un motif de gemmes rappelant les trois yeux des Hylotls.",
    "metadata": {
      "apexDescription": "Les Hylotls aiment vraiment créer des objets à leur image.",
      "avianDescription": "Cette table est sertie de gemmes qui ressemblent à des yeux Hylotls.",
      "floranDescription": "C'est bien les hommess-poisssons de faire des meubles qui leur ressemblent.",
      "glitchDescription": "Amusé. Ce meuble Hylotl ressemble beaucoup à l'un d'entre eux.",
      "humanDescription": "Les Hylotls semblent apprécier fabriquer des meubles à leur propre image.",
      "hylotlDescription": "Nous, les Hylotls, sommes intensément fiers de notre esthétique, et nous aimons donc créer de l'art qui nous ressemble.",
      "novakidDescription": "J'aime pas la façon dont cette table me regarde."
    }
  },
  "hylotltrashcan": {
    "name": "Poubelle Urbaine",
    "desc": "Une poubelle.",
