  },
  "holly": {
    "name": "Houx Décoratif",
    "desc": "Rien de tel qu'un peu de houx pour se sentir joyeux!",
    "metadata": {
      "apexDescription": "Un joli houx vert. Mais ça pique.",
      "avianDescription": "Cette plante épineuse me donne une impression de fête.",
      "floranDescription": "Floran adore les feuilless qui piquent!",
      "glitchDescription": "Surprise. Un brin de houx festif.",
      "humanDescription": "Un brin de houx, ça me rend presque nostalgique.",
      "hylotlDescription": "Une plante acérée et piquante.",
      "novakidDescription": "C'est une assez jolie couleur, mais pourquoi c'est si pointu?"
    }
  },
  "haypile": {
    "name": "Tas de Foin",
    "desc": "Un tas de foin. Probablement pas une super cachette.",
    "metadata": {
      "apexDescription": "Un tas de foin.",
      "avianDescription": "Un gros tas de foin frais. Les Avians utilisent le foin comme litière.",
      "floranDescription": "Le foin fraiss ssent bon!",
      "glitchDescription": "Espiègle. Un gros tas de foin, assez pour s'y cacher.",
      "humanDescription": "Je suis tenté de plonger dedans.",
      "hylotlDescription": "Le foin a l'air doux et sent le frais.",
      "novakidDescription": "Un tas de foin tout frais."
    }
  },
  "hayroll": {
    "name": "Rouleau de Foin",
    "desc": "Une balle de foin enroulée.",
    "metadata": {
      "apexDescription": "Du foin étroitement enroulé.",
      "avianDescription": "Les Avians ne roulent pas le foin de cette manière.",
      "floranDescription": "Ce foin pourrait s'enrouler et s'en aller!",
      "glitchDescription": "Heureux. Du foin tout enroulé et prêt à être vendu.",
      "humanDescription": "Un énorme rouleau de foin.",
      "hylotlDescription": "Une plante de surface, séchée et enroulée en fagot.",
      "novakidDescription": "C'est tentant de donner un p'tit coup de pied dans ce rouleau..."
    }
  },
  "haystack": {
    "name": "Balle de Foin",
    "desc": "Une balle de foin bien nette, prête à être empilée.",
    "metadata": {
      "apexDescription": "Une balle de foin. À quoi cela sert-il, je me le demande?",
      "avianDescription": "Du foin en forme de cube.",
      "floranDescription": "Floran pourrait faire un grand châteu avec des briques de foin.",
      "glitchDescription": "Neutre. Du foin formé en balles pour faciliter le stockage.",
      "humanDescription": "Je crois qu'on appelle ça des bottes de foin.",
      "hylotlDescription": "Une plante de surface séchée, transformée en cube.",
      "novakidDescription": "Une botte de foin."
    }
  },
  "hourglass": {
    "name": "Sablier",
    "desc": "Un sablier numérique. Il est figé dans un état constant.",
    "metadata": {
      "apexDescription": "Un sablier. Le sable ne s'écoule pas. Un bug peut-être?",
      "avianDescription": "Un appareil de mesure du temps. Il semble bloqué.",
      "floranDescription": "Le ssable ne tombe pass. Pourquoi ssça?",
      "glitchDescription": "Observateur. Ce minuteur ne s'épuise jamais.",
      "humanDescription": "Un vieux sablier... Le sable continue de couler sans fin.",
      "hylotlDescription": "Le sable semble infini. Que se passe-t-il ici?",
      "novakidDescription": "Pourquoi ce minuteur ne s'arrête jamais?"
    }
  },
  "hazardmicroscope": {
    "name": "Microscope de Danger",
    "desc": "Un grand microscope, conçu pour observer des bactéries potentiellement dangereuses.",
    "metadata": {
      "apexDescription": "Un microscope - Un outil universel classique pour l'étude et la recherche.",
      "avianDescription": "Regarder de petites choses n'est pas aussi intéressant que de regarder les étoiles.",
      "floranDescription": "Floran peut regarder les plantess de très près avec ssça!",
      "glitchDescription": "Fasciné. Les matières organiques sont curieuses quand on les regarde de très près.",
      "humanDescription": "Un microscope! Les petites choses peuvent s'avérer effrayantes de près.",
      "hylotlDescription": "Cet appareil peut être utilisé pour observer des choses à une échelle minuscule.",
      "novakidDescription": "J'ai pas l'temps de r'garder dans des microscopes."
