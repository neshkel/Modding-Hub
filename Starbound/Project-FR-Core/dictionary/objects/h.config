  "hangingbooster": {
    "name": "Propulseur Suspendu",
    "desc": "Un propulseur de méca suspendu.",
    "metadata": {
      "apexDescription": "Un gros propulseur de méca, suspendu par des chaînes.",
      "avianDescription": "Ce propulseur de méca est partiellement démonté.",
      "floranDescription": "Fusssée de méca ssusspendue à des chaîness.",
      "glitchDescription": "Intéressé. Être suspendu ainsi permet un accès facile aux mécaniques internes de ce propulseur.",
      "humanDescription": "Un propulseur de méca, suspendu à des chaînes. Il est probablement en cours de réparation.",
      "hylotlDescription": "On dirait qu'on travaille sur ce propulseur de méca.",
      "novakidDescription": "Un propulseur de méca, accroché à de grosses chaînes."
    }
  },
  "huntingchampionstatue": {
    "name": "Statue de Champion Floran",
    "desc": "Une statue d'un Floran. Il a l'air d'un grand chasseur.",
    "metadata": {
      "apexDescription": "Un chasseur Floran majestueux mais imposant.",
      "avianDescription": "Une statue d'un guerrier Floran. Les guerriers Avians sont rarement immortalisés dans la pierre.",
      "floranDescription": "L'élite des chasssseurs Florans a droit à de grandess statuesss.",
      "glitchDescription": "Impressionné. Le Floran représenté ici était un chasseur accompli.",
      "humanDescription": "Cette statue serait plus belle si c'était moi à la place.",
      "hylotlDescription": "Une statue érigée en l'honneur d'un chasseur Floran vénéré.",
      "novakidDescription": "Ce gars devait être un sacré bon chasseur!"
    }
  },
  "hangingguardian": {
    "name": "Gardien Suspendu",
    "desc": "Ce lustre est fait de fer forgé. Il a l'air cher.",
    "metadata": {
      "apexDescription": "C'est une vision troublante.",
      "avianDescription": "C'est... malaisant.",
      "floranDescription": "Floran n'aime pass ça.",
      "glitchDescription": "Alarmé. Que fait ceci ici?",
      "humanDescription": "C'est le moins qu'on puisse dire, cela me donne un sentiment de mauvais augure.",
      "hylotlDescription": "Cette chose, enchaînée ici, est un spectacle vraiment triste à contempler.",
      "novakidDescription": "Y'a un truc là-dedans qui me flanque les jetons."
    }
  },
  "hologramprojector": {
    "name": "Projecteur d'Hologrammes",
    "desc": "Un vieux projecteur pour communiquer par hologrammes.",
    "metadata": {
      "apexDescription": "Ce vieil appareil aurait été utilisé pour transmettre des hologrammes sur de courtes distances.",
      "avianDescription": "Cet appareil, une fois activé, peut envoyer de merveilleuses images animées à travers l'espace. Impressionnant!",
      "floranDescription": "Truc en métal fait parfoiss des imagess qui bougent.",
      "glitchDescription": "Intrigué. Cet appareil envoie des hologrammes sur de courtes distances.",
      "humanDescription": "Ce projecteur servait autrefois à envoyer de chouettes hologrammes bleus sur une courte distance.",
      "hylotlDescription": "L'ancienne ingénierie Hylotl permettait au personnel de la Bibliothèque de communiquer à courte distance.",
      "novakidDescription": "Ce tas d'ferraille n'a pas l'air de répondre à grand-chose."
    }
  },
  "hylotlartifactaltar": {
    "name": "Autel d'Artéfact Hylotl",
    "desc": "On dirait qu'il a été conçu pour contenir quelque chose d'important."
  },
  "hockeytable": {
    "name": "Table de Air Hockey",
    "desc": "Une table de air hockey classique. Le premier à dix a gagné!",
    "metadata": {
      "apexDescription": "Du air hockey? Ça a l'air amusant!",
      "avianDescription": "C'est une sorte de jeu de table avec des palets. Ça pourrait être sympa...",
      "floranDescription": "Floran pourrait battre n'importe qui à ce jeu de table sstupide.",
      "glitchDescription": "Déterminé. Je vais maîtriser ce jeu de table.",
      "humanDescription": "Du air hockey! J'étais super doué quand j'étais gosse...",
      "hylotlDescription": "Pour gagner au air hockey, il faut avoir des réflexes superbes.",
      "novakidDescription": "Air hockey? Est-ce que c'est comme une partie de billard?"
    }
  },
  "hylotlbed2": {
    "name": "Lit Traditionnel Douillet",
    "desc": "La légende raconte que si vous passez la nuit dans ce lit, vous perdrez connaissance.",
    "metadata": {
      "apexDescription": "Ce lit est simple sans être rudimentaire.",
      "avianDescription": "Un lit sobre, il a l'air confortable.",
      "floranDescription": "Lit plat. Ennuyeux.",
      "glitchDescription": "Critique. Ce lit semble presque trop simple, mais ses matériaux sont de haute qualité.",
      "humanDescription": "Ce lit a un style traditionnel qui n'a jamais eu besoin de changer.",
      "hylotlDescription": "Un lit traditionnel exquis. Beaucoup d'espèces pourraient s'en inspirer.",
      "novakidDescription": "J'ai vu pire comme lit. J'en ai vu des mieux aussi."
    }
  },
  "hylotlbowl": {
    "name": "Bol Traditionnel",
    "desc": "Un simple bol à rayures.",
    "metadata": {
      "apexDescription": "Un bol à rayures.",
      "avianDescription": "Un bol à rayures basique.",
      "floranDescription": "Bol.",
      "glitchDescription": "Neutre. Un bol.",
      "humanDescription": "C'est un bol.",
      "hylotlDescription": "Un joli bol peint à la main.",
      "novakidDescription": "Parfait pour servir une soupe bien chaude."
    }
  },
  "hylotlbutton": {
    "name": "Bouton de Base Bleu",
    "desc": "Qui sait ce qu'il pourrait activer... appuyez, c'est tout!",
    "metadata": {
      "floranDescription": "Appuyer! Appuyer!",
      "glitchDescription": "Tenté. Un bouton qui ne demande qu'à être pressé.",
      "avianDescription": "Un bouton plutôt tentant.",
      "apexDescription": "Tant de puissance dans un simple bouton.",
      "humanDescription": "Un bouton surdimensionné.",
      "hylotlDescription": "Un bouton bien fabriqué.",
      "novakidDescription": "Un bouton. Est-ce que j'devrais appuyer?"
    }
  },
  "hylotlcalligraphy1": {
    "name": "Calligraphie Hylotl \"Coasse\"",
    "desc": "Calligraphie encadrée pour 'coassement'.",
    "metadata": {
      "apexDescription": "Les Hylotl semblent accorder assez de valeur à leur langue pour la traiter comme un art.",
      "avianDescription": "Sans intérêt pour quiconque n'est pas un Hylotl.",
      "floranDescription": "On dirait des desssin de coups de couteau.",
      "glitchDescription": "Critique. Peut-être que les Hylotl devraient plutôt encadrer le mot 'orgueil'.",
      "humanDescription": "C'est comme l'une de ces œuvres d'art moderne. Je ne suis pas fan.",
      "hylotlDescription": "Cette beauté pure me met les larmes aux yeux.",
      "novakidDescription": "On dirait qu'un accident est arrivé sur cette toile."
    }
  },
  "hylotlcalligraphy2": {
    "name": "Calligraphie Hylotl \"Croâ\"",
    "desc": "Calligraphie encadrée pour 'croassement'.",
    "metadata": {
