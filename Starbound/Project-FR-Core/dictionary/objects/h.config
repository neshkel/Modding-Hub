{
  "hulagirl": {
    "name": "Danseuse de Hula",
    "desc": "Une danseuse de hula. Aloha!",
    "metadata": {
      "apexDescription": "Cette humaine qui se balance semble jouer du ukulélé.",
      "avianDescription": "Cette danseuse porte une jupe en herbe.",
      "floranDescription": "Floran sssait pas s'il aime... Peut-être que Floran s'y habituera.",
      "glitchDescription": "Envoûté. Le mouvement de balancement a un effet presque hypnotique.",
      "humanDescription": "Aloha!",
      "hylotlDescription": "Cela me rappelle le sable blanc et la mer bleue.",
      "novakidDescription": "Regardez-la, en train de gratouiller son minuscule ukulélé."
    }
  },
  "humancaptainschair": {
    "name": "Siège du Capitaine Humain",
    "desc": "Le capitaine s'assoit ici pour piloter le vaisseau.",
    "metadata": {
      "apexDescription": "Ahh... La douce liberté. Je peux utiliser le navigateur du vaisseau depuis ce siège.",
      "avianDescription": "Le siège du capitaine. C'est moi! Je peux utiliser le navigateur du vaisseau d'ici.",
      "floranDescription": "Meilleure chaise du vaisssseau. Floran peut s'asseoir ici pour utilisser le navigateur et piloter!",
      "glitchDescription": "Excité. S'asseoir sur le siège du capitaine me permet de piloter ce vaisseau. Quelle est la prochaine étape?",
      "humanDescription": "Le siège du capitaine. La personne assise ici décide de la destination du vaisseau!",
      "hylotlDescription": "M'asseoir sur le siège du capitaine me permet de piloter ce vaisseau.",
      "novakidDescription": "Le siège du capitaine. Le gars assis ici décide où va le vaisseau! C'est moi!"
    }
  },
  "humanfuelhatch": {
    "name": "Trappe à Carburant RLN",
    "desc": "Accepte l'Erchius Liquide comme carburant pour les sauts RLN.",
    "metadata": {
      "apexDescription": "La trappe à carburant du moteur RLN. Convertit le carburant en liberté.",
      "avianDescription": "La trappe à carburant RLN. Remplissons-la et partons vers les étoiles!",
      "floranDescription": "Trappe à carburant pour moteur RLN. Remplisssons-la!",
      "glitchDescription": "Excité. Cette trappe alimente le moteur RLN pour que je puisse visiter des planètes hors de ce système.",
      "humanDescription": "La trappe à carburant du vaisseau. Avec du carburant pour le moteur RLN, je peux explorer au-delà de ce système.",
      "hylotlDescription": "L'humble trappe à carburant RLN. Le carburant est le moteur de l'exploration.",
      "novakidDescription": "Le carburant RLN va là-dedans!"
    }
  },
