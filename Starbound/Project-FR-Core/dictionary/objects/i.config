  "islandcabinet": {
    "name": "Armoire des Îles",
    "desc": "Une armoire au look tropical, complétée par un petit arbre.",
    "metadata": {
      "apexDescription": "Cette armoire est bien trop expressive pour les maisons Apex.",
      "avianDescription": "Cet arbre est un peu trop petit pour s'y percher.",
      "floranDescription": "Floran aime les chosess avec un arbre desssus.",
      "glitchDescription": "Amusé. Il y a un petit arbre au sommet de cette armoire.",
      "humanDescription": "Une armoire avec un petit arbre au-dessus. Comme c'est adorable!",
      "hylotlDescription": "Cette armoire me rappelle une île au-dessus des flots.",
      "novakidDescription": "Si cet arbre était un peu plus grand, je pourrais m'allonger à l'ombre en dessous."
    }
  },
  "islandchair": {
    "name": "Chaise des Îles",
    "desc": "Une chaise faite de bambou et de feuilles.",
    "metadata": {
      "apexDescription": "Une chaise plus efficace ne se concentrerait pas autant sur l'esthétique.",
      "avianDescription": "Une chaise qui évoque des pensées de nature.",
      "floranDescription": "La chaise essst faite de plantess. C'est un bon choix.",
      "glitchDescription": "Nerveux. La chaise sent bon, mais n'a pas l'air si confortable.",
      "humanDescription": "C'est sûr qu'elle est jolie, mais je vois bien qu'elle n'est pas faite pour le confort.",
      "hylotlDescription": "Cette chaise me donne envie de m'asseoir sur une plage et de regarder le flux et le reflux des vagues.",
      "novakidDescription": "Peut-être qu'un petit repos ne ferait pas de mal."
    }
  },
  "islandhammock": {
    "name": "Hamac des Îles",
    "desc": "Pour certains, un hamac est l'image même du luxe.",
    "metadata": {
      "apexDescription": "Je préfère que mes lits soient sur un sol ferme. La sécurité avant tout.",
      "avianDescription": "Être suspendu au-dessus du sol pendant que l'on dort est merveilleux.",
      "floranDescription": "Floran préfère ddormir sur le ssol.",
      "glitchDescription": "Inquiet. Est-ce que ce hamac supporterait mon poids?",
      "humanDescription": "Des hamacs! Le lit de l'homme du commun nomade.",
      "hylotlDescription": "Il n'y a aucune élégance à dormir dans un lit aussi simple.",
      "novakidDescription": "Un hamac, hein? Voilà une idée qui me plaît."
    }
  },
  "islandlamp": {
    "name": "Lampe des Îles",
    "desc": "Cette lampe en verre diffuse une lueur chaleureuse.",
    "metadata": {
      "apexDescription": "Cette lampe a aussi un parfum d'herbe. Je me demande si c'est intentionnel.",
      "avianDescription": "Cette lampe est comme un petit soleil de verre. J'aime ça.",
      "floranDescription": "Floran aime les lampess feuilluesss.",
      "glitchDescription": "Calme. Cette lumière me donne envie de dormir.",
      "humanDescription": "Cette lampe est parfumée! Dans quel but?",
      "hylotlDescription": "Je peux apprécier la finition lisse du verre de cette lumière.",
      "novakidDescription": "Je me reconnais dans l'éclat coloré de c'te vieille lampe."
    }
  },
  "islandtable": {
    "name": "Table des Îles",
    "desc": "Il y a un visage plutôt sinistre sculpté à la base de cette table.",
    "metadata": {
      "apexDescription": "Cette table est bien trop expressive. Je préfère un décor plus simple.",
      "avianDescription": "Cette table est faite uniquement de bois. J'apprécie cela.",
      "floranDescription": "La table a un vissage en colère. Floran essst impressionné.",
      "glitchDescription": "Alarmé. Cette table tropicale possède un visage très expressif à sa base.",
      "humanDescription": "Quelqu'un a sculpté ce visage à la main. C'est gentil de leur part.",
      "hylotlDescription": "Cette table est assez agressive. Pourquoi ne pas avoir une table calme à la place?",
      "novakidDescription": "Pourquoi les gens ont besoin d'enlaidir une table correcte comme ça?"
    }
  },
  "industrialbed": {
    "name": "Lit Industriel",
    "desc": "Un lit bon marché avec un cadre métallique robuste. Il ne semble pas très confortable.",
    "metadata": {
      "apexDescription": "Ce lit semble avoir été conçu pour son intégrité structurelle plutôt que pour son confort.",
      "avianDescription": "Ce lit a l'air assez lourd...",
      "floranDescription": "Floran pourrait ne pass bien dormir dans un grand lit en métal.",
      "glitchDescription": "Analytique. Ce lit semble pouvoir résister à des mouvements extrêmement turbulents.",
      "humanDescription": "Avec un peu de rembourrage supplémentaire, ce lit pourrait en fait être assez confortable.",
      "hylotlDescription": "Ce lit a l'air horriblement inconfortable, mais comme je n'aime pas juger, je pourrais quand même y dormir.",
      "novakidDescription": "Ce lit a l'air bien raide, mais par chance, j'ai le sommeil facile."
    }
  },
  "industrialcanister": {
    "name": "Bidon Industriel",
    "desc": "Un bidon métallique scellé, pouvant être utilisé pour stocker des liquides dangereux.",
    "metadata": {
      "apexDescription": "Ce bidon semble idéal pour transporter des substances volatiles.",
      "avianDescription": "Quel curieux bidon - je me demande ce qu'il y a à l'intérieur?",
      "floranDescription": "Tube jaune. Pourrait avoir des chosess à l'intérieur.",
      "glitchDescription": "Observateur. Une courte analyse conclut que ce bidon est construit pour stocker des liquides précieux en toute sécurité.",
      "humanDescription": "Le son que fait ce bidon quand on l'ouvre est assez satisfaisant.",
      "hylotlDescription": "Quel curieux conteneur de stockage. Peut-être est-il fait pour stocker du carburant?",
      "novakidDescription": "C'est-y pas un gros tonneau de pétrole? Sacrément bizarre pour un tonneau, si vous voulez mon avis."
    }
  },
  "industrialchair": {
    "name": "Chaise Industrielle",
    "desc": "Une chaise en métal massif avec seulement un léger rembourrage.",
    "metadata": {
      "apexDescription": "Cette chaise a l'air peu coûteuse à produire en masse, mais elle est peut-être un peu inconfortable.",
      "avianDescription": "Je ne pense pas vouloir reposer mes plumes trop longtemps sur cette chaise rigide.",
      "floranDescription": "La chaise a l'air lourde. Floran pourrait quand même la lancer!",
      "glitchDescription": "Inconfortable. Cette chaise semble avoir été faite pour une production efficace plutôt que pour le confort.",
      "humanDescription": "On pourrait croire qu'avec toute cette technologie spatiale, les gens auraient trouvé comment faire des chaises systématiquement confortables.",
      "hylotlDescription": "Une chaise aussi inconfortable n'a pas pu être fabriquée par accident.",
      "novakidDescription": "C'est pas le plus confortable des sièges, mais je pourrais m'y relaxer si j'y mettais du mien."
    }
  },
  "industrialcomputer": {
    "name": "Ordinateur Industriel",
    "desc": "Une vieille tour d'ordinateur en métal. Des câbles mal rangés pendent à l'arrière.",
    "metadata": {
      "apexDescription": "Cette console possède de nombreux boutons et leviers. Je suis sûr que je pourrais la comprendre avec un manuel d'instruction.",
      "avianDescription": "Cet ordinateur affiche plein de petits textes verts. Je me demande à quoi ça sert?",
      "floranDescription": "La boîte a des motss verts desssus. Le vert essst une bonne couleur. Floran approuve.",
      "glitchDescription": "Intrigué. Cet écran affiche beaucoup d'informations - je me demande à quoi tout cela sert?",
      "humanDescription": "Je me demande pourquoi tout le texte sur cet écran d'ordinateur est vert? Est-ce un choix stylistique?",
      "hylotlDescription": "Cet ordinateur est bien plus grand qu'il ne devrait l'être. Les ingénieurs Hylotl pourraient construire quelque chose de plus compact.",
      "novakidDescription": "C'te boîte a pas mal de motss desssus, mais j'ai juste pas la patience d'suivre tout ça."
    }
  },
  "industrialcrate": {
    "name": "Caisse Industrielle",
    "desc": "Une caisse de cargaison pressurisée, conçue pour résister aux conditions des voyages spatiaux.",
    "metadata": {
      "apexDescription": "Une caisse d'apparence robuste, éclairée par un ensemble de faibles lumières rouges.",
      "avianDescription": "Cette caisse a l'air difficile à détruire.",
      "floranDescription": "Est-ce que c'te boîte a des yeux rougesss? Floran s'inquiète.",
      "glitchDescription": "Impressionné. L'extérieur de cette caisse est fait pour résister à une pression extrême. Si seulement j'étais aussi solide que ça...",
      "humanDescription": "Je pourrais prétendre être intéressé par l'apparence de cette caisse, mais en vrai, je veux juste voir ce qu'il y a dedans.",
      "hylotlDescription": "Cette caisse est conçue pour résister à une pression extrême. Je me demande si un Hylotl a aidé à la concevoir?",
      "novakidDescription": "J'aurais du mal à ouvrir c'te vieille chose coriace par la force."
    }
  },
  "industrialdisplay": {
    "name": "Écran Industriel",
    "desc": "Un écran qui semble être connecté à une sorte de radar.",
    "metadata": {
      "apexDescription": "Cet écran affiche une sorte de radar. Je me demande s'il s'agit d'informations importantes?",
      "avianDescription": "Le radar vert sur cet écran est hypnotisant...",
      "floranDescription": "Le verre clignote en vert. Bonne couleur.",
      "glitchDescription": "Intrigué. Je me demande d'où proviennent les informations de cet écran.",
      "humanDescription": "Ça a l'air important, mais en fait, je n'en ai aucune idée.",
      "hylotlDescription": "Je me demande quel est le but de cet affichage?",
      "novakidDescription": "La lumière qui clignote sur ce verre doit vouloir dire quelque chose pour quelqu'un."
    }
  },
  "industrialdoor": {
    "name": "Porte Industrielle",
    "desc": "Une porte automatisée robuste, renforcée pour survivre aux conditions intergalactiques intenses.",
    "metadata": {
      "apexDescription": "Cette porte pourrait probablement résister à une tempête d'astéroïdes ou deux.",
      "avianDescription": "Cette porte n'est pas très jolie mais elle est d'une robustesse impressionnante.",
      "floranDescription": "Floran pourrait casser la porte avec une assez grande lanche.",
      "glitchDescription": "Observateur. À en juger par la conception de cette porte, je dirais qu'elle privilégie la fonction sur l'esthétique.",
      "humanDescription": "Les lumières rouges et les bandes de danger sur cette porte renforcent vraiment son aspect industriel.",
      "hylotlDescription": "Bien que cette porte soit impressionnante de solidité, elle manque du panache visuel du travail artisanal Hylotl.",
      "novakidDescription": "Je pense qu'il faudrait plus que quelques balles de pistolet pour abattre c'te porte."
    }
  },
  "industriallight": {
    "name": "Lampe Industrielle",
    "desc": "Une applique murale en métal qui émet une lueur orange maladive.",
    "metadata": {
      "apexDescription": "Cette lampe diffuse une lueur orange. Elle semble être de fabrication assez médiocre.",
      "avianDescription": "Cette lampe diffuse une lueur orange, mais elle n'est pas chaude comme un soleil.",
      "floranDescription": "Floran veut fracasser la lumière, mais Floran va être poli à la place.",
      "glitchDescription": "Analytique. Cette lampe a été construite pour s'auto-alimenter pendant très longtemps.",
      "humanDescription": "Une lumière orange désagréable. Je me demande combien de temps dure l'ampoule?",
      "hylotlDescription": "La lueur orange de cette lampe me rappelle les coraux de braise que l'on voit couramment au fond des océans.",
      "novakidDescription": "C'te lumière n'est pas aussi brillante que moi!"
    }
  },
  "industrialstoragelocker": {
    "name": "Casier de Stockage Industriel",
    "desc": "Un casier mural avec des bandes de danger et une lumière rouge.",
    "metadata": {
      "apexDescription": "Cela ressemble à un conteneur sécurisé pour des marchandises de valeur.",
      "avianDescription": "Un casier mural en métal pour ranger des choses.",
      "floranDescription": "Floran pourrait garder ses trophéesss ici.",
      "glitchDescription": "Intrigué. Je me demande pourquoi il y a des bandes de danger sur ce casier?",
      "humanDescription": "Un casier mural pour ranger son bazar.",
      "hylotlDescription": "Un casier un peu rudimentaire pour stocker des objets.",
      "novakidDescription": "Je pourrais fourrer quelques affaires là-dedans, si j'en avais envie."
    }
  },
  "industrialtable": {
    "name": "Table Industrielle",
    "desc": "Une table en métal froid, conçue pour survivre à des voyages turbulents.",
    "metadata": {
      "apexDescription": "Cette table a l'air très solide - je me sentirais en sécurité en me cachant dessous pendant un séisme.",
      "avianDescription": "Il n'y a pas grand-chose à dire sur cette table froide et impersonnelle.",
      "floranDescription": "La table a l'air lourde.",
      "glitchDescription": "Peu impressionné. Cette table aurait besoin d'un peu de décoration.",
      "humanDescription": "Quand on ne sait pas comment décorer un meuble, la solution n'est pas forcément d'y mettre des bandes de signalisation.",
      "hylotlDescription": "La forme de cette table est si rigide. Où est l'élégance?!",
      "novakidDescription": "Il doit falloir à un forgeron une journée entière de martelage pour rendre une table aussi plate!"
    }
  },
  "infinityexpress": {
    "name": "Infinity Express",
    "desc": "Un magasin de proximité intergalactique. L'endroit idéal pour faire le plein.",
    "metadata": {
      "apexDescription": "Un magasin. Je vais m'assurer d'acheter tout ce dont j'ai besoin.",
      "avianDescription": "Un magasin bien pratique. Espérons qu'ils vendent ce que je cherche.",
      "floranDescription": "Floran peut obtenir des marchandisesss en échange de pixels brillants.",
      "glitchDescription": "Intéressé. Une sorte de marchand.",
      "humanDescription": "J'espère qu'ils vendent des sodas pétillants.",
      "hylotlDescription": "Un magasin. Je vais peut-être examiner ses marchandises.",
      "novakidDescription": "J'vais m'acheter une p'tite bouteille de jus d'automates en douce.",
      "interactData.paneLayoutOverride.windowtitle.title": " Infinity Express",
      "interactData.paneLayoutOverride.windowtitle.subtitle": " ^#b9b5b2;Carburant, snacks et divers"
    }
  },
  "icespike": {
    "name": "Pointe de Glace",
    "desc": "Mieux vaut ne pas tomber sur l'une d'entre elles...",
    "metadata": {
      "apexDescription": "Une pointe acérée, faite de glace.",
      "avianDescription": "La glace semble tranchante comme un rasoir.",
      "floranDescription": "Tranchant et pointu.",
      "glitchDescription": "Prudent. La glace tranchante pourrait pénétrer la coque d'un Glitch.",
      "humanDescription": "Je ferais mieux de ne pas toucher à ça.",
      "hylotlDescription": "Je vais éviter cela avec élégance.",
      "novakidDescription": "Ça a l'air rudement pointu, je suis prêt à décamper d'ici!"
    }
  },
  "icestalactite1": {
    "name": "Pointes Acérées",
