  "icetable": {
    "name": "Table de Glace",
    "desc": "Une table faite de glace sculptée.",
    "metadata": {
      "apexDescription": "Une table sculptée dans un énorme bloc de glace.",
      "avianDescription": "Une grande table faite de glace.",
      "floranDescription": "Floran découpe sssur la glace.",
      "glitchDescription": "Pensif. Ce serait amusant de voir un repas chaud servi ici.",
      "humanDescription": "C'est une table sur laquelle vous ne voudrez pas poser vos coudes.",
      "hylotlDescription": "Une table de glace. Magnifique, bien que peu pratique.",
      "novakidDescription": "En règle générale, je devrais probablement rester loin des meubles en glace."
    }
  },
  "ironsample": {
    "name": "Échantillon de Fer",
    "desc": "\"Un échantillon parfait de minerai de fer.\""
  },
  "idolsupport": {
    "name": "Poutre de Soutien Sculptée",
    "desc": "Une poutre de soutien sculptée pour ressembler à un oiseau redoutable.",
    "metadata": {
      "apexDescription": "Il semble que ce soit une sculpture porteuse.",
      "avianDescription": "Une poutre de soutien décorative traditionnelle.",
      "floranDescription": "Poutre de l'homme-oiseau pas très sssolide.",
      "glitchDescription": "Indifférent. Une poutre de soutien décorative.",
      "humanDescription": "Est-ce que tout s'effondrerait si je l'enlevais?",
      "hylotlDescription": "Une grande attention portée aux détails.",
      "novakidDescription": "C'est une poutre de soutien rudement élégante."
    }
  },
  "ignomeaf": {
    "name": "Figurine d'Ignome",
    "desc": "L'étiquette indique: \"Sa surface carbonisée est étonnamment agréable au toucher. Gardez-la juste loin des flammes!\""
  },
  "iguarmoraf": {
    "name": "Figurine d'Iguarmor",
