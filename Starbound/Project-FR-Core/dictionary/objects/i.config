  "ixolingpike": {
    "name": "Pieu d'Ixoling",
    "desc": "Une petite créature insectoïde empalée sur un pieu de chasse.",
    "metadata": {
      "apexDescription": "Cela semble être les restes squelettiques d'un insecte sur un pieu taillé.",
      "avianDescription": "On dirait un squelette d'insecte sur un pieu. Est-ce que les insectes ont seulement des squelettes?",
      "floranDescription": "Floran ssse demande si c'était dur de chassser ce scarabée.",
      "glitchDescription": "Curieux. Cela semble être les restes d'une créature sur un pieu.",
      "humanDescription": "Quelqu'un a empalé une créature et l'a laissée là à la vue de tous. Je me demande de quand ça date?",
      "hylotlDescription": "Les restes de cette créature sur un pieu semblent être une démonstration barbare de prouesse à la chasse.",
      "novakidDescription": "Ces os sur un bâton me filent les jetons, c'est sûr et certain."
    }
  },
  "icetip": {
    "name": "Pointe de Glace",
    "desc": "Les ailes de cet insecte sont gelées."
  },
  "icesphere1": {
    "name": "Sphère de Glace",
    "desc": "Une sphère glacée. Brisez-la avant qu'elle ne fonde!",
    "metadata": {
      "apexDescription": "Une boule de glace parfaitement ronde.",
      "avianDescription": "Une sphère de glace creuse. Comme une boule de cristal.",
      "floranDescription": "Floran fracassse l'eau ronde.",
      "glitchDescription": "Neutre. Une sphère de glace.",
      "humanDescription": "C'est comme une bulle gelée.",
      "hylotlDescription": "Une sphère, figée dans le temps."
    }
  },
  "icesphere2": {
    "name": "Sphère de Glace",
