  "index": {
    "name": "Fichier à Fiches",
    "desc": "Un index traditionnel rempli de fiches cartonnées.",
    "metadata": {
      "apexDescription": "Quel travail fastidieux d'entretenir cette chose.",
      "avianDescription": "Certaines personnes doivent vraiment aimer les livres.",
      "floranDescription": "Tant de petits morceaux de papier. Pour quoi faire?",
      "glitchDescription": "Amusé. Les Glitchs n'ont pas besoin d'indexer quoi que ce soit sur de petites cartes.",
      "humanDescription": "De tout cœur avec la personne qui entretient ce fossile.",
      "hylotlDescription": "Un glorieux monument à l'organisation.",
      "novakidDescription": "C'est quoi ce truc, au nom des étoiles?"
    }
  },
  "invisiblelight": {
    "name": "Lumière de Vaisseau",
    "desc": "Éclairage en bande, à utiliser sur un vaisseau spatial.",
    "metadata": {
      "apexDescription": "Rien à voir ici.",
      "avianDescription": "Rien à voir ici.",
      "floranDescription": "Rien à voir ici.",
      "glitchDescription": "Rien à voir ici.",
      "humanDescription": "Rien à voir ici.",
      "hylotlDescription": "Rien à voir ici."
    }
  },
  "invisiblesparker": {
    "name": "Étincelleur Invisible",
    "desc": "Étincelleur Invisible",
    "metadata": {
      "apexDescription": "Ces composants ont été détruits.",
      "avianDescription": "Ces dégâts ne seront pas faciles à réparer.",
      "floranDescription": "Les piècesss sont cassées.",
      "glitchDescription": "Inquiet. Ceci a subi de lourds dégâts.",
      "humanDescription": "Ce n'est pas bon. Ces composants sont gravement endommagés.",
      "hylotlDescription": "Je ferais mieux d'essayer de réparer les dégâts dès que possible."
    }
  },
  "ironbed": {
    "name": "Lit Tranchant",
    "desc": "Un lit en fer fait d'épées. Parfait pour une sieste énergique.",
    "metadata": {
      "apexDescription": "Un lit qui a l'air bien inconfortable.",
      "avianDescription": "Quel lit étrangement tranchant.",
      "floranDescription": "Le lit est tranchant et plein de piquantsss.",
      "glitchDescription": "Félicité. Un lit en fer confortable. Un Glitch peut se reposer facilement ici.",
      "humanDescription": "Je ne pense pas que je dormirais beaucoup sur un lit comme celui-ci.",
      "hylotlDescription": "Un lit remarquablement brutal. Un tel design n'évoque pas le confort."
    }
  },
  "irondoor": {
    "name": "Porte Tranchante",
    "desc": "Une porte faite de lames croisées. On dirait qu'elles peuvent se rétracter.",
    "metadata": {
      "apexDescription": "Une porte en fer menaçante.",
      "avianDescription": "Cette porte semble conçue pour garder quelque chose dehors... ou dedans.",
      "floranDescription": "Floran aime porte qui poignarde. Floran claque la porte.",
      "glitchDescription": "Envieux. Une belle porte pour une forteresse, ou un établissement similaire.",
      "humanDescription": "Cela me rappelle mes jours d'exploration de vieux châteaux.",
      "hylotlDescription": "Quel barbare fabriquerait une porte avec des lames?",
      "novakidDescription": "C'te porte pleine de piques n'effraie personne."
    }
  },
  "ironlight": {
    "name": "Lumière Tranchante",
    "desc": "Est-ce une lampe ou un sabre? Peut-être les deux.",
    "metadata": {
      "apexDescription": "Une épée inhabituelle qui diffuse de la lumière.",
      "avianDescription": "Étrange. Cette épée sert de lampe, pas d'arme.",
      "floranDescription": "Lumière tranchante, coupe l'ombre. Floran est à cran.",
      "glitchDescription": "Pratique. Cette lumière pourrait servir de torche et d'arme.",
      "humanDescription": "Une épée qui s'allume. J'avais des trucs pareils à mon époque Gothique.",
      "hylotlDescription": "Une arme reconvertie pour éclairer une pièce. J'approuve."
    }
  },
  "ironswitch": {
    "name": "Console Tranchante",
    "desc": "L'épée dans la... console?",
    "metadata": {
      "apexDescription": "Ces épées servent de leviers. Je me demande ce qu'elles activent?",
      "avianDescription": "Une utilisation intelligente d'armes usées.",
      "floranDescription": "Floran tire sur l'épée. L'épée fait bourdonner les lumièresss.",
      "glitchDescription": "Impressionné. Une bonne lame a de nombreux usages, même émoussée. Ici, elle sert de levier.",
      "humanDescription": "J'hésite entre tirer le levier et m'inquiéter de me couper.",
      "hylotlDescription": "Des dispositifs comme celui-ci pourraient-ils être un pas vers la paix? Ou sont-ils une menace de violence?"
    }
  },
  "irontable": {
    "name": "Table Tranchante",
    "desc": "Une table avec des épées en guise de pieds. Pas idéal pour jouer du pied sous la table.",
    "metadata": {
      "apexDescription": "Cette table donne un sentiment de fatalité au fait de se cogner l'orteil.",
      "avianDescription": "S'asseoir ici suffirait à rendre n'importe qui nerveux.",
      "floranDescription": "Floran coupe sur la table. Maintenant, Floran coupe AVEC la table.",
      "glitchDescription": "Confort. Une table décontractée. Les autres semblent s'en méfier.",
      "humanDescription": "J'hésite énormément à m'asseoir ici.",
      "hylotlDescription": "Peut-être que c'est un peu trop dangereux comme usage alternatif pour des armes."
    }
  },
  "irontoilet": {
    "name": "Toilettes Tranchantes",
    "desc": "Des toilettes faites d'épées. Risqué.",
    "metadata": {
      "apexDescription": "Ce ne sont pas les toilettes les plus attrayantes que j'aie jamais vues.",
      "avianDescription": "Je n'imagine pas que ces choses soient très populaires.",
      "floranDescription": "Cuvette à piquantsss, Floran va voler le desssein pour ssa propre cuvette.",
      "glitchDescription": "Perplexité. Ces toilettes ne sont vraiment sûres que pour les Glitchs, qui n'en ont pas besoin.",
      "humanDescription": "Des toilettes faites d'épées. Je vais en faire des cauchemars pendant des semaines.",
      "hylotlDescription": "On préférerait presque que ces épées servent encore au combat."
    }
  },
  "ironchest": {
    "name": "Coffre en Fer",
    "desc": "Un coffre en fer basique.",
    "metadata": {
      "apexDescription": "Un coffre! Regardons à l'intérieur.",
      "avianDescription": "Souvent, ces coffres contenaient des objets de valeur. Je suis impatient!",
      "floranDescription": "Coffre! Floran doit fouiller!",
      "glitchDescription": "Anticipation. Que pourrait-il y avoir dedans?",
      "humanDescription": "Un coffre! Ouvrons-le.",
      "hylotlDescription": "Il y a peu de choses aussi excitantes qu'un coffre non ouvert.",
      "novakidDescription": "Eh ben ça alors - un coffre pas encore ouvert! Jetons un œil."
    }
  },
  "icefluffaloegg": {
    "name": "Œuf de Fluffalo de Glace",
    "desc": "Éclot en un vulnérable petit veau fluffalo de glace - une bonne source d'extrait cryogénique une fois adulte.",
    "metadata": {
      "apexDescription": "Cet œuf contient un fluffalo de glace. Une fois adulte, la créature produira de l'extrait cryogénique.",
      "avianDescription": "Un œuf de fluffalo de glace. Les fluffalos de glace sont du bétail - ils produisent de l'extrait cryogénique.",
      "floranDescription": "Y'a un bébé fluffalo de glace tout laineux à l'intérieur!",
      "glitchDescription": "Charmé. Un œuf contenant un fluffalo de glace! Ce bétail adorablement duveteux produit de l'extrait cryogénique.",
      "humanDescription": "Un œuf gelé - il y a un fluffalo de glace dedans!",
      "hylotlDescription": "Le petit dans cet œuf deviendra un fluffalo de glace adulte un jour.",
      "novakidDescription": "Cet œuf contient un fluffalo de glace. Ces créatures demandent du temps, mais elles vous remboursent en produits."
    }
  },
  "ironanvil": {
    "name": "^orange;Enclume en Fer^white;",
    "desc": "Peut être utilisée pour produire des armures et des armes.",
    "metadata": {
      "interactData.paneLayoutOverride.windowtitle.title": " Enclume en Fer",
      "interactData.paneLayoutOverride.windowtitle.subtitle": " ^#b9b5b2;Armures et armes",
      "apexDescription": "Une enclume. Les Apex n'ont pas utilisé cela pour le travail du métal depuis très, très longtemps.",
      "avianDescription": "Un gros bloc de fer avec une surface plane.",
      "floranDescription": "Très lourd, utile pour un piège.",
      "glitchDescription": "Fier. Les Glitchs fabriquent toutes sortes d'armes sur ces enclumes. Ils fabriquent même des enclumes sur ces enclumes.",
      "humanDescription": "Une enclume. Les humains n'ont pas utilisé cela depuis le début de leur histoire.",
      "hylotlDescription": "Probablement utilisé pour le travail du métal.",
      "novakidDescription": "Une enclume. Je connais bien ça."
    }
  },
  "ironcraftingtable": {
    "name": "^orange;Table de Craft en Fer^white;",
    "desc": "On pourrait construire de l'équipement très sophistiqué sur cette table.",
    "metadata": {
      "interactData.paneLayoutOverride.windowtitle.title": "  Table de Craft en Fer",
      "interactData.paneLayoutOverride.windowtitle.subtitle": "  Artisanat intensif!",
      "apexDescription": "Une table de fabrication pour le travail du fer.",
      "avianDescription": "Cette table de fabrication me permet de créer une large gamme d'équipements.",
      "floranDescription": "Table en fer pour fabriquer des chosesss.",
      "glitchDescription": "Intéressé. C'est une table de fabrication en fer. C'est mieux qu'une en bois.",
      "humanDescription": "Le bricolage ne me fait pas peur. C'est parti.",
      "hylotlDescription": "Une table de fabrication en fer peut être utilisée pour fabriquer du bon matériel.",
      "novakidDescription": "Une bonne vieille table de fabrication en fer. C'est mieux qu'une en bois."
    }
  },
  "inventorstable": {
    "name": "^orange;Table de l'Inventeur^white;",
    "desc": "La table de l'inventeur est utilisée pour produire diverses stations d'artisanat.",
    "metadata": {
