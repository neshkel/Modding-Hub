      "hylotlDescription": "Une sphère, figée dans le temps."
    }
  },
  "icespherechest": {
    "name": "Coffre Sphérique de Glace",
    "desc": "Un coffre sphérique gelé. Parfait pour un trésor, ou pour faire des glaçons.",
    "metadata": {
      "apexDescription": "Un coffre gelé tout rond. Regardons à l'intérieur.",
      "avianDescription": "Un coffre lisse, froid et invitant.",
      "floranDescription": "Floran ouvre coffre qui grelotte.",
      "glitchDescription": "Analyse. La glace a des propriétés spéciales, elle ne fondra pas de sitôt.",
      "humanDescription": "Ce coffre ressemble à un igloo. Il y a peut-être un ours polaire dedans.",
      "hylotlDescription": "Un coffre gelé et arrondi. Remarquable.",
      "novakidDescription": "Ce coffre de glace a gardé mon butin bien au frais."
    }
  },
  "icebed": {
    "name": "Lit de Glace",
    "desc": "Un lit fait de glace. En été, il se transforme en lit à eau.",
    "metadata": {
      "apexDescription": "Les Apex ont chaud quand ils dorment. Ce lit est une catastrophe imminente.",
      "avianDescription": "Je n'imagine pas ce lit comme étant très reposant.",
      "floranDescription": "Floran lèche le lit. Le lit a un goût de froid. Floran a mal à la tête.",
      "glitchDescription": "Partagé. Ce lit dur est parfait pour un Glitch, mais et s'il fond?",
      "humanDescription": "Ce lit a l'air de vous jeter un froid. Haha... Ha...",
      "hylotlDescription": "Une utilisation remarquablement intelligente de l'eau.",
      "novakidDescription": "J'ai l'impression que je suis juste trop chaud pour ce lit."
    }
  },
  "icechair": {
    "name": "Chaise de Glace",
    "desc": "Une chaise gelée. Inconfortable après un certain temps.",
    "metadata": {
      "apexDescription": "J'ai peur de rester collé à la chaise si je m'assois.",
      "avianDescription": "Cette chaise me gèle les plumes.",
      "floranDescription": "La chaise fait ssse sentir bizarre. Floran grelotte.",
      "glitchDescription": "Réflexion. Ces chaises ne seraient pas idéales pour des fêtes en extérieur.",
      "humanDescription": "Une idée inhabituelle pour une chaise. Ma peau reste collée dessus.",
      "hylotlDescription": "Je crois que je vois un poisson congelé là-dedans. Pauvre créature.",
      "novakidDescription": "En règle générale, je devrais probablement rester loin des meubles en glace."
    }
  },
  "icechest": {
    "name": "Coffre de Glace",
    "desc": "Un coffre de glace. Totalement sécurisé, jusqu'à ce qu'il fonde.",
    "metadata": {
      "apexDescription": "Ce coffre ne semble pas très pratique.",
      "avianDescription": "On pourrait sûrement faire fondre ce coffre pour accéder à son contenu.",
      "floranDescription": "Floran impressionné par la ssécurité super froide.",
      "glitchDescription": "Hypothèse. Ce coffre était à l'origine conçu pour stocker des documents sensibles. Si le coffre fond, le contenu est ruiné.",
      "humanDescription": "Un coffre de glace. Ça n'a pas l'air très sûr. On pourrait l'ouvrir juste en le faisant fondre.",
      "hylotlDescription": "Un coffre en glace. Pas le design le plus sensé.",
      "novakidDescription": "Mince, je pourrais probablement 'déverrouiller' ce coffre juste en restant à côté un moment."
    }
  },
  "icedoor": {
    "name": "Porte de Glace",
    "desc": "Une porte de glace. Ne tenez pas la poignée trop longtemps.",
    "metadata": {
      "apexDescription": "Une porte faite de glace. Je peux voir mon reflet dedans.",
      "avianDescription": "Rester près de cette porte trop longtemps me fait frissonner.",
      "floranDescription": "Floran ne voit pass la porte, court droit dedans.",
      "glitchDescription": "Analyse. La glace est stratifiée, ce qui rend cette porte difficile à enfoncer.",
      "humanDescription": "Une porte gelée. Froide au toucher.",
      "hylotlDescription": "Cette porte de glace est très bien conçue.",
      "novakidDescription": "C'était l'idée de qui de faire des 'meubles qui fondent', d'abord? Je parie que c'est super cher, en plus."
    }
  },
  "icemachine": {
    "name": "Machine à Glaçons",
    "desc": "Un distributeur de glace fait de glace. C'est l'ice-ception.",
    "metadata": {
      "apexDescription": "Une machine à glace dans tous les sens du terme.",
      "avianDescription": "La glace garde l'autre glace au froid. Malin.",
      "floranDescription": "Floran grimpe dans la boîte à glace, grelotte, et ressort.",
      "glitchDescription": "Mathématique. Il y a exactement six mille quatre cent quatre-vingt-quatre glaçons dans ce distributeur.",
      "humanDescription": "Un distributeur de glaçons, l'une des plus grandes inventions de l'humanité.",
      "hylotlDescription": "Une boîte pour la glace, faite de glace. Intéressant.",
      "novakidDescription": "Toute cette glace va finir par s'agglutiner pour former un seul gros glaçon, non?"
    }
  },
  "iceshard1": {
    "name": "Morceau de Glace",
    "desc": "Un gros morceau de glace.",
    "metadata": {
      "apexDescription": "Un éclat de glace.",
      "avianDescription": "Un éclat de glace froid.",
      "floranDescription": "Glace fracassssée.",
      "glitchDescription": "Neutre. Un éclat de glace.",
      "humanDescription": "Un bout de glace.",
      "hylotlDescription": "Un morceau de glace fracturé.",
      "novakidDescription": "Juste un gros morceau de glace."
    }
  },
