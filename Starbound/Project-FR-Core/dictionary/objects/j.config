{
  "jumppad": {
    "name": "Plateforme de Saut",
    "desc": "Repousse les objets avec une force élastique puissante.",
    "metadata": {
      "floranDescription": "Repousssse les objetsss avec une puissante force élasstique.",
      "glitchDescription": "Impressionné. Repousse les objets avec une force élastique puissante."
    }
  },
  "jupitermodel": {
    "name": "Modèle de Jupiter",
    "desc": "Un modèle détaillé de Jupiter, la plus grande planète du système Sol.",
    "metadata": {
      "apexDescription": "C'est risible de penser que les humains considéraient autrefois Jupiter comme une 'grande' planète.",
      "avianDescription": "Jupiter est assez grande comparée à la Terre.",
      "floranDescription": "Jupiter essst un joli méli-mélo de nuagesss.",
      "glitchDescription": "Émerveillé. Jupiter est une planète relativement petite selon les standards actuels.",
      "humanDescription": "Cette vieille grosse planète gazeuse, elle tient toujours le coup.",
      "hylotlDescription": "Jupiter, autrefois considérée comme une géante pour tant de gens.",
      "novakidDescription": "J'en ai vu des plus grosses."
    }
  },
  "jukebox": {
    "name": "Jukebox",
    "desc": "Ce jukebox a un super son ! Dommage qu'il ne semble y avoir qu'une seule piste.",
    "metadata": {
      "apexDescription": "Une boîte à musique joyeuse. Mais il n'y a qu'un seul groupe.",
      "avianDescription": "Ce jukebox peut égayer même les esprits les plus sombres.",
      "floranDescription": "Boîte bruyante. Floran ne voit passs l'intérêt !",
      "glitchDescription": "Branché. La musique affecte mes circuits de telle manière que je ne peux m'empêcher de danser.",
      "humanDescription": "Oh là là, ils ont mon album préféré ! L'espace vient de devenir plus funky.",
      "hylotlDescription": "La musique humaine manque de la nuance tonale de son équivalent Hylotl.",
      "novakidDescription": "Ces mélodies me sont inconnues, mais c'est pas mauvais, je dois l'admettre."
    }
  },
  "juicekeg": {
    "name": "Fût de Jus",
    "desc": "Un fût plein de jus. Miam, du jus !",
    "metadata": {
      "apexDescription": "Un fût qui sent le jus sucré.",
      "avianDescription": "Un tonneau à l'odeur sucrée rempli de liquide.",
      "floranDescription": "Tonneau sssent les jusss dégoûtantsss.",
      "glitchDescription": "Ravi. Les fûts de jus sont toujours synonymes de réjouissances à venir.",
      "humanDescription": "Un fût. Il est plein de jus.",
      "hylotlDescription": "Le liquide à l'intérieur sent merveilleusement bon.",
      "novakidDescription": "Y'a du bon jus à l'intérieur."
    }
  },
