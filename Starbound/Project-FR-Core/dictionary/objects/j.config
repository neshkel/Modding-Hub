  "junglechest": {
    "name": "Coffre de Lianes",
    "desc": "Un coffre fait de lianes, ce n'est pas vraiment sûr.",
    "metadata": {
      "apexDescription": "Le coffre lui-même semble être organique.",
      "avianDescription": "Ce coffre a-t-il été construit, ou a-t-il poussé ?",
      "floranDescription": "Fait pousser coffre dans le sssol.",
      "glitchDescription": "Impressionné. Il semble que cette plante ait été cultivée dans le but exprès d'être un coffre.",
      "humanDescription": "Est-ce que ce coffre a poussé ?",
      "hylotlDescription": "Il semble que les Florans aient appris à exploiter la nature pour faire pousser les choses dont ils ont besoin.",
      "novakidDescription": "On dirait que ce coffre a poussé direct hors du sol !"
    }
  },
  "jumpbooster": {
    "name": "Booster de Saut",
    "desc": "Le gaz libéré par ces conduits augmente votre puissance de saut.",
    "metadata": {
      "apexDescription": "Si je me tiens sur cette bouche d'aération, cela boostera mon saut.",
      "avianDescription": "Cette aération augmente la hauteur de mes sauts.",
      "floranDescription": "Après avoir marché dans ce gazzz, Floran peut sauter comme un monsstre.",
      "glitchDescription": "Excité. Cette vapeur me permettra de sauter très haut.",
      "humanDescription": "Cela peut paraître dangereux, mais ce gaz a des propriétés bénéfiques.",
      "hylotlDescription": "Imprégné des pouvoirs de cette vapeur, je suis capable d'atteindre de nouveaux sommets.",
      "novakidDescription": "Cet appareil booste mes sauts."
    }
  }
}