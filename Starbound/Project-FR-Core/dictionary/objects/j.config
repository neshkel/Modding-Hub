  "junglebush17": {
    "name": "Fleur Putride",
    "desc": "Une fleur putride et horrible.",
    "metadata": {
      "apexDescription": "Quelque chose sent horriblement mauvais. Est-ce cette fleur ?",
      "avianDescription": "Cette fleur sent terriblement mauvais.",
      "floranDescription": "Fleur qui pue.",
      "glitchDescription": "Observateur. Cette fleur sent horriblement mauvais.",
      "humanDescription": "Cette fleur sent affreusement mauvais !",
      "hylotlDescription": "Une fleur tout à fait atroce. Elle sent la putréfaction.",
      "novakidDescription": "Holà ! En voilà une fleur malodorante."
    }
  },
