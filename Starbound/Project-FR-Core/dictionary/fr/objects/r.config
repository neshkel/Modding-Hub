{
  "retroscifibed": {
    "name": "Pod Rétro",
    "desc": "Un lit conçu dans un style rétro-futuriste.",
    "metadata": {
      "apexDescription": "Ahhh, le meilleur sommeil de ma vie, c'était dans l'un de ces trucs.",
      "avianDescription": "Il faut rester debout pour dormir dans ce lit.",
      "floranDescription": "Étrange pod mécanique pour ssommeiller dedans.",
      "glitchDescription": "Ravi. Ce lit offre un repos suffisant tout en maintenant une position verticale.",
      "humanDescription": "Ce lit est on ne peut plus rétro.",
      "hylotlDescription": "Un lit devrait être plus qu'un simple outil pour récupérer de l'énergie.",
      "novakidDescription": "Dormir là-dedans me donne l'impression d'être une expérience scientifique."
    }
  },
  "retroscificabinet": {
    "name": "Cabinet Rétro",
    "desc": "Un petit meuble de rangement de style rétro-futuriste.",
    "metadata": {
      "apexDescription": "Un meuble élégant pour ranger à peu près n'importe quoi.",
      "avianDescription": "Pour quelque chose d'aussi simple, ce cabinet a son charme.",
      "floranDescription": "Meuble avec des courbess.",
      "glitchDescription": "Observateur. Un cabinet hautement fonctionnel.",
      "humanDescription": "Un cabinet avec une courbe bien distincte.",
      "hylotlDescription": "Ce meuble a une courbe élégante que je peux apprécier.",
      "novakidDescription": "Un endroit pratique pour ranger votre bric-à-brac."
    }
  },
  "retroscifichair": {
    "name": "Chaise Rétro",
    "desc": "Une chaise en forme d'œuf de style rétro-futuriste.",
    "metadata": {
      "apexDescription": "Confortable et attrayante, les qualités idéales pour une chaise.",
      "avianDescription": "Une chaise flottante, c'est plutôt amusant.",
      "floranDescription": "Floran essst méfiant envers la chaise qui flotte.",
      "glitchDescription": "Confus. Comment cette chaise garde-t-elle son équilibre?",
      "humanDescription": "J'ai toujours voulu une chaise volante en forme d'œuf.",
      "hylotlDescription": "Une chaise flottante, quelle nouveauté.",
      "novakidDescription": "Cette chaise a l'air douillette, comme si on était dans une coquille d'œuf."
    }
  },
  "retroscifidresser": {
    "name": "Commode Rétro",
    "desc": "Une commode conçue dans un style rétro-futuriste.",
    "metadata": {
      "apexDescription": "Un classique indémodable.",
      "avianDescription": "Ce style de commode ne semble jamais démodé.",
      "floranDescription": "Toute commode essst utile. Je me moque de son apparence.",
      "glitchDescription": "Pensif. Est-ce l'idée que quelqu'un se fait des meubles du futur?",
      "humanDescription": "Une commode tellement ringarde qu'elle en devient branchée.",
      "hylotlDescription": "La fragilité des modes est évidente dans le design de cette commode.",
      "novakidDescription": "À des années-lumière des commodes dont j'ai l'habitude."
    }
  },
  "retroscifilight": {
    "name": "Projecteur Rétro",
    "desc": "Un projecteur conçu dans un style rétro-futuriste.",
    "metadata": {
      "apexDescription": "Une lampe simple et élégante.",
      "avianDescription": "Une petite lampe qui conviendrait à une maison moderne.",
      "floranDescription": "Ce projecteur essst brillant.",
      "glitchDescription": "Pas impressionné. Une simple lampe avec peu de personnalité.",
      "humanDescription": "Un projecteur idéal pour n'importe quelle demeure moderne.",
      "hylotlDescription": "Cette lumière manque de personnalité.",
      "novakidDescription": "Donnez-moi une lampe à huile plutôt que ce truc n'importe quand."
    }
  },
  "retroscifitable": {
    "name": "Table Rétro",
    "desc": "Une table conçue dans un style rétro-futuriste.",
    "metadata": {
      "apexDescription": "Une belle table, elle complète vraiment une pièce.",
      "avianDescription": "J'ai peur que cette table bascule si je pose quelque chose de lourd dessus.",
      "floranDescription": "Table chic mais toujours bonne pour les banquetss.",
      "glitchDescription": "Impressionné. Une table particulièrement bien équilibrée.",
      "humanDescription": "On dirait que cette table pourrait se renverser à tout moment.",
      "hylotlDescription": "La beauté de cette table réside dans son équilibre parfait.",
      "novakidDescription": "J'envie la capacité de cette table à rester debout."
    }
  },
  "retroscifitv": {
    "name": "Télévision Rétro",
    "desc": "Un téléviseur conçu dans un style rétro-futuriste.",
    "metadata": {
      "apexDescription": "Cette télévision a l'air futuriste, mais j'en avais une quand j'étais enfant.",
      "avianDescription": "Je n'ai jamais vraiment eu envie d'avoir une télé, jusqu'à maintenant.",
      "floranDescription": "Image bruyantess dans une boîte chic.",
      "glitchDescription": "Intéressé. J'aime l'aspect de cette technologie.",
      "humanDescription": "Enfin une télé qui a l'air aussi dépassée que le média lui-même.",
      "hylotlDescription": "Tout dans cet appareil est grotesque. On est loin d'un bon livre.",
      "novakidDescription": "Une boîte à images qui a de l'allure."
    }
  },
  "returnteleporter": {
    "name": "Téléporteur de Retour",
    "desc": "Ce téléporteur vous ramènera d'où vous venez.",
    "metadata": {
      "apexDescription": "Cela me permettra de sortir facilement.",
      "avianDescription": "Je peux sortir en utilisant ceci!",
      "floranDescription": "Téléporteur permet à Floran de ssortir.",
      "glitchDescription": "Soulagé. Ce téléporteur me permettra de revenir.",
      "humanDescription": "Je pourrai utiliser ça quand je serai prêt à rentrer.",
      "hylotlDescription": "Un moyen utile de revenir rapidement.",
      "novakidDescription": "Un moyen pratique de filer vers la prochaine aventure!"
    }
  },
  "remoteteleporter": {
    "name": "Téléporteur de l'Avant-poste",
    "desc": "Un téléporteur personnel, se connecte aux destinations enregistrées.",
    "metadata": {
      "apexDescription": "Un téléporteur personnel. Un équipement fonctionnel mais amusant.",
      "avianDescription": "J'adore le bruissement de mes plumes quand je me téléporte!",
      "floranDescription": "Téléporteur personnnel, c'est la classe!",
      "glitchDescription": "Attiré. Un téléporteur personnel avec un design personnalisé.",
      "humanDescription": "Un téléporteur personnel! Ça, c'est voyager avec style.",
      "hylotlDescription": "Un téléporteur personnel, il arbore un design sur mesure.",
      "novakidDescription": "Pour un téléporteur, il a vraiment une sacrée dégaine!"
    }
  },
  "returnoutpostteleporter": {
    "name": "Téléporteur de l'Avant-poste",
    "desc": "Ce téléporteur devrait vous ramener à l'Avant-poste.",
    "metadata": {
      "apexDescription": "Un lien direct avec l'Avant-poste. Nickel!",
      "avianDescription": "Un téléporteur pour me ramener à l'Avant-poste.",
      "floranDescription": "Ce téléporteur emmènera Floran à l'Avant-posste.",
      "glitchDescription": "Rassuré. Cela me téléportera en toute sécurité à l'Avant-poste.",
      "humanDescription": "Un lien bien pratique vers l'Avant-poste.",
      "hylotlDescription": "Un lien direct vers l'Avant-poste, un appareil fort utile.",
      "novakidDescription": "Si je grimpe là-dedans, je finirai à l'Avant-poste."
    }
  },
  "researchstation": {
    "name": "^orange;Station de Recherche^white;",
    "desc": "Peut être utilisée pour développer des équipements hautement spécialisés.",
    "metadata": {
      "interactData.paneLayoutOverride.windowtitle.title": " Station de Recherche",
      "interactData.paneLayoutOverride.windowtitle.subtitle": " Développer des technologies spécialisées",
      "apexDescription": "Je peux créer des stations et des appareils spécialisés avec ça.",
      "avianDescription": "Une table de recherche.",
      "floranDescription": "Floran peut créer des trucs sspécialisés.",
      "glitchDescription": "Observateur. Cette table est bien adaptée à la recherche et au développement de nouveaux objets.",
      "humanDescription": "Je peux fabriquer des objets spécialisés ici!",
      "hylotlDescription": "Cette table semble bien équipée pour le développement de nouvelles technologies.",
      "novakidDescription": "J'peux fabriquer toutes sortes de trucs spécialisés ici!"
    }
  },
  "railbumper": {
    "name": "Butoir de Rail",
    "desc": "Ferme les extrémités des rails pour renvoyer les passagers d'où ils viennent."
  },
  "railsensor": {
    "name": "Capteur de Rail",
    "desc": "Détecte les passagers du rail lorsqu'ils passent devant."
  },
  "railstop": {
    "name": "Arrêt de Rail",
    "desc": "Arrête et fait repartir les passagers du rail."
  },
  "railswitch": {
    "name": "Aiguillage de Rail",
    "desc": "Dirige les passagers du rail vers différents chemins."
  },
  "railtramstop": {
    "name": "Arrêt de Tramway",
    "desc": "Appelle et arrête les tramways sur rails."
  },
  "repairo": {
    "name": "Rob Repairo",
    "desc": "C'est Rob Repairo, un marchand mécanique qui répare les véhicules perdus ou cassés.",
    "metadata": {
      "subtitle": "Réparation de véhicules",
      "apexDescription": "Cet homme mécanique se consacre à la réparation de choses.",
      "avianDescription": "Ce marchand mécanique réparera les véhicules cassés.",
      "floranDescription": "L'homme en métal brillant fixsse des choses.",
      "glitchDescription": "Soulagé. Cet homme mécanique peut réparer les véhicules cassés.",
      "humanDescription": "Ce bon vieux Rob Repairo. Il a un visage joyeux et il répare des trucs!",
      "hylotlDescription": "Ce marchand mécanique est d'une gaieté déconcertante.",
      "novakidDescription": "Il a l'air drôlement heureux de réparer des trucs toute la sainte journée."
    }
  },
  "roofvent": {
    "name": "Évent de Toit",
    "desc": "Une bouche d'aération.",
    "metadata": {
      "apexDescription": "Un évent de toit.",
      "avianDescription": "La brise de cet évent ébouriffe mes plumes.",
      "floranDescription": "Un évent - pour l'aération, ou pour sse cacher.",
      "glitchDescription": "Surpris. Cet évent semble être en bon état.",
      "humanDescription": "Un évent pour le toit, je parie que certains ont essayé d'entrer par là.",
      "hylotlDescription": "Un simple évent de toit.",
      "novakidDescription": "Une bouche d'aération pour le toit, je me demande si je pourrais passer dedans?"
    }
  },
  "redlight": {
    "name": "Lumière Rouge",
    "desc": "Une faible lumière rouge.",
    "metadata": {
      "apexDescription": "Ces lumières sont couramment utilisées sur les navires.",
      "avianDescription": "Une lumière.",
      "floranDescription": "Lumière rouge! Rouge!",
      "glitchDescription": "Neutre. Cette lampe produit de la lumière à faible puissance.",
      "humanDescription": "Une lumière rouge d'ambiance.",
      "hylotlDescription": "Une lumière passable.",
      "novakidDescription": "Une lumière rouge."
    }
  },
  "redlightBroken": {
    "name": "Lumière Rouge Cassée",
    "desc": "Une lumière défectueuse.",
    "metadata": {
      "apexDescription": "Cette lampe ne reçoit pas assez de puissance.",
      "avianDescription": "Une lumière vacillante.",
      "floranDescription": "Lumière donne le vertigge!",
      "glitchDescription": "Pas impressionné. Cette lumière est défectueuse.",
      "humanDescription": "Cette lumière est en train de lâcher.",
      "hylotlDescription": "Une lumière sous-alimentée.",
      "novakidDescription": "Cette lumière ne passe pas un bon moment."
    }
  },
  "root1": {
    "name": "Racines",
    "desc": "De petites racines dépassent du plafond.",
    "metadata": {
      "apexDescription": "Des racines traversent le plafond.",
      "avianDescription": "Des racines poussent au plafond. Peut-être qu'un jour cet endroit en sera couvert.",
      "floranDescription": "Raciness poussent pendant des années. Comme Floran.",
      "glitchDescription": "Observateur. Il y a des racines qui dépassent du plafond.",
      "humanDescription": "Ces racines ressemblent à des tentacules bruns.",
      "hylotlDescription": "Jusqu'où ces racines ont-elles voyagé? Et à quelle plante appartiennent-elles?",
      "novakidDescription": "C'est juste des racines."
    }
  },
