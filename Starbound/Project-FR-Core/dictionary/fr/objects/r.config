  "redball": {
    "name": "Boule de Noël Rouge",
    "desc": "Une boule rouge ornée d'une grande étoile blanche! Très populaire comme décoration de fête.",
    "metadata": {
      "apexDescription": "Une boule rouge brillante. Jolie.",
      "avianDescription": "Une majestueuse boule rouge.",
      "floranDescription": "Floran frappe dans la boule brillante!",
      "glitchDescription": "Heureux. Une ravissante décoration.",
      "humanDescription": "Faut faire attention à ne pas fracasser cette boule.",
      "hylotlDescription": "Il y a quelque chose d'hypnotisant dans cette boule brillante.",
      "novakidDescription": "Une jolie boule rouge, parfaite pour la déco."
    }
  },
  "redcandycane1": {
    "name": "Sucre d'Orge Rouge",
    "desc": "Un sucre d'orge décoratif rouge.",
    "metadata": {
      "apexDescription": "Je suis tenté de le manger. Est-ce un vrai?",
      "avianDescription": "Ça a l'air assez bon pour être mangé!",
      "floranDescription": "Trop douxss.",
      "glitchDescription": "Affamé. Je parierais que ce sucre d'orge a un goût de menthe poivrée.",
      "humanDescription": "On dirait un vrai sucre d'orge. Est-ce que je devrais essayer de le manger?",
      "hylotlDescription": "Des bonbons comme décoration? Je n'ai jamais entendu parler d'une telle chose.",
      "novakidDescription": "J'ai jamais entendu parler d'utiliser des bonbons pour décorer."
    }
  },
  "redcandycane2": {
    "name": "Sucre d'Orge Tordu",
    "desc": "Un sucre d'orge décoratif rouge. Il est tout de travers.",
    "metadata": {
      "apexDescription": "Je suis tenté de le manger. Est-ce un vrai?",
      "avianDescription": "Ça a l'air assez bon pour être mangé!",
      "floranDescription": "Trop douxss.",
      "glitchDescription": "Affamé. Je parierais que ce sucre d'orge a un goût de menthe poivrée.",
      "humanDescription": "On dirait un vrai sucre d'orge. Est-ce que je devrais essayer de le manger?",
      "hylotlDescription": "Des bonbons comme décoration? Je n'ai jamais entendu parler d'une telle chose.",
      "novakidDescription": "Décorer avec des sucreries... drôle d'idée."
    }
  },
  "redcandycane3": {
    "name": "Sucre d'Orge Cassé",
    "desc": "Un sucre d'orge décoratif rouge. Il est brisé.",
    "metadata": {
      "apexDescription": "Je suis tenté de le manger. Est-ce un vrai?",
      "avianDescription": "Ça a l'air assez bon pour être mangé!",
