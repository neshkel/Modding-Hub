  "reedshelf": {
    "name": "Étagère en Roseau",
    "desc": "Une étagère en roseau.",
    "metadata": {
      "apexDescription": "Une bibliothèque. Il n'y a pas grand-chose ici, à part quelques livres de développement personnel.",
      "avianDescription": "C'est une bibliothèque. Il y a un livre ici sur la gestion du stress.",
      "floranDescription": "Livress sur le soin de 'soi'. Floran prend déjà bien sssin de soi.",
      "glitchDescription": "Curieux. Il y a plusieurs livres ici concernant le bien-être. L'un d'eux n'est rempli que d'images de petits animaux.",
      "humanDescription": "Il y a un livre appelé 'Réflexions en temps de crise'. Je vais le laisser, quelqu'un d'autre en aura peut-être besoin.",
      "hylotlDescription": "Il y a un livre de méditation ici. C'est bien de méditer régulièrement, ça libère l'esprit.",
      "novakidDescription": "J'suis pas un grand fan des bouquins. Je préfère l'expérience du terrain."
    }
  },
  "rainbowbed": {
    "name": "Lit Arc-en-ciel",
    "desc": "Un lit arc-en-ciel. Coloré et confortable.",
    "metadata": {
      "apexDescription": "Un lit arc-en-ciel joyeux. Je l'adore.",
      "avianDescription": "Rien que de regarder ce lit me détend.",
      "floranDescription": "Floran essst hypnotisssé par les couleurs vives. Sssommeil.",
      "glitchDescription": "Heureux. Ce lit améliore considérablement mon humeur.",
      "humanDescription": "Un magnifique lit coloré. J'ai hâte de dormir ici.",
      "hylotlDescription": "Cette myriade de couleurs chatoyantes me rappelle la vie sous l'océan.",
      "novakidDescription": "Ce lit est sacrément coloré."
    }
  },
  "rainbowchair": {
    "name": "Chaise Arc-en-ciel",
    "desc": "Une chaise arc-en-ciel glorieusement colorée.",
    "metadata": {
      "apexDescription": "Cette chaise est extrêmement revigorante.",
      "avianDescription": "Une chaise d'une couleur à couper le souffle.",
      "floranDescription": "Floran adore la jolie chaisse.",
      "glitchDescription": "Émotif. Cette chaise me remplit de la joie de vivre.",
      "humanDescription": "Quelle chaise géniale!",
      "hylotlDescription": "Un meuble qui apporte une telle joie vaut vraiment l'effort qu'il faut pour le produire.",
      "novakidDescription": "Si je m'assois sur cette chaise, est-ce que je vais changer de couleur?"
    }
  },
  "rainbowchest": {
    "name": "Coffre Arc-en-ciel",
    "desc": "Un coffre décoré de magnifiques motifs arc-en-ciel.",
    "metadata": {
      "apexDescription": "Un coffre arc-en-ciel. Le contenu est sûrement agréable.",
      "avianDescription": "Un coffre coloré. J'ai hâte de voir ce qu'il y a dedans.",
      "floranDescription": "Floran doit voir ce qu'il y a dansss le joli coffrre.",
      "glitchDescription": "Ravi. Un beau coffre contient sans aucun doute de beaux objets.",
      "humanDescription": "J'espère qu'il y a un pot d'or à l'intérieur.",
      "hylotlDescription": "Une si belle méthode de stockage.",
      "novakidDescription": "Est-ce que c'est le coffre au bout de l'arc-en-ciel?"
    }
  },
  "rainbowdoor": {
    "name": "Porte Arc-en-ciel",
    "desc": "Une porte arc-en-ciel accueillante.",
    "metadata": {
      "apexDescription": "Une porte aux couleurs de l'arc-en-ciel. Le simple fait de passer par ici me remonte le moral.",
      "avianDescription": "Une porte extrêmement engageante.",
      "floranDescription": "Floran parrt d'un passs léger en passsant la porte.",
      "glitchDescription": "Submergé. Je suis rempli d'excitation à l'idée de voir ce qui se cache derrière cette porte.",
      "humanDescription": "Cette porte ne demande qu'à être ouverte.",
      "hylotlDescription": "Quelle porte incroyablement accueillante.",
      "novakidDescription": "Je me demande ce qui peut bien se trouver derrière une porte aussi colorée?"
    }
  },
  "rainbowtable": {
    "name": "Table Arc-en-ciel",
    "desc": "Une table arc-en-ciel fait de chaque repas une joie.",
    "metadata": {
      "apexDescription": "S'asseoir ici pour manger fera de chaque repas une véritable expérience.",
      "avianDescription": "Une superbe table arc-en-ciel, aussi brillante qu'un paon!",
      "floranDescription": "Floran ne va même passss tacher cette jolie table avec du ssang.",
      "glitchDescription": "Désir. S'asseoir et manger à cette table remontera considérablement mon moral.",
      "humanDescription": "J'ai hâte de manger à cette table.",
      "hylotlDescription": "Une magnifique table colorée.",
      "novakidDescription": "Toutes ces couleurs finiront par vous rendre barjot."
    }
  },
  "rainbowpainting": {
    "name": "Tableau Arc-en-ciel",
    "desc": "Une peinture de deux arcs-en-ciel. Un double arc-en-ciel.",
    "metadata": {
      "apexDescription": "Cette peinture... si intense...",
      "avianDescription": "Une peinture de deux arcs-en-ciel. Qu'est-ce que cela signifie?",
      "floranDescription": "Floran aime les couleurss vives et éclatantess.",
      "glitchDescription": "Submergé. Ce tableau de double arc-en-ciel est d'une grande beauté.",
      "humanDescription": "Waouh, waouh, oh mon dieu. Regardez cette peinture d'arc-en-ciel.",
      "hylotlDescription": "Un double arc-en-ciel peint, c'est tellement beau.",
      "novakidDescription": "Une peinture avec des traînées de lumière flashy."
    }
  },
  "rainbowunicornstatue": {
    "name": "Statue de Licorne Arc-en-ciel",
    "desc": "Une superbe statue de licorne. Attention à la corne!",
    "metadata": {
      "apexDescription": "Cette bête majestueuse me coupe le souffle.",
      "avianDescription": "Un superbe destrier blanc avec une glorieuse corne de nacre.",
      "floranDescription": "Même Floran ne va passss poignarder ce poney.",
      "glitchDescription": "Étonnement. Une statue de licorne. Comme j'aimerais voir cette créature en chair et en os.",
      "humanDescription": "Une statue de licorne. J'ai toujours voulu une licorne domestique.",
      "hylotlDescription": "Cette créature remarquable me rappelle les baleines à corne que l'on voit sous l'océan.",
      "novakidDescription": "À part la corne, c'est un sacré beau cheval."
    }
  },
  "reddangersign": {
    "name": "Panneau de Danger Rouge",
    "desc": "Un panneau où il est écrit \"Danger!\". Le message ne pourrait pas être plus clair.",
    "metadata": {
      "apexDescription": "Peu de choses dans la vie d'un Apex ne sont pas dangereuses.",
      "avianDescription": "Pourquoi les Apex ont-ils besoin de signaler le danger aussi clairement?",
      "floranDescription": "Floran vit et resssspire le danger.",
      "glitchDescription": "Pessimiste. Visiblement, il n'y a pas de quoi s'inquiéter alors.",
      "humanDescription": "Un peu de danger n'a jamais tué personne.",
      "hylotlDescription": "Nous devons avancer avec prudence.",
      "novakidDescription": "Le danger, c'est mon deuxième prénom."
    }
  },
  "redflask": {
    "name": "Flacon Rouge",
    "desc": "Un flacon rempli d'un liquide rouge.",
    "metadata": {
      "apexDescription": "Cette mixture a une odeur sucrée.",
      "avianDescription": "Ce mélange sent délicieusement bon, mais l'odeur seule ne me tentera pas.",
      "floranDescription": "Liquide à l'odeur sssucrée. Floran préfère la nourriture sssalée.",
      "glitchDescription": "Sceptique. Je ne détecte aucun ingrédient actif. C'est peut-être un placebo.",
      "humanDescription": "Ça sent le cola à l'orange.",
      "hylotlDescription": "Une odeur si douce, c'est enivrant.",
      "novakidDescription": "Goût rouge."
    }
  },
  "returnconsole": {
    "name": "Console Antique",
    "desc": "Cela ressemble au panneau de commande de la porte. Il semble encore fonctionner.",
    "metadata": {
      "apexDescription": "Une pièce technologique extrêmement ancienne.",
      "avianDescription": "Cette console doit être aussi vieille que la porte elle-même. C'est dire!",
      "floranDescription": "Commandesss anciennes pour la porte ancienne.",
      "glitchDescription": "Impressionné. Le panneau de commande de la porte, il a l'air vraiment très vieux.",
      "humanDescription": "Le panneau de commande de la porte. Il doit être aussi vieux que la porte.",
      "hylotlDescription": "La console de la porte. Comme la porte elle-même, c'est un mystère.",
      "novakidDescription": "Voyons si j'peux pas faire marcher ce vieux Rossinante."
    }
  },
  "ringramaf": {
    "name": "Figurine de Ringram",
    "desc": "L'étiquette indique: \"Les cornes du Ringram commencent à pousser dès la naissance et ne s'arrêtent jamais.\""
  }
