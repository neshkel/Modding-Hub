  },
  "royalbed": {
    "name": "Lit Royal Orné",
    "desc": "Un magnifique lit fait d'or brillant.",
    "metadata": {
      "apexDescription": "Un lit de soie et d'or. Digne d'un roi.",
      "avianDescription": "Un lit forgé dans des métaux précieux. Qui peut bien dormir au milieu de matériaux si rares?",
      "floranDescription": "Floran veut esssayer le lit qui brille.",
      "glitchDescription": "Identifier. Un lit construit pour la royauté.",
      "humanDescription": "Je soupçonne que cela a été construit pour un monarque.",
      "hylotlDescription": "Un roi a-t-il besoin de tant de splendeur? Cela fait-il de lui un meilleur roi?",
      "novakidDescription": "C'est un sacré lit, presque digne d'un roi!"
    }
  },
  "royalbookcase": {
    "name": "Bibliothèque Royale",
    "desc": "Une bibliothèque de monarque... voyons ce que la royauté lit.",
    "metadata": {
      "apexDescription": "Une bibliothèque décorée de feuilles d'or.",
      "avianDescription": "Une bibliothèque dorée. Les Avians pensent que seul Kluex est digne d'une telle splendeur.",
      "floranDescription": "Bibliothèque qui brille. Est-sse qu'elle contient autre chose que des livres?",
      "glitchDescription": "Observateur. De nombreux membres de la royauté savent lire et écrire.",
      "humanDescription": "Une bibliothèque en or. Peut-être que les rois sont de fervents lecteurs.",
      "hylotlDescription": "Quel genre de roi s'entoure de telles richesses pendant que les paysans meurent de faim?",
      "novakidDescription": "Sûrement que les rois n'ont pas beaucoup de temps pour la lecture?"
    }
  },
  "royalcabinet": {
    "name": "Cabinet Royal",
    "desc": "Les objets de valeur devraient être rangés ici.",
    "metadata": {
      "apexDescription": "Un cabinet royal. Le contenu peut-il vraiment égaler la valeur du meuble?",
      "avianDescription": "J'ai hâte de jeter un œil à l'intérieur d'un meuble aussi précieux.",
      "floranDescription": "Boîte qui brille, qu'est-sse qu'il y a dedans!",
      "glitchDescription": "Pensif. Bien que la valeur du cabinet soit élevée, il est peu probable qu'il abrite quoi que ce soit de spécial.",
      "humanDescription": "Un cabinet en or. J'ai hâte de voir ce qu'il y a là-dedans.",
      "hylotlDescription": "Regardons à l'intérieur. Peut-être y a-t-il quelque chose d'utile au milieu de tout cet or gaspillé.",
      "novakidDescription": "Un truc aussi chic doit forcément contenir un bon butin!"
    }
  },
  "royalcandles": {
    "name": "Bougies Royales",
    "desc": "Une lueur royale.",
    "metadata": {
      "apexDescription": "Un chandelier en or massif.",
      "avianDescription": "Un tel métal semble gaspillé pour un simple chandelier.",
      "floranDescription": "Pourquoi l'homme de métal met du feu ssir un bâton doré? Hsss.",
      "glitchDescription": "Sympathique. Un chandelier en or massif. Un serviteur s'assurerait qu'ils soient tous allumés avant l'arrivée de la royauté.",
      "humanDescription": "Ce chandelier doit valoir une petite fortune.",
      "hylotlDescription": "Quel gaspillage. Du fer suffirait ici, tandis que l'or pourrait remplir bien des ventres vides.",
      "novakidDescription": "Je plains le gars qui doit garder tous ces chandeliers allumés."
    }
  },
  "royalchalice": {
    "name": "Calice Royal",
    "desc": "Un calice royal, pour remplir une bouche royale de boissons royales.",
    "metadata": {
      "apexDescription": "Un calice en or. Il y a une goutte de liquide au fond.",
      "avianDescription": "Une lourde coupe en or.",
      "floranDescription": "Floran fabrique des calicess avec des os pour ajouter du goût.",
      "glitchDescription": "Envieux. Un calice en or massif. La royauté dîne dans le luxe.",
      "humanDescription": "Un calice en or brillant. Il vaut probablement très cher.",
      "hylotlDescription": "Une extravagance inutile.",
      "novakidDescription": "L'or c'est fait pour être dépenssé, pas pour boire dedans."
    }
  },
  "royalchest": {
    "name": "Coffre Royal",
    "desc": "Ce coffre est un trésor en soi, sans même parler de son contenu.",
    "metadata": {
      "apexDescription": "Le coffre lui-même a probablement une grande valeur.",
      "avianDescription": "Un coffre exquis fait de bois et d'or.",
      "floranDescription": "Floran veut regarder à l'intérieur du coffre qui brille.",
      "glitchDescription": "Observateur. Bien que les chambres royales soient bien gardées, il semble que la noblesse prenne toutes les précautions avec ses objets de valeur.",
      "humanDescription": "Un coffre bordé d'or.",
      "hylotlDescription": "L'or ne rend pas le coffre plus sûr.",
      "novakidDescription": "Mettre de l'or sur un coffre, ça casse un peu le principe de la sécurité."
    }
  },
  "royaldesk": {
    "name": "Bureau Royal",
    "desc": "Un bureau royal très chic.",
    "metadata": {
      "apexDescription": "Peut-être que ce bureau contient quelque chose d'intéressant.",
      "avianDescription": "Un bureau d'où un Roi gouverne son royaume.",
      "floranDescription": "Bureau qui brille pour homme de métal important.",
      "glitchDescription": "Observer. Un secrétaire. Généralement utilisé par le page du Roi.",
      "humanDescription": "On dirait un secrétaire, mais il n'y a pas une seule tache d'encre à sa surface.",
      "hylotlDescription": "L'or est un ajout superflu à ce bureau.",
      "novakidDescription": "Je suis pas sûr que ce bureau sserve vraiment au travail d'un roi."
    }
  },
  "royalthrone": {
    "name": "Trône Royal",
    "desc": "Un trône digne d'un fessier royal.",
    "metadata": {
      "apexDescription": "Un grand trône en or.",
      "avianDescription": "La royauté semble aimer s'entourer d'or.",
      "floranDescription": "Chaise en métal qui brille.",
      "glitchDescription": "Impressionné. Un trône comme celui-ci est assurément digne de la royauté.",
      "humanDescription": "Un trône royal. Magnifiquement ouvré à partir d'or et de satin.",
      "hylotlDescription": "Le point central d'une opulence pompeuse.",
      "novakidDescription": "Pour le coup, ce trône en jette un max!"
    }
  },
  "royaltoilet": {
    "name": "Toilettes Royales",
    "desc": "... Un autre trône.",
    "metadata": {
      "apexDescription": "Des toilettes en or sont-elles vraiment nécessaires?",
      "avianDescription": "Une approche luxueuse du passage aux toilettes.",
      "floranDescription": "Bol d'eau en or qui brille.",
      "glitchDescription": "Critique. Un gaspillage de richesse.",
      "humanDescription": "Des toilettes en or, ça semble un peu excessif.",
      "hylotlDescription": "Un terrible étalage de gaspillage.",
      "novakidDescription": "Des toilettes en or, ça me semble être un sacré gâchis de butin."
    }
  },
  "randomfountain": {
    "name": "Fontaine Aléatoire",
    "desc": "Une fontaine aléatoire. La plus imprévisible des fontaines.",
    "metadata": {
      "apexDescription": "Une fontaine!",
      "avianDescription": "Une fontaine.",
      "floranDescription": "Floran boit dans le truc qui éclabousse.",
      "glitchDescription": "Hésitant. Une fontaine.",
      "humanDescription": "J'aimerais avoir du liquide vaisselle pour en verser dedans.",
      "hylotlDescription": "Une ravissante fontaine."
    }
  },
  "recreationalvehicle": {
    "name": "Camping-car",
    "desc": "Un vieux véhicule rouillé, cassé au-delà de toute réparation.",
    "metadata": {
      "apexDescription": "Une vieille machine, autrefois à la mode, aujourd'hui brisée.",
      "avianDescription": "Comme cette machine manque d'élégance.",
      "floranDescription": "Ssent bizarre.",
      "glitchDescription": "Désintéressé. Vieille machine de voyage cassée.",
      "humanDescription": "Un ancien véhicule en panne, c'est pratiquement de la ferraille.",
      "hylotlDescription": "Une vieille machine de transport terrestre, en panne depuis longtemps.",
      "novakidDescription": "C'est comme un cheval et une calèche, sans le cheval. Ni la calèche."
    }
  },
  "redalert": {
    "name": "Lumière d'Avertissement",
    "desc": "Une lumière rouge clignotante... En général, c'est mauvais signe.",
    "metadata": {
      "apexDescription": "Cela ressemble à un signal d'alarme ou d'avertissement.",
      "avianDescription": "Est-ce que c'est moi qui ai déclenché cette alarme?",
      "floranDescription": "La lumière qui clignote amusssse Floran.",
      "glitchDescription": "Inquiet. Une lumière rouge clignotante est un avertissement ou une alarme dans un million de cultures différentes.",
      "humanDescription": "Oh oh, qu'est-ce que ça veut dire?",
      "hylotlDescription": "Cette alarme est un terrible présage.",
      "novakidDescription": "Quel vacarme fait ce truc!"
    }
  },
  "rusticoven": {
    "name": "Four Rustique",
    "desc": "Il crépite doucement, l'odeur de fumée de hickory est un pur délice.",
    "metadata": {
      "subtitle": "Cuisine au feu de bois.",
      "interactData.paneLayoutOverride.windowtitle.title": " Four Rustique",
      "interactData.paneLayoutOverride.windowtitle.subtitle": " Cuisine au feu de bois",
      "apexDescription": "Un charmant petit four.",
      "avianDescription": "Les Cloués adorent cuisiner sur de petits fours comme celui-ci.",
      "floranDescription": "Le four en pierrre cuit bien la viande.",
      "glitchDescription": "Informatif. Les briques réfléchissent la chaleur, permettant une cuisson rapide et uniforme.",
      "humanDescription": "Un four adorable.",
      "hylotlDescription": "Tant de charme.",
      "novakidDescription": "Si c'est pas le plus mignon petit four que j'aie jamais vu!"
    }
  },
  "reefpodseed": {
    "name": "Graine de Reefpod",
    "desc": "Le reefpod a le goût d'un smoothie croquant avec un ajout d'eau de mer.",
    "metadata": {
      "apexDescription": "Les reefpods ont un goût sucré et salé. Inhabituel mais pas désagréable.",
      "avianDescription": "Délicieusement savoureux.",
      "floranDescription": "A le goût des hommess-poissons.",
      "glitchDescription": "Confus. Le reefpod est certainement inhabituel. Comment un fruit peut-il avoir un goût salé?",
      "humanDescription": "Un reefpod est sucré, salé et croquant. Ça me rappelle le pop-corn.",
      "hylotlDescription": "Un reefpod a juste le bon niveau de sucre pour les papilles Hylotl.",
      "novakidDescription": "Est-ce que c'est salé ou sucré? J'en ai aucune idée."
    }
  },
  "riceseed": {
    "name": "Graine de Riz",
    "desc": "Bouillez-le, friez-le, jetez-le sur une mariée. Le riz! Pour tous vos besoins culinaires.",
    "metadata": {
      "apexDescription": "Du riz. Un excellent accompagnement pour n'importe quel repas.",
      "avianDescription": "Du riz, un délicieux en-cas à picorer.",
      "floranDescription": "Floran prépare le riz comme accompagnement pour des cœursss bouillis.",
      "glitchDescription": "Amusé. Un Glitch a un jour mangé du riz cru et a lancé une carrière réussie en tant qu'instrument de percussion.",
      "humanDescription": "Du riz. C'est bien quand on a faim et qu'on veut manger des milliers d'un même truc.",
      "hylotlDescription": "Du riz. Un goût fade, mais utile. Une base simple pour un repas.",
      "novakidDescription": "Le riz, c'est pas mal de temps en temps. Parfait avec du piment!"
    }
  },
  "robothenegg": {
    "name": "Œuf de Poule Robot",
    "desc": "Donne naissance à un poussin robot qui devient une poule robot. La poule adulte pond des piles AA.",
    "metadata": {
      "apexDescription": "Il y a une poule robot à l'intérieur de cet œuf.",
      "avianDescription": "C'est un œuf de poule robot. Quand le poussin aura grandi, il pondra des piles AA.",
      "floranDescription": "Floran ne peut pas manger d'œuf de poule robot... Floran ne peut pas manger de poule robot... Floran est déçssu.",
      "glitchDescription": "Appréciatif. Un œuf de poule robot!",
      "humanDescription": "C'est un œuf de poule robot! Je crois que les poussins robots sont encore plus mignons que les vrais.",
      "hylotlDescription": "Un œuf de poule robot. La poule adulte pondra des piles AA.",
      "novakidDescription": "Cet œuf cache un p'tit poussin de fer."
    }
  },
  "railcraftingtable": {
    "name": "^orange;Table de Fabrication de Rails^white;",
    "desc": "Utilisée pour produire des rails, des objets de transport ferroviaire et autres objets liés.",
    "metadata": {
      "interactData.paneLayoutOverride.windowtitle.title": "Table de Fabrication de Rails",
      "interactData.paneLayoutOverride.windowtitle.subtitle": "Prenez le Rail!",
      "apexDescription": "Je peux utiliser cette station pour construire des rails afin de me déplacer facilement.",
      "avianDescription": "Cette table me permettra de construire des rails sur lesquels je pourrai voyager.",
      "floranDescription": "Cessette table fabrique des rails brillants pour voyager vite.",
      "glitchDescription": "Ravi. Les rails fabriqués ici rendront les déplacements bien plus efficaces.",
      "humanDescription": "Je peux fabriquer des rails ici! Parfait pour se déplacer. Et faire des tours, et des tours.",
      "hylotlDescription": "Les rails que je peux construire ici sont peut-être primitifs, mais leur efficacité est indiscutable.",
      "novakidDescription": "Voyager sur les rails... ça marche toujours aussi bien pour se balader."
    }
  },
  "refinery": {
    "name": "^orange;Raffinerie^white;",
    "desc": "La raffinerie est utilisée pour produire des pixels bruts à partir de minerais.",
    "metadata": {
      "subtitle": "Transformez les minerais en pixels",
      "apexDescription": "Je peux mettre du minerai ici pour fabriquer des pixels.",
      "avianDescription": "Fabriquer des pixels avec du minerai. Très utile.",
      "floranDescription": "La machine écrassse les cailloux, fait de l'argent.",
      "glitchDescription": "Neutre. Le minerai peut être converti en pixels ici.",
      "humanDescription": "Elle imprime de l'argent! Enfin, en quelque sorte...",
      "hylotlDescription": "Un appareil complexe pour transformer le minerai en pixels.",
      "novakidDescription": "Une machine à pixels. J'en ai toujours voulu une!"
    }
  },
  "redwing": {
    "name": "Redwing",
    "desc": "À ne pas confondre avec l'infâme Dreadwing."
  },
  "rightorgans": {
    "name": "Organes Droits",
    "desc": "Organes de la Ruine."
  },
