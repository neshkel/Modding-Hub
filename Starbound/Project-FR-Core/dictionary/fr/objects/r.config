      "novakidDescription": "Même cassé, ça reste un bonbon."
    }
  },
  "redgumdrop1": {
    "name": "Grosse Gomme Rouge",
    "desc": "Une grosse et délicieuse gomme rouge! Miam!",
    "metadata": {
      "apexDescription": "Une savoureuse gomme rouge.",
      "avianDescription": "Une grosse gomme rouge. Appétissant.",
      "floranDescription": "Floran mange la grosse sucrerie rougge!",
      "glitchDescription": "Déclaration. Une savoureuse gomme rouge.",
      "humanDescription": "Des bonbons! Oui!",
      "hylotlDescription": "Ça a l'air bon.",
      "novakidDescription": "Une gomme qui a l'air appétissante."
    }
  },
  "redgumdrop2": {
    "name": "Gomme Rouge Géante",
    "desc": "Une géante et délicieuse gomme rouge! Miam!",
    "metadata": {
      "apexDescription": "Une savoureuse gomme rouge.",
      "avianDescription": "Une grosse gomme rouge. Appétissant.",
      "floranDescription": "Floran mange la grosse sucrerie rougge!",
