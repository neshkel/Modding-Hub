  "rustbed": {
    "name": "Lit Rouillé",
    "desc": "Un lit rouillé. Il a l'air bon marché et fragile.",
    "metadata": {
      "apexDescription": "Un lit rouillé bas de gamme. Ça me rappelle les cellules du Miniknog.",
      "avianDescription": "Un vieux lit négligé. Il commence à rouiller.",
      "floranDescription": "Floran ne veut pass dormir dans un lit qui gratte.",
      "glitchDescription": "Paranoïaque. L'odeur de la rouille va me donner des cauchemars.",
      "humanDescription": "Un vieux lit rouillé. Rien de remarquable.",
      "hylotlDescription": "Un lit rudimentaire. Il tombe pratiquement en morceaux.",
      "novakidDescription": "Ce lit est sur le point de tomber en ruine."
    }
  },
  "rustbush1": {
    "name": "Buisson de Rouille",
    "desc": "Un amas de métal oxydé. Attention aux bords tranchants.",
    "metadata": {
      "apexDescription": "Ce débris a rouillé il y a bien longtemps.",
      "avianDescription": "Un morceau de vieux métal rouillé abandonné.",
      "floranDescription": "Floran pourrait utilissser le métal comme arme.",
      "glitchDescription": "Nerveux. La vue de la rouille me fait défaillir.",
      "humanDescription": "On dirait un morceau de métal rouillé. Est-ce que la nature a créé ça? Comment est-ce possible?",
      "hylotlDescription": "C'est simplement un morceau de métal rouillé et déplaisant.",
      "novakidDescription": "Je suis sûr qu'on pourrait tirer quelque chose de ce vieux métal s'il était nettoyé."
    }
  },
  "rustbush2": {
    "name": "Buisson de Rouille",
