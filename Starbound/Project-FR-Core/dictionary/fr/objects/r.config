  "rustchair": {
    "name": "Chaise Rouillée",
    "desc": "Une chaise rouillée. Ne vous balancez pas dessus.",
    "metadata": {
      "apexDescription": "Cette chaise a connu des jours meilleurs.",
      "avianDescription": "Une vieille chaise toute rouillée.",
      "floranDescription": "Floran lèche la chaisse. La chaisse n'a passs bon goût.",
      "glitchDescription": "Frissonnant. S'asseoir ici serait une torture.",
      "humanDescription": "Une chaise rouillée. Je vais finir avec le tétanos.",
      "hylotlDescription": "Cette chaise a fait son temps."
    }
  },
  "rustchest": {
    "name": "Coffre Rouillé",
    "desc": "Un coffre rouillé. Il tombe presque en morceaux.",
    "metadata": {
      "apexDescription": "Ce coffre ne semble pas très solide.",
      "avianDescription": "On pourrait sans doute simplement attendre que ce coffre tombe en ruine de lui-même.",
      "floranDescription": "Floran ouvre le vilain coffrre.",
      "glitchDescription": "Sardonique. La rouille ici est peut-être un meilleur moyen de dissuasion pour un Glitch qu'une serrure ne pourrait jamais l'être.",
      "humanDescription": "Un coffre rouillé. Peut-être que des pirates l'ont laissé ici.",
      "hylotlDescription": "Un vieux coffre qui s'effrite."
    }
  },
  "rustdoor": {
    "name": "Porte Rouillée",
    "desc": "Une porte rouillée. On dirait qu'elle mène à une cave effrayante.",
    "metadata": {
      "apexDescription": "Une porte rouillée et sinistre.",
      "avianDescription": "Une porte comme celle-ci ne pourrait jamais mener à un endroit remarquable.",
      "floranDescription": "Pour une fois, Floran n'a rien d'intelligent à ddire.",
      "glitchDescription": "Dégoûté. Une porte rouillée.",
      "humanDescription": "Une porte rouillée.",
      "hylotlDescription": "Cette porte n'a pas été bien entretenue."
    }
  },
  "rusttable": {
    "name": "Table Rouillée",
    "desc": "Une table rouillée. Ça ajoute du goût.",
    "metadata": {
      "apexDescription": "Une vieille table rouillée.",
      "avianDescription": "Cette table semble être en fin de vie.",
      "floranDescription": "Table rouge, avec de la rouillle, pas du sang.",
      "glitchDescription": "Agacé. La rouille m'a fait perdre l'appétit.",
      "humanDescription": "Cette table n'a pas l'air très hygiénique.",
      "hylotlDescription": "Une table rouillée et délaissée."
    }
  },
  "rainbowwoodbed": {
    "name": "Lit en Bois Arc-en-ciel",
    "desc": "Un lit fait de bois arc-en-ciel.",
    "metadata": {
      "apexDescription": "Ce lit ne convient que pour une chambre d'enfant.",
      "avianDescription": "Un lit avec un arc-en-ciel dessus! Conçu pour inspirer de beaux rêves.",
      "floranDescription": "Le lit essst brillant et coloré.",
      "glitchDescription": "Amusé. Ce lit a un attrait enfantin.",
      "humanDescription": "Se réveiller sous un arc-en-ciel serait amusant, je pense.",
      "hylotlDescription": "Notre enfant intérieur a tendance à refaire surface face aux arcs-en-ciel.",
      "novakidDescription": "Dormir sous un arc-en-ciel vous portera forcément chance."
    }
  },
  "rainbowwoodchair": {
    "name": "Chaise en Bois Arc-en-ciel",
    "desc": "Une chaise faite de bois arc-en-ciel.",
    "metadata": {
      "apexDescription": "Une chaise en bois arc-en-ciel, adaptée pour un enfant.",
      "avianDescription": "Une magnifique chaise arc-en-ciel.",
      "floranDescription": "La chaisse essst colorée, comme Floran!",
      "glitchDescription": "Satisfait. Cette chaise contient la quantité correcte de couleurs.",
      "humanDescription": "Une chaise au look sympa.",
      "hylotlDescription": "Une chaise en bois arc-en-ciel. Remplie d'ondes positives, parfaite pour la méditation.",
      "novakidDescription": "Une chaise en bois arc-en-ciel? Ça semble être un endroit aussi bon qu'un autre pour s'asseoir."
    }
  },
  "rainbowwooddoor": {
    "name": "Porte en Bois Arc-en-ciel",
    "desc": "Une porte faite de bois arc-en-ciel.",
    "metadata": {
      "apexDescription": "C'est une porte faite de bois arc-en-ciel.",
      "avianDescription": "Une porte avec un arc-en-ciel imprimé dessus. Je doute qu'elle mène à l'un d'entre eux.",
      "floranDescription": "La porrte a une image colorée dessus.",
      "glitchDescription": "Observateur. C'est une porte aux couleurs vives.",
      "humanDescription": "Une porte arc-en-ciel.",
      "hylotlDescription": "Quelle porte à l'air joyeux.",
      "novakidDescription": "Cette porte est vraiment accueillante."
    }
  },
  "rainbowwoodsafe": {
    "name": "Coffre en Bois Arc-en-ciel",
    "desc": "Un coffre fait de bois arc-en-ciel.",
    "metadata": {
      "apexDescription": "Un coffre rouge vif pour ranger ses affaires.",
      "avianDescription": "Ce coffre est très rouge. Il semble réclamer l'attention.",
      "floranDescription": "Floran veut regarder à l'intérieur du coffrre rouge.",
      "glitchDescription": "Curieux. Que pourrait bien contenir un coffre aussi coloré?",
      "humanDescription": "Ce coffre rouge a l'air alarmant... ou excitant?",
      "hylotlDescription": "Un coffre bien conçu fait d'un bois coloré.",
      "novakidDescription": "Ce coffre en bois a l'air amusant."
    }
  },
  "rainbowwoodtable": {
    "name": "Table en Bois Arc-en-ciel",
    "desc": "Une table faite de bois arc-en-ciel.",
    "metadata": {
      "apexDescription": "Le genre de table où l'on s'assiérait pour écrire de la poésie fantaisiste.",
      "avianDescription": "Cette table met bien en valeur le grain de bois arc-en-ciel.",
      "floranDescription": "Floran aime compter les rayuresss dans le bois.",
      "glitchDescription": "Enchanté. Regardez ces rayures colorées!",
      "humanDescription": "Ce bois est superbe, quelle que soit sa forme.",
      "hylotlDescription": "Posséder une table comme celle-ci égayerait la journée de n'importe qui.",
      "novakidDescription": "Cette table donnerait à quiconque une vision plus joyeuse de la vie."
    }
  },
  "reedbed": {
    "name": "Lit en Roseau",
    "desc": "Un lit fait de bois et de roseaux.",
    "metadata": {
      "apexDescription": "J'ai certainement vu des lits plus fonctionnels, mais celui-ci fera l'affaire pour se reposer.",
      "avianDescription": "Je suppose que se reposer ici est censé me donner l'impression d'être dans une jungle dense.",
      "floranDescription": "Dormir ici fait rêver Floran de la chassse.",
      "glitchDescription": "Observateur. C'est un lit fait de bois et de roseaux. Il semble raisonnablement confortable.",
      "humanDescription": "C'est un lit sur le thème de la jungle. Ou... est-il vraiment fait de bois et de roseaux?",
      "hylotlDescription": "Se reposer ici pourrait faire rêver d'aventures dans la jungle.",
      "novakidDescription": "Je ne suis pas sûr de ce que je suis censé retirer d'un sommeil dans un lit en roseaux."
    }
  },
  "reedchair": {
    "name": "Chaise en Roseau",
    "desc": "Une chaise faite de bois et de roseaux.",
    "metadata": {
      "apexDescription": "Une chaise digne du roi de la jungle.",
      "avianDescription": "Cette chaise ressemble à une sorte de trône de la jungle.",
      "floranDescription": "Cette chaisse fait un excellent trône pour Floran.",
      "glitchDescription": "Impressionné. Les roseaux constituent une solution d'assise créative en cas de besoin.",
      "humanDescription": "Ce n'est pas une chaise très confortable, mais elle a l'air cool.",
      "hylotlDescription": "Cette chaise est charmante, conceptuellement, mais un peu peu pratique.",
      "novakidDescription": "C'est une chaise fabriquée avec du bois et des roseaux. Plutôt chic."
    }
  },
  "reedchest": {
    "name": "Coffre en Roseau",
    "desc": "Des roseaux façonnés en coffre.",
    "metadata": {
      "apexDescription": "J'admire la créativité ici.",
      "avianDescription": "Un coffre digne d'un nid. Ça fait frémir mes plumes.",
      "floranDescription": "Floran connaît bien les coffrress comme celui-ci.",
      "glitchDescription": "Analytique. La résistance à la traction de ces roseaux en fait un mauvais matériau pour construire un coffre.",
      "humanDescription": "Il y a un beau travail de tissage ici.",
      "hylotlDescription": "Les roseaux sont en abondance chez les Hylotl.",
      "novakidDescription": "Il faut un sacré talent de tissage pour faire un coffre avec des roseaux."
    }
  },
  "reedclock": {
    "name": "Horloge Murale en Roseau",
    "desc": "Une horloge en roseau avec un tic-tac creux.",
    "metadata": {
      "apexDescription": "Le tic-tac de l'horloge est apaisant.",
      "avianDescription": "Ce tic-tac incessant m'ébouriffe vraiment les plumes.",
      "floranDescription": "L'horloge en roseau a un tic-tac apaisssant.",
      "glitchDescription": "Irrité. Le tic-tac ne s'arrête jamais.",
      "humanDescription": "Une horloge mignonne, dommage pour le tic-tac monotone.",
      "hylotlDescription": "Un tic-tac monotone et apaisant.",
      "novakidDescription": "Un bruit pareil, ça rendrait n'importe qui zinzin."
    }
  },
  "reeddesk": {
