{
  "uranusmodel": {
    "name": "Modèle d'Uranus",
    "desc": "Un modèle détaillé de la planète Uranus du système Sol.",
    "metadata": {
      "apexDescription": "L'axe d'Uranus est incliné à un angle extrême de plus de quatre-vingt-dix-sept degrés.",
      "avianDescription": "Uranus porte le nom d'un dieu terrien du ciel. La légende fait pâle figure face aux dieux du ciel Avians.",
      "floranDescription": "Uranus essst la sssseptième planète du sssystème Sssol. Elle a de finsss anneaux.",
      "glitchDescription": "Fasciné. Uranus est la planète la plus froide du système Sol.",
      "humanDescription": "Uranus a beau porter le nom d'un dieu... ça sonne quand même bizarre.",
      "hylotlDescription": "Uranus est curieuse en raison de son axe bancal, ce qui la rend unique dans le système Sol.",
      "novakidDescription": "Uranus est une géante de glace, bien connue pour masquer les émissions de moteur des vaisseaux cachés."
    }
  },
  "ursaminer": {
    "name": "Ursa Miner",
    "desc": "Une entreprise familiale. Vend des minerais raffinés pour l'artisanat.",
    "metadata": {
      "apexDescription": "Est-ce que c'est un ours... qui vend du minerai?",
      "avianDescription": "Ce magasin semble offrir une alternative au minage pour les matériaux cruciaux.",
      "floranDescription": "Floran veut sssse battre contre la bête à poilsss du magasssin.",
      "glitchDescription": "Intrigué. Ce magasin offre-t-il une alternative au minage de matériaux?",
      "humanDescription": "Des ours! Avec une boutique! Comme c'est merveilleux.",
      "hylotlDescription": "Je n'avais jamais vu un vendeur aussi... poilu, auparavant.",
      "novakidDescription": "C'te boutique a presque autant de caractère que les gens qui la tiennent.",
      "interactData.paneLayoutOverride.windowtitle.title": "Ursa Miner",
      "interactData.paneLayoutOverride.windowtitle.subtitle": "Vente de minerais"
    }
  },
  "ursaminerclosed": {
    "name": "Ursa Miner",
    "desc": "Une entreprise familiale. Vend des minerais raffinés pour l'artisanat.",
