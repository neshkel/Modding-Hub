      "hylotlDescription": "Cet oshroom projette une belle lumière, comme une douce couverture tout autour de lui.",
      "novakidDescription": "Une plante brillante. Sa lumière est la bienvenue."
    }
  },
  "toxictable": {
    "name": "Table Toxique",
    "desc": "Une table épineuse. Faites attention où vous mettez les pieds.",
    "metadata": {
      "apexDescription": "Cette table est molle, spongieuse et quelque peu déconcertante.",
      "avianDescription": "Il est difficile d'être à l'aise à côté de cette table.",
      "floranDescription": "Table épineuse poignarrrde Floran. Floran poignarrrde en rretour!",
      "glitchDescription": "Prudent. Les épines sont exceptionnellement tranchantes.",
      "humanDescription": "On dirait que cette table s'effondrerait sous le poids d'un repas.",
      "hylotlDescription": "Cela me rappelle un magnifique nénuphar.",
      "novakidDescription": "Les tables organiques ne me dérangent pas. Mais ces épiness tranchantes ne sont pas sûres."
    }
  },
  "tentacleegg": {
    "name": "Œuf de Monstre à Tentacules",
    "desc": "Ça tente quelqu'un, des œufs de monstre brouillés?"
  },
  "tentaclepart1": {
    "name": "Morceau de Tentacule",
    "desc": "Quelque chose d'organique et de gluant...",
    "metadata": {
      "apexDescription": "C'est dérangeant.",
      "avianDescription": "C'est dégoûtant. Est-ce vivant?",
      "floranDescription": "A l'airrr gluant.",
      "glitchDescription": "Inconfortable. Il semble que ce soit quelque chose d'organique.",
      "humanDescription": "Beurk. C'est quoi ce truc?",
      "hylotlDescription": "Une structure organique absolument répugnante.",
      "novakidDescription": "Je sais pas ce que c'est. Et je suis pas surr de vouloir le savoir."
    }
  },
