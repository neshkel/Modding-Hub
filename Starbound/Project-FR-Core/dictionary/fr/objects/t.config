  "tentaclespawner1": {
    "name": "Œuf de Tentacule",
    "desc": "Cette substance verte a quelque chose qui bouge à l'intérieur...",
    "metadata": {
      "apexDescription": "Qu'est-ce qui bouge là-dedans...?",
      "avianDescription": "Un truc... vert. Attendez, est-ce que je viens de voir quelque chose bouger à l'intérieur?",
      "floranDescription": "A l'airrr intérressant... Mais sssent bizarre!",
      "glitchDescription": "Stressé. Je devrais probablement m'éloigner de cette glu verrrte!",
      "humanDescription": "Je jure que je viens de voir un truc bouger là-dedans.",
      "hylotlDescription": "Cette substance verte sent absolument horriblement mauvais.",
      "novakidDescription": "Une sorte de gel vert. Je suis pas sur de mon coup."
    }
  },
  "tentaclespike": {
    "name": "Pointe de Tentacule",
    "desc": "Mieux vaut ne pas tomber sur l'une d'elles...",
    "metadata": {
      "apexDescription": "Une pointe à l'air dangereux...",
      "avianDescription": "Cette pointe a l'air tranchante comme un rasoir.",
      "floranDescription": "Trranchant et pointu.",
      "glitchDescription": "Prudent. Des pointes comme celles-ci pourraient pénétrer la carapace d'un Glitch.",
      "humanDescription": "Je ferais mieux de ne pas toucher à ça.",
      "hylotlDescription": "Je vais éviter cela avec élégance.",
      "novakidDescription": "Ça a l'air drrôlement pointu, je suis prêt à décamper d'ici!"
    }
  },
  "tarbed": {
    "name": "Lit de Goudron",
    "desc": "Un simple lit de goudron.",
    "metadata": {
      "apexDescription": "Un choix étrange pour un couchage, mais au moins c'est chaud et non toxique.",
      "avianDescription": "Un lit plus adapté aux êtres sans plumes.",
      "floranDescription": "Lit de boue est chaud.",
      "glitchDescription": "Fier. Mon propre lit tout simple.",
      "humanDescription": "Oh, désolé du retard, je n'ai littéralement pas pu sortir de mon lit ce matin. Il est en goudron.",
      "hylotlDescription": "On pourrait facilement céder à la viscosité de ce lit et s'y reposer trop longtemps.",
      "novakidDescription": "Je vois pas comment un lit en goudron peut être une bonne idée, peu importe le point de vue."
    }
  },
  "tarchair": {
    "name": "Chaise de Goudron",
    "desc": "Une chaise en goudron collante.",
    "metadata": {
      "apexDescription": "On dirait une chaise normale mais je ne lui fais pas confiance, allez savoir pourquoi.",
      "avianDescription": "S'asseoir sur cette chaise vous fera sûrement perdre quelques plumes de queue.",
      "floranDescription": "Floran ferrait mieux de s'asseoir parrr terre que ssur une chaise collante.",
      "glitchDescription": "Insatisfait. Une assise inconfortable n'est pas reposante.",
      "humanDescription": "Un siège pour le moins peu satisfaisant.",
      "hylotlDescription": "Toute chaise qui ne veut pas que vous la quittiez ne fait que vous freiner.",
      "novakidDescription": "Cette chaise a une surface collante. C'est juste pas norrmal."
    }
  },
  "tarconsole": {
    "name": "Console de Goudron",
    "desc": "Une console informatique faite de goudron.",
    "metadata": {
      "apexDescription": "Tant que la console fonctionne, peu importe de quoi elle est faite.",
      "avianDescription": "Il faut maintenant trouver un moyen d'utiliser cette console sans la toucher.",
      "floranDescription": "Floran appuie ssur les boutonsss. Fait passer dess chosess!",
      "glitchDescription": "Impressionné. Les applications techniques du goudron semblent être plus vastes que ce que les Glitchs présumaient.",
      "humanDescription": "Une console en goudron. Ingénieux.",
      "hylotlDescription": "Le potentiel d'une substance naturelle poussé une fois de plus à ses limites pratiques.",
      "novakidDescription": "C'est une console de contrôle. Attendez... elle est faite en goudron?"
    }
  },
  "tarcrystal1": {
    "name": "Éclat de Goudron",
    "desc": "Un éclat de goudron cristallisé.",
    "metadata": {
      "apexDescription": "Brillant, comme si l'on regardait dans un miroir sombre.",
      "avianDescription": "Je préfère de loin le goudron sous cette forme solide. Plus agréable pour les yeux, et les plumes.",
      "floranDescription": "Joliss crristaux sombress.",
      "glitchDescription": "Émerveillé. Quelle transformation par rapport à son état gluant et horrible.",
      "humanDescription": "Plutôt beau, pour du goudron.",
      "hylotlDescription": "Le goudron peut être assez beau sous sa forme cristallisée.",
      "novakidDescription": "Goudron cristallisé."
    }
  },
