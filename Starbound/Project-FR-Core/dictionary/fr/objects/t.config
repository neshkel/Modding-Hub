      "apexDescription": "Un mannequin rempli de paille. Utilisé pour l'entraînement au combat.",
      "avianDescription": "Un homme de paille. Il ne m'effraie pas.",
      "floranDescription": "L'homme-métal a fait un homme-paille.",
      "glitchDescription": "Souvenir. Un mannequin d'entraînement. Les chevaliers pratiquent l'escrime sur ces objets.",
      "humanDescription": "On dirait une sorte de mannequin d'entraînement. Pour l'escrime, peut-être.",
      "hylotlDescription": "Un homme rempli de paille. Quelqu'un s'exerce sans doute au combat avec ceci.",
      "novakidDescription": "Je pourrais tirer dessus, mais je crois qu'il est fait pour les flèches."
    }
  },
  "toxicwastebarrel": {
    "name": "Baril de Déchets Toxiques",
    "desc": "Un baril de déchets toxiques. Attention à ne pas en renverser!",
    "metadata": {
      "apexDescription": "Un baril rempli de déchets.",
      "avianDescription": "Un baril à l'odeur infecte.",
      "floranDescription": "Sssent comme l'eau du bain de Floran.",
      "glitchDescription": "Alarmé. Cette mixture pourrait être dangereuse.",
      "humanDescription": "Si je tombe dans ce baril, est-ce que j'aurai des super-pouvoirs?",
      "hylotlDescription": "Beaucoup de ces barils sont jetés dans l'océan par d'autres espèces négligentes.",
      "novakidDescription": "Ça s'renverse partout! Ça pue autant qu'une mule."
    }
  },
  "trashbag": {
    "name": "Sac Poubelle",
    "desc": "Un sac poubelle. Quel tas d'ordures.",
    "metadata": {
      "apexDescription": "Un sac de déchets.",
      "avianDescription": "Un sac d'objets indésirables.",
      "floranDescription": "Jourrr des orrrdurress!",
      "glitchDescription": "Observateur. Un sac poubelle.",
      "humanDescription": "Juste un autre sac poubelle.",
      "hylotlDescription": "Un sac de déchets laissé ici par négligence.",
      "novakidDescription": "Un sac de détritus, rien d'utile ici."
    }
  },
  "trashcan": {
    "name": "Poubelle",
    "desc": "Une poubelle. Quel tas d'ordures.",
    "metadata": {
      "apexDescription": "Une poubelle.",
      "avianDescription": "Un récipient uniquement destiné à y jeter des choses.",
      "floranDescription": "Jourrr des orrrdurress!",
      "glitchDescription": "Curieux. Un camarade Glitch... ou une poubelle.",
      "humanDescription": "Une poubelle. Elles sont utiles partout dans l'univers.",
      "hylotlDescription": "Un réceptacle pour se débarrasser des ordures.",
      "novakidDescription": "Rien d'utile ici, juste une poubelle."
    }
  },
  "trough": {
    "name": "Auge",
    "desc": "C'est une auge pour nourrir le bétail.",
    "metadata": {
      "apexDescription": "Une auge en bois. Elle est vide.",
      "avianDescription": "Un récipient en bois vide.",
      "floranDescription": "Floran sssent de la nourrrriture ici.",
      "glitchDescription": "Ennuyé. Une auge, comme beaucoup d'autres utilisées pour nourrir le bétail.",
      "humanDescription": "Un de ces trucs pour nourrir les bêtes. J'ai oublié son nom.",
      "hylotlDescription": "Une sorte de récipient à nourriture. Peut-être utilisé pour nourrir des animaux.",
      "novakidDescription": "Un endroit parfait pour nourrir un fier destrier. Ou juste du bétail."
    }
  },
  "teacup1": {
    "name": "Tasse de Thé",
    "desc": "Une tasse fumante de Earl Grey.",
    "metadata": {
      "apexDescription": "Une tasse de thé bien chaude.",
      "avianDescription": "Une boisson chaude et malodorante.",
      "floranDescription": "Floran pas ssûr d'aimer la boissson. Peut-être que Floran s'y habituerrra.",
      "glitchDescription": "Ravi. Le thé est une joie pour les capteurs de goût.",
      "humanDescription": "Rien de tel qu'une bonne tasse de thé et un moment pour s'asseoir.",
      "hylotlDescription": "Les Hylotls préparent des boissons similaires à partir de la flore océanique.",
      "novakidDescription": "J'ai jamais compris ce que tout le monde aimait autant dans le thé."
    }
  },
  "teapot1": {
    "name": "Théière",
    "desc": "La théière parfaite pour un goûter.",
    "metadata": {
      "apexDescription": "Une théière.",
      "avianDescription": "Une grande tasse avec un nez.",
      "floranDescription": "Étrrrange sssculpture d'une créaturre avec une longue trrrompe.",
      "glitchDescription": "Observateur. C'est une nuance de rose assez rare.",
      "humanDescription": "Une jolie théière. Réconfortant.",
      "hylotlDescription": "Un ustensile de service.",
      "novakidDescription": "Donc on met des feuilles dans un pot d'eau et... on boit sa?"
    }
  },
  "techchest": {
    "name": "Coffre High-Tech",
    "desc": "Un coffre orné de marquages lumineux sur toute sa surface.",
    "metadata": {
      "apexDescription": "Un coffre high-tech. Il semble pouvoir contenir quelque chose de précieux.",
      "avianDescription": "Un coffre qui semble abriter des objets de valeur.",
      "floranDescription": "Coffrrre brrrillant sspécial.",
      "glitchDescription": "Indifférent. Ce coffre est d'origine inconnue.",
      "humanDescription": "Qui a fabriqué ça? Qu'est-ce qu'il y a dedans?",
      "hylotlDescription": "Il y a une technologie incroyable intégrée au coffre lui-même.",
      "novakidDescription": "Oh, je parie qu'il est rempli à rabord de technologie de valeur."
    }
  },
