  "toxicgasprimer": {
    "name": "Racine",
    "desc": "C'est une racine.",
    "metadata": {
      "apexDescription": "Une sorte de racine d'arbre.",
      "avianDescription": "C'est une racine.",
      "floranDescription": "Rrraciness.",
      "glitchDescription": "Neutre. Une racine banale.",
      "humanDescription": "Ouaip. C'est une racine.",
      "hylotlDescription": "Une racine."
    }
  },
  "travellersbeacon": {
    "name": "Compteur du Voyageur",
    "desc": "Une machine que les voyageurs amateurs utilisent pour enregistrer des informations géologiques.",
    "metadata": {
      "apexDescription": "Un appareil rudimentaire qui enregistre des statistiques géologiques.",
      "avianDescription": "Est-ce que cet appareil diffuse la parole de Kluex vers les étoiles?",
      "floranDescription": "Lumièrrress et trucsss qui bougent. Ennuyeux!",
      "glitchDescription": "Fasciné. Cet appareil mesure les niveaux atmosphériques locaux.",
      "humanDescription": "Cette machine bancale enregistre apparemment des informations sur la planète.",
      "hylotlDescription": "Un mécanisme mal conçu. Les Hylotls se tournent vers la nature pour recueillir de telles informations.",
      "novakidDescription": "À quoi servent tous ces biduless?"
    }
  },
  "trophybronze": {
    "name": "Trophée du Guerrier",
    "desc": "La plaque indique: « Tout ce qui est or ne brille pas. Décerné pour une victoire héroïque. ».",
    "metadata": {
      "floranDescription": "Ce trrophée est petit mais c'est un joli gage.",
      "glitchDescription": "Ravi. Ce petit trophée est agréable à regarder.",
      "novakidDescription": "Un p'tit trophée, gagné en faisant quelque chose d'impressionnant."
    }
  },
  "trophygold": {
    "name": "Trophée du Champion",
    "desc": "La plaque indique: « Décerné à ceux qui peuvent traverser le feu du combat sans se brûler. ».",
    "metadata": {
      "floranDescription": "Ce trrophée brrrillant est fait d'or.",
      "glitchDescription": "Enchanté. La taille et la finition de ce trophée sont des plus impressionnantes.",
      "novakidDescription": "Un très beau trophée. On ne donne pas ça à n'importe qui."
    }
  },
  "trophysilver": {
    "name": "Trophée du Chasseur",
    "desc": "La plaque indique: « Décerné à ceux qui savent défier la puissance de la nature. ».",
    "metadata": {
      "floranDescription": "Floran peut voirrr son rreflet dans ce trrophée brrrillant.",
      "glitchDescription": "Impressionné. Ce trophée a été fabriqué avec grand soin pour honorer son destinataire.",
      "novakidDescription": "Ce trophée brille comme un six-coups tout neuf."
    }
  },
  "tungstenchair": {
    "name": "Chaise Pliante en Métal",
    "desc": "Une chaise qui a l'air inconfortable.",
    "metadata": {
      "apexDescription": "Cette chaise se replie.",
      "avianDescription": "La chaise se plie pour gagner de la place. Innovant.",
      "floranDescription": "Chaise frrroide et inconforrtable.",
      "glitchDescription": "Désapprobateur. C'est fait avec un métal de mauvaise qualité.",
      "humanDescription": "Une de ces horribles chaises pliantes.",
      "hylotlDescription": "Ça a l'air terriblement inconfortable.",
      "novakidDescription": "Ça a l'air drrôlement inconfortable."
    }
  },
  "tvstation": {
    "name": "Station TV",
    "desc": "Utilisée autrefois pour diffuser un signal vidéo.",
    "metadata": {
      "apexDescription": "Je savais autrefois comment diffuser de la vidéo en direct avec ça.",
      "avianDescription": "Des mots apparaissent encore sur l'écran de la console.",
      "floranDescription": "Floran ne sssait pas comment utilissser sssa.",
      "glitchDescription": "Triste. Il semble que cette station diffusait autrefois de la vidéo en direct.",
      "humanDescription": "C'est une station de diffusion TV. C'était très à la mode sur Terre.",
      "hylotlDescription": "Le panneau semble avoir été capable d'envoyer un signal vidéo autrefois.",
      "novakidDescription": "Cette machine semble avoir connu des jours meilleurs."
    }
  },
  "thornplant": {
    "name": "Plante Épineuse",
    "desc": "Une plante piquante avec des fruits piquants.",
    "metadata": {
      "apexDescription": "Ces fruits n'ont pas l'air très appétissants...",
      "avianDescription": "D'étranges plantes épineuses avec d'étranges fruits épineux.",
      "floranDescription": "Fruitsss à pointesss... bon pourrr jeterr!",
      "glitchDescription": "Prudent. Ces fruits épineux semblent bien protégés contre la faune affamée.",
      "humanDescription": "D'étranges fruits épineux.",
      "hylotlDescription": "Ces plantes protègent farouchement leur précieuse eau...",
      "novakidDescription": "On dirait une sorte de cactus d'un autre monde!"
    }
  },
  "tomatoseed": {
    "name": "Graine de Tomate",
    "desc": "Les tomates sont des fruits riches et juteux. Ou des légumes. L'un des deux.",
    "metadata": {
      "apexDescription": "J'apprécie une tomate mûre et succulente.",
      "avianDescription": "Les graines de tomate peuvent améliorer bien des plats.",
      "floranDescription": "Les tomatess sont rrougess comme le sssang et éclatent.",
      "glitchDescription": "Espiègle. Les tomates pourries font de bons projectiles.",
      "humanDescription": "Les tomates sont parfaites pour une salade saine... Ou mieux encore, une pizza.",
      "hylotlDescription": "Les tomates sont acceptables, bien que banales.",
      "novakidDescription": "Les tomates font un en-cas savourreux, et c'est génial pourr les flanquer sur les vauriens."
    }
  },
  "toxictopseed": {
    "name": "Graine de Toxictop",
    "desc": "Un fruit à l'aspect toxique, mais est-ce si terrible?",
    "metadata": {
      "apexDescription": "Cette plante pourrait me rendre malade. Ou pourrait-elle guérir une maladie?",
      "avianDescription": "Acide et délicieux.",
      "floranDescription": "Floran donne dess toxictopss aux amisss pour rrigolerr.",
      "glitchDescription": "Perplexe. Cette plante est toxique pour toutes les espèces connues, sauf les pingouins.",
      "humanDescription": "Un ananas toxique, pour quand un ananas ordinaire n'est juste pas assez toxique.",
      "hylotlDescription": "La toxicité de ce fruit peut être intelligemment exploitée pour guérir des maux.",
      "novakidDescription": "Je ne ferais pas confiance à quoi que ce soit avec « toxique » dans le nom."
    }
  },
  "thornbee": {
    "name": "Abeille-Épine",
    "desc": "Ce petit compagnon piquant a des ailes tranchantes comme des rasoirs."
  },
  "tidefly": {
    "name": "Mouche des Marées",
    "desc": "Ne sort que pendant certaines phases de la lune."
  },
  "tallchair": {
    "name": "Chaise Haute",
    "desc": "Une chaise absurdement haute.",
    "metadata": {
      "apexDescription": "Une chaise exceptionnellement haute.",
      "avianDescription": "Une chaise très haute.",
      "floranDescription": "Floran se balance ssur la chaise, tombe. Toujourrs.",
      "glitchDescription": "Perplexe. Qui a besoin d'une chaise aussi haute?",
      "humanDescription": "Une chaise vraiment très haute.",
      "hylotlDescription": "Quelle chaise au design ridicule.",
      "novakidDescription": "Une chaise super haute. Pas mal."
    }
  },
  "toxicchair": {
    "name": "Chaise Toxique",
    "desc": "Une chaise faite de lianes. Ces pointes ont l'air empoisonnées.",
    "metadata": {
      "apexDescription": "Cette chaise a un toucher spongieux assez inconfortable.",
      "avianDescription": "S'asseoir ici fait hérisser mes plumes.",
      "floranDescription": "Chaise rrappelle la maison à Floran. Floran s'asssoit.",
      "glitchDescription": "Inquiet. Les épines de cette chaise sont toxiques pour au moins quarante-trois espèces différentes.",
      "humanDescription": "Ce que nous appelons chaise, sous un autre nom serait... aïe. C'est piquant.",
      "hylotlDescription": "Une merveilleuse manipulation de la nature. Également assez pointue.",
      "novakidDescription": "Une chaise qui a l'air pleine d'épines. Frranchement, je préfère ne pas m'y asseoir."
    }
  },
  "toxicchest": {
    "name": "Coffre Toxique",
    "desc": "Un coffre toxique.",
    "metadata": {
      "apexDescription": "Je ne suis pas sûr que toucher ce coffre en vaille la peine.",
      "avianDescription": "Ce coffre semble hautement contaminé.",
      "floranDescription": "Coffrrre ssent le toxique.",
      "glitchDescription": "Suspicieux. Ce coffre est probablement empoisonné par son environnement.",
      "humanDescription": "Ce coffre a l'air assez toxique.",
      "hylotlDescription": "Un coffre grotesque...",
      "novakidDescription": "C'est un drôle de coffre. Je ne devrais sans doute pas le toucherr plus que nécessaire."
    }
  },
  "toxiclamp1": {
    "name": "Lampe Toxique",
    "desc": "Une fleur qui sert de lampe. Comme un tournesol, mais en différent.",
