  "tombthing1": {
    "name": "Tombe en Pierre Non Décorée",
    "desc": "Une simple tombe en pierre recouverte de poussière.",
    "metadata": {
      "apexDescription": "Une tombe sans décoration.",
      "avianDescription": "Une tombe pour ceux qui ne pouvaient pas s'offrir un sarcophage.",
      "floranDescription": "Floran pense que les morrtss devraient rretourrner au ssol.",
      "glitchDescription": "Neutre. Au lieu d'enterrer, les Glitchs récupèrent les morts pour des pièces de rechange.",
      "humanDescription": "Un endroit déprimant pour passer l'éternité.",
      "hylotlDescription": "Un corps mérite mieux que cela.",
      "novakidDescription": "Un lit pour les morts."
    }
  },
  "tombthing2": {
    "name": "Tombe Avienne Gravée",
    "desc": "Une tombe avienne gravée représentant l'éther.",
    "metadata": {
      "apexDescription": "La décoration sur cette tombe pourrait représenter l'au-delà des Aviens.",
      "avianDescription": "Les tombes comme celle-ci sont décorées par la famille de l'Avien après son décès. Cette gravure dépeint l'éther.",
      "floranDescription": "Floran détessterrrait pourrrir dans une telle tombe.",
      "glitchDescription": "Observateur. Cette tombe a été décorée par des mains tremblantes.",
      "humanDescription": "Ils ont essayé d'égayer un peu cette tombe. Ça semble futile.",
      "hylotlDescription": "Il semble que quelqu'un ait tenté d'honorer le défunt avec une gravure.",
      "novakidDescription": "C'est la dernière demeure de quelqu'un. À en juger par les décorations, ils devaient être bien aimés."
    }
  },
  "tombthing3": {
    "name": "Tombe en Pierre Ouverte",
    "desc": "Une tombe en pierre ouverte. Ça sent mauvais.",
    "metadata": {
      "apexDescription": "Une tombe sans décoration. Ni corps.",
      "avianDescription": "Une tombe pour ceux qui n'avaient pas les moyens d'avoir un sarcophage. Celle-ci a été ouverte.",
      "floranDescription": "Floran pense que les morrtss devraient rretourrner au ssol. Peut-être que le morrt était d'accorrrd.",
      "glitchDescription": "Intrigué. Les Glitchs récupèrent les morts pour des pièces de rechange. La même chose s'est peut-être produite ici.",
      "humanDescription": "Un endroit déprimant pour passer l'éternité. On dirait que l'occupant de la tombe a ressenti la même chose.",
      "hylotlDescription": "Peut-être que le corps a bénéficié d'un lieu de repos plus honorable.",
      "novakidDescription": "C'est vide. Où est passé le corrps?"
    }
  },
  "tombthing4": {
    "name": "Tombe Avienne Somptueuse",
    "desc": "Une tombe avienne somptueuse.",
    "metadata": {
      "apexDescription": "Une tombe élégante. La gravure est bien réalisée.",
      "avianDescription": "Une tombe pour ceux qui pouvaient s'offrir un sarcophage mais ont choisi d'éviter la conservation.",
      "floranDescription": "L'homme-oiseau décorre sa tombe comme un homme-oiseau.",
      "glitchDescription": "Observateur. La gravure sur cette tombe est l'œuvre d'un expert.",
      "humanDescription": "Vous imaginez à quoi ressemble le couvercle vu de l'intérieur?",
      "hylotlDescription": "Un corps honoré.",
      "novakidDescription": "C'est un sacré bel endroit pour se reposer."
    }
  },
  "treasuremap": {
    "name": "Carte au Trésor",
    "desc": "La croix marque l'emplacement.",
    "metadata": {
      "apexDescription": "Une carte. Je me demande ce qu'on peut trouver à l'endroit marqué d'une croix.",
      "avianDescription": "Les cartes au trésor sont courantes sur les marchés des rebelles.",
      "floranDescription": "Peut-être que le trrésorr est un énorme ssteak.",
      "glitchDescription": "Confiant. La probabilité que cette carte soit exacte est très faible.",
      "humanDescription": "J'ai toujours voulu partir à la recherche d'un trésor enfoui.",
      "hylotlDescription": "Une telle aventure m'attend!",
      "novakidDescription": "Ça me donne une faim d'aventurres!"
    }
  },
  "tribalbed2": {
    "name": "Lit Avien",
    "desc": "Un lit avien magnifiquement sculpté.",
    "metadata": {
      "apexDescription": "Un ensemble de draps chauds et colorés sur un lit qui semble confortable.",
      "avianDescription": "Même les yeux fermés, les rebelles apprécient d'avoir des couleurs vives autour d'eux.",
      "floranDescription": "Lit doux. Floran pourrrait se rreposer ici.",
      "glitchDescription": "Sentimental. Ce n'est pas sans rappeler le lit dans lequel je me reposais autrefois.",
      "humanDescription": "Ce lit a l'air merveilleusement confortable.",
      "hylotlDescription": "Un bel ensemble de couvertures chaudes.",
      "novakidDescription": "Un très beau lit, je dois dire."
    }
  },
  "tribalbookcase1": {
    "name": "Grande Bibliothèque Sculptée",
    "desc": "Fabriquée à la main et magnifique, cette bibliothèque est finement sculptée.",
    "metadata": {
      "apexDescription": "Cette bibliothèque semble être le résultat du passe-temps de quelqu'un.",
      "avianDescription": "Les rebelles collectionnent des livres provenant de tout l'univers.",
      "floranDescription": "Hsss, dess livrress, perrte de temps.",
      "glitchDescription": "Neutre. Cette bibliothèque semble faite maison.",
      "humanDescription": "On dirait que cette bibliothèque a été faite pour le plaisir.",
      "hylotlDescription": "Bien qu'amateur, ce meuble est charmant.",
      "novakidDescription": "Ces livrres semblent venir de tout l'univerrs."
    }
  },
  "tribalbookcase2": {
    "name": "Petite Bibliothèque Avienne",
    "desc": "Cette bibliothèque a été construite pour conserver l'histoire avienne.",
    "metadata": {
      "apexDescription": "Le cristal au sommet baigne la bibliothèque dans une lueur rouge.",
      "avianDescription": "C'est une bibliothèque conçue pour les livres importants. La lueur du cristal empêche les livres de se détériorer.",
      "floranDescription": "Floran rresssent un drrôle de picotement quand Floran abssorrbe la lumièrre rrouge.",
      "glitchDescription": "Observateur. Le cristal semble avoir un effet restaurateur sur les livres placés à l'intérieur.",
      "humanDescription": "Le cristal de cette bibliothèque semble avoir une utilité précise.",
      "hylotlDescription": "La lumière de ce cristal picote.",
      "novakidDescription": "La bibliothèque a l'air vieille, mais les livrress ne semblent pas avoir vieilli."
    }
  },
  "tribalcabinet1": {
    "name": "Petit Cabinet Sculpté",
    "desc": "Des motifs sculptés entourent ce petit cabinet.",
    "metadata": {
      "apexDescription": "Un cabinet. On dirait que les propriétaires l'ont décoré eux-mêmes.",
      "avianDescription": "La décoration de meubles est le passe-temps le plus pratiqué chez les rebelles. Ce cabinet semble en avoir souffert.",
      "floranDescription": "Floran voit beaucoup d'errreurrss dans la décorration.",
      "glitchDescription": "Observateur. La décoration semble être l'œuvre de plusieurs personnes.",
      "humanDescription": "On dirait que certaines personnes se sont bien amusées à décorer ce cabinet.",
      "hylotlDescription": "Décorer ce cabinet semble avoir été une source de grand divertissement.",
      "novakidDescription": "C'est un cabinet mal décoré."
    }
  },
  "tribalcloset1": {
    "name": "Placard Avien",
    "desc": "Le cristal au sommet de ce placard semble être brisé.",
    "metadata": {
      "apexDescription": "Un cristal trône au-dessus du placard, mais dans quel but?",
      "avianDescription": "Le cristal sur ce placard peut servir de verrou. Il semble cependant être fêlé.",
      "floranDescription": "Y a-t-il quelque chosse pour Floran dans le placarrrd?",
      "glitchDescription": "Intrigué. Le cristal semble avoir cessé de fonctionner à cause d'une petite microfissure.",
      "humanDescription": "Je me demande s'il existe un Narnia Avien...",
      "hylotlDescription": "Le cristal au-dessus de ce placard est endommagé et non fonctionnel.",
      "novakidDescription": "Un placard avec un cristal au-desssuss. Le cristal a l'air cassé."
    }
  },
  "tribalcounter1": {
    "name": "Comptoir Sculpté",
    "desc": "Une surface de cuisson lisse.",
    "metadata": {
      "apexDescription": "Un buffet et une surface de cuisson.",
      "avianDescription": "La cuisine est une activité que les rebelles apprécient énormément.",
      "floranDescription": "Y a-t-il de la nourrrriturre ici?",
      "glitchDescription": "Observateur. À la fois un buffet et une surface de cuisson.",
      "humanDescription": "Sa place est dans une cuisine.",
      "hylotlDescription": "La surface est parfaite pour préparer à manger.",
      "novakidDescription": "Un endroit pour cuisinner et faire de la pâtisserie."
    }
  },
  "tribaldoor": {
    "name": "Porte Sculptée",
    "desc": "Une porte magnifiquement sculptée.",
    "metadata": {
      "apexDescription": "Un oiseau au-dessus d'une créature au visage rond.",
      "avianDescription": "Les images sur cette porte offrent l'amitié à ceux des autres mondes. Ma maison est la tienne.",
      "floranDescription": "L'oiseau pond un œuf avec un vissage.",
      "glitchDescription": "Instruit. Cette porte symbolise qui peut ou ne peut pas entrer.",
      "humanDescription": "C'est un visage plutôt effrayant en bas.",
      "hylotlDescription": "Quelle est cette créature représentée ici?",
      "novakidDescription": "Une porte avec des dessins. Qu'esst-ce que ça essaie de dirre?"
    }
  },
  "triballamp": {
    "name": "Lampe Avienne",
    "desc": "Une magnifique lampe construite grâce à la technologie cristalline avienne.",
    "metadata": {
      "apexDescription": "Cette lampe brille intensément sans électricité.",
      "avianDescription": "Les lampes à cristaux ne s'éteignent jamais.",
      "floranDescription": "La lumièrre rrappelle à Floran un coucher de ssoleil rrouge.",
      "glitchDescription": "Observateur. Cette lampe est sa propre source d'énergie.",
      "humanDescription": "La lueur de ces lampes est de mauvais augure.",
      "hylotlDescription": "Les Hylotls pourraient faire bon usage de cette technologie cristalline sous les vagues.",
      "novakidDescription": "Un cristal lumineux. Comment ça marche?"
    }
  },
  "tribalserver": {
    "name": "Serveur Avien",
    "desc": "Ce serveur avien doit contenir une vaste quantité de données.",
    "metadata": {
      "apexDescription": "Il semble que ce soit une sorte de serveur.",
      "avianDescription": "Les cristaux aviens collectent les données et les stockent dans ces machines.",
      "floranDescription": "Sserrveur avec pluss d'inforrmations que le cerrveau de Floran.",
      "glitchDescription": "Intimidé. La quantité de données stockées ici est immense.",
      "humanDescription": "On dirait un serveur.",
      "hylotlDescription": "Il y a tellement de données ici. Si je pouvais les exporter...",
      "novakidDescription": "Ça doit être un serveur pour stocker des données."
    }
  },
  "tribaltable": {
    "name": "Table Sculptée",
    "desc": "Une table aux sculptures intéressantes.",
    "metadata": {
      "apexDescription": "Une table à manger joliment décorée.",
      "avianDescription": "Après avoir mangé, il est courant d'utiliser couteaux et fourchettes pour ajouter de nouvelles gravures à la table.",
      "floranDescription": "Floran passse les meilleurrss moments à la table du dîner.",
      "glitchDescription": "Appréciatif. La décoration sur cette table est complexe.",
      "humanDescription": "On dirait qu'une famille entière a aidé à décorer cette table.",
      "hylotlDescription": "Les propriétaires semblent avoir décoré cette table en groupe.",
      "novakidDescription": "Une table à manger sculptée à la main."
    }
  },
  "tribalwallcabinet": {
    "name": "Placard Mural Sculpté",
    "desc": "On dirait un endroit où l'on rangerait un coquetier... Les Aviens mangent des œufs?",
    "metadata": {
      "apexDescription": "Un placard qui se fixe au mur. Gain de place!",
      "avianDescription": "Beaucoup de maisons de rebelles sont très petites. Les rangements sont souvent placés sur les murs.",
      "floranDescription": "Unité de sstockage sur le mur.",
      "glitchDescription": "Neutre. Une unité de stockage pour gagner de la place.",
      "humanDescription": "Un placard mural.",
      "hylotlDescription": "Qu'est-ce qu'il y a dedans, je me demande.",
      "novakidDescription": "Un meuble mural. On dirait que c'est fait pour une cuisine."
    }
  },
  "tenstudiesinfemalehylotlgy": {
    "name": "Études de l'Hylotlgie Féminine",
    "desc": "Un portrait très célèbre d'une dame mystérieuse.",
    "metadata": {
      "apexDescription": "C'est agréable de voir une œuvre d'art qui ne représente pas Big Ape.",
      "avianDescription": "Cette peinture d'une Hylotl serait mieux avec un Avien à la place.",
      "floranDescription": "L'image n'a pas de coups de poignarrrd. Floran pense que c'esst ennuyeuxss.",
      "glitchDescription": "Impressionné. Ce tableau d'une femme Hylotl est très détaillé.",
      "humanDescription": "Je ne sais pas trop ce que je suis censé ressentir face à cette œuvre...",
      "hylotlDescription": "Quelle œuvre d'art magnifique et séduisante. Elle capture tant d'émotions.",
      "novakidDescription": "En voilà une dame à l'air étrrange."
    }
  },
  "tesla": {
    "name": "Wireless Generator",
    "desc": "A wireless energy supply.",
    "metadata": {
      "apexDescription": "A device for wireless energy.",
      "avianDescription": "This device sends a rustle through my feathers.",
      "floranDescription": "Floran fear lightning machine.",
      "glitchDescription": "Delighted. A wireless power source. I am a fan of this technology.",
      "humanDescription": "Wireless power.",
      "hylotlDescription": "Such wireless power devices are very useful beneath the ocean.",
      "novakidDescription": "Electrical power generator."
    }
  },
  "teslaspike": {
    "name": "Tesla Spike",
    "desc": "BZZZZZZZZT, ouch.",
    "metadata": {
      "apexDescription": "Apex traps. I'd better not touch.",
      "avianDescription": "If only I could fly over these traps.",
      "floranDescription": "Floran dislikess lightning machines.",
      "glitchDescription": "Fearful. There appears to be enough current here to entirely fry my circuits.",
      "humanDescription": "Uh oh, looks dangerous.",
