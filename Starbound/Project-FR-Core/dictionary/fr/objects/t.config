  "techstation": {
    "name": "S.A.I.L",
    "desc": "Intelligence Artificielle de Bord, ou S.A.I.L pour faire court.",
    "metadata": {
      "apexDescription": "Je peux parler à S.A.I.L via cette console.",
      "avianDescription": "Je peux utiliser cette station pour parler à S.A.I.L.",
      "floranDescription": "Floran utilisssse ssse panneau magique pour parler à S.A.I.L!",
      "glitchDescription": "Heureux. Cette station me permet de parler à S.A.I.L.",
      "humanDescription": "Cette station me permet de communiquer avec S.A.I.L.",
