  "tombstatueavian": {
    "name": "Statue de Héros Avien",
    "desc": "Une statue d'un grand héros Avien.",
    "metadata": {
      "apexDescription": "Pour marquer la tombe d'un guerrier Avien, peut-être.",
      "avianDescription": "Un gardien Avien qui a donné sa vie pour défendre un temple.",
      "floranDescription": "Tant d'hommess-oiseaux morrtss. Quel gâchisss.",
      "glitchDescription": "Observateur. Cet Avien a des ailes. Elles n'ont pas l'air réelles.",
      "humanDescription": "Un guerrier Avien. Il a l'air redoutable.",
      "hylotlDescription": "Peut-être que ce guerrier Avien est mort avec gloire.",
      "novakidDescription": "Une statue d'un Avien à l'air fier."
    }
  },
  "tombstatuebunny": {
    "name": "Statue de Lapin Avienne",
    "desc": "Une statue de lapin.",
    "metadata": {
      "apexDescription": "Une statue de lapin. Qu'est-ce que cela signifie?",
      "avianDescription": "Cette statue marque la tombe de celui qui est destiné à ne jamais recevoir d'ailes dans l'au-delà. Ils sautilleront comme des lapins pour l'éternité.",
      "floranDescription": "Géant homme-lapin ferrait un délicieuxss goûterr.",
      "glitchDescription": "Observateur. Je crois que le lapin a une importance dans la société Avienne.",
      "humanDescription": "Une statue de lapin. Ça doit vouloir dire quelque chose pour les Aviens.",
      "hylotlDescription": "Le lapin est-il une sorte d'insulte? Marque-t-il un Avien tombé en disgrâce?",
      "novakidDescription": "C'est une statue d'animal. Un lapin, pour être précis."
    }
  },
