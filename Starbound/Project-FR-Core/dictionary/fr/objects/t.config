  },
  "tier1light": {
    "name": "Lanterne en Fer",
    "desc": "Une lanterne à huile pratique. Attention à ne pas la renverser.",
    "metadata": {
      "apexDescription": "Rien de fantastique, mais elle remplit son rôle.",
      "avianDescription": "Cette lanterne basique éclairera même la pièce la plus sombre.",
