  "tinywallbutton": {
    "name": "Bouton Mural Minuscule",
    "desc": "Un bouton compact qui s'active lorsqu'on appuie dessus.",
    "metadata": {
      "apexDescription": "Un bouton. Sa fonction est inconnue. Il n'y a qu'un seul moyen de le savoir.",
      "avianDescription": "Pourquoi suis-je toujours poussé à appuyer sur les boutons?",
      "floranDescription": "Floran appuie sssur les boutonsss!",
      "glitchDescription": "Tenté. Un bouton qui ne demande qu'à être pressé.",
      "humanDescription": "Il y a un bouton! Je ne peux pas m'empêcher d'appuyer!",
      "hylotlDescription": "Les boutons sont exaspérants. Pourtant, je dois appuyer dessus.",
      "novakidDescription": "Pourquoi c'est toujours sssi tentant d'appuyer sur les boutons."
    }
  },
  "tinywallswitch": {
    "name": "Interrupteur Mural Minuscule",
    "desc": "Un interrupteur compact qui peut être activé ou désactivé.",
    "metadata": {
      "apexDescription": "Un interrupteur. Il active quelque chose.",
      "avianDescription": "Ce minuscule interrupteur doit activer quelque chose.",
      "floranDescription": "Interrrupteurrr!",
      "glitchDescription": "Surpris. Ce petit interrupteur n'a pas l'air si puissant.",
      "humanDescription": "Je me demande combien de fois je peux basculer cet interrupteur.",
      "hylotlDescription": "Un interrupteur basique. Il peut être utilisé pour activer quelque chose.",
      "novakidDescription": "Je peux basculer c't'interrupteur!"
    }
  },
  "techconsole": {
    "name": "Console de Technologies",
    "desc": "Équipez et améliorez vos technologies à cette station. \n^red;Détruit si brisé.",
    "metadata": {
      "apexDescription": "Cette machine complexe me permet d'équiper des technologies.",
      "avianDescription": "Cette console me permet d'équiper des technologies! Des gadgets utiles, une fois qu'on a passé le côté bizarre.",
      "floranDescription": "Cette consssole permet à Floran d'équiper des techsss! Nouvelless techsss toujours très excitantes.",
      "glitchDescription": "Impressionné. Cette console me permet d'équiper et de retirer des technologies.",
      "humanDescription": "Je peux équiper des technologies ici! Quelle machine pratique.",
      "hylotlDescription": "Les technologies sont une avancée fascinante en bio-ingénierie.",
      "novakidDescription": "Avec un peu de savoir-faire, je peux utiliser cette machine pour m'équiper de technologies."
    }
  },
  "tier1bed": {
    "name": "Lit en Fer",
    "desc": "Un lit en fer commun.",
    "metadata": {
      "apexDescription": "Un lit basique. Suffisamment confortable.",
      "avianDescription": "C'est un endroit assez confortable pour reposer mes plumes.",
      "floranDescription": "Floran sse rrepossse dans lit sssimple.",
      "glitchDescription": "Impressionné. Un lit simple mais robuste.",
      "humanDescription": "Un lit décent. Je devrais pouvoir me reposer ici.",
      "hylotlDescription": "La qualité de fabrication n'est pas la meilleure, mais ça fera l'affaire.",
      "novakidDescription": "Un lit simple pour reposer ma tête fatiguée."
    }
  },
  "tier1chair": {
    "name": "Chaise en Fer",
    "desc": "Une simple chaise en fer.",
    "metadata": {
      "apexDescription": "Pas la chaise la plus confortable au monde, mais elle me convient.",
      "avianDescription": "Un endroit assez correct pour s'asseoir.",
      "floranDescription": "Floran s'asssoit sur chaise et pen sse à la chassse.",
      "glitchDescription": "Relaxé. Cette chaise est parfaitement confortable pour un Glitch.",
      "humanDescription": "Une chaise dure. Ça me rappelle l'école.",
      "hylotlDescription": "Ce n'est pas le luxe auquel les Hylotls sont habitués, mais on peut s'en satisfaire.",
      "novakidDescription": "C'est pas le top, mais je suis pas difficile."
    }
  },
  "tier1door": {
    "name": "Porte en Fer",
    "desc": "Une porte en fer basique.",
    "metadata": {
      "apexDescription": "Cette porte est relativement sécurisée.",
      "avianDescription": "Assez robuste pour une porte basique.",
      "floranDescription": "Floran sse cache derrrière porrte. Ssaute parrtout. Pique!",
