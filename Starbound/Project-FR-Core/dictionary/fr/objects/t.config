  "tardoor": {
    "name": "Porte en Goudron",
    "desc": "Une porte en goudron.",
    "metadata": {
      "apexDescription": "Juste une porte, mais faite de goudron.",
      "avianDescription": "Une porte d'apparence normale, mais c'est un véritable exploit d'ingénierie du goudron.",
      "floranDescription": "Sscollante et lente à ouvrirrr. Pas bon.",
      "glitchDescription": "Désapprobateur. Une porte en goudron pourrait rester coincée à tout moment.",
      "humanDescription": "Assez robuste pour une porte en goudron.",
      "hylotlDescription": "Une cascade de goudron a été façonnée pour former une porte.",
      "novakidDescription": "On dirait une porte en goudron séché. Mais c'est encore drôlement collant."
    }
  },
  "tarlight": {
    "name": "Lanterne en Goudron",
    "desc": "Une lanterne faite de goudron.",
    "metadata": {
      "apexDescription": "Humble mais utile quand on est entouré de goudron.",
      "avianDescription": "J'espère que cette lanterne s'active au son pour ne pas avoir à la toucher.",
      "floranDescription": "Lumièrrre brrrillante.",
      "glitchDescription": "Neutre. Une source de lumière utile.",
      "humanDescription": "Cette lanterne est gou-dron-tesque!",
      "hylotlDescription": "Une lumière dans un océan de ténèbres.",
      "novakidDescription": "Eh bien, je suis bien content qu'il y ait une source de lumière."
    }
  },
  "tarman": {
    "name": "Bonhomme de Goudron",
    "desc": "Comme un bonhomme de neige, mais collant.",
    "metadata": {
      "apexDescription": "Une création à l'allure assez malheureuse. J'ai de la peine pour le bonhomme de goudron.",
      "avianDescription": "Je ne savais pas que le goudron pouvait être utilisé de manière aussi créative.",
      "floranDescription": "L'homme-goudrron est scollant. Floran évite les chosess scollantess.",
      "glitchDescription": "Curieux. Pourquoi faire un bonhomme de goudron qui ressemble à un bonhomme de neige alors qu'il pourrait ressembler à un Glitch?",
      "humanDescription": "Qui fabriquerait un homme avec ce truc collant?",
      "hylotlDescription": "Ce bonhomme de goudron ressemble avec succès à son cousin de neige. C'est assez impressionnant.",
      "novakidDescription": "Celui qu'a construit ce trruc affrreux a besoin d'un peu de neige dans sa vie."
    }
  },
  "tarpitchest": {
    "name": "Coffre de Goudron",
    "desc": "Du goudron façonné en coffre.",
    "metadata": {
      "apexDescription": "Est-ce qu'un coffre collant sert de moyen de dissuasion contre les voleurs?",
      "avianDescription": "Peu importe ce qu'il y a dedans, il vaut mieux que ça vaille le coup de toucher ce coffre.",
      "floranDescription": "Difficile d'ouvrirrr ce coffre scollant, le trrésor à l'intérrieurr a intérrêt à en valoir la peine.",
      "glitchDescription": "Prudent. Quel que soit le trésor à l'intérieur d'un coffre en goudron, il est probable qu'il soit aussi collant.",
      "humanDescription": "Un coffre collant, j'apprécie les avantages de sécurité supplémentaires.",
      "hylotlDescription": "Comme dans la nature, la viscosité de ce coffre est son propre mécanisme d'autodéfense.",
      "novakidDescription": "Un coffre à l'air bien scollant. J'espère que les trésors ne sont pas collés au fond."
    }
  },
  "tallgrass1": {
    "name": "Hautes Herbes",
    "desc": "Un carré d'herbes hautes. N'oubliez pas de vérifier s'il y a des bestioles!",
    "metadata": {
      "apexDescription": "Des herbes hautes. Elles bruissent doucement dans la brise.",
      "avianDescription": "De hautes herbes plumeuses.",
      "floranDescription": "Floran se cache dans l'herrrbe, puis ssaute pour surrprrendre sa proie! Ça ne rrate jamais.",
      "glitchDescription": "Furtif. Les Florans se déguisent souvent dans les hautes herbes pour chasser leurs proies.",
      "humanDescription": "J'ai juste envie de courir pieds nus dans cette herbe.",
      "hylotlDescription": "L'herbe se balançant au gré du vent, y a-t-il quelque chose de plus paisible?",
      "novakidDescription": "Cette herbe est drôlement haute, j'ai pas le temps pour le jardinage."
    }
  },
