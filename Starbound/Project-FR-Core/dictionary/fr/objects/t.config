  "tentaclepopbig": {
    "name": "Grande Capsule de Tentacule",
    "desc": "Une grande excroissance cassable. Je me demande ce qu'il y a dedans.",
    "metadata": {
      "apexDescription": "Une grande excroissance. Elle pourrait contenir quelque chose d'utile.",
      "avianDescription": "Une grosse excroissance. Quelque chose est à l'intérieur, je me demande ce que c'est...",
      "floranDescription": "Frrracas ssa! Prrrends les trrésors à l'intérrieurr!",
      "glitchDescription": "Destructeur. Il est difficile de résister à l'envie de briser cette excroissance.",
      "humanDescription": "Je pense qu'il y a quelque chose là-dedans. Je peux probablement l'ouvrir en la cassant.",
      "hylotlDescription": "Parfois, la force peut porter ses fruits.",
      "novakidDescription": "Cette drôle d'excroissance serait parfaite pour s'entraîner au tir."
    }
  },
  "tentaclepopmed": {
