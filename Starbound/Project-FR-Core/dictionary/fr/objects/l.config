  "loudspeaker": {
    "name": "Haut-parleurs",
    "desc": "Un ensemble de haut-parleurs à travers lesquels les gens parlent fort.",
    "metadata": {
      "apexDescription": "Un haut-parleur. Les Apex ont l'habitude d'en voir chez eux.",
      "avianDescription": "Un grésillement provient de cet appareil.",
      "floranDescription": "Une sssorte de machine à ssson?",
      "glitchDescription": "Test. Cet appareil est capable de recevoir des signaux sur plusieurs fréquences.",
      "humanDescription": "Un ensemble de haut-parleurs. Ils sont probablement très puissants.",
      "hylotlDescription": "Un dispositif pour projeter le son.",
      "novakidDescription": "Ce haut-parleur n'arrête pass de grésiller."
    }
  },
  "librarycodex": {
    "name": "Codex de la Bibliothèque Antique",
    "desc": "Un tome ancien qui répertorie tous les livres Hylotls de la galaxie.",
    "metadata": {
      "apexDescription": "Ce vieux tome contient une liste de tous les livres Hylotls de la galaxie. Ça doit être important pour certains.",
      "avianDescription": "Ce vieux livre poussiéreux contient des informations sur chaque livre Hylotl de la galaxie. Impressionnant!",
      "floranDescription": "Floran n'a pass le temps pour les vieux livresss pousssiéreux.",
      "glitchDescription": "Fasciné. Ce livre contient des informations sur tous les livres de la galaxie. Ces données doivent être précieuses pour certains.",
      "humanDescription": "Ce livre répertorie chaque livre Hylotl de la galaxie. Garder une trace de tout ça doit être un vrai casse-tête.",
      "hylotlDescription": "Nous, les Hylotls, sommes des organisateurs nés - ce tome répertorie chaque livre de la galaxie. Quel dévouement!",
      "novakidDescription": "Ce vieux tome poussiéreux sert à suivre les livres. J'imagine que c'est utile pour certains."
    }
  },
  "librarymodel": {
    "name": "Maquette de Bibliothèque Hylotl",
    "desc": "Une maquette complexe en papier faite main d'une bibliothèque Hylotl. Il y a de petites étagères en papier à l'intérieur!",
    "metadata": {
      "apexDescription": "Cette maquette en papier détaillée doit représenter un bâtiment très important.",
      "avianDescription": "Quelle maquette délicieusement détaillée! Ça a dû prendre un temps fou à fabriquer.",
      "floranDescription": "Floran s'inquiète du nombre d'arbresss utilisés pour faire cette maquette.",
      "glitchDescription": "Impressionné. Cette maquette de bibliothèque Hylotl contient même de minuscules étagères.",
      "humanDescription": "Cette délicate maquette de bibliothèque a même des petites étagères. J'ai presque peur de la toucher de peur qu'elle ne casse.",
      "hylotlDescription": "Quelqu'un a pris grand soin de réaliser cette maquette. Ce bâtiment doit être assez important.",
      "novakidDescription": "C'est une bien belle maquette. Je préférerais ne pass y toucher."
    }
  },
  "lavahopper": {
    "name": "Saute-Lave",
    "desc": "Cette minuscule créature bondit sur les lacs de lave brûlante."
  },
  "litorgans": {
    "name": "Organes Lumineux",
    "desc": "Des organes de la Ruine."
  },
  "lasertripwire": {
    "name": "Piège à Laser",
    "desc": "Traverser ce faisceau laser pourrait déclencher quelque chose!",
    "metadata": {
      "apexDescription": "Un fil de détente laser. Utile pour les pièges.",
      "avianDescription": "Ce piège laser pourrait être utile.",
      "floranDescription": "Piège lassser.",
      "glitchDescription": "Impressionné. Un fil de détente avec un laser.",
      "humanDescription": "Traverser ce faisceau laser pourrait déclencher quelque chose!",
      "hylotlDescription": "Un piège laser, utile pour tromper les intrus.",
      "novakidDescription": "Ça me rappelle tous ces braquages de banques..."
    }
  },
  "ladlelarge": {
    "name": "Grande Poche de Coulée",
    "desc": "Un récipient plein de liquide en fusion bouillonnant.",
    "metadata": {
      "apexDescription": "Ce récipient est plein de liquide chaud et bouillonnant.",
      "avianDescription": "Ce grand récipient contient du liquide en fusion incandescent.",
      "floranDescription": "Récipient contient liquide brûlant.",
      "glitchDescription": "Alarmé. Ce liquide en fusion pourrait causer des dégâts s'il n'est pas correctement confiné.",
      "humanDescription": "Je ne saurais dire s'il s'agit de métal en fusion ou de lave. Quoi qu'il en soit, ça a l'air très chaud.",
      "hylotlDescription": "Ce conteneur mécanique parvient d'une manière ou d'une autre à contenir la chaleur du liquide à l'intérieur.",
      "novakidDescription": "Un grand bassin de truc en fusion bouillonnant."
    }
  },
  "ladlesmall": {
    "name": "Petite Poche de Coulée",
    "desc": "Un grand récipient plein de liquide en fusion bouillonnant.",
    "metadata": {
      "apexDescription": "Le liquide en fusion dans ce récipient brille faiblement.",
      "avianDescription": "Ce récipient contient des liquides en fusion surchauffés.",
      "floranDescription": "Liquide brûlant fait desss bullesss et brille.",
      "glitchDescription": "Intéressé. Ce récipient maintient-il d'une manière ou d'une autre le niveau de température du liquide à l'intérieur?",
      "humanDescription": "La chaleur qui se dégage du liquide à l'intérieur est extrême.",
      "hylotlDescription": "Ce récipient contient le liquide en fusion à l'intérieur.",
      "novakidDescription": "Le liquide là-dedans dégage une sacrée chaleur."
    }
  },
  "lavatankcascade": {
    "name": "Réservoir de Lave en Cascade",
    "desc": "Ce réservoir fait circuler le liquide en fusion à l'intérieur pour l'empêcher de s'immobiliser.",
    "metadata": {
      "apexDescription": "Ce réservoir transforme l'énergie du liquide en fusion à l'intérieur.",
      "avianDescription": "Du liquide brûlant s'écoule en cascade de ce réservoir.",
      "floranDescription": "Vilaine cassecade de lave brûlante.",
      "glitchDescription": "Impressionné. L'ingénierie nécessaire pour entretenir une machine de cette taille est complexe.",
      "humanDescription": "Ce jet de lave est plus grand que moi.",
      "hylotlDescription": "Cette lave est presque apaisante, mieux vaut s'assurer qu'aucune goutte ne m'éclabousse.",
      "novakidDescription": "Un gros réservoir qui déverse un sacré paquet de lave."
    }
  },
  "lavatanklarge": {
    "name": "Grand Réservoir de Lave",
    "desc": "Un réservoir scellé rempli de liquide en fusion.",
    "metadata": {
      "apexDescription": "Des nuages de fumée s'échappent de ce réservoir de lave.",
      "avianDescription": "Ce réservoir contient de la lave en fusion.",
      "floranDescription": "Réservoir garde la lave enfermée.",
      "glitchDescription": "Accablé. Les dimensions de ce réservoir sont impressionnantes.",
      "humanDescription": "Ce réservoir géant contient du liquide en fusion.",
      "hylotlDescription": "Les vapeurs de ce réservoir sont presque toxiques.",
      "novakidDescription": "Un gros réservoir crachant des nuages de fumée."
    }
  },
  "lavatanksmall": {
