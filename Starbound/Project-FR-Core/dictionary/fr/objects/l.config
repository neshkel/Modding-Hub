      "glitchDescription": "Ravi. Une sucette géante.",
      "humanDescription": "C'est l'heure de la montée de sucre!",
      "hylotlDescription": "Une sucette exceptionnellement sucrée. Pour une fois, je vais me laisser tenter.",
      "novakidDescription": "J'ai jamais vu une sucette aussi grande!"
    }
  },
  "largebell": {
    "name": "Grosse Cloche",
    "desc": "Cette cloche doit faire un sacré boucan.",
    "metadata": {
      "apexDescription": "Une grosse cloche. Elle doit sonner très fort.",
      "avianDescription": "Une cloche immense. Je me demande quel son elle produit.",
      "floranDescription": "Gros ssson pour gros sssonne!",
      "glitchDescription": "Effrayé. Cette cloche signale un danger.",
      "humanDescription": "Une cloche géante. La tentation de la faire sonner est forte.",
      "hylotlDescription": "Le son des cloches est quelque chose que la plupart des Hylotls n'ont jamais entendu.",
      "novakidDescription": "Je parie qu'on peut entendre cette cloche de super loin."
    }
  },
  "largecastledoor": {
    "name": "Grande Porte Médiévale",
    "desc": "Une porte immense et intimidante.",
    "metadata": {
      "apexDescription": "Une porte énorme. Il faudrait un bélier pour l'abattre.",
      "avianDescription": "C'est peut-être la plus grande porte que j'aie jamais vue.",
      "floranDescription": "La porte fait sssentir Floran tout petit.",
      "glitchDescription": "Rassuré. Cette porte peut être verrouillée de l'intérieur par une énorme poutre en bois.",
      "humanDescription": "Une énorme porte fortifiée. Il faudrait plus qu'un bélier pour l'ouvrir.",
      "hylotlDescription": "De telles portes sont construites pour ceux qui craignent les intrus.",
      "novakidDescription": "Celui qui a bâti cette porte ne veut clairement pass de visite."
    }
  },
  "largewoodencrate": {
    "name": "Grande Caisse en Bois",
    "desc": "Une caisse en bois.",
    "metadata": {
      "apexDescription": "Une caisse en bois.",
      "avianDescription": "Une boîte de rangement en bois.",
      "floranDescription": "Belle boîte en bois.",
      "glitchDescription": "Neutre. Une caisse en bois.",
      "humanDescription": "C'est juste une caisse.",
      "hylotlDescription": "Une caisse faite de bois.",
      "novakidDescription": "Une caisse énorme."
    }
  },
  "largecooler1": {
    "name": "Grande Glacière",
    "desc": "Parfaite pour conserver une grande quantité de nourriture au frais.",
    "metadata": {
      "apexDescription": "Une glacière. J'espère qu'elle contient du milkshake à la banane.",
      "avianDescription": "Une glacière. Idéalement remplie de boissons et d'en-cas.",
      "floranDescription": "Floran peut sssentir la viande à l'intérieur.",
      "glitchDescription": "Ravi. Cette glacière fonctionne à une température optimale.",
      "humanDescription": "Je vibre d'excitation à l'idée de ce qu'elle pourrait contenir.",
      "hylotlDescription": "Sous l'eau, la réfrigération est plus facile. Ces appareils sont un substitut ingénieux.",
      "novakidDescription": "Une bête vieille glacière."
    }
  },
