{
  "landmine": {
    "name": "Mine Terrestre Militaire",
    "desc": "Regardez où vous mettez les pieds, ça a l'air explosif!",
    "metadata": {
      "apexDescription": "Une mine terrestre, elle pourrait encore être active.",
      "avianDescription": "Oh oh! Je n'ai pas envie de marcher là-dessus.",
      "floranDescription": "Faisss attention où tu marchesss!",
      "glitchDescription": "Prudent. Une mine terrestre active, je ferais mieux de faire attention.",
      "humanDescription": "Je ne veux pas prendre de risque, ce truc pourrait encore exploser.",
      "hylotlDescription": "Des mines terrestres, plus petites que les mines marines mais tout aussi mortelles.",
      "novakidDescription": "Ce truc pourrait encore sauter!"
    }
  },
  "lightsensor": {
    "name": "Capteur de Lumière",
    "desc": "Active le nœud inférieur en cas de faible luminosité et le nœud supérieur en cas de forte luminosité.",
    "metadata": {
      "floranDescription": "Active le nœud inférieur en cas de faible luminossité et le nœud ssupérieur en cas de forte luminossité.",
      "glitchDescription": "Pensif. Active le nœud inférieur en cas de faible luminosité et le nœud supérieur en cas de forte luminosité."
    }
  },
  "liquidsensor": {
    "name": "Capteur de Liquide",
    "desc": "N'utilisez pas votre doigt! Ce capteur fiable indique la présence de liquides.",
    "metadata": {
      "floranDescription": "N'utilisss pas ton doigt! Ce capteur fiable indique la préssence de liquidess.",
      "glitchDescription": "Impressionné. Ce capteur fiable indique la présence de liquides."
    }
  },
  "lamppost1": {
    "name": "Lampadaire Basique",
    "desc": "Une lampe, adaptée pour l'extérieur.",
    "metadata": {
      "apexDescription": "Un lampadaire en métal.",
      "avianDescription": "Un guide utile dans l'obscurité.",
      "floranDescription": "Grand et brillant lampadaire.",
      "glitchDescription": "Satisfait. Un grand lampadaire fait de métal robuste.",
      "humanDescription": "Un simple lampadaire. C'est assez explicite.",
      "hylotlDescription": "Comme une étoile brillante brillant dans le ciel.",
      "novakidDescription": "Un réverbère électrique."
    }
  },
  "lamppost2": {
    "name": "Triple Lampadaire",
    "desc": "Un lampadaire, avec trois fois plus de lumières.",
    "metadata": {
      "apexDescription": "Un magnifique lampadaire.",
      "avianDescription": "Idéal pour les ruelles particulièrement sombres.",
      "floranDescription": "Brille comme troiss lunesss dans le ciel.",
      "glitchDescription": "Appréciatif. Je suis reconnaissant pour cet éclairage supplémentaire.",
      "humanDescription": "Est-ce que trois lampes sont vraiment nécessaires?",
      "hylotlDescription": "Trois lampes, rappelant les trois têtes de l'hydre mythique.",
      "novakidDescription": "Le trois, mon chiffre chanceux."
    }
  },
  "lamppost3": {
    "name": "Double Lampadaire",
    "desc": "Un lampadaire avec deux lampes. Astucieux!",
    "metadata": {
      "apexDescription": "Un grand lampadaire doté de deux lumières.",
      "avianDescription": "Deux lumières, comme des yeux qui m'observent d'en haut.",
      "floranDescription": "Lumièresss brillantes au sommet d'un grand lampadaire.",
      "glitchDescription": "Observateur. Quel grand et brillant lampadaire.",
      "humanDescription": "Deux lumières qui me fixent depuis un lampadaire.",
      "hylotlDescription": "Une source lumineuse généreuse pour éclairer le chemin qui m'attend.",
      "novakidDescription": "Ce lampadaire a deux lumières."
    }
  },
  "liftoffseat": {
    "name": "Siège de Décollage",
    "desc": "Un siège horizontal comme le fauteuil d'un capitaine sur une navette spatiale terrestre.",
    "metadata": {
      "apexDescription": "C'est assez fascinant de simuler l'expérience des premiers voyages spatiaux humains.",
      "avianDescription": "Je comprends que cette position ait été la plus confortable pendant le décollage.",
      "floranDescription": "Ce sserait amusant d'être allongé en filant à toute vites sse dans l'essspace.",
      "glitchDescription": "Fasciné. Quelle idée ingénieuse de s'allonger pendant le transit.",
      "humanDescription": "Un superbe design. Il tient toujours la route.",
      "hylotlDescription": "L'idée de piloter un vaisseau spatial dans cette position est risible pour un Hylotl.",
      "novakidDescription": "Ce siège donne un nouveau sens à l'expression 'dormir au travail'."
    }
  },
  "lunarlander": {
    "name": "Module d'Atterrissage Lunaire",
    "desc": "Un témoignage légendaire des débuts du voyage spatial.",
    "metadata": {
      "apexDescription": "Je pense que c'est une réplique, les modules comme celui-ci ne sont plus utilisés depuis longtemps.",
      "avianDescription": "Un rappel que chaque voyage commence par un petit pas...",
      "floranDescription": "Ce module n'est passs plus grand qu'une cabane.",
      "glitchDescription": "Émerveillé. Des êtres se sont jadis confiés à ces capsules primitives dans l'espace.",
      "humanDescription": "On n'en fait plus des comme ça.",
      "hylotlDescription": "Contempler ceci rappelle le chemin parcouru dans l'exploration spatiale.",
      "novakidDescription": "J'ai vu des cabinets de jardin plus spacieux que ce vieux module."
    }
  },
  "laboratorylight": {
    "name": "Lampe de Laboratoire",
    "desc": "Une élégante applique murale rouge.",
    "metadata": {
      "apexDescription": "Cette lampe conçue par le Miniknog est faite pour fonctionner même à faible puissance.",
      "avianDescription": "Cette lampe est d'une luminosité dérangeante.",
      "floranDescription": "La lumière donne envie à Floran de sse battre.",
      "glitchDescription": "Impressionné. C'est une lampe très économe en énergie.",
      "humanDescription": "Cette lampe émet une lueur rouge et chaude. C'est un peu désagréable.",
      "hylotlDescription": "Cette lumière consomme très peu d'énergie. Il est inhabituel que le Miniknog se soucie de l'environnement.",
      "novakidDescription": "Brille en rouge comme un ssoleil mourant."
    }
  },
  "laboratoryverticaldoor": {
    "name": "Écoutille de Laboratoire",
    "desc": "Une porte verticale élégante, parfaite pour les labos secrets.",
    "metadata": {
      "apexDescription": "Cette écoutille ressemble à une conception du Miniknog. Ça me donne des frissons.",
      "avianDescription": "Une écoutille finement construite.",
      "floranDescription": "Floran n'aime pass les portess brillantes.",
      "glitchDescription": "Critique. Cette écoutille est faite d'un métal blanc et lisse.",
      "humanDescription": "Une porte qui se divise en trois parties à l'ouverture. Classe.",
      "hylotlDescription": "Une porte plutôt élégante qui se sépare en trois pour s'ouvrir.",
      "novakidDescription": "Une écoutille. Utile dans un labo de ssscience, j'imagine!"
    }
  },
  "lunarbasebunk": {
    "name": "Couchette de Base Lunaire",
    "desc": "Ces lits douillets peuvent être empilés les uns sur les autres.",
    "metadata": {
      "apexDescription": "Un lit superposé basique.",
      "avianDescription": "Ce lit superposé a l'air assez rudimentaire.",
      "floranDescription": "Floran aimerait dormir dans lit ssuperpossé.",
      "glitchDescription": "Sentimental. Un lit superposé, semblable à ceux de l'académie du Protectorat.",
      "humanDescription": "Un lit superposé. Pas très spacieux, mais étonnamment confortable.",
      "hylotlDescription": "J'ai de bons souvenirs de mes nuits dans un lit comme celui-ci à l'académie du Protectorat.",
      "novakidDescription": "Un lit superposé ordinaire."
    }
  },
  "lunarbasechair": {
    "name": "Chaise de Base Lunaire",
    "desc": "Une chaise étonnamment confortable.",
    "metadata": {
      "apexDescription": "Une jolie chaise.",
      "avianDescription": "Une chaise relaxante.",
      "floranDescription": "Chaissse sssouple.",
      "glitchDescription": "Satisfait. Une chaise confortable.",
      "humanDescription": "Une chaise agréable et douillette.",
      "hylotlDescription": "Une chaise passable.",
      "novakidDescription": "C'est un bon coin pour se relaxer."
    }
  },
  "lunarbaseconsole": {
    "name": "Console de Base Lunaire",
    "desc": "Une console de commande élégante.",
    "metadata": {
      "apexDescription": "C'est une console de commande avec un grand écran tactile.",
      "avianDescription": "Un panneau de commande avec des boutons sur lesquels je peux appuyer, si je le souhaite.",
      "floranDescription": "Consssole de contrôle a desss boutonsss.",
      "glitchDescription": "Mfiant. Quelque chose pourrait arriver si j'interagis avec ce panneau de commande.",
      "humanDescription": "C'est une console de commande. Qui la contrôle?",
      "hylotlDescription": "Cet appareil électronique est utilisé pour contrôler des choses à distance.",
      "novakidDescription": "Une console de contrôle. Qu'est-ce qui s'passerait si j'appuyais sur les boutons?"
    }
  },
  "lunarbasecrate": {
    "name": "Caisse de Base Lunaire",
    "desc": "Une caisse de stockage, généralement utilisée pour ranger l'équipement et les minerais.",
    "metadata": {
      "apexDescription": "Une belle caisse de stockage faite d'un matériau robuste.",
      "avianDescription": "Cette caisse est utilisée pour stocker différents types d'équipement.",
      "floranDescription": "Caisssse brillante peut sstocker beaucoup de choosess.",
      "glitchDescription": "Envieux. Cette caisse est bien entretenue et polie.",
      "humanDescription": "Cette caisse semble pouvoir survivre à n'importe quelle condition spatiale.",
      "hylotlDescription": "Une grande caisse utilisée pour organiser les objets et les garder en sécurité.",
      "novakidDescription": "Une belle grosse caisse. Je me demande c'qu'il y a dedans."
    }
  },
  "lunarbasedoor": {
    "name": "Porte Blindée de Base Lunaire",
    "desc": "Cette porte est hermétique et faite de matériaux incroyablement résistants.",
    "metadata": {
      "apexDescription": "Cette porte est solide et hermétique.",
      "avianDescription": "Une porte qui s'ouvre selon un angle curieux.",
      "floranDescription": "Cette porte a l'air lourde. Floran ne veut pass finir écrasssé.",
      "glitchDescription": "Intrigué. Cette entrée semble être penchée.",
      "humanDescription": "Elle a l'air fiable pour garder les choses dehors. Ou dedans.",
      "hylotlDescription": "Cette entrée est inclinée. Peut-être pour nous rappeler de voir les choses sous différents angles.",
      "novakidDescription": "C'est comme une porte normale. Mais en diagonale."
