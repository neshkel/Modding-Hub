  },
  "lamp": {
    "name": "Lampe Dorée",
    "desc": "Une odeur doucereuse et écœurante imprègne l'intérieur.",
    "metadata": {
      "apexDescription": "L'odeur de cette lampe est vieille et doucereuse.",
      "avianDescription": "Autrefois utilisée pour parfumer un temple avec une odeur de fruit. Maintenant, ça sent juste le fruit pourri.",
      "floranDescription": "L'odeur essst répulsssive.",
      "glitchDescription": "Dégoûté. La puanteur de vieux fruits pourris à l'intérieur est encore très présente.",
      "humanDescription": "Une lampe! On dirait qu'elle contient des fruits pourris.",
      "hylotlDescription": "L'odeur de cette lampe offense tous mes sens.",
      "novakidDescription": "Une superbe lampe dorée. Dommage qu'elle pue."
    }
  },
