  "oasisbed": {
    "name": "Chaise Longue de Pont",
    "desc": "Une chaise longue avec un parasol, parfaite pour le beau temps.",
    "metadata": {
      "apexDescription": "Ahh, un endroit pour faire la sieste au soleil. Ça pourrait être sympa.",
      "avianDescription": "Ça a l'air d'être un bon endroit pour faire un somme.",
      "floranDescription": "Pourquoi bloquer sssoleil avec gros s s s e fleur? Idio-te.",
      "glitchDescription": "Ravi. Je pourrais me reposer ici un jour de pluie sans craindre de rouiller.",
      "humanDescription": "Ooh, j'adorerais me reposer ici avec un livre et une boisson fraîche.",
      "hylotlDescription": "Un endroit charmant pour se reposer et lire un livre à la chaleur du soleil - parfaitement serein.",
      "novakidDescription": "C'est là au cas où on voudrait faire une sieste dehors sous la pluie? J'pige pas."
    }
  },
  "obsidianbookcase": {
    "name": "Grande Bibliothèque en Obsidienne",
    "desc": "Une bibliothèque en obsidienne ornée.",
    "metadata": {
      "apexDescription": "La bibliothèque semble construite pour protéger son contenu.",
      "avianDescription": "Les Avians ne collectionnent pas beaucoup de livres. Ceux qu'ils possèdent sont sacrés.",
      "floranDescription": "Bibliothèque sssolide. Floran ne voit passs l'intérêt.",
      "glitchDescription": "Observateur. Les Avians semblent accorder une grande valeur à leurs livres.",
      "humanDescription": "Cette bibliothèque est bâtie comme un char d'assaut.",
      "hylotlDescription": "Tous les livres méritent d'être protégés.",
      "novakidDescription": "C'est une bibliothèque drôlement solide. Impressionnant."
    }
  },
  "owlclock": {
    "name": "Horloge Murale Chouette",
    "desc": "Tic, tac, tic, tac.",
    "metadata": {
      "apexDescription": "Une horloge mignonne, ses yeux bougent.",
      "avianDescription": "Les Terrestres aiment l'artisanat pour s'amuser.",
      "floranDescription": "L'horloge de l'homme-oisssseau a desss yeux sssournoiss s.",
      "glitchDescription": "Amusé. Les yeux bougent à chaque seconde.",
      "humanDescription": "Quelle horloge adorable.",
      "hylotlDescription": "Il est difficile de ne pas sourire devant ce minuteur.",
      "novakidDescription": "Une horloge en forme de chouette. C'est plutôt mignon."
    }
  },
  "oliverstatue": {
    "name": "Statue de xOliver137",
    "desc": "Les seules lettres que je parviens à déchiffrer sont \"xOliver137\".",
    "metadata": {
      "apexDescription": "Il y a bien plus de statues de soldats que de civils.",
      "avianDescription": "Une idée fixe est comme la tige de fer placée dans les statues. Elle empale et soutient.",
      "floranDescription": "Floran penssse que cet homme a fait quelque chossse d'important sss'il a une ssstatue.",
      "glitchDescription": "Observateur. Cette plaque est effacée. Je parviens tout juste à lire les lettres \"xOliver137\".",
      "humanDescription": "Les seules lettres que j'arrive à lire sur cette plaque sont \"xOliver137\".",
      "hylotlDescription": "On dit que les statues des grands hommes sont faites des pierres qu'on leur a jetées de leur vivant."
    }
  },
  "oculobaf": {
    "name": "Figurine d'Oculob",
    "desc": "L'étiquette indique : \"C'est désagréable à regarder. C'est aussi désagréable quand il vous regarde.\""
  },
  "oogleraf": {
    "name": "Figurine d'Oogler",
    "desc": "L'étiquette indique : \"Il semble mystifié lorsqu'il rencontre de nouvelles formes de vie. Vous ne pouvez pas vous empêcher de vous sentir observé.\""
  },
  "orbideaf": {
    "name": "Figurine d'Orbide",
    "desc": "L'étiquette indique : \"Il y a quelque chose dans sa façon de boiter qui vous met mal à l'aise.\""
  }
}