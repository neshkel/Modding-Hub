  "deathwarning": {
    "name": "Vieux Panneau d'Avertissement",
    "desc": "Un vieux panneau pour prévenir d'un danger mortel.",
    "metadata": {
      "apexDescription": "Ce panneau me laisse penser que je devrais être prudent.",
      "avianDescription": "Un signe menaçant. De quoi peut-il bien nous avertir?",
      "floranDescription": "Le sssigne veut dire sss'amuser!",
      "glitchDescription": "Observateur. Cela semble être un avertissement.",
      "humanDescription": "Quel mauvais présage!",
      "hylotlDescription": "Ce crâne ne semble pas avoir trois orbites. Peut-être que les Hylotls ne sont pas concernés par ce danger.",
      "novakidDescription": "Une sorte de panneau avec un crâne."
    }
  },
  "deathwarningmodern": {
    "name": "Panneau de Danger de Mort",
    "desc": "Ce panneau semble m'avertir d'un danger quelconque.",
    "metadata": {
      "apexDescription": "Un symbole de danger est plus ou moins universellement reconnaissable.",
      "avianDescription": "Un crâne Avian n'a pas de dents, donc ce panneau me semble étrange.",
      "floranDescription": "S s signe Floran pour l'excitation!",
      "glitchDescription": "Analytique. Ce panneau est un avertissement que je devrais écouter si je ne souhaite pas faire une mauvaise rencontre.",
      "humanDescription": "Un crâne menaçant. Un excellent présage, sans aucun doute.",
      "hylotlDescription": "Un panneau mal dessiné, fait pour avertir les autres.",
      "novakidDescription": "Un crâne, le genre de truc qu'on trouve dans la tête d'une forme de vie organique."
    }
  },
  "dirttrapdoor": {
    "name": "Trappe de Terre",
    "desc": "Quelque chose cloche avec cette terre.",
    "metadata": {
      "apexDescription": "Il y a quelque chose de suspect avec le sol ici.",
      "avianDescription": "Cette terre n'a pas l'air réelle.",
      "floranDescription": "Terre sssent différent des autresss terresss.",
      "glitchDescription": "Suspicieux. Quelque chose est caché ici.",
      "humanDescription": "Cette terre a un aspect contre nature.",
      "hylotlDescription": "La façon dont cette terre est tassée n'est pas digne de confiance.",
      "novakidDescription": "Y'a un truc étrange avec c'te terre."
    }
  },
  "drip1": {
    "name": "Source de Gouttes d'Eau",
    "desc": "Des gouttes d'eau."
  },
  "drip2": {
    "name": "Source de Gouttes d'Acide",
    "desc": "De l'acide s'égoutte de cet endroit."
  },
  "drillmachine": {
    "name": "Foreuse Minière",
    "desc": "Une grande foreuse minière industrielle.",
    "metadata": {
      "apexDescription": "C'est une vision magnifique.",
      "avianDescription": "C'est certainement la plus grosse foreuse que j'aie jamais vue.",
      "floranDescription": "Foreussse a l'air amusss ante pour jouer.",
      "glitchDescription": "Excité. Quelle pièce de machinerie impressionnante.",
      "humanDescription": "C'est la deuxième plus grosse foreuse minière que j'aie vue de ma vie!",
      "hylotlDescription": "Des machines similaires sont utilisées par les Hylotls pour forer le fond des océans.",
      "novakidDescription": "Quelle beauté!"
    }
  },
  "drillconsole": {
    "name": "Console de Foreuse Minière",
    "desc": "Une console montée sur foreuse.",
    "metadata": {
      "apexDescription": "Une console avec une foreuse attachée.",
      "avianDescription": "Une console avec sa propre foreuse intégrée.",
      "floranDescription": "Consssole avec foreussse.",
      "glitchDescription": "Intrigué. Une console connectée directement à une foreuse minière.",
      "humanDescription": "Une foreuse, probablement actionnée par la console attachée.",
      "hylotlDescription": "Une console de minage avec des fonctions de récolte.",
      "novakidDescription": "Console de minage."
    }
  },
  "displaylight": {
    "name": "Spot d'Exposition",
    "desc": "Un projecteur directionnel utilisé pour éclairer des objets exposés.",
    "metadata": {
      "apexDescription": "C'est une lampe, son seul but est de pointer vers ce truc.",
      "avianDescription": "Je devrais regarder ce que la lumière pointe, c'est peut-être plus intéressant.",
      "floranDescription": "Lumière vive brille sur jolisss objetsss.",
      "glitchDescription": "Humble. Cette lampe accomplit diligemment son unique mission.",
      "humanDescription": "Je devrais probablement m'intéresser davantage à ce que cette lampe vise.",
      "hylotlDescription": "Cette lumière est là pour illuminer un sujet plus digne d'intérêt qu'elle-même.",
      "novakidDescription": "Je me demande bien c'que c'te lumière pointe?"
    }
  },
  "displaylightbroken": {
    "name": "Spot d'Exposition Cassé",
    "desc": "Cette lampe est censée éclairer une exposition quelconque.",
    "metadata": {
      "apexDescription": "Peut-être qu'elle a juste besoin d'une nouvelle ampoule.",
      "avianDescription": "Qu'est-ce qu'elle éclairerait si elle était allumée?",
      "floranDescription": "Quelqu'un a casss é la lumière.",
      "glitchDescription": "Horrifié. Quel spectacle tragique, cette lampe a besoin d'une ampoule de rechange de toute urgence.",
      "humanDescription": "Cette lampe est éteinte, quelqu'un a une ampoule en trop?",
      "hylotlDescription": "Quel dommage, quelqu'un devrait vraiment réparer cette lampe avant qu'elle ne cause un accident.",
      "novakidDescription": "Ça vacille comme une flamme mourante."
    }
  },
  "dangersignh": {
    "name": "Panneau de Danger Horizontal",
    "desc": "Le panneau dit \"DANGER\". Attendez, comment ces gens connaissent mon deuxième prénom?",
    "metadata": {
      "apexDescription": "C'est écrit danger, mais il n'y a aucune indication sur ce qui est dangereux...",
      "avianDescription": "Quelque chose de dangereux est proche.",
      "floranDescription": "Floran rit au nez du danger. Haha!",
      "glitchDescription": "Courageux. Ce panneau est plus un défi qu'un avertissement.",
      "humanDescription": "Est-ce que le danger est proche, ou est-ce le panneau lui-même qui est dangereux? Les bords ont l'air sacrément tranchants...",
      "hylotlDescription": "Un avertissement clair, bien que criard.",
      "novakidDescription": "Le seul danger ici, c'est moi."
    }
  },
  "dangersignv": {
    "name": "Panneau de Danger Vertical",
    "desc": "Le panneau dit \"DANGER\". Attendez, comment ces gens connaissent mon deuxième prénom?",
    "metadata": {
      "apexDescription": "C'est écrit danger, mais il n'y a aucune indication sur ce qui est dangereux...",
      "avianDescription": "Quelque chose de dangereux est proche.",
      "floranDescription": "Floran rit au nez du danger. Haha!",
      "glitchDescription": "Courageux. Ce panneau est plus un défi qu'un avertissement.",
      "humanDescription": "Est-ce que le danger est proche, ou est-ce le panneau lui-même qui est dangereux? Les bords ont l'air sacrément tranchants...",
      "hylotlDescription": "Un avertissement clair, bien que criard.",
      "novakidDescription": "Le seul danger ici, c'est moi."
    }
  },
  "decoratedtree": {
    "name": "Arbre Décoré",
    "desc": "Un arbre synthétique décoré de guirlandes lumineuses et d'ornements festifs.",
    "metadata": {
      "apexDescription": "La vue de cet arbre me réchauffe le cœur.",
      "avianDescription": "J'ai une envie soudaine de me mettre à chanter!",
      "floranDescription": "Arbre brillant.",
      "glitchDescription": "Heureux. Cet arbre me donne envie de chanter des chansons de fête.",
      "humanDescription": "Cet arbre me rappelle beaucoup de souvenirs de la maison...",
      "hylotlDescription": "Je dois admettre que cet arbre festif a un effet apaisant sur mon cœur d'amphibien.",
      "novakidDescription": "Eh bien, ces décorations rendent vraiment un simple arbre spécial."
    }
  },
  "dreidel": {
    "name": "Toupie Dreidel",
    "desc": "Une toupie à quatre faces. Il y a de curieux symboles sur chaque côté.",
    "metadata": {
      "apexDescription": "Une toupie amusante.",
      "avianDescription": "Ce jouet rotatif est plutôt amusant.",
      "floranDescription": "Jouet qui tourne sss!",
      "glitchDescription": "Joyeux. Une toupie.",
      "humanDescription": "Cool, un dreidel, dans l'espace!",
      "hylotlDescription": "Cette toupie rudimentaire me remplit de joie, allez savoir pourquoi.",
      "novakidDescription": "Je me demande si ces symboles ressemblent à ma marque?"
    }
  },
  "diamonddisplay": {
    "name": "Présentoir à Diamant",
    "desc": "Un présentoir pour un gros diamant.",
    "metadata": {
      "apexDescription": "Une vitrine pour un diamant de grande taille.",
      "avianDescription": "Une belle façon d'exposer des gemmes inestimables.",
      "floranDescription": "Floran a déjà volé gemme dans musée. Gardesss en colère. Floran plante.",
      "glitchDescription": "Critique. Cette vitrine ne semble pas être protégée par un système d'alarme.",
      "humanDescription": "On se croirait dans un film de braquage!",
      "hylotlDescription": "Une présentation peu gracieuse pour une si belle pierre.",
      "novakidDescription": "Je me demande si quelqu'un remarquera s'il vient à disparaître."
    }
  },
  "darkbannermedievallarge": {
    "name": "Grande Bannière Glitch Sombre",
    "desc": "Une bannière tissée de couleurs sombres.",
    "metadata": {
      "apexDescription": "Les couleurs sombres de cette bannière la rendent plutôt menaçante.",
      "avianDescription": "Cette bannière a du cuivre finement tissé dans la bordure. Quel joli détail!",
      "floranDescription": "Cette bannière essst sombre comme les ombresss. Floran veut sss'y cacher.",
      "glitchDescription": "Inquiet. Ce genre de bannière est souvent déployé quand des individus peu amicaux sont dans les parages...",
      "humanDescription": "Cette bannière tissée noire s'efforce vraiment d'être menaçante.",
      "hylotlDescription": "C'est dommage qu'une si belle bannière ait été créée avec des choix de couleurs aussi lugubres.",
      "novakidDescription": "Cette bannière est aussi sombre que de l'huile de vidange d'une semaine."
    }
  },
  "darkbannermedievalsmall": {
    "name": "Petite Bannière Glitch Sombre",
    "desc": "Une petite bannière tissée de couleurs sombres.",
    "metadata": {
      "apexDescription": "Les couleurs sombres de cette bannière la rendent plutôt menaçante.",
      "avianDescription": "Cette bannière a du cuivre finement tissé dans la bordure. Quel joli détail!",
      "floranDescription": "Cette bannière essst sombre comme les ombresss. Floran veut sss'y cacher.",
      "glitchDescription": "Inquiet. Ce genre de bannière est souvent déployé quand des individus peu amicaux sont dans les parages...",
      "humanDescription": "Cette bannière tissée noire s'efforce vraiment d'être menaçante.",
      "hylotlDescription": "C'est dommage qu'une si belle bannière ait été créée avec des choix de couleurs aussi lugubres.",
      "novakidDescription": "Cette bannière est aussi sombre que de l'huile de vidange d'une semaine."
    }
  },
  "darkbattlestandard": {
    "name": "Étendard de Bataille Sombre",
    "desc": "Un drapeau à damier sombre portant un emblème.",
    "metadata": {
      "apexDescription": "Je me demande s'il est ici pour marquer un territoire?",
      "avianDescription": "Je me demande si ces couleurs sombres ont été choisies pour le rendre plus menaçant?",
      "floranDescription": "Floran n'aime pas trop drapeau. Couleursss ennuyeusss es.",
      "glitchDescription": "Inquiet. Les Glitchs qui fabriquent des drapeaux de ces couleurs ne sont souvent pas les plus fréquentables.",
      "humanDescription": "Une bannière aux couleurs maussades qui peut être placée n'importe où.",
      "hylotlDescription": "Ces couleurs ternes prouvent qu'un Hylotl n'a pas fabriqué ça.",
      "novakidDescription": "Ce drapeau est si sombre qu'on pourrait le prendre pour un signal d'alarme."
    }
  },
  "darkcomputer": {
    "name": "Ordinateur Sombre",
    "desc": "Un terminal informatique antique, avec un affichage rouge profond.",
    "metadata": {
      "apexDescription": "L'écran de ce terminal est d'un rouge menaçant.",
      "avianDescription": "On dirait un vieux terminal informatique. Il semble bien fonctionner malgré son âge.",
      "floranDescription": "Floran veut sssavoir pourquoi boîte est sssi rouge.",
      "glitchDescription": "Impressionné. Ce vieil ordinateur semble fonctionner sans accroc malgré un entretien minimal.",
      "humanDescription": "Aïe, un affichage uniquement rouge. Ça doit piquer les yeux.",
      "hylotlDescription": "Cet ordinateur a un jeu de couleurs très déconcertant, c'est certain.",
      "novakidDescription": "C'te vieillerie devait être plus impressionnante il y a un siècle."
    }
  },
  "datastation": {
    "name": "Station de Données",
    "desc": "Cette station semble transmettre une grande quantité de données.",
    "metadata": {
      "apexDescription": "Elle semble traiter beaucoup de données.",
      "avianDescription": "Cette machine a l'air de travailler dur.",
      "floranDescription": "Machine brillante fait bruit de gensss occupésss.",
      "glitchDescription": "Analytique. Ce terminal semble traiter des données topographiques sur la planète.",
      "humanDescription": "C'est une sorte de station informatique. Ça a l'air important, je ne devrais probablement pas y toucher.",
      "hylotlDescription": "Cette station semble traiter une quantité massive d'informations.",
      "novakidDescription": "Un genre d'ordi sophistiqué avec plein de panneaux clinquants."
    }
  },
