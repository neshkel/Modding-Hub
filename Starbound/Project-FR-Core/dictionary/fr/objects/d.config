  "diodiaseed": {
    "name": "Graine de Diodia",
    "desc": "La Diodia, un légume-racine tendre avec un goût de cuivre.",
    "metadata": {
      "apexDescription": "Les Diodias n'ont pas le goût le plus agréable, mais elles sont faciles à cultiver.",
      "avianDescription": "Une diodia ressemble à une noix, mais n'en a pas le goût.",
      "floranDescription": "A le goût du sssang, Floran trouve Diodia acceptable comme sss ubsss titut.",
      "glitchDescription": "Insulté. Les Diodias sont vraiment des légumes sous-estimés.",
      "humanDescription": "On dirait une pomme de terre, mais ça a le goût d'une pièce de monnaie. Pas un super échange.",
      "hylotlDescription": "Un légume-racine amer. Idéal pour relever le goût.",
      "novakidDescription": "Les Diodias au goût de cuivre font fureur chez les Glitchs."
    }
  },
  "dirturchinseed": {
    "name": "Graine d'Oursin de Terre",
    "desc": "Les oursins de terre sont spongieux et plutôt insipides.",
    "metadata": {
      "apexDescription": "C'est plus une mauvaise herbe commune qu'un légume.",
      "avianDescription": "Quand il n'y a rien de mieux à manger, l'oursin de terre fait l'affaire.",
      "floranDescription": "Oursin de terre ressemble à un tout petit cactusss rond.",
      "glitchDescription": "Désintéressé. Une plante commune et ennuyeuse.",
      "humanDescription": "Il a été prouvé statistiquement que 93 % des humains ont la phobie des oursins de terre.",
      "hylotlDescription": "Pourquoi quiconque mangerait ça dépasse mon entendement.",
      "novakidDescription": "Les oursins de terre sont aussi ternes que la terre d'où ilsss sortent."
    }
  },
  "dewhopper": {
