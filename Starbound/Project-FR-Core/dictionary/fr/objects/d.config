  "dustybed": {
    "name": "Lit Poussiéreux",
    "desc": "Un vieux lit usé et poussiéreux.",
    "metadata": {
      "apexDescription": "Vieux et usé, mais probablement encore assez efficace.",
      "avianDescription": "Un lit avec un drap rembourré d'herbe. Je pourrais m'y habituer!",
      "floranDescription": "Floran pourrait probablement sss'endormir là-dedans sans problème.",
      "glitchDescription": "Confus. Ce meuble est-il censé avoir l'air aussi débraillé?",
      "humanDescription": "Il a l'air vieux et sec. Je n'oserais pas le placer près d'une flamme nue.",
      "hylotlDescription": "Je ne suis pas à l'aise à l'idée de dormir dans des conditions aussi précaires.",
      "novakidDescription": "Un peu de poussière n'a jamais tué personne."
