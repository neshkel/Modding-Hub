  "dirtyfossil1": {
    "name": "Fossile",
    "desc": "Une sorte de fossile, tout couvert de boue et de roche. Il va falloir un nettoyage minutieux pour l'extraire en un seul morceau.",
    "metadata": {
      "apexDescription": "Un fossile encastré dans la terre. Il faudra un travail minutieux pour le sortir intact.",
      "avianDescription": "Ce fossile a l'air intéressant, je me demande si je pourrais le déterrer sans l'endommager?",
      "floranDescription": "Un fosss ile piégé dans la terre. Je me demande ce que c'était avant.",
      "glitchDescription": "Intrigué. J'aimerais voir ce fossile dans son intégralité.",
      "humanDescription": "Un fossile! Je me demande si je peux le sortir de là?",
      "hylotlDescription": "Une créature fossilisée, ancienne et délicate, ensevelie dans la roche.",
      "novakidDescription": "De vieux os... des os en pierre! Comment on appelle ça déjà? Ah, des fossiles!"
    }
  },
