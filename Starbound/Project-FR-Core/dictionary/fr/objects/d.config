{
  "drain": {
    "name": "Drain",
    "desc": "Glou glou!",
    "metadata": {
      "apexDescription": "Ceci est conçu pour évacuer l'eau.",
      "avianDescription": "Ceci drainera l'eau, parfait pour garder mes plumes au sec!",
      "floranDescription": "Drainsss emportent l'eau.",
      "glitchDescription": "Impressionné. Ceci évacue l'eau avec aisance.",
      "humanDescription": "Ça va drainer cette eau rapidement!",
      "hylotlDescription": "Un dispositif utile pour évacuer l'eau. Pour ceux qui aiment ça.",
      "novakidDescription": "Ça va nous débarrasser de c'te maudite flotte!"
    }
  },
  "delay": {
    "name": "Porte de Délai",
    "desc": "Un circuit qui relaie les signaux après un délai défini.",
    "metadata": {
      "floranDescription": "Un circuit qui relaie les sssignaux après un délai ssspécifique.",
      "glitchDescription": "Neutre. Un circuit qui relaie les signaux après un délai défini."
    }
  },
  "dlatch": {
    "name": "Verrou",
    "desc": "Un verrou. Peut être utilisé pour stocker l'état d'un circuit.",
    "metadata": {
      "floranDescription": "Un verrou. Peut ssservir à garder l'état d'un fil.",
      "glitchDescription": "Fasciné. Un verrou. Peut être utilisé pour stocker l'état d'un circuit."
    }
  },
  "doombed": {
    "name": "Lit Funeste",
    "desc": "Un lit funeste sublime. Un peu piquant, par contre.",
    "metadata": {
      "apexDescription": "Un lit exceptionnellement agréable et confortable. Étrangement effrayant à regarder.",
      "avianDescription": "C'est un endroit aussi bon qu'un autre pour reposer mes plumes.",
      "floranDescription": "Floran s'repose dans grand lit avec dents.",
      "glitchDescription": "Inquiet. L'apparence de ce lit est perturbante.",
      "humanDescription": "Un lit fantastique. Je devrais pouvoir me reposer ici sans problème, tant qu'il ne me donne pas de cauchemars.",
      "hylotlDescription": "Excellente qualité de fabrication. J'aime ça. Pas très sûr pour l'apparence, par contre.",
      "novakidDescription": "Ce lit est drôlement douillet pour un truc si pointu."
    }
  },
  "doomchair": {
    "name": "Chaise Funeste",
    "desc": "Une chaise funeste confortable.",
    "metadata": {
      "apexDescription": "Une chaise immensément confortable, même si elle a un air un peu sinistre.",
      "avianDescription": "Un merveilleux endroit pour s'asseoir, si l'on peut ignorer les pointes.",
      "floranDescription": "Floran s'assied sur chaise, caressse les pointesss et pense à la chassse.",
      "glitchDescription": "Relaxé. Cette chaise est exceptionnellement confortable pour un Glitch.",
      "humanDescription": "Une chaise désarmante de douceur. Ça me rappelle la maison, les pointes en plus.",
      "hylotlDescription": "C'est à peu près le luxe auquel les Hylotls sont habitués, le style en moins.",
      "novakidDescription": "C'te chaise est sacrément confortable pour un truc si piquant."
    }
  },
  "doomdoor": {
    "name": "Porte Funeste",
    "desc": "Une porte funeste effrayante.",
    "metadata": {
      "apexDescription": "Cette porte est assez glauque pour stopper n'importe quel cambrioleur.",
      "avianDescription": "Une porte très sinistre.",
      "floranDescription": "Floran s'cache derrière porte. Puis porte fait peur à Floran.",
      "glitchDescription": "Nerveux. Cette porte a un œil dessus.",
      "humanDescription": "Une porte funeste plutôt terrifiante.",
      "hylotlDescription": "Une porte funeste robuste. Elle a aussi un œil. Étrange concept.",
      "novakidDescription": "C'te porte est en train de m'regarder."
    }
  },
  "doomlight": {
    "name": "Lampe Funeste",
    "desc": "Une lampe funeste. L'œil brille dans le noir.",
    "metadata": {
      "apexDescription": "Le globe oculaire projette une lueur sinistre.",
      "avianDescription": "La lumière semble me suivre peu importe où je me tiens dans la pièce.",
      "floranDescription": "Floran regarde lumière, et lumière regarde Floran.",
      "glitchDescription": "Alarmé. Cette lampe ressemble à un œil géant.",
      "humanDescription": "Whoa, la classe. Un œil géant qui brille.",
      "hylotlDescription": "Cette lumière a un style particulier.",
      "novakidDescription": "J'aime pas la façon dont c'te lampe me lorgne."
    }
  },
  "doomswitch": {
    "name": "Console Funeste",
    "desc": "Une console funeste. Faites attention en l'utilisant: elle vous regarde.",
    "metadata": {
      "apexDescription": "Cette console offre un large degré de contrôle.",
      "avianDescription": "Une console utile.",
      "floranDescription": "Floran appuie sur boutonsss. Fait bouger chosesss!",
      "glitchDescription": "Impressionné. Une seule console peut contrôler tant de mécanismes différents à la fois.",
      "humanDescription": "Une console de commande. C'est plus fort que moi, il faut que je joue avec.",
      "hylotlDescription": "Une console de contrôle.",
      "novakidDescription": "Faut qu'j'appuie sur ce bouton."
    }
  },
  "doomtable": {
    "name": "Table Funeste",
    "desc": "Une table funeste terrifiante. Elle vous regarde manger.",
    "metadata": {
      "apexDescription": "Un œil scrute depuis le dessous de cette table.",
      "avianDescription": "Cette table est glauque pour s'y attabler.",
      "floranDescription": "Floran pense que cette table a ausssi faim que Floran.",
      "glitchDescription": "Déstabilisé. En jetant un œil sous la table, un œil géant me fixe en retour.",
      "humanDescription": "Cette table ne convient pas aux personnes portant des jupes.",
      "hylotlDescription": "Si tu regardes la table trop longtemps, la table finit par regarder en toi.",
      "novakidDescription": "J'suis pas sûr que les tables devraient avoir des yeux."
    }
  },
  "dockingfield": {
    "name": "Champ d'Amarrage",
    "desc": "Ce champ d'énergie peut contenir à la fois l'atmosphère et la gravité artificielle.",
    "metadata": {
      "apexDescription": "Un champ d'amarrage spatial, cette énergie retient l'atmosphère à l'intérieur.",
      "avianDescription": "L'énergie de ce champ d'amarrage maintient l'air et la gravité à l'intérieur.",
      "floranDescription": "Cette énergie crépitante garde l'air à l'intérieur.",
      "glitchDescription": "Informé. Ce champ est un type d'énergie spécial destiné à contenir l'atmosphère et la gravité artificielle.",
      "humanDescription": "Ce type de champ d'énergie peut contenir l'atmosphère et la gravité dans les structures spatiales.",
      "hylotlDescription": "Les champs d'amarrage comme celui-ci sont courants dans l'espace, ils font des sas très efficaces.",
      "novakidDescription": "Ce champ d'énergie garde l'air et la gravité dedans et l'vide dehors."
    }
  },
  "dockingfieldsmall": {
    "name": "Champ d'Amarrage (Petit)",
    "desc": "Ce champ d'énergie peut contenir à la fois l'atmosphère et la gravité artificielle.",
    "metadata": {
      "apexDescription": "Un champ d'amarrage spatial, cette énergie retient l'atmosphère à l'intérieur.",
      "avianDescription": "L'énergie de ce champ d'amarrage maintient l'air et la gravité à l'intérieur.",
      "floranDescription": "Cette énergie crépitante garde l'air à l'intérieur.",
      "glitchDescription": "Informé. Ce champ est un type d'énergie spécial destiné à contenir l'atmosphère et la gravité artificielle.",
      "humanDescription": "Ce type de champ d'énergie peut contenir l'atmosphère et la gravité dans les structures spatiales.",
      "hylotlDescription": "Les champs d'amarrage comme celui-ci sont courants dans l'espace, ils font des sas très efficaces.",
      "novakidDescription": "Ce champ d'énergie garde l'air et la gravité dedans et l'vide dehors."
    }
  },
  "desertceilingspike1": {
    "name": "Pointes Aiguisées",
    "desc": "Attention!",
    "metadata": {
      "apexDescription": "Des pointes de pierre tranchantes.",
      "avianDescription": "La pierre semble tranchante comme un rasoir.",
      "floranDescription": "Tranchant et pointu.",
      "glitchDescription": "Prudent. La roche tranchante pourrait pénétrer la coque d'un Glitch.",
      "humanDescription": "Je ferais mieux de ne pas toucher à ça.",
      "hylotlDescription": "Je vais éviter cela avec grâce.",
      "novakidDescription": "Ça a l'air drôlement coupant, j'suis prêt à déguerpir!"
    }
  },
