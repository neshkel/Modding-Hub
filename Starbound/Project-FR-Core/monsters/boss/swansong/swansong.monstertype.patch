[{"op":"replace","path":"/shortdescription","value":"The Swansong"},{"op":"replace","path":"/baseParameters/openingDialog/0","value":"I knew you'd come. We have unfinished business, after all."},{"op":"replace","path":"/baseParameters/openingDialog/1","value":"What do I have left to fight for? My quest failed... My ideology was weak."},{"op":"replace","path":"/baseParameters/openingDialog/2","value":"And yet I'm too ashamed to give myself up, and I'm too stubborn to die."},{"op":"replace","path":"/baseParameters/openingDialog/3","value":"So... Care for one last dance, \"Protector\"?"}]